$(H
Macro Generic Type: Results

------------------------------------------------------------------------
$)
$(D
General element delete. This macro if required delete all directly related
elements to the deleted item, example SCTNs' connected joins will be deleted,
HANGs' attachment point and fittings will also be deleted.

NOTE - ALL deletion routines should use this as the means to delete elements.

Arguments: <gid> <flag> <flag> <flag> <flag>
  1 - General Identity.
  2 - Association delete flag.
  3 - Routine flag, in this mode undeleted associations are passed back
      via a global variable
  4 - Retain CE, delete its members
  5 - Confirm deletion
Global Arguments:
Returns:
  !!CDPARTN  - Undeletable associations
        !!CDWARTN       - Undeletable type
  !!CDCARTN  - Reason for not being deleted
$)

$:debug$:
$d1=CE
$d2=false
$d3=false
$d4=false
$d5=true

$* Initialise Variables
 var !GID |$1|
 var !AFLG $2
 var !RFLG $3
 var !CFLG $4
 var !PFLG $5
 var !EFLG false
 var !CREF REFE
 var !!CDPARTN delete
 var !!CDCARTN delete
 var !!CDWARTN delete

 var !CNAM (NAME of $!GID )
 var !OREF (REFE of OWNE of $!GID )

!needConfirmation = TRUE

!hvacEleToDel = 0

if (defined(!!ALERTONCEDELSEL)) then
  if(not (!!alertOnceDelSel.ShowAgain()) AND not(!!isDeleteSelection)) then
    !!alertOnceDelSel.confirm = TRUE
  endif
endif

if (undefined(!!runningUnitlTest)) then
  if (undefined(!!CDCERRMESS)) then
    CALLIB FERRMESS
  endif
endif

if (undefined(!!runningUnitlTest)) then
  var pane _CDCERRMESS_LIST clear
  exit
endif

$* If GID is CE, change to REFE
 if(|$!GID| eq |CE|) then
   var !GID REFE
 endif

$* Check for world
 if(TYPE of $!GID eq |WORL|) then
    error |Unable to delete World.|
    return
  endif

 --Group elements but ignoring GPITEM elements as these are hidden from users
 var !TYPE TYPE of $!GID
 if (!TYPE EQ 'GPITEM') then
   -- Just do not touch it
   return
 endif
 if (!TYPE INSET('GPWL','GPSET','GROU')) then
   -- Only consider deleting these and not the element they reference
   var !groupElements collect all (GPWL GPSET GROU) for $!GID
   !groupElement = !GID.dbref()
   !groupElementName = !GID.dbref().fullname
   var !notLocked collect all (GPWL GPSET GROU) with (not(LOCK)) from !groupElements
   !testActualElement = !!dbrefUpdatable(!GID.dbref())
   if (!testActualElement.not()) then
     return error 1 |$!!error.text|
   endif
   if (!groupElements.size() neq !notLocked.size()) then
     return error 1 |$!CNAM has Locked offspring.|
   endif
   if ($!CFLG) then
     if (!GID.dbref().type eq 'GROU') then
       !answer = !!alert.confirm(|Ok to attempt deletion of 'All Members' of GROU | & !groupElementName & | ...BEWARE! - referenced elements WILL be deleted!|)
     else
       !answer = !!alert.confirm(|Ok to attempt deletion of 'All Members' of 'Groups' element | & !groupElementName & | ...referenced elements will not be deleted|)
     endif
   else
     !answer = !!alert.confirm(|Ok to attempt deletion of 'Groups' element | & !groupElementName & | ...referenced elements will not be deleted|)
   endif
   if (!answer.boolean()) then
     !!ce = !groupElement
     if ($!CFLG) then
       -- If retain flag delete members of element but not the element itself
       !members = !GID.dbref().members
       !numberErrors = 0
       do !i indices !members
         !memberType = !members[!i].type
         !!ce = !members[!i]
         DELETE $!memberType
         handle ANY
           !numberErrors = !numberErrors + 1
         endhandle
       enddo
       if (!numberErrors gt 0) then
         !!alert.message(|It was not possible to delete | & !numberErrors.string() & | of 'All Members' |)
       endif
     else
       DELETE $!TYPE
       handle ANY
         !!alert.error('Unable to Delete ' & !groupElementName & ' ' & !!error.text.after(')'))
       endhandle
     endif
   endif
   return
 endif

$* Check for Spooling site/network/drawing or associated texts and boundaries
  if ( TYPE of $!GID eq |SITE| and FUNC of $!GID eq |Network| ) then
    error |Use Spooling Application Delete > Network Site... to delete SITE $!CNAM|
    return
  elseif ( TYPE of $!GID eq |ZONE| and FUNC of $!GID eq |Network| ) then
    error |Use Spooling Application Delete > Network... to delete NETWORK $!CNAM|
    return
  elseif ( TYPE of $!GID eq |BOUN| ) then
    if ( FUNC of OWNE of $!GID eq |Network| ) then
      error |Use Spooling Application Delete > Network... to delete NETWORK owning BOUN $!CNAM|
      return
    endif
  elseif ( TYPE of $!GID eq |DRAWI| ) then
    if ( FUNC of OWNE of $!GID eq |Network| ) then
      error |Use Spooling Application Delete > Drawing... to delete DRAWING $!CNAM|
      return
    endif
  elseif ( TYPE of $!GID eq |TEXT| ) then
    if ( TYPE of OWNE of $!GID eq |ZONE| and FUNC of OWNE of $!GID eq |Network| ) then
      error |Use Spooling Application Delete > Network... to delete NETWORK owning TEXT $!CNAM|
      return
    elseif ( TYPE of OWNE of $!GID eq |BOUN| and FUNC of OWNE of OWNE of $!GID eq |Network| ) then
      error |Use Spooling Application Delete > Network... to delete NETWORK owning BOUN owning TEXT $!CNAM|
      return
    elseif ( TYPE of OWNE of $!GID eq |DRAWI| and FUNC of OWNE of OWNE of $!GID eq |Network| ) then
      error |Use Spooling Application Delete > Drawing... to delete DRAWING owning TEXT $!CNAM|
      return
    endif
  endif

  !haveSupports = FALSE

--If CE is member of SUPPO, then return error message.------------------------------------
  !supportMember = false
  do !owner values !GID.dbref().ownlst
    if !owner.type.eq('SUPPO') then
      -- Check that we're not deleting a member of a special
      STRU
      handle NONE
        !mdsstype = !!ce.:MDSSuppType
        handle (99,532)
          --cannot find the :MDSSuppType UDA
        elsehandle NONE
          !!ce = !GID.dbref()
          if (!GID.dbref().type inset ('STRU','FRMW')) then
            return error 1 |Unable to delete an associated SUPPORTS element. Use SUPPORTS application Delete Supports...|
          else
            if (!mdsstype.neq('SPECIAL')) then
              return error 1 |Unable to delete an associated SUPPORTS element. Use SUPPORTS application Delete Supports...|
            else
              break
            endif
          endif
        endhandle
      elsehandle ANY
      endhandle
      !supportMember = true
      break
    endif
  enddo

$* SUPPORTS check - Do not delete a ZONEs members if it is a SUPPORTS storage area
--If CE is a ZONE or SITE, and it has SUPPO elements in it, then return error message.
  if !GID.dbref().type inset('ZONE','SITE') then
    var !zoneSupportMembers collect all SUPPO for $!GID
    if !zoneSupportMembers.size().neq(0) then
      !supportMember = true
    endif
  endif

  if !supportMember or !GID.dbref().type.eq('SUPPO') then
    return error 1 |Unable to delete an associated SUPPORTS element. Use SUPPORTS application Delete Supports...|
  endif
------------------------------------------------------------------------------------------

$* SUPPORTS check - Do not delete a RESTRAINT if associated with a support
  if ( (hardtype of $!GID eq |REST| or hardtype of $!GID eq |SUPP|) and hspec neq nulref) then
      !restRef = !GID.dbref()
      if(!restRef.purp.eq(|MDS|)) then
         return error 1 |Unable to delete an associated SUPPORTS element. Use SUPPORTS application Delete Supports...|
      endif
  endif

$* SUPPORTS Check for a trunnion
  TRUNNI
  handle NONE
    return error 1 |Unable to delete an associated SUPPORTS element. Use SUPPORTS application Delete Supports...|
  elsehandle any
  endhandle

  !getOwnerType = !!ce.owner.type
  handle any
    !getOwnerType = 'unset'
  endhandle

  if (!!ce.type inset ('PIPE','ZONE','SITE','BRAN')) then
    var !supAncilArr coll all BRAN with not(unset(supallancis)) for ce
    if !supAncilArr.size().gt(0) then
      !haveSupports = true
    endif
  endif

  if !getOwnerType.eq('BRAN')  then
    !getSuprfArray = !!ce.suprfArray
    handle any
    elsehandle none
      if !getSuprfArray.size().gt(0) then
        !haveSupports = true
      endif
    endhandle
  endif

  if(!haveSupports) then
    if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
      var !TXT |Ok to delete $!!ce.fullname? This component has associated Support(s) |
      !!alertOnceDelSel.question.val = |$!TXT|
      waiton !!alertOnceDelSel
      if(!!alertOnceDelSel.confirm.not()) then
        return
      endif
    endif
    !needConfirmation = FALSE
  endif
-------------------------------------------------------------------------------------------------------------------------
$* Check for trying to partially delete support
  if ( TYPE of $!GID eq |REST| or TYPE of $!GID eq |SUPP|) then
    if (not badref (STLREF of $!GID )) then
      var !SUPFLAG true
    else
      var !SUPFLAG false
    endif
  elseif ( TYPE of $!GID eq |FRMW| ) then
    if (not badref (SUPREF of $!GID )) then
      var !SUPFLAG true
    else
      var !SUPFLAG false
    endif
  else
    var !SUPFLAG false
  endif
  if ($!SUPFLAG and $!PFLG) then
    error |Use H&S Application Delete > Support to delete support|
    return
  endif

-- Special case for CABLING application
  !elementRequestedDelete     = object DBREF(!GID)
  !elementRequestedDeleteType = !elementRequestedDelete.type
  var !cablewayBranches collect all CWBRAN for $!GID
  !cabledBranchFound = false
  do !i indices !cablewayBranches
    -- See if there are cables running on any of the cableway branches
    !clist = !cablewayBranches[!i].dbref().clist[0]
    if (!clist.set()) then
      -- what if those cables are in the hierarchy being deleted, then it would be OK
      do !j indices !clist
        var !cableRelationship NAME OF $!elementRequestedDeleteType OF $!clist[$!j]
        handle ANY
          -- Cannot possibly be in same hierarchy
          var !cableRelationship 'Nulref'
        endhandle
        !testElement = object DBREF(!cableRelationship)
        if (!elementRequestedDelete.string() neq !testElement.string()) then
          -- We have a cableway with a cable on but the cable is not in the same hierarchy cannot delete it
          !firstFound = !cablewayBranches[!i].dbref()
          !cabledBranchFound = true
          break
        endif
      enddo
    endif
  enddo

  if ( !cabledBranchFound ) then
    !!alert.message('Cannot delete ' & !elementRequestedDelete.flnn & ' because there are cables on ' & !firstFound.flnn )
    handle ANY
      -- Text could be too long
      !!alert.message('Cannot delete ' & !elementRequestedDelete.flnn & ' because there are cables on it')
      handle ANY
        -- Text could be still too long
        !!alert.message('Cannot delete, because there are referenced cables')
      endhandle
    endhandle
    !cabledBranchFound = false
    return
  endif

-- Special case 1 for RNODE and CNODE
  var !nodes collect all (RNODE CNODE) for $!GID
  !nodeFound = false
  do !i indices !nodes
    -- See if there are associations on any of the cableway nodes
    !nodeList = !nodes[!i].dbref().assos
    if (!nodeList.set()) then
      -- We have a node with an association so cannot delete it
      !firstNodeFound = !nodes[!i].dbref()
      !nodeFound = true
      break
    endif
  enddo

  if ( !nodeFound ) then
    if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
      var !TXT |Confirm deletion, because node has an association |
      !!alertOnceDelSel.question.val = |$!TXT|
      waiton !!alertOnceDelSel
      if(!!alertOnceDelSel.confirm.not()) then
        !nodeFound = false
        return
      else
        var !PFLG 'false'
      endif
    endif
  endif

-- Special case 2 for RNODE and CNODE
  var !nodes collect all (RNODE CNODE) for $!GID
  !nodeFound = false
  do !i indices !nodes
    !qualifier = object ARRAY()
    !qualifier[1] = 3
    if (!nodes[!i].dbref().attribute('CLIST',!qualifier).set()) then
      -- We have a node with a reference to a cable
      !nodeFound = true
      break
    endif
  enddo

  if ( !nodeFound ) then
    if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
      var !TXT |Confirm deletion, because node has a cable connection |
      !!alertOnceDelSel.question.val = |$!TXT|
      waiton !!alertOnceDelSel
      if(!!alertOnceDelSel.confirm.not()) then
        !nodeFound = false
        return
      else
        var !PFLG 'false'
      endif
    endif
  endif

-- Special case 1 for RATTA HATTA TATTA
  var !TYPE TYPE of $!GID
  if ( !TYPE inset(|CONSEQ|,|RATTA|,|HATTA|,|TATTA|,|RTFEAT|,|RNODE|)) then
    var !attas collect all (RATTA HATTA TATTA RNODE) for $!GID
    !attaFound = false
    do !i indices !attas
      -- See if there are connections on any of the attas
      !cableList = false
      !cableList = !attas[!i].dbref().clist[0].size().gt(0)
      handle ANY
        -- not all elements may have clist or clist set
      endhandle
      -- Another cable list
      !lalcab = false
      !lalcab = !attas[!i].dbref().lalcab.size().gt(0)
      handle ANY
        -- not all elements may have lalcab or lalcab set
      elsehandle none
        if (!lalcab.not()) then
          !cableList = false
        endif
      endhandle
      if (!cableList or !lalcab) then
        -- We have an atta with a cable going to or from it
        !firstAttaFound = !attas[!i].dbref()
        !attaFound = true
        break
      endif
    enddo

    if ( !attaFound ) then
      if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
        var !TXT |Confirm deletion, because referenced cables will be invalidated |
        !!alertOnceDelSel.question.val = |$!TXT|
        waiton !!alertOnceDelSel
        if(!!alertOnceDelSel.confirm.not()) then
          !attaFound = false
          return
        else
          var !PFLG 'false'
        endif
      endif
    endif
  endif

-- Special case 2 for RATTA HATTA TATTA
  if ( !TYPE inset(|CONSEQ|,|RATTA|,|HATTA|,|TATTA|)) then
    var !attas collect all (RATTA HATTA TATTA) for $!GID
    !attaFound = false
    do !i indices !attas
      -- See if there are cableway connections on any of the attas
      !connList = false
      !connList = !attas[!i].dbref().connref.size().gt(0)
      handle ANY
        -- not all elements may have connref or connref set
      endhandle
      -- Another cableway list
      !atconn = false
      !atconn = !attas[!i].dbref().atconn.size().gt(0)
      handle ANY
        -- not all elements may have atconn or atconn set
      endhandle
      -- Another cableway list
      !conats = false
      !conats = !attas[!i].dbref().conats.size().gt(0)
      handle ANY
        -- not all elements may have conats or conats set
      endhandle
      if (!connList or !atconn or !conats) then
        -- We have an atta with a cableway going to or from it
        !firstAttaFound = !attas[!i].dbref()
        !attaFound = true
        break
      endif
    enddo

    if ( !attaFound ) then
      if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
        var !TXT |Confirm deletion, because it has a cableway branch connection that will be invalidated |
        !!alertOnceDelSel.question.val = |$!TXT|
        waiton !!alertOnceDelSel
        if(!!alertOnceDelSel.confirm.not()) then
          !attaFound = false
          return
        else
          var !PFLG 'false'
        endif
      endif
    endif
  endif

-- Special case 3 for PULLNODE and JNODE
  var !nodes collect all (PULLNODE JNODE) for $!GID

  !nodeFound = false

  do !i indices !nodes
    -- See if there are references on any of the cableway nodes

        !qualifiersArray = object ARRAY()
        !qualifiersArray[1] = 'CWBRAN'
        !nodeList = !nodes[!i].dbref().attribute('BACKREF',!qualifiersArray)
    handle ANY
      !nodeList = ARRAY()
    endhandle
    if !nodeList.size().gt(0) then
      !nodeFound = true
      break
    endif

  enddo

  if ( !nodeFound ) then
            !!alert.message('Cannot delete ' & !elementRequestedDelete.flnn & ' because there are cableway branches connected to it')
        !nodeFound = false
        return
  endif
-- End of special case for CABLING application

-- Handling special case for HVAC

  !deletingHvac = !!ce.ahList.findFirst('HVAC').set() AND (!!ce.owner.type eq 'BRAN' OR !!ce.owner.owner.type eq 'BRAN')
  if (!deletingHvac) then
    !hvacLastElementDelete = false
    if ( ( !CFLG eq 'false') and ( !AFLG eq 'true' ) and ( !PFLG eq 'true')) then
      !hvacEleToDel = !!deleteHvac()
      if( !hvacEleToDel eq 0 ) then
        if ( !!ce.hardtype.neq('SUBCOM') AND !!ce.seq.eq(!!ce.owner.mcount)) then
          if ( !!ce.type inset('SILE','DAMP','BATT','FAN','AHU','GRIL','CAP','PCOM')) then
            !hvacLastElementDelete = false
          else
            !tailDistance = !!ce.lPos.distance(!!ce.owner.tPos).convertUnits('mm').string('D0').real()
            handle (2,779)

            elsehandle none
              if ( !tailDistance.eq(999mm)) then
                !hvacLastElementDelete = true
              endif
            endhandle
          endif
        endif
      endif
      if (!hvacEleToDel.eq(1)) then
        return
      elseif (!hvacEleToDel.eq(2)) then
        !zeroStrtEle = !!ce.owner
        if (!zeroStrtEle.seq.eq(!zeroStrtEle.owner.mcount )) then
          !tailDistance = !zeroStrtEle.lPos.distance(!zeroStrtEle.owner.tPos).convertUnits('mm').string('D0').real()
          if ( !tailDistance.eq(999mm)) then
            !hvacLastElementDelete = true
          endif
        endif
      elseif (!hvacEleToDel.eq(5)) then
        !zeroStrtEle = !!ce.owner
        !p3pos = !!ce.ppos[3]
        !branTpos = !!ce.cref.tPos
        !distVal = !p3pos.distance(!branTpos).convertUnits('mm').string('D0').real()
        if ( !distVal.eq(999mm) and !!ce.cref.mcount.eq(0)) then
          !branRef = !!ce.cref
        else
          !hvacEleToDel = 2
        endif
        if (!zeroStrtEle.seq.eq(!zeroStrtEle.owner.mcount )) then
          !tailDistance = !zeroStrtEle.lPos.distance(!zeroStrtEle.owner.tPos).convertUnits('mm').string('D0').real()
          if ( !tailDistance.eq(999mm)) then
            !hvacLastElementDelete = true
          endif
        endif
      elseif ( !hvacEleToDel.eq(4)) then
        !p3pos = !!ce.ppos[3]
        if (!!ce.cref.badRef().not()) then
          !branTpos = !!ce.cref.tPos
        endif
        !distVal = !p3pos.distance(!branTpos).convertUnits('mm').string('D0').real()
        if ( !distVal.eq(999mm) and !!ce.cref.mcount.eq(0)) then
          !branRef = !!ce.cref
        else
          !hvacEleToDel = 0
        endif
      elseif ( !hvacEleToDel.eq(3)) then
        !branchRefList = object ARRAY()
        !hvbrcoList = !!collectallfor(|HVBRCO|,||,!!ce)
        if (!hvbrcoList.size().gt(0)) then
          !branOfSubCom = !!ce.owner
          do !hvbrcoRef values !hvbrcoList
            if (!hvbrcoRef.cref.badRef().not()) then
              !branRef = !hvbrcoRef.cref
              if (!branRef.type eq 'BRAN') then
                !p3pos = !hvbrcoRef.ppos[3]
                !branTpos = !hvbrcoRef.cref.tPos
                !distVal = !p3pos.distance(!branTpos).convertUnits('mm').string('D0').real()
                if ( !distVal.eq(999mm) and !branRef.mcount.eq(0)) then
                  !branchRefList.append(!branRef)
                endif
              endif
            endif
          enddo
        endif
        if ( !branchRefList.size().eq(0)) then
          !hvacEleToDel = 0
        endif
        if (!!ce.seq.eq(!!ce.owner.mcount)) then
          !tailDistance = !!ce.lPos.distance(!!ce.owner.tPos).convertUnits('mm').string('D0').real()
          if ( !tailDistance.eq(999mm)) then
            !hvacLastElementDelete = true
          endif
        endif
      endif
    else
      !hvacEleToDel = 0
      if (!!ce.ddepth.eq(5)) then
        !tailDistance = !!ce.lPos.distance(!!ce.owner.tPos).convertUnits('mm').string('D0').real()
        if ( !tailDistance.eq(999mm)) then
          !hvacLastElementDelete = true
        endif
      endif
    endif
  elseif(!!ce.type.eq('HVAC') OR (( !!ce.ahList.findFirst('HVAC').set()) AND (!!ce.owner.type eq 'HVAC'))) then
    --trigger hvacStore to update the list of branches
    !hvacEleToDel = 6
  endif

 -- End of special case for HVAC

-- special cases for hole management
  !assocGroups = ARRAY()
  !elementToDelete = !GID.dbref()
  if ( !elementToDelete.type eq |ASSOWL| ) then
    VAR !assocGroups COLL MEMBERS OF $!GID WITH (TYPE EQ 'ASSOGP' AND PURP EQ 'HOLE' )
  else
    !associationGroup = !!dtbFindOwnerOfType(!elementToDelete,'ASSOGP',false)
    if ( !associationGroup.set() ) then
      if( !associationGroup.purpose eq |HOLE| ) then
        !assocGroups[1] = !associationGroup.string()
      endif
    endif
  endif
  if( !assocGroups.empty().not() ) then
    do !holeAssociationGroup values !assocGroups
      !dbHoleAssociationGroup = !holeAssociationGroup.dbref()
      if( !dbHoleAssociationGroup.mcount gt 0 ) then
        error |$!CNAM cannot be deleted because it is hole management association data. These must be deleted using the Hole Management utility|
        return
      endif
    enddo
  endif

if (undefined(!!runningUnitlTest)) then
  !owningZone = !!dtbFindOwnerOfType(!elementToDelete,'ZONE',false)
  if( !owningZone.set() ) then
    if(!!alertOnceDelSel.ShowAgain() AND !!isDeleteSelection.not()) then
      -- check for HM zone to minimise time on ASSOS query
      if( !owningZone.purpose eq 'HOLE' ) then
        var !TXT |This element contains managed hole data. Deleting it may result in invalid managed holes. Do you want to continue? |
        !!alertOnceDelSel.question.val = !TXT
        waiton !!alertOnceDelSel
        if(!!alertOnceDelSel.confirm.not()) then
          return
        endif
      else
        -- check for associations only below ZONE level
        !associations = !elementToDelete.assos
        handle any
          !associations = ARRAY()
        endhandle
        -- loop through associations and warn if this is a hole management element
        do !assocRef values !associations
          !assocPurpose   = !assocRef.owner.purp
          handle any
            !assocPurpose = ''
          endhandle
          if( !assocPurpose eq 'HOLE' ) then
            var !TXT |This element contains managed hole data. Deleting it may result in invalid managed holes. Do you want to continue? |
            !!alertOnceDelSel.question.val = !TXT
            waiton !!alertOnceDelSel
            if(!!alertOnceDelSel.confirm.not()) then
              return
            else
              break
            endif
          endif
        enddo
      endif
    endif
  endif
endif

-- End of special case for hole management

$* Check if we can delete the element
 var !TYPE (TYPE of $!GID )
 var !DFLG exists $!GID $!TYPE DELETE
 var !DFLG (substr(|$!DFLG|,1,1))
 var !DMEM coll all with ((LOCK) and TYPE neq 'TMPL') for $!GID

-- In structures templates are created locked, but this should not prevent deletion.
-- Unlock templates and their members, but re-lock them if deletion fails.
!lockedTemplateItems = object ARRAY()
if ( !TYPE INSET(|FIXING|, |JLDATU|, |PLDATU|, |ENDATU|, |GENSEC|) ) then

  -- unlock items in template
  !lockedTemplateItems = !!unlockTemplateMembers($!GID)

  -- Rebuild list of locked members.  We have only unlocked the members or TMPLs.  There may be more.
  var !DMEM coll all with ((LOCK) and TYPE neq 'TMPL') for $!GID

endif

$* Return if we cannot delete element
if(not $!DFLG or LOCK or (arraysize(!DMEM) gt 0)) then
  -- First re-lock members we unlocked above
  do !item values !lockedTemplateItems
    !item.dbref().lock = true
    handle (2,813)
      -- skip if somehow the item is an invalid dbref
    endhandle
  enddo  

  if(LOCK of $!GID ) then
  !!deleteErrorEncountered = TRUE
    return error 1 |$!CNAM is Locked.|
  elseif (arraysize(!DMEM) gt 0) then
    return error 1 |$!CNAM has Locked offspring.|
  else
    return error 1 |$!CNAM is in a read-only database.|
  endif
endif

$* check for dacs
 if ($!CFLG) then
   -- If retain flag delete members of element but not the element itself
   !members = !GID.dbref().members
   do !i indices !members
     if (!!qryDacState()) then
       !member = !members[!i].string()
