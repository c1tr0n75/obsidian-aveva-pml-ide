------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add CE to drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Actioned gadget
--    2   R      STRING      Action
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .add(!gadget is GADGET, !action is STRING)

  -- Add CE to drawlist
  !this.drawlist.addOnly(!!ce)
  if (!this.track.val.not()) then
    !this.refresh(-1, 0)
  endif

endmethod
-- End of method definition for .add()

------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove selected elements from drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .remove()

  -- Remove selected elements
  !this.drawlist.removeOnlyMembers(!this.gridSelection())
  if (!this.track.val.not()) then
    !this.refresh(-1, 0)
  endif

endmethod
-- End of method definition for .remove()

------------------------------------------------------------------------
--
-- Method:      refresh
--
-- Description: Refresh lists
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        type of change
--    2   R      REAL        sgl id
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .refresh(!change is REAL, !sglId is REAL)

  -- Trace
  if (!!gphDrawlists.debug) then
    !this.traceCount = !this.traceCount + 1
    !message = |[| & !this.traceCount & |] !!gphDrawlist.refresh()| & !change
    write !message
  endif

  -- Save current selection and tags
  !currentSelection = !this.gridSelection()
  !selectedTags     = !this.getSelectedRowTags(!this.visibleFrame())

  -- For primitives tab save top level element as this is cleared when form is reinitialised
  -- (clearing drawlist grid raises unselect event which causes call to drawlistSelect)
  !topLevelElement = !this.topLevelElement


  -- Reinitialise form and graphical selection tabs
  if (!change eq 2 or !change eq -1) then
  	-- Members changed
    !this.drawlistTabInit()
  endif
  if (!this.isDesign and (!change eq 3 or !change eq -1)) then
  	if (!this.visibleFrame().Tag eq 'Graphical Selection') then
  		-- Graphical selection changed and tab visible
      !this.selectedTabInit()
      !this.primtypeTabInit()
      !this.primtypeFrame.active  = FALSE
    endif
  endif

  -- Deactivate visual property gadgets until an element is selected
  !this.setActive(FALSE)

  -- Reselect top level element and repopulate primitives tab after initialisation (design/outfitting only)
  if (!this.isDesign) then
    if (!this.primtypeFrame.selected) then
      if (not badref(!topLevelElement)) then
        !this.select(!topLevelElement, !this.netDrawlistFrame, FALSE)
      endif
      !this.primtypeTabInit()
      !this.setActive(FALSE)
    endif
  endif


  -- Reselect first item found from previous selection to trigger selection callback
--  !this.selectFirstOf(!currentSelection, !this.visibleFrame(), FALSE)

  -- Reselect all rows previously selected that are still available without select callback
--  !this.suspendSelection = TRUE
--  !this.setSelectedRowTags(!this.visibleFrame(), !selectedTags)
--  !this.suspendSelection = FALSE

endmethod
-- End of method definition for .refresh()

------------------------------------------------------------------------
--
-- Method:      update
--
-- Description: Process drawlist update event
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        type of change
--    2   R      REAL        sgl id
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .update(!change is REAL, !sglId is REAL)

  -- Refresh the form on any drawlist update event
  if (!this.reallyShown() and !this.track.val and !this.suspendUpdates.not() ) then
    !this.refresh(!change, !sglId)
  endif

  -- Restore updates
  !this.suspendUpdates = FALSE

endmethod
-- End of method definition for .update()

------------------------------------------------------------------------
--
-- Method:      track
--
-- Description: Toggle track changes
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .track()

  -- Refresh the form immediately if tracking is switched on
  if (!this.track.val) then
    !this.refresh(-1, 0)
  endif

endmethod
-- End of method definition for .update()

------------------------------------------------------------------------
--
-- Method:      gridSelection
--
-- Description: Return selection for currently displayed grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       Selection for currently displayed grid
--
------------------------------------------------------------------------

define method .gridSelection() is ARRAY

  -- Get selection for visible grid
  if (!this.drawlistFrame.selected) then
    !gridSelection = !this.drawlistGridSelection
  elseif (!this.selectedFrame.selected) then
    !gridSelection = !this.selectedGridSelection
  elseif (!this.primtypeFrame.selected) then
    !gridSelection = !this.primtypeGridSelection
  endif
  return !gridSelection

endmethod
-- End of method definition for .gridSelection() is ARRAY

------------------------------------------------------------------------
--
-- Method:      visibleFrame
--
-- Description: Return currently displayed frame tab
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    GADGET      Currently displayed frame
--
------------------------------------------------------------------------

define method .visibleFrame() is GADGET

  -- Get visible grid
  !frame = object GADGET()
  if (!this.drawlistFrame.selected) then
    !frame = !this.netDrawlistFrame
  elseif (!this.selectedFrame.selected) then
    !frame = !this.netSelectedFrame
  elseif (!this.primtypeFrame.selected) then
    !frame = !this.netPrimtypeFrame
  endif
  return !frame

endmethod
-- End of method definition for .visibleFrame() is GADGET

------------------------------------------------------------------------
--
-- Method:      reallyShown
--
-- Description: Return true if show of form is complete
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True if really shown
--
------------------------------------------------------------------------

define method .reallyShown() is BOOLEAN

  -- Return true if form really is shown so that one of the tabs thinks it is visible
  return (!this.shown() and !this.visibleFrame().set())

endmethod
-- End of method definition for .reallyShown() is BOOLEAN

------------------------------------------------------------------------
--
-- Method:      goodRefs
--
-- Description: Validate references of selected elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       Array of good references from selected elements
--
------------------------------------------------------------------------

define method .goodRefs() is ARRAY

  -- Validate references for all selected elements
  !goodRefs = ARRAY()
  do !element values !this.gridSelection()
    if (not badref(!element)) then
      !goodRefs.append(!element)
    endif
  enddo
  return !goodRefs

endmethod
-- End of method definition for .goodRefs()

------------------------------------------------------------------------
--
-- Method:      colour
--
-- Description: Select display colour
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .colour()

  -- Display colour selection form
  call !!colourSelectLoad(|!!gphDrawlist.applyColour(!!colourSelectGet())|, |Colour|, !this.currentColour)

endmethod
-- End of method definition for .colour()

------------------------------------------------------------------------
--
-- Method:      colour
--
-- Description: Set display colour
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Colour code
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .colour(!colour is REAL)

  -- Set display colour
  !useColour              = !colour
  !this.colourName.val    = !!colourName(!useColour)
  handle any
    -- If colour is not a named colour then default to colour 1 grey
    !useColour            = 1
    !this.colourName.val  = !!colourName(!useColour)
  endhandle
  !this.currentColour     = !useColour
  !this.colour.background = !useColour
  !this.colourName.refresh()

endmethod
-- End of method definition for .colour(REAL)

------------------------------------------------------------------------
--
-- Method:      applyColour
--
-- Description: Apply colour change to selected elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Colour code
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .applyColour(!colour is REAL)

  -- Trace
  if (!!gphDrawlists.debug) then
    !this.traceCount = !this.traceCount + 1
    !message = |[| & !this.traceCount & |] !!gphDrawlist.applyColour(REAL)|
    write !message
  endif

  -- Display selected colour
  !this.colour(!colour)

  -- Suspend updates whilst form changes visual properties
  !this.suspendUpdates = TRUE

  -- Set colour for all good references from selected elements
  if (!this.suspendCallbacks.not()) then
    !this.saveSettings()
    !goodRefs = !this.goodRefs()
    if (!goodRefs.empty().not()) then
      !this.drawlist.colour(!goodRefs, !this.savedColour)
    endif
  endif

endmethod
-- End of method definition for .applyColour(REAL)

------------------------------------------------------------------------
