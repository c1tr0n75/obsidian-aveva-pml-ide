    !this.saveSettings()
    !goodRefs = !this.goodRefs()
    if (!goodRefs.empty().not()) then
      !this.drawlist.visibility(!goodRefs, !this.savedShown)
    endif
  endif

endmethod
-- End of method definition for .applyVisibility()

