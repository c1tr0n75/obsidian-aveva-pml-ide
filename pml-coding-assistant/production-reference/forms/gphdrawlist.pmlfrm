------------------------------------------------------------------------
--
-- Method:      selectFirstOf
--
-- Description: Select first of these elements found in currently visible grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       References of elements to be selected
--    2   R      GADGET      Frame of grid in which elements are to be selected
--    3   R      BOOLEAN     True if want warning that element is not in list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .selectFirstOf(!itemsToSelect is ARRAY, !frame is GADGET, !wantToKnow is BOOLEAN)

  -- Select first of these elements that are in the currently visible grid
  !this.select(!itemsToSelect, !frame, !wantToKnow, TRUE)

endmethod
-- End of method definition for .selectFirstOf(ARRAY, GADGET, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      select
--
-- Description: Select elements in currently visible grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       References of elements to be selected
--    2   R      GADGET      Frame of grid in which elements are to be selected
--    3   R      BOOLEAN     True if want warning that element is not in list
--    4   R      BOOLEAN     True if want to select only the first one found
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .select(!itemsToSelect is ARRAY, !frame is GADGET, !wantToKnow is BOOLEAN, !firstOnly is BOOLEAN)

  -- Trace
  if (!!gphDrawlists.debug) then
    !this.traceCount = !this.traceCount + 1
    !message = |[| & !this.traceCount & |] !!gphDrawlist.select(ARRAY, GADGET, BOOLEAN)|
    write !message
  endif

  -- Find which rows to select
  !rowsToSelect = ARRAY()
  !rows = !this.getRows(!frame)
  do !item values !itemsToSelect

    if (not badref(!item)) then
      !found = FALSE
      do !row indices !rows
        if (!item.fullname eq !rows[!row][1]) then
          !rowsToSelect.append(!row)
          !found = TRUE
          break
        endif
      enddo
      if (!found.not()) then
        -- Check if significant owner is in list
        if (!item.signif.not()) then
          do !row indices !rows
            if (!item.prmown.fullname eq !rows[!row][1]) then
              !rowsToSelect.append(!row)
              !found = TRUE
              break
            endif
          enddo
        endif
      endif
      if (!found.not() and !wantToKnow) then
        !!alert.warning(!item.fullname & | is not in the list|)
      endif
      break if (!found and !firstOnly)
    endif
  enddo

  -- Select items in grid
  !this.clearRowSelection(!frame)
  if (!rowsToSelect.size() gt 0) then
    !this.suspendSelection = TRUE
    do !i from 2 to !rowsToSelect.size()
      !this.selectRow(!frame, !rowsToSelect[!i])
    enddo
    !this.suspendSelection = FALSE
    !this.selectRow(!frame, !rowsToSelect[1])
  endif

endmethod
-- End of method definition for .select(ARRAY, GADGET, BOOLEAN, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      clearRowSelection
--
-- Description: Clear selection in grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Frame of grid in which selection is to be cleared
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clearRowSelection(!frame is GADGET)

  -- Select items in grid
  if (!frame eq !this.netDrawlistFrame) then
    !this.drawlistGrid.clearRowSelection()
  elseif (!frame eq !this.netSelectedFrame) then
    !this.selectedGrid.clearRowSelection()
  elseif (!frame eq !this.netPrimtypeFrame) then
    !this.primtypeGrid.clearRowSelection()
  endif

endmethod
-- End of method definition for .clearRowSelection(GADGET)

------------------------------------------------------------------------
--
-- Method:      getRows
--
-- Description: Get rows of grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Frame of grid from which to get rows
-- Return:
--   [Data Type] [Description]
--    ARRAY       Rows from grid
--
------------------------------------------------------------------------

define method .getRows(!frame is GADGET) is ARRAY

  -- Select items in grid
  if (!frame eq !this.netDrawlistFrame) then
    !rows = !this.drawlistGrid.getRows()
  elseif (!frame eq !this.netSelectedFrame) then
    !rows = !this.selectedGrid.getRows()
  elseif (!frame eq !this.netPrimtypeFrame) then
    !rows = !this.primtypeGrid.getRows()
  endif
  return !rows

endmethod
-- End of method definition for .getRows(GADGET) is ARRAY

