------------------------------------------------------------------------
--
-- Method:      translucency
--
-- Description: Set display of translucency
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Translucency percentage
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .translucency(!translucency is REAL)

  -- Set display of translucency
  !this.translucency.val = !translucency.string()
  !this.slide.val        = !translucency
  !this.translucency.refresh()
  !this.slide.refresh()

endmethod
-- End of method definition for .translucency(REAL)

------------------------------------------------------------------------
--
-- Method:      slide
--
-- Description:
--   Set translucency
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Actioned gadget
--    2   R      STRING      Action
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .slide(!gadget is GADGET, !action is STRING)

  if (!action eq |START|) then

    -- No action

  elseif (!action eq |STOP|) then

    -- Apply translucency change
    !this.applyTranslucency()

  elseif (!action eq |MOVE|) then

    -- Update value
    !this.translucency.val = !this.slide.val.string()
    !this.translucency.refresh()

  endif

endmethod
-- End of method definition for .slide(GADGET, STRING)

------------------------------------------------------------------------
--
-- Method:      nudge
--
-- Description:
--   Nudge slider
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Actioned gadget
--    2   R      STRING      Action
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .nudge(!gadget is GADGET, !action is STRING)

  -- Offset is from text gadget or arrow button
  !translucency = !this.translucency.val.real()
  if (!gadget eq !this.less) then
    if (!translucency gt 0) then
      !translucency = !translucency - 1
    endif
  elseif (!gadget eq !this.more) then
    if (!translucency lt 99) then
      !translucency = !translucency + 1
    endif
  endif

  -- Update value
  !this.translucency(!translucency)

  -- Apply translucency change
  !this.applyTranslucency()

endmethod

-- End of method definition for .nudge()

------------------------------------------------------------------------
--
-- Method:      setActive
--
-- Description: Set visual properties gadgets active or inactive
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     Active setting
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setActive(!active is BOOLEAN)

  -- Set active status of visual property gadgets
  !this.shown.active        = !active
  !this.edges.active        = !active
  !this.colourTitle.active  = !active
  !this.colour.active       = !active
  !this.colourName.active   = !active
  !this.transTitle.active   = !active
  !this.translucency.active = !active
  !this.slide.active        = !active
  !this.less.active         = !active
  !this.more.active         = !active

  -- Activate remove button when something is selected
  !this.remove.active = !active

endmethod
-- End of method definition for .setActive(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      highlight
--
-- Description: Highlight elements selected
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Dbrefs to be highlighted
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .highlight(!gridSelection is ARRAY)

  -- Highlight selected elements and store for subsequent unhighlighting
  do !element values !gridSelection
    !this.drawlist.highlight(!element, !!gphcolopt.highlight.code)
    !this.currentlyHighlighted.append(!element)
  enddo

endmethod
-- End of method definition for .highlight()

------------------------------------------------------------------------
--
-- Method:      unhighlight
--
-- Description: Unhighlight elements previously highlighted
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .unhighlight()

  -- Remove any highlighting
  do !element values !this.currentlyHighlighted
    !this.drawlist.unhighlight(!element)
  enddo
  !this.currentlyHighlighted.clear()

endmethod
-- End of method definition for .unhighlight()

------------------------------------------------------------------------
--
-- Method:      close
--
-- Description: Tidy up on closing form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .close()

  -- Remove any highlighting
  !this.unhighlight()

endmethod
-- End of method definition for .close()
