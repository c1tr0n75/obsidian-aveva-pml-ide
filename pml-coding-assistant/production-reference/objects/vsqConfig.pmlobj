endmethod

----------------------------------------------------------------------
--
-- Method:      updateCollection
--
-- Description: update a collection
--
----------------------------------------------------------------------
define method .updateCollection(!i is REAL, !description is STRING, !types is ARRAY) is VSQTYPECOLLECTION

  --update the collection in the object set
  !this.typeCollections[!i].update(!description, !types)
  return !this.typeCollections[!i]

endmethod

----------------------------------------------------------------------
--
-- Method:      getNextInternalId
--
-- Description: increment and return the internal id counter
--
----------------------------------------------------------------------
define method .getNextInternalId() is REAL

  --move the counter on
  !this.lastInternalId = !this.lastInternalId + 1
  return !this.lastInternalId

endmethod

----------------------------------------------------------------------
--
-- Method:      removeSet
--
-- Description: remove a set
--
----------------------------------------------------------------------
define method .removeSet(!set is VSQVISUALQUERYSET)

  --find and remove the set, setting its db element to be deleted in the write method
  do !i indices !this.visualQuerySets
    if (!this.visualQuerySets[!i].equals(!set)) then
      !index = !i
    endif
  enddo
  if (defined(!index)) then
    !this.removeSet(!index)
  endif

endmethod

----------------------------------------------------------------------
--
-- Method:      removeSet
--
-- Description: remove a set
--
----------------------------------------------------------------------
define method .removeSet(!i is REAL)

  --remove the set, setting its db element to be deleted in the write method
  !this.addElementToDelete(!this.visualQuerySets[!i].getDbElement())
  !this.visualQuerySets.remove(!i)
  !this.pendingChanges = true

endmethod

----------------------------------------------------------------------
--
-- Method:      removeMember
--
-- Description: remove members from a query set
--
----------------------------------------------------------------------
define method .removeMember(!setIndex is REAL, !memberQueryIndices is ARRAY)

  --remove the queries from the set
  !memberQueries = !this.visualQuerySets[!setIndex].visualQueries
  do !i values !memberQueryIndices
    !this.visualQuerySets[!setIndex].removeQuery(!memberQueries[!i])
  enddo

endmethod

