-- Configuration object for visual queries in application data world
-- File: vsqConfig.pmlobj
-- This is the interface object for visual queries configuration and running queries

define object VSQCONFIG

  --arrays of visual query sets, visual queries, view style and type collection definitions
  member .visualQuerySets       is ARRAY
  member .visualQueries         is ARRAY
  member .viewStyles            is ARRAY
  member .typeCollections       is ARRAY

  --application data world
  member .dataWorld             is DBREF

  --writable containers flag
  member .writable              is BOOLEAN

  --application data areas
  member .querySetsArea         is DBREF
  member .queriesArea           is DBREF
  member .stylesArea            is DBREF
  member .collectionsArea       is DBREF

  --container names
  member .dataWorldName         is STRING
  member .querySetsAreaName     is STRING
  member .queriesAreaName       is STRING
  member .stylesAreaName        is STRING
  member .collectionsAreaName   is STRING

  --internal id seed, used to generate internal ids for visual queries, view styles and type collections
  member .lastInternalId        is REAL

  --db elements to delete on write to database
  member .elementsToDelete      is ARRAY

  --flag for unsaved changes
  member .pendingChanges        is BOOLEAN

endobject

----------------------------------------------------------------------
--
-- Method:      vsqConfig
--
-- Description: default constructor
--
----------------------------------------------------------------------
define method .vsqConfig()

  --we want to run the constructor that creates the config from an export macro but not from a form setup member
  !inFormSetup = false
  blah
  handle any
    do !stack values !!error.callstack
      if (!stack.match('member ').gt(0)) then
        !inFormSetup = true
      endif
    enddo
  endhandle
  if (!inFormSetup.not()) then
    !this.vsqConfig(true)
  endif

endmethod

----------------------------------------------------------------------
--
-- Method:      vsqConfig
--
-- Description: constructor called from form init not on object creation so not run within form setup
--
----------------------------------------------------------------------
define method .vsqConfig(!forConfig is BOOLEAN)

  --argument for config is true if called from config form or plug method, false if called from run queries

  --set names for the data areas used in configuration
  !this.dataWorldName       = '/VSQ/VISUALQUERIES'
  !this.querySetsAreaName   = !this.dataWorldName & '/QUERYSETS'
  !this.queriesAreaName     = !this.dataWorldName & '/QUERIES'
  !this.stylesAreaName      = !this.dataWorldName & '/VIEWSTYLES'
  !this.collectionsAreaName = !this.dataWorldName & '/TYPECOLLECTIONS'

  --initialise the container refs
  !this.dataWorld           = object DBREF()
  !this.querySetsArea       = object DBREF()
  !this.queriesArea         = object DBREF()
  !this.stylesArea          = object DBREF()
  !this.collectionsArea     = object DBREF()

  --initialise the writable containers flag
  !this.writable = false

  --initialise the internal id counter, used to match objects until they have a dbref
  !this.lastInternalId = 0

  --check the data world and areas and load config if they are available
  if (!this.checkDataWorld(!forConfig)) then
    !this.loadConfig()
  endif
  !this.pendingChanges = false

endmethod

----------------------------------------------------------------------
--
-- Method:      checkDataWorld
--
-- Description: check the data world where our configuration data is stored
--
----------------------------------------------------------------------
define method .checkDataWorld() is BOOLEAN

  --default check is from run queries
  return !this.checkDataWorld(false)

endmethod

----------------------------------------------------------------------
--
-- Method:      checkDataWorld
--
-- Description: check the data world where our configuration data is stored
--
----------------------------------------------------------------------
define method .checkDataWorld(!forConfig is BOOLEAN) is BOOLEAN

  --check if data world exists
  !name = !this.dataWorldName
  var !exists EXISTS $!name APPLDW
  if (!exists.eq('TRUEB')) then
    !this.dataWorld = object DBREF(!this.dataWorldName)
    --check and create the data areas for the sets, queries, view styles and collection types
    !this.checkQuertSetsContainer(false)
    !this.checkQueriesContainer(false)
    !this.checkStylesContainer(false)
    !this.checkCollectionsContainer(false)
  endif

  --if for configuration and not just to run queries, and only the query sets data area is unavailable this is an upgrade
  if (!forConfig and !this.querySetsArea.badRef() and !this.queriesArea.badRef().not() and !this.stylesArea.badRef().not() and !this.collectionsArea.badRef().not()) then
    !this.checkQuertSetsContainer(true)
    handle any
      !!alert.error('Unable to create query sets application data area: $!!error.text')
    endhandle
  endif

  --confirm all data areas excluding sets are available
  !allContainersAvailable = (!this.queriesArea.badRef().not() and !this.stylesArea.badRef().not() and !this.collectionsArea.badRef().not())
  !this.writable          = (!allContainersAvailable and !this.dataWorld.dbwrit and !this.dataWorld.lock.not() and !this.dataWorld.dacmod)
  return !allContainersAvailable
  
endmethod

----------------------------------------------------------------------
--
-- Method:      createDataWorld
--
-- Description: create the data world where our configuration data is stored
--
----------------------------------------------------------------------
define method .createDataWorld()

  !currentElement = !!ce

  --create application data world
  !name = !this.dataWorldName
  NEW APPLDW $!name
  handle any
    return error 1 'Unable to create application data world: $!!error.text'
  endhandle
  PURP WORD VISQ
  !this.dataWorld = !!ce

  --check and create the data areas for the sets, queries, view styles and collection types
  !this.checkQuertSetsContainer(true)
  !this.checkQueriesContainer(true)
  !this.checkStylesContainer(true)
  !this.checkCollectionsContainer(true)

  !!ce = !currentElement
  handle any
  endhandle

endmethod

----------------------------------------------------------------------
--
-- Method:      checkQuertSetsContainer
--
-- Description: check and if necessary create the container for query sets configuration
--
----------------------------------------------------------------------
define method .checkQuertSetsContainer(!create is BOOLEAN)

  !currentElement = !!ce

  --check if container exists and create if not
  !name = !this.querySetsAreaName
  var !exists EXISTS $!name APPDAR
  if (!exists.eq('TRUEB')) then
    !this.querySetsArea = object DBREF(!this.querySetsAreaName)
  elseif (!create) then
    !!ce = !this.dataWorld
    NEW APPDAR
    !!ce.name = !name
    PURP WORD VQQS
    !this.querySetsArea = !!ce
    NEW APPLDA
    PURP WORD VQQS
  endif

  !!ce = !currentElement

endmethod

----------------------------------------------------------------------
--
-- Method:      checkQueriesContainer
--
-- Description: check and if necessary create the container for queries configuration
--
----------------------------------------------------------------------
define method .checkQueriesContainer(!create is BOOLEAN)

  !currentElement = !!ce

  --check if container exists and create if not
  !name = !this.queriesAreaName
  var !exists EXISTS $!name APPDAR
  if (!exists.eq('TRUEB')) then
    !this.queriesArea = object DBREF(!this.queriesAreaName)
  elseif (!create) then
    !!ce = !this.dataWorld
    NEW APPDAR
    !!ce.name = !name
    PURP WORD VQVQ
    !this.queriesArea = !!ce
    NEW APPLDA
    PURP WORD VQVQ
  endif

  !!ce = !currentElement

endmethod

