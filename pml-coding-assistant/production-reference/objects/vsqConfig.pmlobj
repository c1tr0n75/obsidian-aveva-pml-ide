----------------------------------------------------------------------
--
-- Method:      removeAll
--
-- Description: remove all queries, styles and collections from the object and the database
--
----------------------------------------------------------------------
define method .removeAll()

  --remove all sets, queries, styles and collections
  !this.removeAllQuerySets()
  !this.removeAllQueries()
  !this.removeAllStyles()
  !this.removeAllCollections()

endmethod

----------------------------------------------------------------------
--
-- Method:      removeAllQuerySets
--
-- Description: remove all query sets from the object and the database
--
----------------------------------------------------------------------
define method .removeAllQuerySets()

  --remove all query sets
  do !set values !this.visualQuerySets
    !this.addElementToDelete(!set.getDbElement())
  enddo
  !this.visualQuerySets.clear()
  !this.pendingChanges = true

endmethod

----------------------------------------------------------------------
--
-- Method:      removeAllQueries
--
-- Description: remove all queries from the object and the database
--
----------------------------------------------------------------------
define method .removeAllQueries()

  --remove all queries
  do !query values !this.visualQueries
    !this.addElementToDelete(!query.getDbElement())
  enddo
  !this.visualQueries.clear()
  !this.pendingChanges = true

endmethod

----------------------------------------------------------------------
--
-- Method:      removeAllStyles
--
-- Description: remove all styles from the object and the database
--
----------------------------------------------------------------------
define method .removeAllStyles()

  --remove all queries
  do !style values !this.viewStyles
    !this.addElementToDelete(!style.getDbElement())
  enddo
  !this.viewStyles.clear()
  !this.pendingChanges = true

endmethod

----------------------------------------------------------------------
--
-- Method:      removeAllCollections
--
-- Description: remove all collections from the object and the database
--
----------------------------------------------------------------------
define method .removeAllCollections()

  --remove all queries
  do !collection values !this.typeCollections
    !this.addElementToDelete(!collection.getDbElement())
  enddo
  !this.typeCollections.clear()
  !this.pendingChanges = true

endmethod

----------------------------------------------------------------------
--
-- Method:      addElementToDelete
--
-- Description: add a db element to the list to be deleted
--
----------------------------------------------------------------------
define method .addElementToDelete(!dbElement is DBREF)

  --check and add the db element
  if (!dbElement.badRef().not()) then
    if (!this.elementsToDelete.findFirst(!dbElement).unset()) then
      !this.elementsToDelete.append(!dbElement)
    endif
  endif

endmethod

----------------------------------------------------------------------
--
-- Method:      deleteRemovedElements
--
-- Description: delete all db elements from removed queries, styles and collections
--
----------------------------------------------------------------------
define method .deleteRemovedElements()

  !currentElement = !!ce

  --delete any db elements from removed styles, collections and queries
  do !item values !this.elementsToDelete
    !!ce = !item
    handle any
    elsehandle none
      !type = !!ce.type
      DELETE $!type
      handle any
        !message = |Error deleting | & !!ce.flnm & | : | & !!error.text
        write !message
      endhandle
    endhandle
  enddo

  !!ce = !currentElement
  handle any
  endhandle

endmethod

------------------------------------------------------------------------
--
-- Method:   moveSetUp
--
-- Description: move query set up in list order
--
------------------------------------------------------------------------
define method .moveSetUp(!index is REAL)

  --move up
  !temp = !this.visualQuerySets[!index]
  !this.visualQuerySets[!index] = !this.visualQuerySets[!index - 1]
  !this.visualQuerySets[!index - 1] = !temp
  !this.pendingChanges = true

endmethod

------------------------------------------------------------------------
--
-- Method:   moveSetDown
--
-- Description: move query set down in list order
--
------------------------------------------------------------------------
define method .moveSetDown(!index is REAL)

  --move down
  !temp = !this.visualQuerySets[!index]
  !this.visualQuerySets[!index] = !this.visualQuerySets[!index + 1]
  !this.visualQuerySets[!index + 1] = !temp
  !this.pendingChanges = true

endmethod

