----------------------------------------------------------------------
--
-- Method:      loadConfig
--
-- Description: load config data for queries, styles and collections
--
----------------------------------------------------------------------
define method .loadConfig()

  --load config data from the database
  !this.visualQuerySets = ARRAY()
  if (!this.querySetsArea.badref().not()) then
    do !item values !!kCollectAllFor('DDSE', '', !this.querySetsArea)
      !this.visualQuerySets.append(object VSQVISUALQUERYSET(!item))
    enddo
  endif
  !this.visualQueries = ARRAY()
  if (!this.queriesArea.badref().not()) then
    do !item values !!kCollectAllFor('DDSE', '', !this.queriesArea)
      !this.visualQueries.append(object VSQVISUALQUERY(!item))
    enddo
  endif
  !this.viewStyles = ARRAY()
  if (!this.stylesArea.badref().not()) then
    do !item values !!kCollectAllFor('DDSE', '', !this.stylesArea)
      !this.viewStyles.append(object VSQVIEWSTYLE(!item))
    enddo
  endif
  !this.typeCollections = ARRAY()
  if (!this.collectionsArea.badref().not()) then
    do !item values !!kCollectAllFor('DDSE', '', !this.collectionsArea)
      !this.typeCollections.append(object VSQTYPECOLLECTION(!item))
    enddo
  endif
  !this.elementsToDelete.clear()
  !this.pendingChanges = false

endmethod

----------------------------------------------------------------------
--
-- Method:      write
--
-- Description: write to database
--
----------------------------------------------------------------------
define method .write()

  --delete any db elements from removed styles, collections and queries
  !this.deleteRemovedElements()

  --write all the styles and collections data first, this must be done before the queries are written
  do !style values !this.viewStyles
    if (!style.pendingChanges) then
      !style.write()
    endif
  enddo
  do !collection values !this.typeCollections
    if (!collection.pendingChanges) then
      !collection.write()
    endif
  enddo

  --update the dbElements in the objects owned by the queries before writing the queries and sets
  !this.setQueriesFrom()
  do !query values !this.visualQueries
    if (!query.pendingChanges) then
      !query.write()
    endif
  enddo
  !this.setSetsFrom()
  do !set values !this.visualQuerySets
    if (!set.pendingChanges) then
      !set.write()
    endif
  enddo

  --reorder saved elements
  do !i indices !this.viewStyles
    !this.setSequence(!this.viewStyles[!i].getDbElement(), !i)
  enddo
  do !i indices !this.typeCollections
    !this.setSequence(!this.typeCollections[!i].getDbElement(), !i)
  enddo
  do !i indices !this.visualQueries
    !this.setSequence(!this.visualQueries[!i].getDbElement(), !i)
  enddo
  do !i indices !this.visualQuerySets
    !this.setSequence(!this.visualQuerySets[!i].getDbElement(), !i)
  enddo

  !this.pendingChanges = false

endmethod

----------------------------------------------------------------------
--
-- Method:      setSequence
--
-- Description: set element in sequence order
--
----------------------------------------------------------------------
define method .setSequence(!element is DBREF, !sequence is REAL)

  --set order
  !currentElement = !!ce
  !!ce = !element.owner
  REORDER $!element BEFORE $!sequence
  !!ce = !currentElement

endmethod

----------------------------------------------------------------------
--
-- Method:      styleIndexForQueryIndex
--
-- Description: return style array index for query array index
--
----------------------------------------------------------------------
define method .queryIndexForSetIndex(!setIndex is REAL) is REAL

  --get style index
  return !this.visualQuerySets[!setIndex].queryIndex(!this.visualQueries)

endmethod

----------------------------------------------------------------------
--
-- Method:      styleIndexForQueryIndex
--
-- Description: return style array index for query array index
--
----------------------------------------------------------------------
define method .styleIndexForQueryIndex(!queryIndex is REAL) is REAL

  --get style index
  return !this.visualQueries[!queryIndex].styleIndex(!this.viewStyles)

endmethod

----------------------------------------------------------------------
--
-- Method:      collectionIndexForQueryIndex
--
-- Description: return collection array index for query array index
--
----------------------------------------------------------------------
define method .collectionIndexForQueryIndex(!queryIndex is REAL) is REAL

  --get collection index
  return !this.visualQueries[!queryIndex].collectionIndex(!this.typeCollections)

endmethod

----------------------------------------------------------------------
--
-- Method:      queryInUse
--
-- Description: return true if the query is in a set
--
----------------------------------------------------------------------
define method .queryInUse(!i is REAL) is BOOLEAN

  --check if any query uses the style
  return !this.queryInUse(!this.visualQueries[!i])

endmethod

----------------------------------------------------------------------
--
-- Method:      queryInUse
--
-- Description: return true if the query is in a set
--
----------------------------------------------------------------------
define method .queryInUse(!visualQuery is VSQVISUALQUERY) is BOOLEAN

  --check if any set uses the query
  do !set values !this.visualQuerySets
    if (!set.usesQuery(!visualQuery)) then
      return true
    endif
  enddo
  return false

endmethod

----------------------------------------------------------------------
--
-- Method:      styleInUse
--
-- Description: return true if the style is in use
--
----------------------------------------------------------------------
define method .styleInUse(!i is REAL) is BOOLEAN

  --check if any query uses the style
  return !this.styleInUse(!this.viewStyles[!i])

endmethod

----------------------------------------------------------------------
--
-- Method:      styleInUse
--
-- Description: return true if the style is in use
--
----------------------------------------------------------------------
define method .styleInUse(!viewStyle is VSQVIEWSTYLE) is BOOLEAN

  --check if any query uses the style
  do !query values !this.visualQueries
    if (!query.usesStyle(!viewStyle)) then
      return true
    endif
  enddo
  return false

endmethod

----------------------------------------------------------------------
--
-- Method:      collectionInUse
--
-- Description: return true if the style is in use
--
----------------------------------------------------------------------
define method .collectionInUse(!i is REAL) is BOOLEAN

  --check if any query uses the collection
  return !this.collectionInUse(!this.typeCollections[!i])

endmethod

----------------------------------------------------------------------
--
-- Method:      collectionInUse
--
-- Description: return true if the collection is in use
--
----------------------------------------------------------------------
define method .collectionInUse(!typeCollection is VSQTYPECOLLECTION) is BOOLEAN

  --check if any query uses the collection
  do !query values !this.visualQueries
    if (!query.usesCollection(!typeCollection)) then
      return true
    endif
  enddo
  return false

endmethod

----------------------------------------------------------------------
--
-- Method:      setSetsFrom
--
-- Description: update the dbElements in the objects owned by the query sets
--
----------------------------------------------------------------------
define method .setSetsFrom()

  --update the dbElements in the objects owned by the sets before writing the sets
  do !set values !this.visualQuerySets
    !set.setFrom(!this.visualQueries)
  enddo

endmethod

----------------------------------------------------------------------
--
-- Method:      setQueriesFrom
--
-- Description: update the dbElements in the objects owned by the queries
--
----------------------------------------------------------------------
define method .setQueriesFrom()

  --update the dbElements in the objects owned by the queries before writing the queries
  do !query values !this.visualQueries
    !query.setFrom(!this.viewStyles, !this.typeCollections)
  enddo

endmethod

----------------------------------------------------------------------
--
-- Method:      addSet
--
-- Description: add a new query set
--
----------------------------------------------------------------------
define method .addSet() is VSQVISUALQUERYSET

  --add the new query set to the object set
  !set = object VSQVISUALQUERYSET(!this.getNextInternalId(), !this.querySetsArea, 'New visual query set')
  !this.visualQuerySets.append(!set)
  return !set

endmethod

----------------------------------------------------------------------
--
-- Method:      addSet
--
-- Description: add a new query set
--
----------------------------------------------------------------------
define method .addSet(!description is STRING) is VSQVISUALQUERYSET

  --add the new query set to the object set
  !set = object VSQVISUALQUERYSET(!this.getNextInternalId(), !this.querySetsArea, !description)
  !this.visualQuerySets.append(!set)
  return !set

endmethod

----------------------------------------------------------------------
--
-- Method:      addSet
--
-- Description: add a new query set
--
----------------------------------------------------------------------
define method .addSet(!description is STRING, !visualQueries is ARRAY) is VSQVISUALQUERYSET

  --add the new query set to the object set
  !set = object VSQVISUALQUERYSET(!this.getNextInternalId(), !this.querySetsArea, !description, !visualQueries)
  !this.visualQuerySets.append(!set)
  return !set

endmethod

----------------------------------------------------------------------
--
-- Method:      updateSet
--
-- Description: update a query set
--
----------------------------------------------------------------------
define method .updateSet(!setRow is REAL, !description is STRING)

  --update the set in the object set
  !this.visualQuerySets[!setRow].update(!description)

endmethod

----------------------------------------------------------------------
--
-- Method:      addMember
--
-- Description: add new members from the available queries to a query set
--
----------------------------------------------------------------------
define method .addMember(!setIndex is REAL, !availableQueryIndices is ARRAY)

  --add the queries to the set
  !availableQueries = !this.getAvailableQueries(!setIndex)
  do !i values !availableQueryIndices
    !this.visualQuerySets[!setIndex].addQuery(!availableQueries[!i])
  enddo

endmethod

----------------------------------------------------------------------
--
-- Method:      addQueryToSet
--
-- Description: add a new member from the total queries to a query set
--
----------------------------------------------------------------------
define method .addQueryToSet(!setIndex is REAL, !queryIndex is REAL)

  --add the query to the set
  !this.visualQuerySets[!setIndex].addQuery(!this.visualQueries[!queryIndex])

endmethod

----------------------------------------------------------------------
--
-- Method:      addQuery
--
-- Description: add a new query
--
----------------------------------------------------------------------
define method .addQuery(!description is STRING, !expression is EXPRESSION, !viewStyle is VSQVIEWSTYLE, !typeCollection is VSQTYPECOLLECTION) is VSQVISUALQUERY

  --add the style if not already defined
  !found = false
  do !style values !this.viewStyles
    if (!style.equals(!viewStyle)) then
      !found = true
    endif
  enddo
  if (!found.not()) then
    !this.viewStyles.append(!viewStyle)
  endif

  --add the collection if not already defined
  !found = false
  do !collection values !this.typeCollections
    if (!collection.equals(!typeCollection)) then
      !found = true
    endif
  enddo
  if (!found.not()) then
    !this.typeCollections.append(!typeCollection)
  endif

  --add the new query to the object set
  !query = object VSQVISUALQUERY(!this.getNextInternalId(), !this.queriesArea, !description, !expression, !viewStyle, !typeCollection)
  !this.visualQueries.append(!query)
  return !query

endmethod

----------------------------------------------------------------------
--
-- Method:      addQuery
--
-- Description: add a new query with basic properties
--
----------------------------------------------------------------------
define method .addQuery() is VSQVISUALQUERY

  --add the new query to the object set with the the first view style and type collection if available, otherwise new basic versions
  !expression = object EXPRESSION('( TRUE )')
  if (!this.viewStyles.empty()) then
    !style = !this.addStyle()
  else
    !style = !this.viewStyles[1]
  endif
  if (!this.typeCollections.empty()) then
    !collection = !this.addCollection()
  else
    !collection = !this.typeCollections[1]
  endif
  !query = object VSQVISUALQUERY(!this.getNextInternalId(), !this.queriesArea, 'New visual query', !expression, !style, !collection)
  !this.visualQueries.append(!query)
  return !query

endmethod

----------------------------------------------------------------------
--
-- Method:      copyQuery
--
-- Description: copy a query
--
----------------------------------------------------------------------
define method .copyQuery(!i is REAL) is VSQVISUALQUERY

  --add the copied query to the object set
  !query = !this.visualQueries[!i]
  !query = !this.addQuery(!query.getDescription(), !query.getExpression(), !query.getViewStyle(), !query.getTypeCollection())
  return !query

endmethod

----------------------------------------------------------------------
--
-- Method:      updateQuery
--
-- Description: update a query
--
----------------------------------------------------------------------
define method .updateQuery(!query is VSQVISUALQUERY, !description is STRING, !expression is EXPRESSION, !viewStyle is VSQVIEWSTYLE, !typeCollection is VSQTYPECOLLECTION) is VSQVISUALQUERY

  --update the query in the object set
  do !i indices !this.visualQueries
    if (!this.visualQueries[!i].equals(!query)) then
      return !this.updateQuery(!i, !description, !expression, !viewStyle, !typeCollection)
    endif
  enddo
  return !query

endmethod

----------------------------------------------------------------------
--
-- Method:      updateQuery
--
-- Description: update a query
--
----------------------------------------------------------------------
define method .updateQuery(!i is REAL, !description is STRING, !expression is EXPRESSION, !viewStyle is VSQVIEWSTYLE, !typeCollection is VSQTYPECOLLECTION) is VSQVISUALQUERY

  --update the query in the object set
  !this.visualQueries[!i].update(!description, !expression, !viewStyle, !typeCollection)
  return !this.visualQueries[!i]

endmethod

----------------------------------------------------------------------
--
-- Method:      updateQuery
--
-- Description: update a query
--
----------------------------------------------------------------------
define method .updateQuery(!i is REAL, !description is STRING, !expression is EXPRESSION, !style is REAL, !collection is REAL) is VSQVISUALQUERY

  --update the query in the object set
  !this.visualQueries[!i].update(!description, !expression, !this.viewStyles[!style], !this.typeCollections[!collection])
  return !this.visualQueries[!i]

endmethod

