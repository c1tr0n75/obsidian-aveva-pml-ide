-- Method:      reload
--
-- Description: discard data and reload from database
--
----------------------------------------------------------------------
define method .reload()

  --clear the queries, styles and collections then reload from database
  !this.clear()
  !this.loadConfig()

endmethod

----------------------------------------------------------------------
--
-- Method:      clear
--
-- Description: remove all queries, styles and collections from the object without deleting from the database
--
----------------------------------------------------------------------
define method .clear()

  --empty the arrays for sets, queries, styles and collections, allowing them to be reinitialised from saved data
  !this.visualQuerySets.clear()
  !this.visualQueries.clear()
  !this.viewStyles.clear()
  !this.typeCollections.clear()

endmethod

------------------------------------------------------------------------
--
-- Method:   isGoodQuerySet
--
-- Description: check if a dbref is a valid visual query set
--
------------------------------------------------------------------------
define method .isGoodQuerySet(!ref is DBREF) is BOOLEAN

  --confirm if good ref with correct type and purpose
  if (!ref.badRef().not()) then
    if (!ref.type.eq('DDSE') and !ref.purpose.eq('VQQS')) then
      return true
    endif
  endif
  return false

endmethod

------------------------------------------------------------------------
--
-- Method:   isGoodQuery
--
-- Description: check if a dbref is a valid visual query
--
------------------------------------------------------------------------
define method .isGoodQuery(!ref is DBREF) is BOOLEAN

  --confirm if good ref with correct type and purpose
  if (!ref.badRef().not()) then
    if (!ref.type.eq('DDSE') and !ref.purpose.eq('VQVQ')) then
      return true
    endif
  endif
  return false

endmethod

------------------------------------------------------------------------
--
-- Method:   isGoodStyle
--
-- Description: check if a dbref is a valid view style
--
------------------------------------------------------------------------
define method .isGoodStyle(!ref is DBREF) is BOOLEAN

  --confirm if good ref with correct type and purpose
  if (!ref.badRef().not()) then
    if (!ref.type.eq('DDSE') and !ref.purpose.eq('VQVS')) then
      return true
    endif
  endif
  return false

endmethod

------------------------------------------------------------------------
--
-- Method:   isGoodCollection
--
-- Description: check if a dbref is a valid type collection
--
------------------------------------------------------------------------
define method .isGoodCollection(!ref is DBREF) is BOOLEAN

  --confirm if good ref with correct type and purpose
  if (!ref.badRef().not()) then
    if (!ref.type.eq('DDSE') and !ref.purpose.eq('VQTC')) then
      return true
    endif
  endif
  return false

endmethod

----------------------------------------------------------------------
--
-- Method:      test
--
-- Description: test with some sample config data
--
----------------------------------------------------------------------
define method .test()

  --to test run the following commands
  --if the application data world does not already exist, first ensure CE is where we want to create it
$(
  !visq = object VSQCONFIG()
  !visq.test()
$)
  --check and create data world
  if (!this.checkDataWorld().not()) then
    !this.createDataWorld()
  endif

  --create styles
  !styleLargePipes = !this.addStyle('Large bore pipes style', 47, 20, false)
  !jazzyEquipment  = !this.addStyle('EyeCatching equipment style', 303, 0, false)
  !styleSmallPipes = !this.addStyle('Small bore pipes style', 13, 0, false)

  --create collections
  !collectionPiping     = !this.addCollection('Piping and Equipment types', 'PIPE EQUI')
  !collectionStructural = !this.addCollection('Structural types', 'STRU FRMW PANEL')

  --create queries
  !expressionLargePipes  = object EXPRESSION(|(BORE GT 150mm)|)
  !expressionSmallPipes  = object EXPRESSION(|(BORE LE 150mm)|)
  !queryLargePipes       = !this.addQuery('Large pipes in orange', !expressionLargePipes, !styleLargePipes, !collectionPiping)
  !unusedQuerySmallPipes = !this.addQuery('Small pipes in mauve', !expressionSmallPipes, !styleSmallPipes, !collectionPiping)
  !jazzySmallPipes       = !this.addQuery('Small pipes in gold', !expressionSmallPipes, !jazzyEquipment, !collectionPiping)

  --update some settings
  !styleSmallPipes  = !this.updateStyle(!styleSmallPipes, 'Small bore pipes style', 12, 0, false)
  !collectionPiping = !this.updateCollection(!collectionPiping, 'Piping collection', 'PIPE')
  !queryLargePipes  = !this.updateQuery(!queryLargePipes, 'Large pipes in orange red', !expressionLargePipes, !styleLargePipes, !collectionPiping)

  --write it to database
  !this.write()

  --remove unwanted things
  !this.removeStyle(!jazzyEquipment)
  !this.removeCollection(!collectionStructural)
  !this.removeQuery(!jazzySmallPipes)

  --check and output results
  !expected = ARRAY()
  !expected.append(|Visual query Large pipes in orange red at DDSE 1 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/QUERIES|)
  !expected.append(|  Expression (BORE GT 150mm)|)
  !expected.append(|  Style Large bore pipes style at DDSE 1 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/VIEWSTYLES|)
  !expected.append(|    Colour 47 translucency 20 edges FALSE|)
  !expected.append(|  Type collection Piping collection at DDSE 1 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/TYPECOLLECTIONS|)
  !expected.append(|    Types PIPE|)
  !expected.append(|Visual query Small pipes in mauve at DDSE 2 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/QUERIES|)
  !expected.append(|  Expression (BORE LE 150mm)|)
  !expected.append(|  Style Small bore pipes style at DDSE 2 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/VIEWSTYLES|)
  !expected.append(|    Colour 12 translucency 0 edges FALSE|)
  !expected.append(|  Type collection Piping collection at DDSE 1 of APPLDATA 1 of APPDAREA /VSQ/VISUALQUERIES/TYPECOLLECTIONS|)
  !expected.append(|    Types PIPE|)
  !actual = !this.output()
  if (!actual.neq(!expected)) then
    write 'Results do not match'
  else
    write 'Results match'
  endif
  !this.print()

endmethod

----------------------------------------------------------------------
--
-- Method:      export
--
-- Description: write out config data as a macro to be run into a new project
--
----------------------------------------------------------------------
define method .export()

  --save queries config
  !file = object FILE(|%AVEVA_DESIGN_USER%/vsqConfig.pmlmac|)
  !this.export(!file)

endmethod

----------------------------------------------------------------------
--
-- Method:      export
--
-- Description: write out config data as a macro to be run into a new project
--
----------------------------------------------------------------------
define method .export(!file is FILE)

  --save queries config
  !data = ARRAY()
  !data.append( |--Visual queries configuration| )
  !data.append( |--if the application data world does not already exist, first ensure CE is where we want to create it| )
  !data.append( |!visq = object VSQCONFIG()| )
  !data.append( |if (!visq.checkDataWorld().not()) then| )
  !data.append( |  !visq.createDataWorld()| )
  !data.append( |endif| )

  --type collections
  !data.append( |!collections = ARRAY()| )
  do !collection values !this.typeCollections
    !data.append( '!collections.append(!visq.addCollection(|'  & !collection.getDescription() & '|, |' & !collection.getTypeList() & '|))' )
  enddo

  --view styles
  !data.append( |!styles = ARRAY()| )
  do !style values !this.viewStyles
    !data.append( '!styles.append(!visq.addStyle(|' & !style.getDescription() & '|, ' & !style.getColour() & ', ' & !style.getTranslucency() & ', ' & !style.getEdges() & '))' )
  enddo

  --visual queries
  !data.append( |!queries = ARRAY()| )
  do !query values !this.visualQueries
    !expression = 'object EXPRESSION(|' & !query.getExpression()  & '|)'
    !viewStyle  = !query.getViewStyle()
    !styleIndex = 0
    do !i indices !this.viewStyles
      if (!this.viewStyles[!i].equals(!viewStyle)) then
        !styleIndex = !i
        break
      endif
    enddo
    !typeCollection  = !query.getTypeCollection()
    !collectionIndex = 0
    do !i indices !this.typeCollections
      if (!this.typeCollections[!i].equals(!typeCollection)) then
        !collectionIndex = !i
        break
      endif
    enddo
    if (!styleIndex.gt(0) and !collectionIndex.gt(0)) then
      !data.append( '!queries.append(!visq.addQuery(|' & !query.getDescription() & '|, ' & !expression & ', !styles[' & !styleIndex & '], !collections[' & !collectionIndex & ']))' )
    endif
  enddo

  --visual query sets
  !data.append( '!testObject = object VSQVISUALQUERYSET()' )
  !data.append( 'handle any' )
  !data.append( '  --older version' )
  !data.append( 'elsehandle none' )
  !data.append( |  !sets = ARRAY()| )
  do !i indices !this.visualQuerySets
    !data.append( '  !sets.append(!visq.addSet(|' & !this.visualQuerySets[!i].getDescription() & '|))' )
    do !j indices !this.visualQuerySets[!i].visualQueries
      do !k indices !this.visualQueries
        if (!this.visualQuerySets[!i].visualQueries[!j].equals(!this.visualQueries[!k])) then
          !data.append( '  !visq.addQueryToSet(' & !i & ', ' & !k & ')' )
          break
        endif
      enddo
    enddo
  enddo
  !data.append( 'endhandle' )

  --save to file
  !data.append( '!visq.write()' )
  !file.writeFile('Overwrite', !data)

endmethod

----------------------------------------------------------------------
--
-- Method:      plugQuerySet
--
-- Description: application callable method to plug a query set into the config
--
----------------------------------------------------------------------
define method .plugQuerySet(!setDescription is STRING, !typeList is STRING, !descriptions is ARRAY, !expressions is ARRAY, !colourNos is ARRAY)

  --example macro for green, yellow, red on cable fill
  -- !visq = object VSQCONFIG(true)
  -- !descriptions[1] = 'Fill level below max'
  -- !descriptions[2] = 'Fill level close to max'
  -- !descriptions[3] = 'Fill level over max'
  -- !expressions[1] = object EXPRESSION(' ( FLEVEL LEQ ( 0.9 * MAXFIL ) ) ')
  -- !expressions[2] = object EXPRESSION(' ( ( FLEVEL GT ( 0.9 * MAXFIL ) ) AND ( FLEVEL LEQ MAXFIL ) ) ')
  -- !expressions[3] = object EXPRESSION(' ( FLEVEL GT MAXFIL ) ')
  -- !colourNos[1] = 5
  -- !colourNos[2] = 4
  -- !colourNos[3] = 18
  -- !visq.plugQuerySet('Cable fill levels', 'CWBRAN', !descriptions, !expressions, !colourNos)
  -- !visq.write()

  --check config has been created
  if (!this.checkDataWorld().not()) then
    return error 1 'Visual Queries configuration must be created before you can plug a query set'
  endif

  --any forms using visual queries need to be closed with any changes saved
  !configShown = !!vsqConfiguration.shown()
  handle any
    !configShown = false
  endhandle
  if (!configShown) then
    return error 1 'Visual Queries Configuration form must be closed before you can plug a query set'
  endif
  !runShown = !!vsqRunQueries.shown()
  handle any
    !runShown = false
  endhandle
  if (!runShown) then
    return error 1 'Run Visual Queries form must be closed before you can plug a query set'
  endif
  !seqShown = !!awpRunSequence.shown()
  handle any
    !seqShown = false
  endhandle
  if (!seqShown) then
    return error 1 'Work Pack Sequence form must be closed before you can plug a query set'
  endif

  --add the definitions
  !set    = !this.addSet(!setDescription)
  !setRow = !this.visualQuerySets.maxIndex()
  !types  = !this.addCollection(!setDescription & | types|, !typeList.split())
  do !i indices !descriptions
    !style = !this.addStyle(!descriptions[!i] & | style|, !colourNos[!i], 0, FALSE)
    !query = !this.addQuery(!descriptions[!i], !expressions[!i], !style, !types)
    !this.addQueryToSet(!setRow, !this.visualQueries.maxIndex())
  enddo

endmethod

----------------------------------------------------------------------
--
-- Method:      output
--
-- Description: return the config data
--
----------------------------------------------------------------------
define method .output() is ARRAY

  --output config data
  !output = ARRAY()
  do !set values !this.visualQuerySets
    !output.appendArray(!set.output())
  enddo
  do !query values !this.visualQueries
    !output.appendArray(!query.output())
  enddo
  return !output

endmethod

----------------------------------------------------------------------
--
-- Method:      print
--
-- Description: print the config data
--
----------------------------------------------------------------------
define method .print()

  --print config data
  do !line values !this.output()
    write !line
  enddo

endmethod

----------------------------------------------------------------------
--
-- Method:      getPendingChanges
--
-- Description: return true if unsaved changes
--
----------------------------------------------------------------------
define method .getPendingChanges() is BOOLEAN

  --find if anything unsaved
  !pendingChanges = !this.pendingChanges
  do !style values !this.viewStyles
    !pendingChanges = (!pendingChanges or !style.getPendingChanges())
  enddo
  do !collection values !this.typeCollections
    !pendingChanges = (!pendingChanges or !collection.getPendingChanges())
  enddo
  do !query values !this.visualQueries
    !pendingChanges = (!pendingChanges or !query.getPendingChanges())
  enddo
  do !set values !this.visualQuerySets
    !pendingChanges = (!pendingChanges or !set.getPendingChanges())
  enddo
  return !pendingChanges

endmethod

----------------------------------------------------------------------
--
-- Method:      getSetHeadings
--
-- Description: return the set table headings
--
----------------------------------------------------------------------
define method .getSetHeadings() is ARRAY

  !headings = ARRAY()
  !headings[1] = 'Description'
  return !headings

endmethod

----------------------------------------------------------------------
--
-- Method:      getSetAsRowSet
--
-- Description: return the currently configured visual query sets
--
----------------------------------------------------------------------
define method .getSetsAsRowSet() is ARRAY

  !rowset = ARRAY()
  do !set values !this.visualQuerySets
    !rowset.append(!set.getAsRow())
  enddo
  return !rowset

endmethod

----------------------------------------------------------------------
--
-- Method:      getSetMembersHeadings
--
-- Description: return the set member or available queries table headings
--
----------------------------------------------------------------------
define method .getSetMembersHeadings() is ARRAY

  !headings = ARRAY()
  !headings[1] = 'Color'
  !headings[2] = 'Query Description'
  !headings[3] = 'Index'
  !headings[4] = 'Color No'
  return !headings

endmethod

----------------------------------------------------------------------
--
-- Method:      getSetMembersAsRowSet
--
-- Description: return the currently configured set members
--
----------------------------------------------------------------------
define method .getSetMembersAsRowSet(!setRow is REAL) is ARRAY

  !rowset = ARRAY()
  if (!setRow.leq(!this.visualQuerySets.size())) then
    !rowset = !this.visualQuerySets[!setRow].getMembersAsRowSet()
  endif
  return !rowset

endmethod

----------------------------------------------------------------------
--
-- Method:      getAvailableQueries
--
-- Description: return the currently configured available queries
--
----------------------------------------------------------------------
define method .getAvailableQueries(!setRow is REAL) is ARRAY

  -- return the queries that are not members of the set
  !availableQueries = ARRAY()
  if (!setRow.gt(!this.visualQuerySets.size())) then
    return !this.visualQueries
  endif
  do !i indices !this.visualQueries
    !isMember = false
    do !j indices !this.visualQuerySets[!setRow].visualQueries
      if (!this.visualQuerySets[!setRow].visualQueries[!j].equals(!this.visualQueries[!i])) then
        !isMember = true
        break
      endif
    enddo
    if (!isMember.not()) then
      !availableQueries.append(!this.visualQueries[!i])
    endif
  enddo
  return !availableQueries

endmethod

----------------------------------------------------------------------
--
-- Method:      getAvailableAsRowSet
--
-- Description: return a row set suitable for a grid
--
----------------------------------------------------------------------
define method .getAvailableAsRowSet(!setRow is REAL) is ARRAY

  --return a row set array
  !rowset = ARRAY()
  !availableQueries = !this.getAvailableQueries(!setRow)
  do !i indices !availableQueries
    --columns will be [1] blank to display colour, [2] query description, [3] hidden query index, [4] hidden colour number
    !row[1]  = ' '
    !row[2]  = !availableQueries[!i].getDescription()
    !row[3]  = !i
    !row[4]  = !availableQueries[!i].getColour()
    !rowset.append(!row)
  enddo
  return !rowset

endmethod

----------------------------------------------------------------------
--
-- Method:      getVisualQueryHeadings
--
-- Description: return the query table headings
--
----------------------------------------------------------------------
define method .getVisualQueryHeadings() is ARRAY

  !headings = ARRAY()
  !headings[1] = 'Description'
  !headings[2] = 'Expression'
  !headings[3] = 'View Style'
  !headings[4] = 'Type Collection'
  return !headings

endmethod

----------------------------------------------------------------------
--
-- Method:      getVisualQueriesAsRowSet
--
-- Description: return the currently configured visual queries
--
----------------------------------------------------------------------
define method .getVisualQueriesAsRowSet() is ARRAY

  !rowset = ARRAY()
  do !query values !this.visualQueries
    !rowset.append(!query.getAsRow())
  enddo
  return !rowset

endmethod

