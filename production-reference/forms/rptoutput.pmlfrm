--
-- Description:
--   Standard Data Output.
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  addCe(DBREF)                     -                   Add Current element to the List and Display
--  addCeMem(DBREF)                  -                   Add Current element member to the List and Display
--  addList()                        -                   Add Current List members to the List and Display
--  addPicked(DBREF)                 -                   Add Picked element to the List and Display
--  backtrackMode()                  -                   Sets the option to output changes in backtrack mode or not
--  cColours(STRING)                 -                   Output Highlight colours
--  changeSinceExtr(STRING)          -                   Output changes since extract
--  changeSinceStamp(STRING)         -                   Output changes since stamp
--  changeSinceTime(STRING)          -                   Output changes since time
--  check(STRING)                    -                   Validate input to gadgets
--  chosenECol()                     -                   Enhance the elements
--  close()                          -                   Close the form down
--  dateSession(GADGET,GADGET,STRING) -                   Maintain session number from session time
--  dbList()                         -
--  diffSinceExtr()                  -                   Output difference since extract
--  diffSinceStamp()                 -                   Output difference since stamp
--  display()                        -                   Select list and make current active
--  eColours()                       -                   Element Highlight colours
--  errorWrite()                     -                   Output errors from apply
--  extractChoice(BOOLEAN)           -                   Maintain gadget based on Extract Session choice
--  fileBrowserLoad()                -                   Load the PML FileBrowser to Save the location of the DB Output File
--  footerComment(STRING)            -                   Output footer comment
--  getDate()                        DATETIME            Get the date of the stamped session for the current db
--  getDbName()                      STRING              Get the dbname for the current element
--  highOutputMode()                 -                   Set active state of highlight gadget
--  highlight()                      -                   Highlight elements that will be output
--  highlightDef(BOOLEAN)            -
--  ifSave()                         -                   Setup Since Gadgets for SAVE option
--  ifScreen()                       -                   Maintain the Screen or File Gadgets
--  ifTime()                         -                   Maintain the Since Gadgets
--  initialise()                     -                   Initialisation for the form
--  listLst(STRING,STRING)           -                   Maintain the list of elements
--  mode(STRING)                     -
--  onApply(STRING)                  -
--  pick(MENU,STRING)                -                   Setup Pick mode to Add/Remove items
--  pickElement(DBREF)               -                   Pick Significant element when graphical pick is used
--  pullDowns()                      -                   Maintain the pull-downs
--  qClaimlist(STRING)               -                   Query Claimlists
--  qElement(DBREF,STRING)           -
--  query(STRING,STRING)             -
--  rElement(DBREF,STRING,FILE)      -                   Report to file Session, History, ClaimBy and Database Information
--  removeAll()                      -                   Remove all elements
--  removeCe(DBREF)                  -                   Remove Current Element List
--  removeCeMem(DBREF)               -                   Remove Current Element members List
--  removeList()                     -                   Remove Current List members
--  removeMembers(ARRAY)             -                   Remove list or elements
--  removePicked(DBREF)              -                   Remove Picked element from the List and unhighlight
--  removeSelected()                 -                   Remove selected items List
--  rptOutput()                      -                   Constructor
--  selectMember(GADGET,STRING)      -                   Selected entry from Members
--  sessCount(REAL)                  -                   Session Plus/Minus counter
--  sessionDate()                    -                   Maintain session time from session number
--  setFile()                        BOOLEAN             Set the Filename Gadget and Access Mode
--  setSignificantElement(DBREF,string) -                   Sets the significant element to be picked on using graphical pick
--  setUseDate(GADGET,GADGET,STRING) -                   Store the date/time to be used
--  sinceSelect()                    -                   Store current SINCE selection & Maintain the Since Gadgets
--  sortStamps()                     -                   Wrapper around !!admStampSort, handling an empty list of stamps
--  stampDate()                      -                   Populate the date/time gadgets
--  stampDisplayMode()               -                   Populate the stamp list gadget
--  stampList()                      -                   Populate the stamp list
--  update()                         -                   Maintain the List menu
--
------------------------------------------------------------------------

-- Define form
--setup form !!rptOutput
layout form !!rptOutput AutoAlign
import 'pmlfilebrowser'
handle any
endhandle

  -- Body of form definition

  -- Bar Menu
  bar
  exit

  frame .destination           'Destination' at xmin     ymax width 59

    frame .fileScreenFrame     'Output'                       width 27.5 height 4
    	path down
    	vdis 0
      rtoggle .fileToggle      'File'
      rtoggle .screenToggle    'Screen'
    exit

    frame .fileTypeFrame       'File Type'   at xmax.fileScreenFrame+.5 ymin.fileScreenFrame width.fileScreenFrame height.fileScreenFrame
    	path down
    	vdis 0
      rtoggle .newFileToggle   'New File'
      rtoggle .overwriteToggle 'Overwrite'
      rtoggle .appendToggle    'Append'
    exit

    frame .outputFrame 'DB Listing Output'   at xmin.fileScreenFrame   ymax.fileScreenFrame  width 55.5
      text   .filename 'Filename:' width 40 scroll 80 string
      button .browser	 'Browse...' at xmax+1 ymin pixmap width 16 height 16
    exit
  exit

  -- Current List Contents
  frame  .elementFrame 'Elements'  at xmin.destination ymax       width.destination
    list   .members                at xmin+1           ymax multi width 52 length 5
  exit

  frame .since 'DB Listing' at xmin ymax width.destination

    frame .sinceTypeFrame at ymin+.2 width.outputFrame
      rtoggle .saveToggle    'Savework'  at         ymax+.15 tagwidth 8
      rtoggle .timeToggle    'Time/Date' at xmax+.25 ymin tagwidth 8
      rtoggle .sessionToggle 'Session'   at xmax+.25 ymin tagwidth 8
      rtoggle .extractToggle 'Extract'   at xmax+.25 ymin tagwidth 8
      rtoggle .stampToggle   'Stamp'     at xmax+.25 ymin tagwidth 8
    exit

    para     .tim             at xmin         ymax+0.5 text 'Date (HH:MM  DD/Mon/Year):'
    text     .time            at xmax.tim+14  ymin     width 5  string
    text     .date            at xmax.time+.5 ymin     width 11 string
    para     .sessNu          at x1           ymax+0.2 text 'Session Number:   '
    button   .minus '-'       at xmin.time    ymin     width 2
    path right
    text     .sessNum                                  width 5  is REAL
    button   .plus  '+'                                width 2
    para     .sessUser        at x1           ymax+0.2 text 'Session User:' width 30
    button   .more  'More...' at xmin.minus   ymin     width 8
    para     .sessDb          at x1           ymax+0.2 text 'Database Name  =  DBNAME/DBNAME      ' width 45 lines 2

    frame .sinceExtract  'Since Extract'           at x1        ymax                width.sinceTypeFrame
      option .extract                              at x1        ymax                width 26
      path right
      option .extSession                           at xmin.more ymin                width 6
      text   .extSessNum                                                            width 6  is REAL
      text   .extTime  'Date (HH:MM DD/Mon/Year):' at x1        ymax+0.4  tagwid 30 width 5  string
      text   .extDate                              at xmax+.5                       width 11 string
    exit

    -- Stamp list
    frame .sinceStamp   'Since Stamp' at xmin.sinceExtract ymax      width.sinceExtract
      -- Stamp display mode
      option .stampMode 'Display:'    at xmin.extSession   ymax      tagwidth 7 width 6
      -- Stamp list
      list .stamp                     at xmin.extTime      ymax+.25  width 51 height 3
    exit
  exit
  toggle .highOutput 'Highlight Elements' at xmin.sinceStamp ymax+.25 tagwidth 20
  button .apply      'Apply'          at xmax form-10-size ymin    anchor b+r  width 8 Apply
  button .dismiss    'Cancel'         at xmax form-size    ymin    anchor b+r  width 8 Cancel


  -- Current List
  member .listName    is STRING

  -- Element list
  member .elements    is ARRAY

  -- Error flag
  member .errorFlag   is BOOLEAN

  -- Element flag
  member .elementFlag   is BOOLEAN

  -- Specific flag
  member .specificFlag   is BOOLEAN

  -- Highlight Colour
  member .hElementColour is REAL
  member .hOutputColour  is REAL

  -- Current DB Name
  member .dbName is STRING

  -- Backtrack option
  member .backtrack    is BOOLEAN

  -- Maximum session number
  member .sessMax      is REAL

  -- Was - or + button pressed or direct number input (0 = Minus, 1 = Plus, 2 = Number input)
  member .plusMinusNum is REAL

  -- Design based modules edg/enhance available
  member .designModule is BOOLEAN

  -- Set Significant Elements for DES Module
  member .desModule is BOOLEAN

  -- Significant Elements for Picking Marine Elements using Graphical Pick
  member .projMarine is BOOLEAN

  -- Marine Drafting module
  member .mardraModule is BOOLEAN

  -- E3D Draw module
  member .drawModule is BOOLEAN

  -- Current SINCE type (added to avoid a PML bug)
  member .sinceOption  is STRING

  -- Counter for labels
  member .labelCounter is REAL

  -- Stamps for the current db
  member .allStamp is ARRAY

  -- Current enhance command
  member .enhance    is STRING

  -- Current unenhance command
  member .unenhance    is STRING

exit
-- End of form definition for !!rptOutput
------------------------------------------------------------------------
--
-- Method:      rptOutput
--
-- Description: Constructor
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rptOutput()

  !this.formTitle     = 'DB Listing'
  !this.iconTitle     = 'Output'
  !this.callback      = '!!rptOutput.initialise()'
  !this.formRevision  = ' $Revision: 1.84 $ '
  !this.cancelCall    = '!!rptOutput.close()'

  -- Callbacks
  !this.fileToggle.callback    = '!!rptOutput.ifScreen()'
  !this.screenToggle.callback  = '!!rptOutput.ifScreen()'
  !this.browser.callback       = '!this.fileBrowserLoad()'
  !this.members.callback       = '!!rptOutput.selectMember('
  !this.saveToggle.callback    = '!!rptOutput.sinceSelect()'
  !this.timeToggle.callback    = '!!rptOutput.sinceSelect()'
  !this.sessionToggle.callback = '!!rptOutput.sinceSelect()'
  !this.extractToggle.callback = '!!rptOutput.sinceSelect()'
  !this.stampToggle.callback   = '!!rptOutput.sinceSelect()'
  !this.time.callback          = '!!rptOutput.dateSession(!this.time,!this.date,|GADGET|)'
  !this.date.callback          = '!!rptOutput.dateSession(!this.time,!this.date,|GADGET|)'
  !this.minus.callback         = '!!rptOutput.sessCount(0)'
  !this.sessNum.callback       = '!!rptOutput.sessionDate()'
  !this.plus.callback          = '!!rptOutput.sessCount(1)'
  !this.more.callback          = 'SHOW !!rptSessComment'
  !this.extract.callback       = '!this.stampList()'
  !this.extSession.callback    = '!this.extractChoice(true)'
  !this.extTime.callback       = '!this.setUseDate(!this.extTime,!this.extDate,|GADGET|)'
  !this.extDate.callback       = '!this.setUseDate(!this.extTime,!this.extDate,|GADGET|)'
  !this.stamp.callback         = |!this.stampDate()|
  !this.dismiss.callback       = '!!rptOutput.close()'
  !this.apply.callback         = '!!rptOutput.onApply(|Datal|)'

  --Tooltips
  !this.browser.setTooltip('Browse...')
  !this.more.setTooltip('More...')
  !this.minus.setTooltip('Minus')
  !this.plus.setTooltip('Plus')

  -- Icons
  !this.browser.addPixmap('StandardIcons>ID_SEARCHFOLDER')

  --Initialise label counter
  !this.labelCounter = 1

  -- Define Bar Menu
  !bar = !this.bar
    !bar.add('Control',   'ControlMenu')
    !bar.add('Add',       'addMenu')
    !bar.add('Remove',    'RemoveMenu')
    !bar.add('Colour', 'HighlightMenu')
    !bar.add('Query',     'QueryMenu')


  -- Control Menu
  !menu = !this.newMenu('ControlMenu')
    !menu.add('CALLBACK', 'Clear Output',   '!!cadcReq.cadcReq.clear()')
    !menu.add('separator')
    !menu.add('TOGGLE', 'DB Listing',     '!!rptOutput.mode(|Datal|)')
    !menu.add('TOGGLE', 'DB Changes',     '!!rptOutput.mode(|Change|)')
    !menu.add('TOGGLE', 'DB Differences', '!!rptOutput.mode(|Differ|)')
    !menu.add('separator')
    !menu.add('MENU',   'Output',        'OptionsMenu')

  -- Add Menu
  !menu = !this.newMenu('addMenu')
    !menu.add('CALLBACK', 'Current Element',              '!!rptOutput.addCe(!!ce)')
    !menu.add('CALLBACK', 'Current Element Members',      '!!rptOutput.addCeMem(!!ce)')
    !menu.add('separator')
    !menu.add('TOGGLE', 'Graphical Pick',              '!!rptOutput.pick(')
    !menu.add('CALLBACK', 'Current Collection',    '!this.addList()')
--    !menu.add('MENU',     'List',       'AddListMenu')

  -- Remove Menu
  !menu = !this.newMenu('RemoveMenu')
    !menu.add('CALLBACK', 'All',        '!!rptOutput.removeAll()')
    !menu.add('CALLBACK', 'Selected',   '!!rptOutput.removeSelected()')
    !menu.add('separator')
    !menu.add('CALLBACK', 'Current Element',         '!!rptOutput.removeCe(!!ce)')
    !menu.add('CALLBACK', 'Current Element Members', '!!rptOutput.removeCeMem(!!ce)')
    !menu.add('separator')
    !menu.add('TOGGLE', 'Graphical Pick',   '!!rptOutput.pick(')
    !menu.add('CALLBACK', 'Current Collection',  '!this.removeList()')
--    !menu.add('MENU',     'List',  'RemoveListMenu')

         -- Options Menu
  !menu = !this.newMenu('OptionsMenu')
    !menu.add('CALLBACK', 'Options...',      'show !!rptOutputOpts')
    !menu.add('TOGGLE', 'Backtrack Mode',       '!!rptOutput.backtrackMode()')

       -- Highlight Menu
  !menu = !this.newMenu('HighlightMenu')
    !menu.add('MENU', 'Highlight',       'ColourMenu')
    !menu.add('MENU', 'Unhighlight',  'UnhighlightMenu')

    -- Colour Menu
  !menu = !this.newMenu('ColourMenu')
    !menu.add('CALLBACK', 'Elements...',     '!!rptOutput.eColours()')
    !menu.add('CALLBACK', 'Output...',       '!!rptOutput.cColours()')

  !menu = !this.newMenu('UnHighlightMenu')
    !menu.add('CALLBACK', 'CE',       'UNENHANCE CE')
    !menu.add('CALLBACK', 'Elements', '!!rptOutput.highlightDef(false)')
    !menu.add('CALLBACK', 'All',      'UNENHANCE ALL')

  -- Query Menu
  !menu = !this.newMenu('QueryMenu')
    !menu.add('CALLBACK', 'Clock',  '!!rptOutput.qClaimlist(|Clock|)')
    !menu.add('MENU', 'CE',         'CESessionMenu')
    !menu.add('MENU', 'Elements',   'ElSessionMenu')
--    !menu.add('MENU', 'Claimlists', 'ClaimlistMenu')

  -- Add Menu
  !menu = !this.newMenu('CESessionMenu')
    !menu.add('CALLBACK', 'Session',       '!!rptOutput.query(|CE|, |Session|)')
    !menu.add('CALLBACK', 'Last Modified', '!!rptOutput.query(|CE|, |LastMod|)')
    !menu.add('CALLBACK', 'History',       '!!rptOutput.query(|CE|, |History|)')
    !menu.add('CALLBACK', 'Claimed By',    '!!rptOutput.query(|CE|, |ClaimBy|)')
    !menu.add('CALLBACK', 'DB Name/Mode',  '!!rptOutput.query(|CE|, |DB info|)')

  -- Add Menu
  !menu = !this.newMenu('ElSessionMenu')
    !menu.add('CALLBACK', 'Session',       '!!rptOutput.query(|Elements|, |Session|)')
    !menu.add('CALLBACK', 'Last Modified', '!!rptOutput.query(|Elements|, |LastMod|)')
    !menu.add('CALLBACK', 'History',       '!!rptOutput.query(|Elements|, |History|)')
    !menu.add('CALLBACK', 'Claimed By',    '!!rptOutput.query(|Elements|, |ClaimBy|)')
    !menu.add('CALLBACK', 'DB Name/Mode',  '!!rptOutput.query(|Elements|, |DB info|)')

  -- Add Menu
  -- MTB: Commented out because it is not clear that these queries should be on this form
  -- There are problems with the qClaimlist method. The text produced is too long for a
  -- PML variable, so it gets truncated.
--     !menu = !this.newMenu('ClaimlistMenu')
--     !menu.add('CALLBACK', 'Active Claimlist',     '!!rptOutput.qClaimlist(|Active|)')
--     !menu.add('CALLBACK', 'Others Claimlist',     '!!rptOutput.qClaimlist(|Other|)')
--     !menu.add('CALLBACK', 'Extract Claimed',      '!!rptOutput.qClaimlist(|Extract|)')
--     !menu.add('CALLBACK', 'Others Extract Claim', '!!rptOutput.qClaimlist(|othersExtract|)')

   -- Add Lists
--   !menu = !this.newMenu('AddListMenu')

   -- Remove Lists
--   !menu = !this.newMenu('RemoveListMenu')

   -- Update the Add Lists menu and Remove Lists menu
   !this.update()

  -- Option gadget for Extract Latest
  !dText = ARRAY()
  !dText.append('Only')
  !dText.append('Latest')
  !dText.append('Session')
  !dText.append('Date')
  !dText.append('Stamp')
  !this.extSession.dText = !dText

  -- Option gadget for stamp display mode
  !!admStampSortGadg(!this.stampMode,'SHORT')
  !this.stampMode.callback = '!this.sortStamps()'

  -- Generate Linkage to List
--  call !!lstAddLinkMenu('DBREFS', !this.addListMenu,    false, ARRAY(), ARRAY(), '!!rptOutput.listLst(''ADD'',')
--  call !!lstAddLinkMenu('DBREFS', !this.removeListMenu, false, ARRAY(), ARRAY(), '!!rptOutput.listLst(''REMOVE'',')

  -- Make sure the Style options form is loaded
  pml load form !!rptOutputOpts

  -- Validate input values for extract session time gadgets
  !this.extTime.validateCall    = '!this.check(|extTime|)'
  !this.extDate.validateCall    = '!this.check(|extDate|)'
  !this.time.validateCall       = '!this.check(|time|)'
  !this.date.validateCall       = '!this.check(|date|)'
  !this.extSessNum.validateCall = '!this.check(|extSessNum|)'
--Issue 44930:PDMS11.6 SP4.8 - DESIGN - DB CHANGES - Backtrack M (HPD0037517)
--BackTrack Option
   !this.backtrack = false
  !this.sinceOption = |SAVE|


endmethod
-- End of method definition for .rptOutput()

------------------------------------------------------------------------
--
-- Method:      initialise
--
-- Description: Initialisation for the form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .initialise()

  -- Get module information
  !module            = !!module()
  !this.designModule = !module.appkey.upCase() inset('DES','MARODES','MARHDES')
  !this.desModule = !module.appkey.upCase() inset('DES')
  !this.projMarine = !module.projecttype.upCase() inset('MARINE')
  !this.mardraModule = !module.appkey.upCase() inset('MARDRA')
  !this.drawModule = !module.appkey.upCase() inset('DRA')

  -- Set command
  if (!this.mardraModule) then
    !this.enhance = 'DESENHANCE'
    !this.unenhance = 'DESUNENHANCE'
  elseif (!this.drawModule) then
    !this.enhance = 'DRAENHANCE'
    !this.unenhance = 'DRAUNENHANCE'
  else
    !this.enhance = 'ENHANCE'
    !this.unenhance = 'UNENHANCE'
  endif

  -- Set definite values for showing or re-showing form
  !this.fileToggle.val       = true
  !this.newFileToggle.val    = true
  !this.fileTypeFrame.active = true
  !this.filename.active      = true
  !this.saveToggle.val       = true
  !this.sinceOption          = |SAVE|

  -- Initialise PlusMinusNum member
  !this.plusMinusNum    = 2

  -- Set Boolean highlight changes
  !this.highOutput.val  = FALSE

   -- Set a Default colour for Highlighting
  if (!this.hElementColour.set() ) then
  else
    !this.hElementColour = 10
  endif
  if (!this.hOutputColour.set() ) then
  else
    !this.hOutputColour = 13
  endif

   -- Clear Filename
   !this.filename.val = '%AVEVA_DESIGN_USER%/DBOutput.txt'

   -- Maintain Menu's
   !this.pullDowns()

   -- get current Database name
   !this.dbName = !this.getDbName()

--   !this.dbList()

  if (!this.drawModule) then
    -- High datal output precision- matching macload that sets this at application startup
    if (!!distanceFmt.units.eq('FINCH')) then    
       PRECI VAR 1024ths
    else
       PRECI VAR 6dp
    endif
  else
    -- MAW 2023: this TFS 84169 bugfix was bad because the modules generally set it to 6 during application startup,
    -- and this is only 2. For now I've only overriden it for DRAW, above, though.
    -- Really the user should be able to determine the precision on this form (even if it's just 
    -- a low or high setting), and it should be set, not here, but just during output AND restored after (new query syntax required?)
    -- If we do this then other places that set VAR precision should also restore it after use.

    -- reset precision (TFS 84169)
    PRECI VAR DEFAULT
  endif

endmethod
-- End of method definition for .initialise()
------------------------------------------------------------------------
--
-- Method:      sessionDate
--
-- Description: Maintain session time from session number
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .sessionDate()

  -- check for extract set, but ce is not in an extract
  !this.dbList()

  -- Find out the high session number of this DB
  var !clockStr CLOCK
  !clockArr = !clockStr.split()
  -- Set Session number
  var !sessDnum SESSION ON $!clockArr[4]  $!clockArr[1] $!clockArr[2] $!clockArr[3]
  !sessDnumReal = !sessDnum.real()
  !this.sessMax = !sessDnumReal

  if (!this.sessNum.val gt !this.sessMax or !this.sessNum.val eq 0) then
    !this.sessNum.val = 0
    var !sessDate SESSDATE $!this.sessNum.val
  else
    -- Set Date of the Session number
    var !sessDate SESSDATE $!this.sessNum.val
    handle (2,1)
      -- handle number less than zero
      -- Set the time
      var !clockStr CLOCK
      !clockArr = !clockStr.split()
      !this.time.val = !clockArr[4]
      !this.date.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]

      -- Set Session number
      var !sessDnum SESSION ON $!this.time.val $!this.date.val
      !sessDnumReal = !sessDnum.real()
      !this.sessNum.val = !sessDnumReal

      var !sessDate SESSDATE $!this.sessNum.val

    elsehandle (2,201)
      -- handle number higher than current session
      -- Should not be possible to go higher than max because the button
      -- will be greyed out
      -- merged session number i.e. sessions 1 2 3 4 could be sessions 1 4
      -- where 2 and 3 have been merged into 4
      if (!this.plusMinusNum eq 1 ) then
        do !merged from 1 to !this.sessMax
          !this.sessNum.val = !this.sessNum.val + 1
          var !sessDate SESSDATE $!this.sessNum.val
          handle any
            -- ignore any errors
          elsehandle none
            break
          endhandle
        enddo
      else
        do !merged from 1 to !this.sessMax
          !this.sessNum.val = !this.sessNum.val - 1
          var !sessDate SESSDATE $!this.sessNum.val
          handle any
            -- ignore any errors
          elsehandle none
            break
          endhandle
        enddo
      endif
    endhandle
  endif

  if (!this.sessNum.val eq 0 ) then
    var !clockStr CLOCK
    !clockArr = !clockStr.split()
    !this.time.val = !clockArr[4]
    !this.date.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]
    !this.sessUser.val = 'Session User:'
    -- get current Database name
    !this.dbName = !this.getDbName()
    !this.sessDb.val   = 'Database Name  =  ' & !this.dbName
  else
    !clockArr = !sessDate.split()
    !this.time.val = !clockArr[1]
    !this.date.val = !clockArr[2] & ' ' & !clockArr[3] & ' ' & !clockArr[4]

    -- Set Session user
    var !sessUserStr SESSUSER $!this.sessNum.val
    !this.sessUser.val = 'Session User: ' & !sessUserStr
    -- get current Database name
    !this.dbName = !this.getDbName()
    !this.sessDb.val   = 'Database Name  =  ' & !this.dbName
  endif

  -- Maintain the session comments form
  if (defined(!!rptSessComment)) then
    if (!!rptSessComment.shown()) then
      !!rptSessComment.initialise()
    endif
  endif

endmethod
-- End of method definition for .sessionDate()
------------------------------------------------------------------------
--
-- Method:      dateSession
--
-- Description: Maintain session number from session time
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Time gadget
--    2   R      GADGET      Date gadget
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .dateSession(!timeGadget is GADGET, !dateGadget is GADGET, !callType is STRING)

  -- check for extract set, but ce is not in an extract
  !this.dbList()

  -- Set Session number
  var !sessDnum SESSION ON $!this.time.val $!this.date.val
  !sessDnumReal = !sessDnum.real()
  !this.sessNum.val = !sessDnumReal
  !this.sessDb.val   = 'Database Name  =  ' & !this.dbName

  -- Set Session user
  var !sessUserStr SESSUSER $!this.sessNum.val
  !this.sessUser.val = 'Session User: ' & !sessUserStr
  -- get current Database name
  !this.dbName = !this.getDbName()
  !this.sessDb.val   = 'Database Name  =  ' & !this.dbName

  -- Maintain the session comments form
  if (defined(!!rptSessComment)) then
    if (!!rptSessComment.shown()) then
      !!rptSessComment.initialise()
    endif
  endif

  -- Store the date to be used
  !this.setUseDate(!timeGadget,!dateGadget, !callType)

endmethod
-- End of method definition for .dateSession()

------------------------------------------------------------------------
--
-- Method:      onApply
--
-- Description: Action the form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING       mode - i.e. Datal, Change or Differ
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .onApply(!modeSel is STRING )

  -- Initialise error flag
  !this.errorFlag = false

  -- Collect the style options

  -- What elements are to be output?
  if (!!rptOutputOpts.specific.val) then
    if (!!rptOutputOpts.onlyElements.split().size() gt 0) then
      !specificOpt = 'ONLY( ' & !!rptOutputOpts.onlyElements & ' ) '
    else
      !specificOpt = ''
      !!alert.error(|'Specific Types' option chosen but none defined! Nothing will be output. Define using Control >Output >Options... >Define...|)
      return
    endif
  else
    !specificOpt = ''
  endif

  -- What attributes to be listed?
  if (!!rptOutputOpts.standard.val and !!rptOutputOpts.connections.val.not()) then
    !attributesOpt = 'PASS 1 '
  elseif (!!rptOutputOpts.standard.val.not() and !!rptOutputOpts.connections.val) then
    !attributesOpt = 'PASS 2 '
  else
    !attributesOpt = ''
  endif
  if (!!rptOutputOpts.standard.val and !!rptOutputOpts.udas.val.not()) then
    !attributesOpt = !attributesOpt & ' NOUDA '
  elseif (!!rptOutputOpts.standard.val.not() and !!rptOutputOpts.udas.val.not() and !!rptOutputOpts.connections.val.not()) then
    !attributesOpt = !attributesOpt & ' BRIEF '
  endif

  -- Create or Modify
  if (!!rptOutputOpts.modifyToggle.val) then
    !createOpt = 'OLDFORMAT '
  else
    !createOpt = ''
  endif
  -- Same Reference number to be used or not.
  if (!!rptOutputOpts.sameRef.val) then
    !sameRef = 'SAMEREF '
  else
    !sameRef = ''
  endif

  -- Commented Reference numbers or not.
  if (!!rptOutputOpts.comment.val) then
    !commentOpt = 'COMMENT '
  else
    !commentOpt = ''
  endif

  -- Indexing or not.
  if (!!rptOutputOpts.index.val) then
    !indexOpt = 'INDEX '
  else
    !indexOpt = ''
  endif

  -- Number of spaces for tabs
  !tabOpt = !!rptOutputOpts.tabs.selection()

  -- String to options together in one variable
  !options = !sameRef & !specificOpt & !attributesOpt & !createOpt & !commentOpt & !indexOpt & 'TABULATE' & !tabOpt
  !changesOptions = !sameRef & !specificOpt & !attributesOpt & !createOpt & !commentOpt & !indexOpt & 'TABULATE' & !tabOpt

-- *************************** DATAL Section ***************************

if (!modeSel eq 'Datal') then

  if (!this.screenToggle.val) then
    -- make sure output is to requests window
    !this.ifScreen()

    ALPHA FILE END
    handle(61,274)
      -- Even if no file in use
    endhandle
    do !indx indices !this.members.rText
      OUTPUT $!options $!this.members.dText[$!indx]
      handle ANY
        !this.errorWrite()
      endhandle
    enddo
  else
    -- make sure output is not to requests window
--    !this.ifScreen()

    -- Filename must be set in correct mode then open alpha file
    if (!this.setFile()) then
    else
      return
    endif

    -- insert a header comment
    var !clock CLOCK
    WRITEALPHAFILE '$S-  -- Synonym translation OFF '
    WRITEALPHAFILE '-- ----------------------------------------------------------------'
    WRITEALPHAFILE '-- Data Listing    Date : $!clock '
    WRITEALPHAFILE ''
    WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
    WRITEALPHAFILE ''

    -- P-36220 : build space-separated list of items for OUTPUT command
    !itemsText = ||
    do !indx indices !this.members.rText
      !itemsText = !itemsText & |$!this.members.dText[$!indx]| & | |
      handle(2,442)
         -- string too long
         OUTPUT $!options $!itemsText
         !itemsText = |$!this.members.dText[$!indx]| & | |
      endhandle
    enddo
    if (!itemsText ne ||) then
      OUTPUT $!options $!itemsText
      handle ANY
        !this.errorWrite()
      endhandle
    endif

    -- insert a footer comment
    !this.footerComment('End Data Listing    Date : $!clock ')
    ALPHA FILE END
  endif

  -- Highlight all elements if Highlight Elements requested
  -- commented out SB - test team comment 14.09.98
--  if (!this.highOutput.val) then

--  do !i indices !this.elements
--    !elem = !this.elements[!i]
--    !choi = !this.hElementColour
--   ENHANCE $!elem COLOUR $!choi
--  enddo

--  endif

  -- Tag all elements if Tag Elements requested

--  if (!this.tagsOutput.val) then

--  do !i indices !this.elements
--    !elem = !this.elements[!i]
--    tag $!elem
--  enddo

--  endif

-- *************************** Changes Section ***************************

elseif (!modeSel eq 'Change') then

  -- Remember current element
  !refe = REFE

  if (!this.sinceOption eq 'TIME') then

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output changes since time
      !this.changeSinceTime(!changesOptions)
    else
      -- make sure output is not to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Change Listing (BackTrack : $!this.backtrack )  Date : $!clock '
      WRITEALPHAFILE '-- Changes since $!this.time.val $!this.date.val '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- output changes since time
      !this.changeSinceTime(!changesOptions)
      -- insert a footer comment
      !this.footerComment('End Data Change Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  elseif (!this.sinceOption eq 'SESS') then

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output changes since time
      !this.changeSinceTime(!changesOptions)
    else
      -- make sure output is not to requests window
 --     !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Change Listing (BackTrack : $!this.backtrack )  Date : $!clock '
      WRITEALPHAFILE '-- Changes since session $!this.sessNum.val '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- output changes since time
      !this.changeSinceTime(!changesOptions)
      -- insert a footer comment
      !this.footerComment('End Data Change Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  elseif (!this.sinceOption eq 'EXTR') then

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output changes since extract
      !this.changeSinceExtr(!changesOptions)
    else
      -- make sure output is not to requests window
 --     !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Change Listing (BackTrack : $!this.backtrack )  Date : $!clock '
      WRITEALPHAFILE '-- Changes since EXTRACT $!this.extract '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- output changes since extract
      !this.changeSinceExtr(!changesOptions)
      -- insert a footer comment
      !this.footerComment('End Data Change Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  elseif (!this.sinceOption.eq('STAMP')) then

    -- Check that there is a stamp able to be used
    if (!this.stamp.selection().eq('NONE')) then
      !!alert.warning('There is no selected stamp to use!')
      return
    endif

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output changes since stamp
      !this.changeSinceStamp(!changesOptions)
    else

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Change Listing (BackTrack : $!this.backtrack )  Date : $!clock '
      WRITEALPHAFILE '-- Changes since STAMP $!this.stamp.selection().dbRef().flnm '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- Output changes since stamp
      !this.changeSinceStamp(!changesOptions)

      -- insert a footer comment
      !this.footerComment('End Data Change Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  else

    -- Since last savework
    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      do !indx indices !this.members.rText
        if (!this.backtrack ) then
          OUTPUT $!changesOptions $!this.members.dText[$!indx] REVERSE CHANGES
          handle ANY
            !this.errorWrite()
          endhandle
        else
          OUTPUT $!changesOptions $!this.members.dText[$!indx] CHANGES
          handle ANY
            !this.errorWrite()
          endhandle
        endif
      enddo
    else
      -- make sure output is not to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Change Listing (BackTrack : $!this.backtrack )  Date : $!clock '
      WRITEALPHAFILE '-- Changes since last Savework $!this.time.val $!this.date.val'
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      do !indx indices !this.members.rText
        if (!this.backtrack ) then
          OUTPUT $!changesOptions $!this.members.dText[$!indx] REVERSE CHANGES
          handle ANY
            !this.errorWrite()
          endhandle
        else
          OUTPUT $!changesOptions $!this.members.dText[$!indx] CHANGES
          handle ANY
            !this.errorWrite()
          endhandle
        endif
      enddo
      -- insert a footer comment
      !this.footerComment('End Data Change Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  endif

  -- Highlight all changes if Highlight changes requested
  !this.highlight()

  -- Navigate back to original element
  !!ce = !refe

-- *************************** Differences Section ***************************

else

  -- Remember current element
  !refe = REFE

  if (!this.sinceOption eq 'TIME') then
    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx] SINCE $!this.time.val $!this.date.val
        handle ANY
          !this.errorWrite()
        endhandle
      enddo
    else
      -- make sure output is not to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Differences Listing    Date : $!clock '
      WRITEALPHAFILE '-- Differences since $!this.time.val $!this.date.val '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx] SINCE $!this.time.val $!this.date.val
        handle ANY
          !this.errorWrite()
        endhandle
      enddo
      -- insert a footer comment
      !this.footerComment('End Data Differences Listing    Date : $!clock ')
      ALPHA FILE END
    endif
  elseif (!this.sinceOption eq 'SESS') then
    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx] SINCE $!this.time.val $!this.date.val
        handle ANY
           !this.errorWrite()
        endhandle
      enddo
    else
      -- make sure output is not to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile()) then
      else
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Differences Listing    Date : $!clock '
      WRITEALPHAFILE '-- Differences since session $!this.sessNum.val '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx] SINCE $!this.time.val $!this.date.val
        handle ANY
          !this.errorWrite()
        endhandle
      enddo
      -- insert a footer comment
     !this.footerComment('End Data Differences Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  elseif (!this.sinceOption eq 'EXTR') then

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output difference since extract
      !this.diffSinceExtr()
    else
      -- make sure output is not to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile().not()) then
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Differences Listing    Date : $!clock '
      WRITEALPHAFILE '-- Differences since EXTRACT $!this.extract '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- output difference since extract
      !this.diffSinceExtr()

      -- insert a footer comment
      !this.footerComment('End Data Differences Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  elseif (!this.sinceOption eq 'STAMP') then

    -- Check that there is a stamp able to be used
    if (!this.stamp.selection().eq('NONE')) then
      !!alert.warning('There is no selected stamp to use!')
      return
    endif

    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      -- output difference since stamp
      !this.diffSinceStamp()
    else

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile().not()) then
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Differences Listing    Date : $!clock '
      WRITEALPHAFILE '-- Differences since STAMP $!this.stamp.selection().dbRef().flnm '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      -- output difference since stamp
      !this.diffSinceStamp()

      -- insert a footer comment
      !this.footerComment('End Data Differences Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  else

    -- Since last savework
    if (!this.screenToggle.val) then
      -- make sure output is to requests window
      !this.ifScreen()

      ALPHA FILE END
      handle(61,274)
        -- Even if no file in use
      endhandle
      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx]
        handle ANY
          !this.errorWrite()
        endhandle
      enddo
    else
      -- make sure output is to requests window
--      !this.ifScreen()

      -- Filename must be set in correct mode then open alpha file
      if (!this.setFile().not()) then
        return
      endif

      -- insert a header comment
      var !clock CLOCK
      WRITEALPHAFILE '$S-  -- Synonym translation OFF '
      WRITEALPHAFILE '-- ----------------------------------------------------------------'
      WRITEALPHAFILE '-- Data Differences Listing    Date : $!clock '
      WRITEALPHAFILE '-- Differences since Savework $!this.time.val $!this.date.val '
      WRITEALPHAFILE ''
      WRITEALPHAFILE 'ONERROR GOLABEL /ERROR$!this.labelCounter'
      WRITEALPHAFILE ''

      do !indx indices !this.members.rText
        DIFFERENCE $!this.members.dText[$!indx]
        handle ANY
          !this.errorWrite()
        endhandle
      enddo
      -- insert a footer comment
      !this.footerComment('End Data Differences Listing    Date : $!clock ')
      ALPHA FILE END
    endif

  endif

  -- Highlight all changes if Highlight differences requested
  !this.highlight()

  -- Navigate back to original element
  !!ce = !refe

endif

-- Give a single warning if any errors occur
if (!this.errorFlag) then
  !!alert.warning('Errors occurred in the listing that need reviewing')
endif

endmethod
-- End of method definition for .onApply(STRING )

------------------------------------------------------------------------
--
-- Method:      changeSinceExtr(STRING)
--
-- Description: Output changes since extract
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Change options (part of command string)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .changeSinceExtr(!changesOptions is STRING)

  do !indx indices !this.members.rText
    if (!this.backtrack ) then
      !changes = 'REVERSE CHANGES'
    else
      !changes = 'CHANGES'
    endif
    if (!this.extSession.selection() eq 'Only') then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] $!changes SINCE EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Latest') then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] $!changes SINCE LATEST EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Session') then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] $!changes SINCE SESSION $!this.extSessNum.val EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Date') then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] $!changes SINCE $!this.extTime $!this.extDate EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection().eq('Stamp')) then
      if (!this.stamp.selection().eq('NONE')) then
        !!alert.warning('There is no selected stamp to use!')
        return
      else
        !stampName = !this.stamp.selection().dbRef().flnm
        OUTPUT $!changesOptions $!this.members.dText[$!indx] $!changes SINCE STAMP $!stampName
        handle ANY
          !this.errorWrite()
        endhandle
      endif
    endif
  enddo

endmethod
-- End of method definition for .changeSinceExtr(STRING)

------------------------------------------------------------------------
--
-- Method:      changeSinceTime(STRING)
--
-- Description: Output changes since time
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Change options (part of command string)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .changeSinceTime(!changesOptions is STRING)

  do !indx indices !this.members.rText
    if (!this.backtrack ) then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] REVERSE CHANGES SINCE $!this.time.val $!this.date.val
      handle ANY
        !this.errorWrite()
      endhandle
    else
      OUTPUT $!changesOptions $!this.members.dText[$!indx] CHANGES SINCE $!this.time.val $!this.date.val
      handle ANY
        !this.errorWrite()
      endhandle
    endif
  enddo

endmethod
-- End of method definition for .changeSinceTime(STRING)

------------------------------------------------------------------------
--
-- Method:      changeSinceStamp(STRING)
--
-- Description: Output changes since stamp
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Change options (part of command string)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .changeSinceStamp(!changesOptions is STRING)

  -- Get stamp
  !stampName = !this.stamp.selection().dbRef().flnm

  -- Make output
  do !indx indices !this.members.rText
    if (!this.backtrack ) then
      OUTPUT $!changesOptions $!this.members.dText[$!indx] REVERSE CHANGES SINCE STAMP $!stampName
      handle ANY
        !this.errorWrite()
      endhandle
    else
      OUTPUT $!changesOptions $!this.members.dText[$!indx] CHANGES SINCE STAMP $!stampName
      handle ANY
        !this.errorWrite()
      endhandle
    endif
  enddo

endmethod
-- End of method definition for .changeSinceStamp(STRING)

------------------------------------------------------------------------
--
-- Method:      diffSinceExtr
--
-- Description: Output difference since extract
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .diffSinceExtr()

  do !indx indices !this.members.rText
    if (!this.extSession.selection() eq 'Only') then
      DIFFERENCE $!this.members.dText[$!indx] SINCE EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Latest') then
      DIFFERENCE $!this.members.dText[$!indx] SINCE LATEST EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Session') then
      DIFFERENCE $!this.members.dText[$!indx] SINCE SESSION $!this.extSessNum.val EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    elseif (!this.extSession.selection() eq 'Date' or !this.extSession.selection().eq('Stamp')) then
      DIFFERENCE $!this.members.dText[$!indx] SINCE $!this.extTime $!this.extDate EXTRACT $!this.extract
      handle ANY
        !this.errorWrite()
      endhandle
    endif
  enddo

endmethod
-- End of method definition for .diffSinceExtr()

------------------------------------------------------------------------
--
-- Method:      diffSinceStamp
--
-- Description: Output difference since stamp
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .diffSinceStamp()

  -- Get stamp
  !stampName = !this.stamp.selection().dbRef().flnm

  -- Make output
  do !indx indices !this.members.rText
    DIFFERENCE $!this.members.dText[$!indx] SINCE STAMP $!stampName
      handle ANY
        !this.errorWrite()
      endhandle
  enddo

endmethod
-- End of method definition for .diffSinceStamp()

------------------------------------------------------------------------
--
-- Method:      errorWrite
--
-- Description: Output errors from apply
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .errorWrite()

  if (!this.screenToggle.val) then
    !error = !!error.text
    WRITE ''
    WRITE '-- ERROR - $!error'
    WRITE ''
  else
    !error = !!error.text
    WRITEALPHAFILE ''
    WRITEALPHAFILE '-- ERROR - $!error'
    WRITEALPHAFILE ''
  endif

  -- Set the error flag
  !this.errorFlag = true

endmethod
-- End of method definition for .errorWrite()
------------------------------------------------------------------------
--
-- Method:      pullDowns
--
-- Description: Maintain the pull-downs
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .pullDowns()

  !bar  = !this.bar
  !menu = !this.removeMenu

  -- If there are no members, then grey-out remove options
  if(!this.members.dText.size() eq 0 ) then
    !bar.setActive('Remove', false)
    !bar.setActive('Colour', false)
    !menu.setActive('All',        false)
    !menu.setActive('Selected',   false)
    !menu.setActive('Current Element',         false)
    !menu.setActive('Current Element Members', false)
    --!this.okButton.active = false
    !this.apply.active = false
    !menu.setActive('Graphical Pick',       false)

    !menu = !this.queryMenu
    !menu.setActive('Elements',   false)
    -- Also switch off any remove picking edg
    if (!this.designModule) then
      !!edgCntrl.remove('Output report packet')
    endif

--    !menu.setActive('Select...',  false)
  else
    !bar.setActive('Remove', true)
    !bar.setActive('Colour', true)
    !menu.setActive('All',        true)
    !menu.setActive('Selected',   true)
    !menu.setActive('Current Element',         true)
    !menu.setActive('Current Element Members', true)
    --!this.okButton.active = true
    !this.apply.active = true
    !menu.setActive('Graphical Pick',       true)

    !menu = !this.queryMenu
    !menu.setActive('Elements',   true)

--    !menu.setActive('Select...',  true)
  endif

  if (!this.designModule.not()) then
    !bar.setActive('Colour', false)
    !this.highOutput.active = false
    !menu = !this.addMenu
    !menu.setActive('Graphical Pick', false)
    !menu = !this.removeMenu
    !menu.setActive('Graphical Pick', false)
  endif

  !this.update()

endmethod
-- End of method definition for .pullDowns()
------------------------------------------------------------------------
--
-- Method:      update
--
-- Description: Maintain the List menu
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .update()

  -- deactivate Current Collection menu items if no list
  !listInterface  = object LISTINTERFACE()
  !hasCurrentList = !listInterface.hasCurrentList()
  !this.addMenu.setActive('Current Collection', !hasCurrentList)
  !this.removeMenu.setActive('Current Collection', !hasCurrentList)

endmethod
-- End of method definition for .update()
------------------------------------------------------------------------
--
-- Method:      ifScreen
--
-- Description: Maintain the Screen or File Gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .ifScreen()

  if (!this.screenToggle.val) then
    if (!!cadcReq.shown()) then
      !!cadcReq.cadcReq.setFocus()
      !!cadcReq.cadcReq.channel = 'RQUEST'
    else
      show !!cadcReq free
      !!cadcReq.cadcReq.clear()
      !!cadcReq.cadcReq.setFocus()
      !!cadcReq.cadcReq.channel = 'RQUEST'
    endif
    !this.fileTypeFrame.active = false
    !this.filename.active      = false
  else
    !!cadcReq.cadcReq.clear()
    hide !!cadcReq
    !this.fileTypeFrame.active = true
    !this.filename.active      = true
  endif

endmethod
-- End of method definition for .ifScreen()

------------------------------------------------------------------------
--
-- Method:      sinceSelect
--
-- Description: Store current SINCE selection & Maintain the Since Gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .sinceSelect()

  -- set the saved current option

  if (!this.saveToggle.val) then
     !this.sinceOption = 'SAVE'
    elseif (!this.timeToggle.val) then
  	 !this.sinceOption = 'TIME'
    elseif (!this.sessionToggle.val) then
  	 !this.sinceOption = 'SESS'
    elseif (!this.extractToggle.val) then
  	 !this.sinceOption = 'EXTR'
    elseif (!this.stampToggle.val) then
  	 !this.sinceOption = 'STAMP'
  endif

  -- build the extract list if extract
  !this.dbList()

  -- Build the stamp list if stamp
  !this.allStamp = ARRAY()
  !this.stampList()

  -- set up Since gadgets
  !this.ifTime()

endmethod
-- End of method definition for .sinceSelect()

------------------------------------------------------------------------
--
-- Method:      ifTime
--
-- Description: Maintain the Since Gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .ifTime()

  if (!this.sinceOption eq 'TIME') then
    !this.time.active       = true
    !this.date.active       = true
    !this.sessNum.active    = false
    !this.plus.active       = false
    !this.minus.active      = false
    !this.more.active       = true
    !this.dateSession(!this.time,!this.date,'OPTION')
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSessNum.active = false
    !this.extTime.active    = false
    !this.extDate.active    = false
    !this.stampMode.active  = false
    !this.stamp.active      = false
    !this.stamp.clear()
  elseif (!this.sinceOption eq 'SESS') then
    !this.time.active       = false
    !this.date.active       = false
    !this.sessNum.active    = true
    !this.plus.active       = true
    !this.minus.active      = true
    !this.more.active       = true
    !this.sessionDate()
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSessNum.active = false
    !this.extTime.active    = false
    !this.extDate.active    = false
    !this.stampMode.active  = false
    !this.stamp.active      = false
    !this.stamp.clear()
  elseif (!this.sinceOption eq 'SAVE') then
    -- Since last savework
    -- Set the time
    var !clockStr CLOCK
    !clockArr = !clockStr.split()
    !this.time.val = !clockArr[4]
    !this.date.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]

    -- Set Session number
    var !sessDnum SESSION ON $!this.time.val $!this.date.val
    !sessDnumReal = !sessDnum.real()
    !this.sessNum.val = !sessDnumReal

    !this.sessionDate()
    !this.ifSave()
  elseif (!this.sinceOption eq 'STAMP') then
    -- Since Stamp
    -- Set active gadgets
    !this.time.active       = true
    !this.date.active       = true
    !this.sessNum.active    = false
    !this.plus.active       = false
    !this.minus.active      = false
    !this.more.active       = true
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSessNum.active = false
    !this.extTime.active    = false
    !this.extDate.active    = false
    !this.stampMode.active  = true
    !this.stamp.active      = true
    -- Get session for this date
    !this.dateSession(!this.time,!this.date,'OPTION')
  else
    -- Since Extract
    -- Set the time
    var !clockStr CLOCK
    !clockArr = !clockStr.split()
    !this.time.val = !clockArr[4]
    !this.date.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]

    -- Set Session number
    !this.sessNum.val = 0


    -- Grey out all the session gadget and set the clock as now
    !this.tim.active        = false
    !this.time.active       = false
--    !this.dat.active       = false
    !this.date.active       = false
    !this.sessNu.active     = false
    !this.sessNum.active    = false
    !this.sessUser.active   = false
    !this.sessDb.active     = false
    !this.minus.active      = false
    !this.plus.active       = false
    !this.more.active       = false
    !this.stampMode.active  = false
    !this.stamp.active      = false
    !this.stamp.clear()

    !this.sessionDate()
--    !this.dbList()
    !this.extractChoice(true)

  endif

  -- set highlight gadget active state
  !this.highOutputMode()

endmethod
-- End of method definition for .ifTime()

------------------------------------------------------------------------
--
-- Method:      ifSave
--
-- Description: Setup Since Gadgets for SAVE option
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .ifSave()

  if (!this.sinceOption eq 'SAVE') then
    -- Since last savework

    !this.time.active    = false
    !this.date.active    = false
    !this.sessNum.active = false
    !this.plus.active    = false
    !this.minus.active   = false
    !this.more.active    = false
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSessNum.active = false
    !this.extTime.active    = false
    !this.extDate.active    = false
    !this.stampMode.active  = false
    !this.stamp.active      = false
    !this.stamp.clear()

  endif

endmethod
-- End of method definition for .ifSave()

------------------------------------------------------------------------
--
-- Method:      close
--
-- Description: Close the form down
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .close()

  -- Cease the event driven graphics
  if (!this.designModule) then
    !!edgCntrl.remove('Output report packet')
  endif

  -- unhighlight all elements
  !this.highlightDef(false)

  -- Remove all and hide the form
  !this.removeAll()
  !this.hide()

  -- Remove the request window
-- !!cadcReq.hide()

endmethod
-- End of method definition for .close()

------------------------------------------------------------------------
--
-- Method:      addCe
--
-- Description: Add Current element to the List and Display
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element to be added into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .addCe(!item is DBREF)

  -- Add item to list
  if (!this.members.pickedField lt 1 or !this.members.pickedField ge !this.members.rText.size()) then
  !this.elements.append(!item)
  else
    !nextField = !this.members.pickedField + 1
    !this.elements.insert(!nextField, !item)
  endif

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .addCe(DBREF)

------------------------------------------------------------------------
--
-- Method:      addCeMem
--
-- Description: Add Current element member to the List and Display
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element to be added into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .addCeMem(!item is DBREF)

  -- Add item to list
  if (!this.members.pickedField lt 1 or !this.members.pickedField ge !this.members.rText.size()) then
  !this.elements.appendArray(!item.members)
  else
    !nextField = !this.members.pickedField + 1
    !this.elements.insertArray(!nextField, !item.members)
  endif

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .addCeMem(DBREF)

------------------------------------------------------------------------
--
-- Method:      addList
--
-- Description: Add Current Collection members to the List and Display
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .addList()

  -- Add item to list
  !listInterface = object LISTINTERFACE()
  !this.elements.appendArray(!listInterface.getCurrentListAsReferences())

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .addCeMem(DBREF)
------------------------------------------------------------------------
--
-- Method:      pick
--
-- Description: Setup Pick mode to Add/Remove items
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     True add picked items to list
--                           False for removing items List
-- return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .pick(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !option  = !menu.pickedField

if(!option.upCase() eq 'GRAPHICAL PICK') then

  if(!selected eq 'SELECT') then

    if (!this.designModule) then
      !!edgCntrl.remove('Output report packet')
    endif

    -- Define edg Packet for picking elements
    !packet             = object EDGPACKET()

    if (!menu.name().upCase() eq 'ADDMENU') then
      !packet.elementPick('Pick element to Add')
      !packet.remove      = false
      !packet.description = 'Output report packet'
      !packet.action      = '!!rptOutput.addPicked(!this.return[1].item)'
      !this.removeMenu.select('Graphical Pick',false)
      !packet.close       = '!!rptOutput.addMenu.select(''Graphical Pick'',false)'
    else
      !packet.elementPick('Pick element to Remove')
      !packet.remove      = false
      !packet.description = 'Output report packet'
      !packet.action      = '!!rptOutput.removePicked(!this.return[1].item)'
      !this.addMenu.select('Graphical Pick',false)
      !packet.close       = '!!rptOutput.removeMenu.select(''Graphical Pick'',false)'
    endif

    if (!this.designModule) then
      !!edgCntrl.add(!packet)
    endif

  else
    if (!this.designModule) then
      !!edgCntrl.remove('Output report packet')
    endif
  endif

endif

endmethod
-- End of method definition for .pick(MENU, STRING)
------------------------------------------------------------------------
--
-- Method:      addPicked
--
-- Description: Add Picked element to the List and Display
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element to be added into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .addPicked(!picked is DBREF)

  --366110:Set the significant elements when using graphical pick

  if(!this.desModule) then
    !this.specificFlag = false
    !this.elementFlag = false

    !this.pickElement(!picked)

    if(!this.specificFlag) then
      return
    endif
  endif

  -- Maintain the array of picks

  -- If the picked element is not already in the array then add it
  if (!this.elements.findFirst(!picked).unset()) then

    -- Add item to list
    if (!this.members.pickedField lt 1 or !this.members.pickedField ge !this.members.rText.size()) then
    !this.elements.append(!picked)
    else
      !nextField = !this.members.pickedField + 1
      !this.elements.insert(!nextField, !picked)
    endif

    -- Enhance Colour of picked element
    !colour = !!gphColOpt.highlight.key()
    $!this.enhance $!picked COLOUR $!colour

  else
    -- If the picked element is already in the array then remove it
    --!this.elements.remove(!this.elements.findFirst(!picked))

   !colour = !!gphColOpt.highlight.key()
   $!this.enhance $!picked COLOUR $!colour

  endif

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .addPicked(DBREF)
------------------------------------------------------------------------
--
-- Method:      removePicked
--
-- Description: Remove Picked element from the List and unhighlight
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element to be added into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removePicked(!picked is DBREF)

  if(!this.desModule) then
    !this.elementFlag = false
    !this.specificFlag = false

    !this.pickElement(!picked)

    if(!this.specificFlag) then
       return
    endif
  endif

   -- If passed item exists in list, the remove it
  !index = !this.elements.findFirst(!picked)
  if(!index.set()) then
    !this.elements[!index].delete()
    $!this.unenhance $!picked
  endif

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .removePicked(DBREF)

------------------------------------------------------------------------
--
-- Method:      listLst
--
-- Description: Maintain the list of elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING       ADD or REMOVE
--    2   R      STRING       list name
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .listLst(!option is STRING, !listData is STRING)

    !entries = ARRAY()

    -- Get list
    !entriesStr  = '!!' & 'CDLIST' & !listData

    do !i indices $!entriesStr
      !entries[!i] = $!entriesStr[$!i].dbRef()
    enddo

    -- Option
    if(!option.upCase() eq 'ADD') then

      -- Add item to list
      if (!this.members.pickedField lt 1 or !this.members.pickedField ge !this.members.rText.size()) then
      !this.elements.appendArray(!entries)
      else
        !nextField = !this.members.pickedField + 1
        !this.elements.insertArray(!nextField, !entries)
      endif

      -- Re Display
      !this.display()

    elseif (!option.upCase() eq 'REMOVE') then

      -- Difference
      !newList     = !this.elements.difference(!entries)
      !this.elements = !newList

      -- Display
      !this.display()

    endif

endmethod
-- End of method definition for .listLst(STRING, STRING)

------------------------------------------------------------------------
--
-- Method:      removeCe
--
-- Description: Remove Current Element List
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element which members are to be removed from list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeCe(!item is DBREF)

    -- If passed item exists in list, the remove it
  !index = !this.elements.findFirst(!item)
  if(!index.set()) then
    $!this.unenhance $!item
    !this.elements[!index].delete()
  endif

  -- Re Display
  !this.display()

endmethod
-- End of method definition for .removeCe(DBREF)

------------------------------------------------------------------------
--
-- Method:      removeCeMem
--
-- Description: Remove Current Element members List
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Element which members are to be added into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeCeMem(!item is DBREF)

  -- Get members of Item
  !this.removeMembers(!item.members)

endmethod
-- End of method definition for .removeCeMem(DBREF)

------------------------------------------------------------------------
--
-- Method:      removeList
--
-- Description: Remove Current Collection members
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeList()

  -- Remove from list
  !listInterface = object LISTINTERFACE()
  !this.removeMembers(!listInterface.getCurrentListAsReferences())

endmethod
-- End of method definition for .removeList()

------------------------------------------------------------------------
--
-- Method:      removeSelected
--
-- Description: Remove selected items List
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeSelected()

  -- Check there are some selections
  if(!this.members.selection().unset()) then
    !!messageFile.warning(149,006)
    return
  endif

  -- Remove entries List
  do !i values !this.members.val
    $!this.unenhance $!this.elements[$!i]
    !this.elements[!i].delete()
  enddo

  -- Display
  !this.display()

endmethod
-- End of method definition for .removeSelected()

------------------------------------------------------------------------
--
-- Method:      removeMembers
--
-- Description: Remove list or elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Elements to be removed into list
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeMembers(!members is ARRAY)

  do !indx indices !members
    $!this.unenhance $!members[$!indx]
  enddo

  -- Difference
  !newList       = !this.elements.difference(!members)
  !this.elements = !newList

  -- Display
  !this.display()

endmethod
-- End of method definition for .removeMembers(ARRAY)

------------------------------------------------------------------------
--
-- Method:      removeAll
--
-- Description: Remove all elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .removeAll()

  -- unhighlight all elements
  !this.highlightDef(false)

  -- Remove all entries List
  !this.elements.clear()

  -- Display
  !this.display()

endmethod
-- End of method definition for .removeAll()

------------------------------------------------------------------------
--
-- Method:      selectMember
--
-- Description: Selected entry from Members
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Gadget (Menu)
--    2   R      STRING      Selected/Unselected
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .selectMember(!listGadget is GADGET, !select is STRING)

  -- If select, then move to item
  if(!select.upCase() eq 'SELECT') then
    !picked  = !listGadget.pickedField
    !!ce = !this.members.rText[!picked].dbRef()
    handle any
      !!alert.error(!!error.text)
    endhandle
  endif

endmethod
-- End of method definition for .selectMember(GADGET, STRING)
------------------------------------------------------------------------
--
-- Method:      display
--
-- Description: Select list and make current active
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .display()

  -- Re-build list
  if(!this.elements.set()) then

      -- Remove Duplications
    !this.elements.unique()

      do !indx indices !this.elements
        !listStr[!indx] = !this.elements[!indx].string()
        !listNam[!indx] = !listStr[!indx].dbRef().fullName
      enddo

      !this.members.dText = !listNam
      !this.members.rText = !listStr

  else
    !this.members.dText = ARRAY()

  endif

  -- Maintain Pull-Downs for current list
  !this.pullDowns()
  -- Maintain If Screen Gadgets
--  !this.ifScreen()

endmethod
-- End of method definition for .display()

------------------------------------------------------------------------
--
-- Method:      highlightDef
--
-- Description: Highlight default
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN      enhance or unenhance
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .highlightDef(!high is BOOLEAN )

  do !i indices !this.elements
    if (!high ) then
    else
      $!this.unenhance $!!rptOutput.elements[$!i]
      handle any
        -- element must have been deleted, so remove it from the element list
       !this.elements[!i].delete()
      endhandle
    endif
  enddo

endmethod
-- End of method definition for .highlightDef(BOOLEAN )

------------------------------------------------------------------------
--
-- Method:      eColours
--
-- Description: Element Highlight colours
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .eColours()

  -- Type of Colour to be changed
  !command   = '!!rptOutput.chosenECol()'
  !title     = 'Highlight Elements Colour'

  -- Current Background colour
    !refColour = !this.hElementColour

  -- Display colour selection form
  call !!colourSelectLoad(!command, !title, !refColour)

endmethod
-- End of method definition for .eColours()
------------------------------------------------------------------------
--
-- Method:      cColours
--
-- Description: Output Highlight colours
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Mode changes or differences
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .cColours(!mode is STRING)

  -- Type of Colour to be changed
  !command   = '!!rptOutput.hOutputColour = !!colourSelect.currentColour.background'
  if (!mode eq 'Differences') then
    !title     = 'Highlight Differences Colour'
  else
    !title     = 'Highlight Changes Colour'
  endif

  -- Current Background colour
    !refColour = !this.hOutputColour

  -- Display colour selection form
  call !!colourSelectLoad(!command, !title, !refColour)

endmethod
-- End of method definition for .cColours(STRING)

------------------------------------------------------------------------
--
-- Method:      chosenECol
--
-- Description: Enhance the elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .chosenECol()

  !this.hElementColour = !!colourSelect.currentColour.background

  do !i indices !this.elements
    !elem = !this.elements[!i]
    !choi = !!colourSelect.currentColour.background
    $!this.enhance $!elem COLOUR $!choi
  enddo

endmethod
-- End of method definition for .chosenECol()

------------------------------------------------------------------------
--
-- Method:      sessCount
--
-- Description: Session Plus/Minus counter
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL       1 is plus
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .sessCount(!select is REAL)

  -- remember which button was pressed
  !this.plusMinusNum = !select

  if (!select eq 1) then
    !this.sessNum.val = !this.sessNum.val + 1
  else
    !this.sessNum.val = !this.sessNum.val - 1
  endif

  !this.sessionDate()

endmethod
-- End of method definition for .sessCount(REAL)
------------------------------------------------------------------------
--
-- Method:      dblist
--
-- Description: Populate the database gadget
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .dbList()

-- initialise variables
!dText = ARRAY()

-- Only do this if the extract option is chosen
if (!this.sinceOption eq 'EXTR') then

  -- Make a collection of all ancestors of current database
  !this.dbName = !this.getDbName()
  !dbName = !this.dbName
  !db = object DB('/*' + !dbName)
  !dbRef = !db.refNo.dbRef()
  !ancestors = !dbRef.extals
  if (!ancestors.size() gt 1) then
    do !i indices !ancestors
      -- Do not add the extract itself
      skip if (!i lt 2)
      !dText.append(!ancestors[!i].name.substring(3))
    enddo
    !menu = !this.controlMenu
    !inDbListingMode = !menu.selected('DB Listing')
    -- make extract gadgets active if there are extracts and not in DB Listing mode
    !this.extract.active    = !inDbListingMode.not()
    !this.extSession.active = !inDbListingMode.not()
  else
    !dText.append('Not an Extract')
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSession.select('RTEXT','Only')
    !!alert.warning('Database ' + !this.dbName + ' is not an extract database')
    !this.saveToggle.val     = TRUE
    if (!this.saveToggle.val) then
      !this.timeToggle.val     = FALSE
      !this.sessionToggle.val  = FALSE
      !this.extractToggle.val  = FALSE
      !this.stampToggle.val    = FALSE
      !this.sinceOption = 'SAVE'
    endif
    !this.ifSave()
    -- NOTE THAT THIS CODE HAS BEEN TWEAKED TO AVOID A PML BUG ON NT
    -- DO NOT REMOVE THE setFocus OR CHANGE THE ORDER OF CALLS HERE
    !this.dismiss.setFocus()
  endif

  !this.extract.dText = !dText

else

--  !this.extract.dText = !dText

endif

endmethod
-- End of method definition for .dbList()
------------------------------------------------------------------------
--
-- Method:      extractChoice
--
-- Description: Maintain gadget based on Extract Session choice
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     Set the date to now
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .extractChoice(!setNow is BOOLEAN)

    var !clockStr CLOCK
    !clockArr = !clockStr.split()
    !this.allStamp = ARRAY()

  if (!this.extSession.selection() eq 'Only') then
    !this.extSessNum.active = false
    !this.extTime.active = false
    !this.extDate.active = false
    !this.extSessNum.val = 0
    !this.extTime.val = ''
    !this.extDate.val = ''
    !this.stampMode.active  = false
    !this.stamp.active = false
    !this.stamp.clear()
  elseif (!this.extSession.selection() eq 'Latest') then
    !this.extSessNum.active = false
    !this.extTime.active = false
    !this.extDate.active = false
    !this.extSessNum.val = 0
    !this.extTime.val = !clockArr[4]
    !this.extDate.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]
    !this.stampMode.active  = false
    !this.stamp.active = false
    !this.stamp.clear()
  elseif (!this.extSession.selection() eq 'Session') then
    !this.extSessNum.active = true
    !this.extTime.active = false
    !this.extDate.active = false
    !this.extTime.val = ''
    !this.extDate.val = ''
    !this.stampMode.active  = false
    !this.stamp.active = false
    !this.stamp.clear()
  elseif (!this.extSession.selection() eq 'Date') then
    !this.extSessNum.active = false
    !this.extTime.active = true
    !this.extDate.active = true
    !this.extSessNum.val = 0
    !this.stampMode.active  = false
    !this.stamp.active = false
    !this.stamp.clear()
    if (!setNow) then
      !this.extTime.val = !clockArr[4]
      !this.extDate.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]
    endif
  else
    !this.extSessNum.active = false
    !this.extTime.active = true
    !this.extDate.active = true
    !this.extSessNum.val = 0
    !this.stampMode.active  = true
    !this.stamp.active = true
    !this.stampList()
  endif

endmethod
-- End of method definition for .extractChoice(BOOLEAN)
------------------------------------------------------------------------
--
-- Method:      check
-- Description: Validate input to gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING      Gadget name
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .check(!check is STRING)

if (!check eq 'extSessNum') then

  if (!this.extSessNum.val lt 0) then
    return error 1 'Cannot be a negative session number'
  endif

  -- Find the last session number of the specified database
  !db = '/*' + !this.extract.selection()
  !lastSession = MSESS of $!db
  if (!this.extSessNum.val gt !lastSession) then
    !string = 'Highest session number of ' + !this.extract.selection() + ' is ' + !lastSession.string()
    return error 1 '$!string'
  endif

elseif (!check eq 'extTime' or !check eq 'time') then

  -- Check hour input as a real number
  !hour = REAL()
  !hour = !this.attribute(!check).val.before(':').real()
  handle ANY
    return error 1 'Invalid input'
  endhandle
  if (!hour.unset() or !hour gt 23 or !hour lt 0) then
    return error 1 'Invalid input'
  endif

  -- Check minute input as a real number
  !minute = REAL()
  !minute = !this.attribute(!check).val.after(':').real()
  handle ANY
    return error 1 'Invalid input'
  endhandle
  if (!minute.unset() or !minute gt 59 or !minute lt 0) then
    return error 1 'Invalid input'
  endif

elseif (!check eq 'extDate' or !check eq 'date') then

  -- Check day input as a real number
  !day = REAL()
  !dayLength = 2
  !day = !this.attribute(!check).val.trim().substring(1,2).real()
  handle ANY
    !dayLength = 1
    !day = !this.attribute(!check).val.trim().substring(1,1).real()
    handle ANY
      return error 1 'Invalid input'
    endhandle
  endhandle
  if (!day.unset() or !day gt 31 or !day lt 1) then
    return error 1 'Invalid input'
  endif

  -- Check year input as a real number
  !length = !this.attribute(!check).val.trim().length()
  !checkLength = !length - 3
  !year = REAL()
  !year = !this.attribute(!check).val.trim().substring(!checkLength,!length).real()
  handle ANY
    return error 1 'Invalid input'
  endhandle
  if (!year.unset() or !year lt 0) then
    return error 1 'Invalid input'
  endif
  !month = STRING()
  !month = !this.attribute(!check).val.trim().after(!day.string()).before(!year.string()).trim()
  if (!month.unset()) then
    return error 1 'Invalid input'
  endif

  -- Try to set up the input into a dateTime object
  !unusedDate = object DATETIME(!year,!month,!day)
  handle ANY
    return error 1 'Invalid input'
  endhandle

endif

endmethod
-- End of method definition for .check(STRING )
------------------------------------------------------------------------
--
-- Method:      mode
--
-- Description: Change form mode (DB Listing, DB Changes, DB Differences)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Mode is Datal, Change or Differ
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .mode(!modeSel is STRING )

  -- initialise form - mode is called externally
  !this.initialise()

 if (!modeSel eq 'Datal') then
    !this.formTitle         = 'DB Listing'
    !this.since.tag         = '   DB Listing    '
    !this.highOutput.tag    = 'Highlight Elements   '
--    !this.tagsOutput.tag  = 'Tag Elements         '
		--!this.okButton.callback = '!!rptOutput.onApply(|Datal|)'
    !this.apply.callback    = '!!rptOutput.onApply(|Datal|)'
    -- Make the Since panel inactive because we cannot output db elements on a given date yet
    !this.sinceTypeFrame.active  = false
    !this.tim.active        = false
    !this.time.active       = false
--    !this.dat.active        = false
    !this.date.active       = false
    !this.sessNu.active     = false
    !this.sessNum.active    = false
    !this.sessUser.active   = false
    !this.sessDb.active     = false
    !this.minus.active      = false
    !this.plus.active       = false
    !this.more.active       = false
    !this.highOutput.active = false
    -- deactivate the extract gadgets
    !this.extract.active    = false
    !this.extSession.active = false
    !this.extSessNum.active = false
    !this.extTime.active    = false
    !this.extDate.active    = false
    -- deactivate the stamp gadgets
    !this.stampMode.active  = false
    !this.stamp.active      = false
    !this.stamp.clear()

  !menu = !this.controlMenu
    !menu.select('DB Listing', true)
    !menu.select('DB Changes',   false)
    !menu.select('DB Differences',  false)
    !this.optionsMenu.setActive('Options...',  true)
    !this.optionsMenu.setActive('Backtrack Mode',  false)

    !this.sessNum.val = 0
    !this.sessionDate()

  !menu = !this.colourMenu
    !menu.clear()
    !menu.add('CALLBACK', 'Elements...',    '!!rptOutput.eColours()')

  elseif (!modeSel eq 'Change') then
    !this.formTitle       = 'DB Changes'
    !this.since.tag       = '  Changes since  '
    !this.highOutput.tag  = 'Highlight Changes    '
--    !this.tagsOutput.tag  = 'Tag Changes          '
		--!this.okButton.callback = '!!rptOutput.onApply(|Change|)'
    !this.apply.callback  = '!!rptOutput.onApply(|Change|)'
    -- Make the Since panel active
    !this.sinceTypeFrame.active = true
    !this.tim.active       = true
    !this.time.active      = true
--    !this.dat.active       = true
    !this.date.active      = true
    !this.sessNu.active    = true
    !this.sessNum.active   = true
    !this.sessUser.active  = true
    !this.sessDb.active    = true
    !this.minus.active     = true
    !this.plus.active      = true
    !this.more.active      = true

  !menu = !this.controlMenu
    !menu.select('DB Listing', false)
    !menu.select('DB Changes',   true)
    !menu.select('DB Differences',  false)
    !this.optionsMenu.setActive('Options...',  true)
    !this.optionsMenu.setActive('Backtrack Mode',  true)
    !this.ifTime()

  !menu = !this.colourMenu
    !menu.clear()
    !menu.add('CALLBACK', 'Elements...',     '!!rptOutput.eColours()')
    !menu.add('CALLBACK', 'Changes...',      '!!rptOutput.cColours(|Changes|)')

  else
    !this.formTitle       = 'DB Differences'
    !this.since.tag       = 'Differences Since'
    !this.highOutput.tag  = 'Highlight Differences'
--    !this.tagsOutput.tag  = 'Tag Differences      '
		--!this.okButton.callback = '!!rptOutput.onApply(|Differ|)'
    !this.apply.callback  = '!!rptOutput.onApply(|Differ|)'
    -- Make the Since panel active
    !this.sinceTypeFrame.active = true
    !this.tim.active       = true
    !this.time.active      = true
--    !this.dat.active       = true
    !this.date.active      = true
    !this.sessNu.active    = true
    !this.sessNum.active   = true
    !this.sessUser.active  = true
    !this.sessDb.active    = true
    !this.minus.active     = true
    !this.plus.active      = true
    !this.more.active      = true

  !menu = !this.controlMenu
    !menu.select('DB Listing', false)
    !menu.select('DB Changes',   false)
    !menu.select('DB Differences',  true)
    !this.optionsMenu.setActive('Options...',  false)
    !this.optionsMenu.setActive('Backtrack Mode',  false)
    !this.ifTime()

  !menu = !this.colourMenu
    !menu.clear()
    !menu.add('CALLBACK', 'Elements...',     '!!rptOutput.eColours()')
    !menu.add('CALLBACK', 'Differences...',  '!!rptOutput.cColours(|Differences|)')

  endif

endmethod
-- End of method definition for .mode(STRING )

------------------------------------------------------------------------
--
-- Method:      setFile
--
-- Description: Set the Filename Gadget and Access Mode
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN    Validated write mode
--
---------------------------------------------------------------------------------

define method .setFile() is BOOLEAN

  if (!this.filename.val.length() eq 0) then
    !!messageFile.warning(146,028)
    !returnValue = false
    return !returnValue
  endif

  if (!this.newFileToggle.val) then
  	!fileTypeSele = 'WRITE'
  elseif (!this.overwriteToggle.val) then
  	!fileTypeSele = 'OVERWRITE'
  else
  	!fileTypeSele = 'APPEND'
  endif

  !inputFile = !!file(!this.filename.val)
  !inputFile.open(!fileTypeSele)

  !this.labelCounter = !inputFile.size()
  -- if option is new file then WRITE must be ''
  if (!inputFile.accessMode() eq 'WRITE') then
    !inputFile.close()
    !inputFile.deleteFile()
    !fileTypeSele = ''
    !this.appendToggle.val = true
  elseif (!inputFile.accessMode() eq 'OVERWRITE') then
    !inputFile.close()
    !fileTypeSele = 'OVERWRITE'
    !this.appendToggle.val = true
  else
    -- must be file access mode must be append
    !inputFile.close()
    !fileTypeSele = 'APPEND'
    !this.appendToggle.val = true
  endif
  ALPHA FILE "$!this.filename.val" $!fileTypeSele
    handle (61,273)
      -- Trying to open a new file that already exists
      !!alert.message(!!error.text )
      !returnValue = false
      return !returnValue
    endhandle

  !returnValue = true
  return !returnValue

endmethod
-- End of method definition for .setFile() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      backtrackMode
--
-- Description: Sets the option to output changes in backtrack mode or not
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .backtrackMode()

  if (!this.backtrack) then
    !this.backtrack = false
  else
    !this.backtrack = true
  endif

endmethod
-- End of method definition for .backtrackMode()

------------------------------------------------------------------------
--
-- Method:      query
--
-- Description: Query Session, History, ClaimBy and Database Information
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING      element example CE
--    2    R     STRING      History of Last Modified
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .query(!element is STRING , !mode is STRING)

 if (!this.screenToggle.val) then
    -- make sure output is to requests window
    !this.ifScreen()

--    CLOSEFILE $!fileToken
--    handle any
--      -- Even if no file in use
--    endhandle
    if(!element eq 'CE') then
      if ((!!ce.type eq 'WORL' or !!ce.owner.type eq 'WORL') and (!mode eq 'History' or !mode eq 'LastMod')) then
        !name = FULLNAME
        !type = TYPE
        -- get current Database name
        !dbName = !this.getDbName()
        !answer = !!alert.confirm(!!messageFile.messageString(149,200,!name,!type,!dbName))
        if (!answer neq 'YES') then
          return
        endif
      endif
      -- output queries
      !this.qElement(!!ce, !mode)
    else
      do !indx indices !this.members.rText
        !!ce = !this.elements[!indx]
        if ((!!ce.type eq 'WORL' or !!ce.owner.type eq 'WORL') and (!mode eq 'History' or !mode eq 'LastMod')) then
          !answer = !!alert.confirm(!!messageFile.messageString(149,201))
          if (!answer neq 'YES') then
            return
          endif
        endif
      enddo
      do !indx indices !this.members.rText
        !!ce = !this.elements[!indx]
        -- output queries
        !this.qElement(!!ce, !mode)
      enddo
    endif

  else
    -- make sure output is not to requests window
--    !this.ifScreen()

    -- Filename must be set
    if (!this.filename.val.length() eq 0) then
      !!messageFile.warning(146,028)
      return
    endif

    if (!this.newFileToggle.val) then
	  	!fileTypeSele = 'WRITE'
	  elseif (!this.overwriteToggle.val) then
	  	!fileTypeSele = 'OVERWRITE'
	  else
	  	!fileTypeSele = 'APPEND'
	  endif

    !inputFile = !!file(!this.filename.val)
    !inputFile.open(!fileTypeSele)

    !this.appendToggle.val = true

    if(!element eq 'CE') then
      ----------------------------- CE --------------------------------------
      if ((!!ce.type eq 'WORL' or !!ce.owner.type eq 'WORL') and (!mode eq 'History' or !mode eq 'LastMod')) then
        !name = FULLNAME
        !type = TYPE
        -- get current Database name
        !dbName = !this.getDbName()
        !answer = !!alert.confirm(!!messageFile.messageString(149,200,!name,!type,!dbName))
        if (!answer neq 'YES') then
          return
        endif
      endif
      -- output element details to file
      !this.rElement(!!ce, !mode, !inputFile)

    else
      ------------------------------- Selected elements --------------------------
      do !indx indices !this.members.rText
        !!ce = !this.elements[!indx]
        if ((!!ce.type eq 'WORL' or !!ce.owner.type eq 'WORL') and (!mode eq 'History' or !mode eq 'LastMod')) then
          !answer = !!alert.confirm(!!messageFile.messageString(149,201))
          if (!answer neq 'YES') then
            return
          endif
        endif
      enddo
      do !indx indices !this.members.rText
        !!ce = !this.elements[!indx]
        -- output element details to file
        !this.rElement(!!ce, !mode, !inputFile)
      enddo
    endif
    !inputFile.close()

    -- Even if writing to file we still want to see the query result on the screen
    if (!!cadcReq.shown()) then
      !!cadcReq.cadcReq.setFocus()
      !!cadcReq.cadcReq.channel = 'RQUEST'
    else
      show !!cadcReq free
      !!cadcReq.cadcReq.clear()
      !!cadcReq.cadcReq.setFocus()
      !!cadcReq.cadcReq.channel = 'RQUEST'
    endif

    if(!element eq 'CE') then
      -- output queries for CE
      !this.qElement(!!ce, !mode)
    else
      do !indx indices !this.members.rText
        !!ce = !this.elements[!indx]
        -- output queries
        !this.qElement(!!ce, !mode)
      enddo
    endif

  endif

endmethod
-- End of method definition for .query(STRING , STRING)
------------------------------------------------------------------------
--
-- Method:      qElement
--
-- Description: Query Session, History, ClaimBy and Database Information
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     DBREF       element to query
--    2    R     STRING      History of Last Modified
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .qElement(!element is DBREF , !mode is STRING)

  !curRef = !!ce
  !!ce = !element

  if(!!module().appName.trim().upCase() eq 'ADMIN') then
    -- in ADMIN
    !dbName = ''
  else
    -- not in ADMIN
    if( !element.dbName eq !element.wdbName ) then
      -- not a working extract
      !dbName = 'DBNAME'
    else
      -- in a working extract
      !dbName = 'WDBNAME DBNAME'
    endif
  endif

  QUERY FULLNAME
  if (!mode eq 'Session') then

    QUERY SESSION

  elseif (!mode eq 'History') then

    QUERY $!dbName HISTORY
    QUERY LASTMOD HIER SESSMOD HIER USERMOD HIER

  elseif (!mode eq 'LastMod') then

    QUERY $!dbName LASTMOD HIER SESSMOD HIER USERMOD HIER

  elseif (!mode eq 'ClaimBy') then

    -- only output extract claim if element is extract claimed
    !extrClaim = !element.extrClaim
    handle any
      !extrClaim = ''
    elsehandle none
      if( !extrClaim.empty().not() ) then
        !extrClaim = 'EXTRCLAIM'
      endif
    endhandle
    if( !extrClaim.empty() ) then
      QUERY EXTRCLAIM
      handle any
      endhandle
    else
      QUERY USERC $!extrClaim
    endif

  else

    QUERY $!dbName DBCL DBAC

  endif

  !!ce = !element

endmethod
-- End of method definition for .qElement(DBREF , STRING)
------------------------------------------------------------------------
--
-- Method:      rElement
--
-- Description: Report to file Session, History, ClaimBy and Database Information
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     DBREF       element to query
--    2    R     STRING      History of Last Modified
--    3    R     FILE        File object. File must already be open
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rElement(!element is DBREF, !mode is STRING, !inputFile is FILE)

  !curRef = !!ce
  !!ce = !element

  -- get full element name for all output modes
  !name = FULLNAME

  if (!mode eq 'Session') then

     -- Time now
     var !clockStr CLOCK
     !clockArr = !clockStr.split()
     !this.time.val = !clockArr[4]
     !this.date.val = !clockArr[1] & ' ' & !clockArr[2] & ' ' & !clockArr[3]

     -- Set Session number
     var !sessDnum SESSION ON $!this.time.val $!this.date.val
     !sessDnumReal = !sessDnum.real()
     var !sessDate SESSDATE $!sessDnum
     var !sessUsr  SESSUSER $!sessDnum
     var !sessComm SESSCOMM $!sessDnum
     if (!!module().appName.upCase() neq 'ADMIN') then
       -- get current Database name
       !this.dbName = !this.getDbName()
       !dbName = !this.dbName
       !dbNumb = DBNUMB
     else
       !dbName = 'None'
       !dbNumb = 'None'
     endif

     !inputFile.writeRecord('-- Name $!name')
     !inputFile.writeRecord('--  ')
     !inputFile.writeRecord('-- Db $!dbName , number $!dbNumb ')
     !inputFile.writeRecord('--  ')
     !inputFile.writeRecord('-- Last saved session number $!sessDnumReal ')
     !inputFile.writeRecord('-- Session $!sessDnumReal :')
     !inputFile.writeRecord('-- Date: $!sessDate User: $!sessUsr')
     !inputFile.writeRecord('-- Description: $!sessComm')
     !inputFile.writeRecord('--  ')

  elseif (!mode eq 'History') then

     -- get current Database name
     !this.dbName = !this.getDbName()
     var !history HISTORY
     !lastMod = LASTMOD HIER
     !sessMod = SESSMOD HIER
     !userMod = USERMOD HIER
     !inputFile.writeRecord('-- Name $!name')
     !inputFile.writeRecord('-- History of modifications $!history')
     !inputFile.writeRecord('-- Date last modified $!lastMod')
     !inputFile.writeRecord('-- Last modified Session $!sessMod')
     !inputFile.writeRecord('-- Last modified by user $!userMod')
     !inputFile.writeRecord('--  ')

  elseif (!mode eq 'LastMod') then

     -- get current Database name
     !this.dbName = !this.getDbName()
     !lastMod = LASTMOD HIER
     !sessMod = SESSMOD HIER
     !userMod = USERMOD HIER
     !inputFile.writeRecord('-- Name $!name')
     !inputFile.writeRecord('-- Date last modified $!lastMod')
     !inputFile.writeRecord('-- Last modified Session $!sessMod')
     !inputFile.writeRecord('-- Last modified by user $!userMod')
     !inputFile.writeRecord('--  ')

  elseif (!mode eq 'ClaimBy') then

     !userC = USERC
     !inputFile.writeRecord('-- Name $!name')
     if ( LCLM ) then
       !inputFile.writeRecord('-- Claimed By $!userC')
     else
       !inputFile.writeRecord('-- Unclaimed')
     endif
     !extrClaim = !element.extrClaim
     handle any
       !extrClaim = ''
     endhandle
     if( !extrClaim.empty().not() ) then
       !inputFile.writeRecord('-- Claimed to Extract Database $extrClaim')
     endif
     !inputFile.writeRecord('--  ')

  else

    if (!!module().appName.upCase() neq 'ADMIN') then
      -- get current Database name
      !dbName = !this.getDbName()
    else
      !dbName = 'None'
    endif
    !dbcl = DBCL
    !dbac = DBAC

    !inputFile.writeRecord('-- Name $!name')
    !inputFile.writeRecord('-- Dbname   $!dbName')
    !inputFile.writeRecord('-- Dbclaim  $!dbcl')
    !inputFile.writeRecord('-- Dbaccess $!dbac')
    !inputFile.writeRecord('--  ')

  endif

  !!ce = !element

endmethod
-- End of method definition for .rElement(DBREF , STRING)

------------------------------------------------------------------------
--
-- Method:      qClaimlist
--
-- Description: Query Claimlists
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING       Other or This or Clock
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .qClaimlist(!mode is STRING)

    if (!this.screenToggle.val) then
    -- make sure output is to requests window
    !this.ifScreen()

--    CLOSEFILE $!fileToken
--    handle any
--      -- Even if no file in use
--    endhandle
      if (!mode eq 'Other') then
        QUERY CLAIMLIST OTHER
      elseif (!mode eq 'Extract') then
        QUERY CLAIMLIST EXTRACT
      elseif (!mode eq 'othersExtract') then
        QUERY CLAIMLIST EXTRACT OTHER
      elseif (!mode eq 'Clock') then
        CLOCK
      else
        QUERY CLAIMLIST
      endif
    else
    -- make sure output is not to requests window
--    !this.ifScreen()

    -- Filename must be set
    if (!this.filename.val.length() eq 0) then
      !!messageFile.warning(146,028)
      return
    endif

    if (!this.newFileToggle.val) then
	  	!fileTypeSele = 'WRITE'
	  elseif (!this.overwriteToggle.val) then
	  	!fileTypeSele = 'OVERWRITE'
	  else
	  	!fileTypeSele = 'APPEND'
	  endif

    !inputFile = !!file(!this.filename.val)
    !inputFile.open(!fileTypeSele)

    !this.appendToggle.val = true

      if (!mode eq 'Other') then
        var !claimlistOther SPLIT CLAIMLIST OTHER
        var !clock CLOCK
        !inputFile.writeRecord('-- Others Claimlist :- ( $!clock ) ')
        do !i indices !claimlistOther
          !inputFile.writeRecord('-- $!claimlistOther[$!i]')
        enddo
        !inputFile.writeRecord('--  ')
      elseif (!mode eq 'Active') then
        var !claimlist SPLIT CLAIMLIST
        var !clock CLOCK
        !inputFile.writeRecord('-- Active Claimlist :- ( $!clock ) ')
        do !i indices !claimlist
          !inputFile.writeRecord('-- $!claimlist[$!i]')
        enddo
        !inputFile.writeRecord('--  ')
      elseif (!mode eq 'Extract') then
        var !claimlist SPLIT CLAIMLIST EXTRACT
        var !clock CLOCK
        !inputFile.writeRecord('-- Extract Claimed :- ( $!clock ) ')
        do !i indices !claimlist
          !inputFile.writeRecord('-- $!claimlist[$!i]')
        enddo
        !inputFile.writeRecord('--  ')
      elseif (!mode eq 'othersExtract') then
        var !claimlist SPLIT CLAIMLIST EXTRACT OTHER
        var !clock CLOCK
        !inputFile.writeRecord('-- Others Extract Claim :- ( $!clock ) ')
        do !i indices !claimlist
          !inputFile.writeRecord('-- $!claimlist[$!i]')
        enddo
        !inputFile.writeRecord('--  ')
      else
        var !clock CLOCK
        !inputFile.writeRecord('-- $!clock' )
        !inputFile.writeRecord('--  ')
      endif
      !inputFile.close()

      -- Even if writing to file we still want to see
      -- the query result on the screen
      if (!!cadcReq.shown()) then
        !!cadcReq.cadcReq.setFocus()
        !!cadcReq.cadcReq.channel = 'RQUEST'
      else
        show !!cadcReq free
        !!cadcReq.cadcReq.clear()
        !!cadcReq.cadcReq.setFocus()
        !!cadcReq.cadcReq.channel = 'RQUEST'
      endif
      if (!mode eq 'Other') then
        QUERY CLAIMLIST OTHER
      elseif (!mode eq 'Extract') then
        QUERY CLAIMLIST EXTRACT
      elseif (!mode eq 'othersExtract') then
        QUERY CLAIMLIST EXTRACT OTHER
      elseif (!mode eq 'Clock') then
        CLOCK
      else
        QUERY CLAIMLIST
      endif
    endif

endmethod
-- End of method definition for .qClaimlist(STRING)

------------------------------------------------------------------------
--
-- Method:      getDate()
--
-- Description: Get the date of the stamped session for the current db
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    DATETIME    Date
--
---------------------------------------------------------------------------------
-- Define method
define method .getDate() is DATETIME

  -- Initialise variables
  !stamp = !this.stamp.selection()

  -- Get stamped session
  VAR !allStlst COLL ALL STLST FOR $!stamp
  do !stlst val !allStlst
    if (!stlst.dbRef().stlsf.badref().not()) then
      if (!stlst.dbRef().stlsf.name.eq('/*' & !this.dbName)) then
        !stampedSess = !stlst.dbRef().stsess
      endif
    endif
  enddo

  -- Get db session numbers
  !dbObj = object DB(!this.dbName)
  !sessions = !dbObj.sessions()
  !getNumb = object BLOCK('!sessions[!evalIndex].number')
  !sessNumb = !sessions.evaluate(!getNumb)

  -- Find stamped session object
  !sessObj = !sessions[!sessNumb.findFirst(!stampedSess)]

  -- Set session gadget to the stamped session number
  if (!this.sinceOption.eq('STAMP')) then
    !this.sessNum.val = !stampedSess
  else
    !this.extSessNum.val = !stampedSess
  endif

  -- Build dateTime object of stamped session date
  !dateTime = object DATETIME(!sessObj.date)

  return !dateTime

endmethod
-- End of method definition for .getDate()

------------------------------------------------------------------------
--
-- Method:      getDbName()
--
-- Description: Get the dbname for the current element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    STRING      Name of database or 'None' for ADMIN
--
---------------------------------------------------------------------------------

define method .getDbName() is STRING

  --current Database name
  if (!!module().appName.trim().upCase() neq 'ADMIN') then
    !dbName = !!ce.wdbName
  else
    !dbName = 'None'
  endif
  return !dbName

endmethod
-- End of method definition for .getDbName()

------------------------------------------------------------------------
--
-- Method:      highlight()
--
-- Description: Highlight elements that will be output
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .highlight()

  -- Highlight all changes if Highlight changes requested
  !coll = ARRAY()
  if (!this.highOutput.val and !this.highOutput.active) then
-- HIGHLIGHT OF EXTRACT DATA WITHDRAWN BECAUSE IT IS NOT POSSIBLE TO GET THE
-- LIST OF ITEMS TO OUTPUT WITHOUT NEW CORE FEATURES (array of references of all
-- elements to be output0
    -- Cannot highlight since extract changes except for Only
--     if (!this.sinceOption eq 'EXTR') then
--       if (!this.extSession.selection() eq 'Only') then
--         do !i indices !this.elements
--           !chColour = !this.hOutputColour
--           var !coll APPEND COLLECT ALL WITH (WDBNAME eq '$!this.dbName' and EXMOD EQ TRUE) FOR $!this.elements[$!i]
--         enddo
--         !coll.unique()
--         ENHANCE ALL FROM !coll COLOUR $!chColour
--         do !tubes indices !coll
--           ENHANCE IL TUBE OF $!coll[$!tubes] COLOUR $!chColour
--           handle any
--             -- it might not be a valid item for ILTUBE or tube could be 0 length
--           endhandle
--         enddo
--       else
--         -- Navigate back to original element
--         !!ce = !refe
--         !!alert.message(|Cannot highlight differences since 'Extract | + !this.extSession.selection() + |'|)
--         return
--       endif
--     endif
    do !i indices !this.elements
      !!ce = !this.elements[!i]
      var !sess SESSION ON $!this.time.val $!this.date.val
      var !dbNum DBNUMB
      var !coll APPEND COLLECT ALL WITH ((SESSMOD EQ 0 OR SESSMOD GT $!sess) AND DBNUM EQ $!dbNum) FOR $!this.elements[$!i]
    enddo
    !chColour = !this.hOutputColour
    !coll.unique()
    $!this.enhance ALL FROM !coll COLOUR $!chColour
    do !tubes indices !coll
      $!this.enhance IL TUBE OF $!coll[$!tubes] COLOUR $!chColour
      handle any
        -- it might not be a valid item for ILTUBE or tube could be 0 length
      endhandle
    enddo
  endif

endmethod
-- End of method definition for .highlight()

------------------------------------------------------------------------
--
-- Method:      highOutputMode()
--
-- Description: Set active state of highlight gadget
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .highOutputMode()

  -- if this is not Design or Marine Drafting, then no highlight possible
   if (!this.designModule.not() AND !this.mardraModule.not()) then
    !this.highOutput.val    = false
    !this.highOutput.active = false
    return
  endif

  -- if in db list mode, highlight is inactive
  -- if in extract mode, highlight is inactive
  -- In other modes highlight is permitted
  !this.highOutput.active = !this.controlMenu.selected('DB Listing').not() and !this.sinceOption neq 'EXTR'

endmethod
-- End of method definition for .highOutputMode()

------------------------------------------------------------------------
--
-- Method:      footerComment(STRING)
--
-- Description: Output footer comment
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .footerComment(!comment is STRING)

  WRITEALPHAFILE '-- Switch synonyms back on if an error occurs.'
  WRITEALPHAFILE 'LABEL /ERROR$!this.labelCounter'
  WRITEALPHAFILE 'handle ANY'
  WRITEALPHAFILE '$S+'
  WRITEALPHAFILE 'RETURN ERROR'
  WRITEALPHAFILE 'endhandle'
  WRITEALPHAFILE ''
  WRITEALPHAFILE '-- $!comment'
  WRITEALPHAFILE '$S+  -- Synonym translation ON '
  WRITEALPHAFILE '-- ----------------------------------------------------------------'
  WRITEALPHAFILE ''

endmethod
-- End of method definition for .footerComment(STRING)
------------------------------------------------------------------------
--
-- Method:      stampDate
--
-- Description: Populate the date/time gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .stampDate()

  -- Get selected time/date
  if (!this.stamp.selection().eq('NONE')) then
    return
  endif
  if (!this.stamp.selection().dbRef().STPDAT.eq('')) then
    -- Use the date of the stamped session for this db
    !dateTime = !this.getDate()
  else
    -- Use the stamp date
    !dateTime = object DATETIME(!this.stamp.selection().dbRef().STPDAT)
  endif

  -- Test minutes for leading zero
  if (!dateTime.minute().string().length().eq(1)) then
    !mins = '0' & !dateTime.minute().string()
  else
    !mins = !dateTime.minute().string()
  endif

  -- Set form gadgets
  if (!this.extractToggle.val) then
    !this.extTime.val = !dateTime.hour() & ':' & !mins
    !this.extDate.val = !dateTime.date() & ' ' & !dateTime.monthString().substring(1,3) & ' ' & !dateTime.year()
    !this.dateSession(!this.extTime, !this.extDate,'OPTION')
  else
    !this.time.val = !dateTime.hour() & ':' & !mins
    !this.date.val = !dateTime.date() & ' ' & !dateTime.monthString().substring(1,3) & ' ' & !dateTime.year()
    !this.dateSession(!this.time, !this.date,'OPTION')
  endif

endmethod
-- End of method definition for .stampDate()
------------------------------------------------------------------------
--
-- Method:      stampList
--
-- Description: Populate the stamp list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------------

define method .stampList()

  -- Only do this is the stamp option is chosen
  if (!this.sinceOption.eq('STAMP')) then

    -- Get the current db
    !currDb = object DB(!this.dbName)

    -- Get all stamps for this db
    !this.allStamp = !currDb.refNo.dbRef().stpDbs

    -- Populate stamp list
    !this.stampDisplayMode()

    -- Set date
    !this.stampDate()

  elseif (!this.sinceOption.eq('EXTR') and !this.extSession.selection().upCase().eq('STAMP')) then

   -- Get the current db
    !currDb = object DB(!this.extract.selection())

    -- Get all stamps for this db
    !this.allStamp = !currDb.refNo.dbRef().stpDbs

    -- Populate stamp list
    !this.stampDisplayMode()

    -- Set date
    !this.stampDate()

  endif

endmethod
-- End of method definition for .stampList()

------------------------------------------------------------------------
--
-- Method:      stampDisplayMode
--
-- Description: Populate the stamp list gadget
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .stampDisplayMode()

  -- Initialise variables
  !dText = ARRAY()
  !rText = ARRAY()

  -- For no found stamps
  if (!this.allStamp.empty()) then

    -- Populate stamp list
    !dText[1] = 'None'
    !rText[1] = 'NONE'
    !this.stamp.dText = !dText
    !this.stamp.rText = !rText

  else

    -- Populate stamp list
    do !stamp val !this.allStamp
      if (!this.stampMode.selection().upCase().eq('NAME')) then
        !dText.append(!stamp.flnm)
      elseif (!this.stampMode.selection().upCase().eq('DESCRIPTION')) then
        if (!stamp.desc.eq('')) then
          !dText.append('unset')
        else
          !dText.append(!stamp.desc)
        endif
      else
        if (!stamp.func.eq('')) then
          !dText.append('unset')
        else
          !dText.append(!stamp.func)
        endif
      endif
      !rText.append(!stamp.string())
    enddo

    -- Sort the output
    !sorted = !dText.sortedIndices()
    !dText.sort()
    !rText.reIndex(!sorted)

    -- Populate the stamp list
    !this.stamp.dText = !dText
    !this.stamp.rText = !rText

  endif

endmethod
-- End of method definition for .stampMode()

------------------------------------------------------------------------
--
-- Method:      setUseDate
--
-- Description: Store the date/time to be used
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Time gadget
--    2   R      GADGET      Date gadget
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setUseDate(!timeGadget is GADGET, !dateGadget is GADGET, !callType is STRING)

  -- If called by the time or date gadgets
  if (!callType.eq('GADGET')) then

    -- Check if the input date matches any of the listed stamps
    do !stamp val !this.allStamp
      if (!stamp.STPDAT.eq(!timeGadget.val & ' ' & !dateGadget.val)) then
        !this.stamp.select('RTEXT',!stamp.string())
        return
      endif
    enddo

    -- Check if the time/date gadgets have been modified whilst the Stamp option is active
    -- If so then switch to the time/date option
    if (!this.sinceOption.eq('STAMP')) then
      !this.timeToggle.val = true
      !this.sinceSelect()
    elseif (!this.sinceOption.eq('EXTR') and !this.extSession.selection().upCase().eq('STAMP')) then
      !this.extSession.select('DTEXT','Date')
      !this.extractChoice(false)
    endif

  endif

endmethod
-- End of method definition for .setUseDate(GADGET,GADGET)

--------------------------------------------------------------------------
--
-- Method:      fileBrowserLoad
--
-- Description: Load the PML FileBrowser to Save the location of the DB Output File
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------

define method .fileBrowserLoad()

	using namespace 'Aveva.Core.Presentation'

	!browser = object PMLFILEBROWSER('SAVE')

	-- Show Browser

	var !userEvar '%AVEVA_DESIGN_USER%'

	!browser.show(!userEvar, 'DBOutput.txt', 'DB Listing Output', false, 'txt files (*.txt)|*.txt', 2)

	!outFileName = !browser.file()

  if (!outFileName eq '') then
  		!this.filename.val = '%AVEVA_DESIGN_USER%\DBOutput.txt'
	else
			!this.filename.val = !outFileName
	endif

endmethod
-- End of method definition for .fileBrowserLoad()

------------------------------------------------------------------------
--
-- Method:      sortStamps
--
-- Description: Wrapper around !!admStampSort, handling an empty list of stamps
--
-- Method Type: Procedure
-- Arguments:
-- Return:
--
------------------------------------------------------------------------

define method .sortStamps()
  if( !this.allStamp.empty() ) then
    !dText[1] = 'None'
    !rText[1] = 'NONE'
    !this.stamp.dText = !dText
    !this.stamp.rText = !rText
  else
    !!admStampSort(!this.allStamp,!this.stampMode,!this.stamp)
  endif
endmethod
-- End of method definition for .sortStamps()
------------------------------------------------------------------------
--
-- Method:      pickElement
--
-- Description: picks the significant element when graphical pick is used
--
-- Method Type: Function/Procedure
-- Arguments:
--     [#] [R/RW] [Data Type] [Description]
--      1    R      DBREF       Picked element reference
-- Return:
--
------------------------------------------------------------------------
define method .pickElement(!picked is DBREF)

  !temp = !picked

  if(!!rptoutputopts.elements.val) then
     if(!this.projMarine) then
	   !text = 'UPANEL FNCCAR  FNCAAR SRFSUR CURWLD SPMSPC GRIDPL BRANCH SBFRAMEWORK SUBSTRUCTURE FRMWORK CWBRAN SUBEQUIPMENT EQUIPMENT CABLE SUPPORT'
	   !this.setSignificantElement(!picked,!text)
     else
	   !text = 'GRIDPL BRANCH SBFRAMEWORK SUBSTRUCTURE FRMWORK CWBRAN SUBEQUIPMENT EQUIPMENT CABLE SUPPORT'
	   !this.setSignificantElement(!picked,!text)
     endif

     if(!this.elementFlag neq true) then
       !picked = !temp
     endif

  elseif(!!rptoutputopts.specific.val and !!rptOutputOpts.onlyElements.split().size() gt 0) then
	 !this.setSignificantElement(!picked,!!rptOutputOpts.onlyElements)

	 if(!this.elementFlag neq true) then
       !!alert.error('The picked element did not match any of the specified elements! Check using Control >Output >Options >Specific Types > Define.. ')
	   !this.specificFlag = true
       return
     endif

  else
	 !!alert.error(|'Specific Types' option chosen but none defined! Define using Control >Output >Options >Define... to use graphical pick|)
	 !this.specificFlag = true
	 return
  endif

endmethod

-- End of method definition for .pickElement()
------------------------------------------------------------------------
--
-- Method:      setSignificantElement
--
-- Description: Sets the significant element to be picked on using graphical pick
--
-- Method Type: Function/Procedure
-- Arguments:
--     [#] [R/RW] [Data Type] [Description]
--      1    R      DBREF       Picked element reference
--      2    R      STRING      Significant elements types
-- Return:
--
------------------------------------------------------------------------
define method .setSignificantElement(!picked is DBREF, !text is string)

  !types = !text.split()

  do !n to 100
	if(!picked.unset()) then
	  break
    else
	  do !indx indices !types
	    var !nameString NOUNDEF $!picked.type NAME
	    if(!nameString[1] eq !types[!indx]) then
		   !this.elementFlag = true
           break
        endif
      enddo

	  if(!this.elementFlag) then
	    return
      else
	    !picked = !picked.owner
      endif

    endif
   enddo

   endmethod
-- End of method definition for .setSignificantElement(!picked is DBREF, !text is string)

------------------------------------------------------------------------
