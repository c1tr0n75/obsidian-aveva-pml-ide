--
-- Description: Test only to see how long collections of days take
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R      STRING    Option (all, allExisting or userExisting)
--
------------------------------------------------------------------------

define method .testDays(!option is STRING)

  clock init
  --!dates = !this.object.collectFromDates(!this.object.afterDateFilter, !this.object.beforeDateFilter, !option)
  clock read
  --This took 0.651 seconds elapsed time for 400 days collected
   -- q var !dates

endmethod
-- End of method definition for .testDays()
------------------------------------------------------------------------
--
-- Method:      clearFlag
--
-- Description: Clear the flag of the selected transactions
--
------------------------------------------------------------------------

define method .clearFlag()

  -- For each selected command on the owning set the flag via the transaction object of the owning form
  !unusedPasses = !this.object.setFlag(!this.transactions.selection('rtext'), !this.transactions.val, '' )

  -- Remember the page number
  !pageNumber = !!glbTransactions.pageGadget.val

  -- Update the Transactions
  !!glbTransactions.updateTransactions()

  -- We need to find the page again
  !!glbTransactions.goPage(!pageNumber)

endmethod
-- End of method definition for .clearFlag()
------------------------------------------------------------------------
--
-- Method:      getCommand
--
-- Description: Move up and down the commands
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R      STRING    Option (previous, next or current)
--
------------------------------------------------------------------------

define method .getCommand(!option is STRING)

  -- What is selected at the moment
  !index = !this.transactions.val.size()
  if (!index gt 0) then
    !picked = !this.transactions.val
    !pickedField = !picked[!index]
  endif

  if (!option.lowcase() eq 'previous') then
    if (!pickedField gt 1) then
      !this.transactions.clearSelection()
      !this.transactions.select('rtext', !this.transactions.rtext[!pickedField - 1])
    endif
  elseif (!option.lowcase() eq 'next') then
    if (!pickedField lt (!this.transactions.rtext.size())) then
      !this.transactions.clearSelection()
      !this.transactions.select('rtext', !this.transactions.rtext[!pickedField + 1])
    endif
  endif

  -- Update the Navigation if necessary
  !this.navigate()

  --Update the messages form if it's shown
  !this.updateMessages(!this.transactions, 'SELECT')

  --Update the gadgets
  !this.activeButtons()

endmethod
-- End of method definition for .getCommand()
------------------------------------------------------------------------
--
-- Method:      activeButtons
--
-- Description: Activate the next and previous command buttons accordingly
--
------------------------------------------------------------------------

define method .activeButtons()

   -- What is selected at the moment
  !index = !this.transactions.val.size()
  if (!index gt 0) then
    !picked = !this.transactions.val
    !pickedField = !picked[!index]
  else
    !this.backCommand.active = false
    !this.forwardCommand.active = false
    return
  endif

  -- Activate the back and forward buttons as required
  -- First command
  if (!pickedField eq 1) then
    !this.backCommand.active = false
  else
    !this.backCommand.active = true
  endif

  -- Last command
  if (!pickedField lt !this.transactions.rtext.size()) then
    !this.forwardCommand.active = true
  else
    !this.forwardCommand.active = false
  endif

endmethod
-- End of method definition for .activeButtons()
------------------------------------------------------------------------
--
-- Method:      setUserActiveMenus
--
-- Description: Activate command deletion etcetera only if a general user is himself
--
------------------------------------------------------------------------

define method .setUserActiveMenus()

  if (!this.userType.upcase() eq 'GENERAL' or !this.module neq 'ADMIN') then
    !session = current session
    if (!this.setUserFilter.selection('dtext') eq !session.user().name) then
      !this.messageSelect.setActive('Flag...', true)
      !this.messageSelect.setActive('Clear Flag', true)
      !this.messageSelect.setActive('Delete Selected', true)
      !this.messageSelect.setActive('Cancel Selected Commands', true)
    else
      !this.messageSelect.setActive('Flag...', false)
      !this.messageSelect.setActive('Clear Flag', false)
      !this.messageSelect.setActive('Delete Selected', false)
      !this.messageSelect.setActive('Cancel Selected Commands', false)
    endif
  else
    !this.messageSelect.setActive('Flag...', true)
    !this.messageSelect.setActive('Clear Flag', true)
    !this.messageSelect.setActive('Delete Selected', true)
    !this.messageSelect.setActive('Cancel Selected Commands', true)
  endif

endmethod
-- End of method definition for .setActiveUser()
------------------------------------------------------------------------
--
-- Method:      setActiveUser
--
-- Description: Create command deletion menus
--
------------------------------------------------------------------------

define method .setActiveUser()

  -- Pop up menus
  !menu = !this.messageSelect
    !menu.clear()
    !menu.add('callback', 'Transaction Messages...', 'show !!glbTransactionMessages at xr1 yr1')
    if (!this.module eq 'ADMIN') then
      -- Intended - Needs to run on two lines so APPSPAG errors can be ignored.
      --    This should probably be in a function.
      !menu.add('callback', 'Transaction Details...',  'show !!cadcReq
!this.showAttributes()')
    endif
    !session = current session
    if (!this.module eq 'ADMIN') then
      !menu.add('separator')
      !menu.add('callback', 'Flag...',  'show !!glbTransactionFlag')
      !menu.add('callback', 'Clear Flag',  '!this.clearFlag()')
      !menu.add('separator')
      !menu.add('callback', 'Delete Selected',  '!this.deleteTransactions()')
      !menu.add('callback', 'Cancel Selected Commands',  '!this.cancelTransactions()')
      !menu.add('toggle', 'Navigate on Selection',  '')
    elseif (!this.module neq 'ADMIN') then
        !menu.add('separator')
        !menu.add('callback', 'Flag...',  'show !!glbTransactionFlag')
        !menu.add('callback', 'Clear Flag',  '!this.clearFlag()')
        !menu.add('separator')
        !menu.add('callback', 'Delete Selected',  '!this.deleteTransactions()')
        !menu.add('callback', 'Cancel Selected Commands',  '!this.cancelTransactions()')
    endif
    !menu.add('separator')
    !menu.add('callback', 'Update', '!this.updateTransactions()')
    !menu.add('callback', 'Select All', '!this.selectAllTransactions()')
    !menu.add('callback', 'Clear Selection', '!this.clearSelection()')
  !this.transactions.setPopup(!this.messageSelect)

endmethod
-- End of method definition for .setActiveUser()
------------------------------------------------------------------------
--
-- Method:      getWork
--
-- Description: Get work from the transaction DB only
--
------------------------------------------------------------------------
define method .getWork()

   !session = current session
   !module = !!module().appName
   if (!module.upcase() eq 'ADMIN') then
     GETWORK
     --226444 adding the handle for (41,243) to show as a warning not as an error -Nithin Anchuri
     handle (41,243)
      !!alert.warning('Your current element has been deleted, moving you back to the WORLD')
      endhandle
   else
     !location = CURLOC
     !locationId = !location.locId
     !command = 'GETWORK TRANSACTION/' & !locationId
     call !!admCommand(!command)
     handle ANY
       !!alert.error('Unable to getwork for TRANSACTION/' & !locationId)
     endhandle
   endif

endmethod
-- End of method definition for .getWork()
------------------------------------------------------------------------
--
-- Method:      .purgeTransaction()
--
-- Description: Purge the Transaction DB.
--
-- Function Type:   Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--    STRING      Returned string
--
------------------------------------------------------------------------
-- Define method
define method .purgeTransaction()

  !days = !this.purgeDays.val.real()
  !purgeOption = !this.purgeOptions.selection()


  -- Confirm that they want to do this
  !answer = !!alert.confirm('Purging Transactions takes time to execute. Do you want to continue?')
  if (!answer.boolean().not() ) then
      return
  endif

  !answer = !!alert.confirm('The local daemon must be shut down before you can continue with the purge/merge operation. Do you wish to continue?')
  if( !answer.boolean().not() ) then
      return false
  endif


  -- deleting TRINCO elements and the hierarchical elements
  !!glbPurgeTransaction(!days,!purgeOption)

  -- update the transactions page with the new data
  !this.updateTransactions()

endmethod
-- End of method definition for .purgeTransaction()
--------------------------------------------------------------------------
-- Method:      .mergeTransaction()
--
-- Description: Merge the Transaction DB.
--
-- Function Type:   Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--    STRING      Returned string
--
------------------------------------------------------------------------
-- Define method
define method .mergeTransaction()
  !curLoc = !this.object.collectLocations('current', 'rtext')[1]
  !command = 'MERGE CHANGES TRANSACTION/' & !curLoc
  call !!admCommand(!command)

endmethod
-- End of method definition for .mergeTransaction()
------------------------------------------------------------------------
--
-- Method:      .checkDays
--
-- Description: To check entered the days is valid.
--
-- Function Type:   Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--    STRING      Returned string
--
------------------------------------------------------------------------
define method .checkDays()

  if (!this.purgeDays.val.eq('')) then
    !this.purgeTransDb.active = false
    !this.mergeTransDb.active = false
    !!alert.error('Enter number of days to be purged')
    !this.purgeDays.val = STRING(30)
    !this.purgeDays.setFocus()
  else
    !this.purgeTransDb.active = true
  endif

endmethod
-- End of method definition for .checkDays()
------------------------------------------------------------------------
