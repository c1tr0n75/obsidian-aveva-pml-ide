define method .updateTime()

  !dText[1]               = 'Second'
  !dText[2]               = 'Minute'
  !dText[3]               = 'Hour'
  !dText[4]               = 'None'
  !rText[1]               = 'SECOND'
  !rText[2]               = 'MINUTE'
  !rText[3]               = 'HOUR'
  !rText[4]               = ''

  if( !this.timeList.rText.empty() ) then
    -- initialise the list
    !this.timeList.dText  = !dText
    !this.timeList.rText  = !rText
  endif

  !timeSelection          = !this.timeList.selection()
  !index                  = !this.timeList.val
  !index                  = !this.validateIndex(!index, !rText, 'TIME')

  !dText[!index]          = '> ' + !dText[!index] + ' <'
  !this.timeList.dText    = !dText
  !this.timeList.rText    = !rText
  !this.timeList.val      = !index

  -- reset local force format
  !!tryTimeFmt            = !!comFormats.timeFormat(!timeSelection.upcase())
  if(!timeSelection.empty()) then
    !!tryTimeFmt.units    = 'SECOND'
    !!tryTimeFmt.label    = ''
  else
    !!tryTimeFmt.units    = !timeSelection
  endif

  !this.timeExample.val   = 1 hour
  !this.timeExample.setFocus()

