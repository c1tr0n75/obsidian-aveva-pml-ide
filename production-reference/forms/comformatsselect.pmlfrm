------------------------------------------------------------------------

define method .saveCurrentUnits()

  -- save the current units to file
  !!comFormats.saveCurrentUnits()

endmethod
-- End of method definition for .saveCurrentUnits()
------------------------------------------------------------------------
--
-- Method:     restoreSavedUnits()
--
-- Description: restore the units from AVEVA_DESIGN_USER or AVEVA_DESIGN_DFLTS
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING      Key word AVEVA_DESIGN_USER or AVEVA_DESIGN_DFLTS
--    2    R     BOOLEAN     Output a warning message
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .restoreSavedUnits(!location is STRING, !warn is BOOLEAN)

  -- Clear out the last Distance Tokens
  !this.lastDistanceToken = ''
  !this.lastBoreToken = ''

  -- Restore the units from file
  !!comFormats.restoreSavedUnits(!location, !warn)

  -- Refresh the form
  !this.init()

endmethod
-- End of method definition for .restoreSavedUnits()
------------------------------------------------------------------------
--
-- Method:     selectDimension()
--
-- Description: Select dimension from list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .selectDimension()

  !dimensionIndex = !this.dimension.val
  !this.attribute(!this.dimensionFrame[!this.currentDimensionFrame]).visible = false
  !this.attribute(!this.dimensionFrame[!dimensionIndex]).visible             = true
  !this.currentDimensionFrame = !dimensionIndex

  -- update dimension list in case it was changed outside of this form
  !this.updateDimension()

  if( !this.distFrame.visible ) then
    !this.updateDistance(false)
  elseif( !this.boreFrame.visible ) then
    !this.updateBore(false)
  elseif( !this.anglFrame.visible ) then
    -- reset to current settings
    !this.angleList.clear()
    !this.updateAngle()
  elseif( !this.massFrame.visible ) then
    -- reset to current settings
    !this.massList.clear()
    !this.updateMass()
  elseif( !this.presFrame.visible ) then
    -- reset to current settings
    !this.presList.clear()
    !this.updatePressure()
  elseif( !this.tempFrame.visible ) then
    -- reset to current settings
    !this.tempList.clear()
    !this.updateTemperature()
  elseif( !this.poweFrame.visible ) then
    -- reset to current settings
    !this.poweList.clear()
    !this.updatePower()
  elseif( !this.forcFrame.visible ) then
    -- reset to current settings
    !this.forcList.clear()
    !this.updateForce()
  elseif( !this.enerFrame.visible ) then
    -- reset to current settings
    !this.enerList.clear()
    !this.updateEnergy()
  elseif( !this.timeFrame.visible ) then
    -- reset to current settings
    !this.timeList.clear()
    !this.updateTime()
  elseif( !this.currFrame.visible ) then
    -- reset to current settings
    !this.currList.clear()
    !this.updateCurrent()
  elseif( !this.emfFrame.visible ) then
    -- reset to current settings
    !this.emfList.clear()
    !this.updateEMF()
  elseif( !this.impeFrame.visible ) then
    -- reset to current settings
    !this.impeList.clear()
    !this.updateImpedance()
  else
  endif

endmethod
-- End of method definition

------------------------------------------------------------------------
--
-- Method:     updateList()
--
-- Description: Update gadget for given dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .updateList(!list is GADGET, !pType is STRING)

  !dimension             = object MEASURE(!pType)
  !unitsOfDimension      = !dimension.unitsOf()
  !dText                 = ARRAY()
  !rText                 = ARRAY()
  do !i indices !unitsOfDimension
    !dText.append(!unitsOfDimension[!i].description())
    !unitQualifier       = !unitsOfDimension[!i].unitQualifier().upcase()
    !rText.append(!unitQualifier)
    -- special cases
    if( !unitQualifier eq 'PASCAL' ) then
      !dText.append('kiloPascal')
      !rText.append('KILOPASCAL')
      !dText.append('megaPascal')
      !rText.append('MEGAPASCAL')
    elseif( !unitQualifier eq 'CALORIE' ) then
      !dText.append('kiloCalorie')
      !rText.append('KILOCALORIE')
    elseif( !unitQualifier eq 'NEWTON' ) then
      !dText.append('kiloNewton')
      !rText.append('KILONEWTON')
    endif
  enddo
  !dText.append('None')
  !rText.append('')

  !index = !list.val

  if( !list.rText.empty() ) then
    -- initialise the list
    !list.dText          = !dText
    !list.rText          = !rText
  endif

  !index = !this.validateIndex(!index, !rText, !pType)

  !list.val              = !index

  !row                   = !list.val
  !dText[!row]           = '> ' + !dText[!row] + ' <'
  !list.dText            = !dText
  !list.rText            = !rText
  !list.val              = !row

endmethod
-- End of method definition

------------------------------------------------------------------------
--
-- Method:     validateIndex()
--
-- Description: Checks the index's value is valid and corrects it if not.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        The current index
--    2   R      ARRAY       List of rText for the unit
--    3   R      STRING      The unit's pType
-- Return:
--   [Data Type] [Description]
--    REAL        Valid index
--
------------------------------------------------------------------------
define method .validateIndex(!index is REAL, !rText is ARRAY, !pType is STRING) is REAL

  if( !index eq 0 OR !index.unset()) then
    if(!pType eq 'ANGLE') then
      !unit = !!angleFmt.units.upcase()
    else
      !unit = !!comFormats.getCurrentUnitsByPtype(!pType).upcase()
    endif
    !index = !rText.findFirst(!unit)
    if( !index.unset() ) then
      !index = 1
    endif
  endif

  return !index

endmethod
-- End of method definition

------------------------------------------------------------------------
--
-- Method:     changeDimension()
--
-- Description: Set unit for given dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .changeDimension(!unitString is STRING, !dimensionString is STRING)

  !dimension = object MEASURE(!dimensionString)
  if( !unitString.empty() ) then
    UNITS NUMERIC $!dimension
  else
    !unit      = object UNIT(!unitString)
    !dimension.setUnits(!unit)
  endif

endmethod
-- End of method definition
-----------------------------------------------------------------------
--
-- Method:     getAllowedUnits()
--
-- Description: Get dtext array as comma separated string
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R      GADGET     The dimension list to get units from
-- Return:
--   [Data Type] [Description]
--    STRING      List of units separated with commas
--
------------------------------------------------------------------------

define method .getAllowedUnits(!dimension is GADGET) is STRING

  !unitList = ''

  do !unit values !dimension.dtext
    !unitList = !unitList + !unit + ','
  enddo

  return !unitList

endmethod
-- End of method definition
-----------------------------------------------------------------------
--
-- Method:     getDefaultUnitIndex()
--
-- Description: Gets the index of the current saved unit for the dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Dimension list
--    2   R      STRING      Ptype of the dimension
-- Return:
--   [Data Type] [Description]
--    REAL        Index of the default dimension unit
--
------------------------------------------------------------------------

define method .getDefaultUnitIndex(!list is GADGET, !pType is STRING) is REAL

  !unit                = !!comFormats.getCurrentUnitsByPtype(!pType).upcase()

  -- Time is a special case where the rText for Minute does not match the value in the common units object
  if (!pType eq 'TIME') then
    !timeUnits = !list.rtext
    !timeUnits[2] = 'MIN'
    !index               = !timeUnits.findFirst(!unit)
  else
    !index               = !list.rText.findFirst(!unit)
  endif

  if( !index.unset() ) then
    !index = 1
  endif

  return !index

endmethod
-- End of method definition
