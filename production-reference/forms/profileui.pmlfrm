----------------------------------------------------------------------
--
-- Copyright 1974 to current year. AVEVA Solutions Limited and its subsidiaries. All rights reserved in original code only.
--
--    Type:          Form Definition
-- File:            profileui.pmlfrm
--   Group:         all
--     Keyword:     Stairs
--   Module:        DESIGN
-- Author:          Martin Eich
--  Created:        Tue Feb 07 09:00:00 2007
--
--
-- Description:    Profile definition form
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  accept()                         -                   run the callback and close the form
--  acceptReorder()                  -                   run the callback for reorder
--  alignDirection(GADGET,STRING)    -                   align xDir or yDir with the picked line
--  alignDirectionReturn(GADGET,EDGPOSITIONDATA) -                   repositions intermediate landing
--  calculateProfile()               -                   calculate the profile from the given vertices and radius
--  calculateVertices()              -                   calculate the vertices from the given profile
--  clearFeedback()                  -                   draw the profile
--  closeForm()                      -
--  coordinateSettings()             -                   Set the value of position gadgets with current coordinate system
--  create()                         -                   switches the form appearance in the create mode
--  deleteGroup()                    -                   delete all vertices of the group
--  deleteVertex()                   -                   delete the current vertex
--  discard()                        -                   run the discard callback and close the form
--  displayEdge()                    -                   update the gadgets for the current vertex
--  displayEdges()                   -                   display all edges
--  displayGroup()                   -                   display all vertices of the group
--  displayGroupVertices()           -
--  displayVertex()                  -                   update the gadgets for the current vertex
--  displayVertices()                -                   display all vertices
--  draw()                           -                   draw the profile
--  drawAxes()                       -                   draw the axes system
--  drawProfile()                    -                   draw the profile
--  edgShapePick()                   -                   start edg for shape pick
--  expandProfile(GADGET,STRING)     -
--  frameTabset(GADGET,STRING)       -                   make the tabset frames visible/invisible
--  insertVertex()                   -                   pick position of new vertex
--  insertVertexReturn(EDGPOSITIONDATA) -                   position of new vertex
--  mergeProfile()                   -                   merge profile
--  mergeProfileReturn(EDGPICKDATA)  -                   merge profile
--  mirrorGroup()                    -                   mirror group
--  mirrorGroupReturn(EDGPICKDATA)   -                   repositions vertex
--  mirrorProfile()                  -                   mirror profile
--  mirrorProfileReturn(EDGPICKDATA) -                   mirrors profile
--  mirrorVertex()                   -                   mirror position of vertex
--  mirrorVertexReturn(EDGPICKDATA)  -                   repositions vertex
--  modify()                         -                   switches the form appearance in the modify mode
--  modifyExplicitAttributes()       -                   callback of frame "Explicit Attributes"
--  modifyExplicitOrientation(GADGET,STRING) -                   select main shape like octagon
--  modifyGraphicalAttributes()      -                   callback of frame "Graphical Attributes"
--  modifyNumberOfEdges()            -                   callback from numeric input gadget
--  modifyOption(GADGET,STRING)      -                   callback from toggle/linklabel
--  modifyProfileAttributes()        -                   modify the attributes of the profile
--  modifyProfileAttributes(GADGET,STRING) -                   gadget callback, must set the undo marker
--  modifyVertexAttributes()         -                   modify the attributes of the current vertex
--  modifyVertexAttributes(GADGET,STRING) -                   modify the attributes of the current vertex
--  moveGroup(GADGET,STRING)         -                   move group in x or y direction
--  moveStart(GADGET,STRING)         -                   move start point one forward or backward
--  pickExplicitPosition()           -                   select main shape like octagon
--  pickExplicitPositionReturn(EDGPOSITIONDATA) -                   repositions intermediate landing
--  pickShapeReturn(EDGPOSITIONDATA) -                   return of the shape pick
--  profileUI()                      -                   Constructor
--  redo()                           -                   redo the last step
--  repickProfile()                  -                   repick position of the profile
--  repickProfileReturn(EDGPOSITIONDATA) -                   repositions intermediate landing
--  repickVertex()                   -                   pick position of vertex
--  repickVertexReturn(EDGPOSITIONDATA) -                   repositions vertex
--  reverseProfile()                 -                   reverse definition of the vertices
--  rotateProfile(GADGET,STRING)     -                   rotate profile
--  selectDefinitionOption(GADGET,STRING) -                   select explicit or graphical option
--  selectMainShape(GADGET,STRING)   -                   select main shape like octagon
--  setUndoMarker()                  -                   set undo marker
--  setup()                          -                   init callback
--  splitProfile()                   -                   split profile on line
--  splitProfileReturn(EDGPICKDATA)  -                   repositions vertex
--  toggleOptions()                  -                   toggle between the polyhedron options
--  undo()                           -                   undo the last step
--  updateBottomGadgets(BOOLEAN)     -                   Updating the status of bottom gadgets.
--  updateEdgeGadgets()              -                   update the edge gadgets
--  updateExplicitGadgets()          -                   update the gadgets depending on the object
--  updateGraphicalGadgets()         -                   update the graphical gadgets depending on the picks
--  updateGroupGadgets()             -                   update the group gadgets
--  updateProfileFrame()             -                   update the profile frame
--  updateProfileGadgets()           -                   update the profile gadgets
--  updateVertexGadgets()            -                   update the profile gadgets
--  useVertexAsOrigin()              -                   use vertex point as origin of the profile
--

setup form !!profileUI dialog dock

  path down vdist 0.1

  -- main shapes
  ---------------------------------------------------------------------------
  frame .frMainShapes PANEL at x0 y0 anchor T+L+R
    para   .paMainShapes                                          text 'Define main shapes'
    line   .lnMainShapes                   at xmin                ymax-.2 anchor T+L+R HORIZ width 30

    para   .paDefineSquare                 at x2                  pixmap                                                              width 16 height 16
    button .lkDefineSquare       linklabel at x5                  ymin   'Square shape'             callback '!this.selectMainShape(' width 16
    para   .paDefineRectangular            at xmin.paDefineSquare pixmap                                                              width 16 height 16
    button .lkDefineRectangular  linklabel at xmin.lkDefineSquare ymin   'Rectangular shape'        callback '!this.selectMainShape(' width 16
    para   .paDefineCircular               at xmin.paDefineSquare pixmap                                                              width 16 height 16
    button .lkDefineCircular     linklabel at xmin.lkDefineSquare ymin   'Circular shape'           callback '!this.selectMainShape(' width 16
    para   .paDefinePolyhedron             at xmin.paDefineSquare pixmap                                                              width 16 height 16
    button .lkDefinePolyhedron   linklabel at xmin.lkDefineSquare ymin   'Polyhedron shape'         callback '!this.selectMainShape(' width 16
    para   .paDefinePolygon                at xmin.paDefineSquare pixmap                                                              width 16 height 16
    button .lkDefinePolygon      linklabel at xmin.lkDefineSquare ymin   'Polygon shape'            callback '!this.selectMainShape(' width 16
  exit

  -- create panel
  ---------------------------------------------------------------------------
  frame .frDefineShape PANEL at x0 y0 anchor T+L+R

    frame .frDefinitionOptions PANEL at x0 y0 anchor T+L+R
      button .toGraphicalInteraction toggle    at xmin.paDefineSquare pixmap                          callback '!this.selectDefinitionOption(' width 16 height 16
      button .lkGraphicalInteraction linklabel at xmin.lkDefineSquare ymin   'Graphical interaction'  callback '!this.selectDefinitionOption(' width 16
      button .toExplicitDefinition   toggle    at xmin.paDefineSquare pixmap                          callback '!this.selectDefinitionOption(' width 16 height 16
      button .lkExplicitDefinition   linklabel at xmin.lkDefineSquare ymin   'Explicit attributes'    callback '!this.selectDefinitionOption(' width 16
    exit

    frame .frShapeDefinitions PANEL anchor T+L+R

      -- graphical definition
      ---------------------------------------------------------------------------
      frame .frGraphicalDefinition PANEL at xmin.frShapeDefinitions ymin.frShapeDefinitions anchor T+L+R
        para   .paGraphicalDefinition                         text 'Graphical definition' width 20
        line   .lnGraphicalDefinition  at xmin                ymax-.2 anchor T+L+R HORIZ  width 28

        para   .paRepick            at xmin.toExplicitDefinition                                                                             pixmap width 16 height 16
        button .lkRepick  linklabel at xmin.lkExplicitDefinition  ymin 'Repick shape positions' callback '!this.modifyGraphicalAttributes()'        width 15

        vdist .2
        numeric .nuEdges   at x2 'Number of edges'    tagwidth 12                               callback '!this.modifyNumberOfEdges()' anchor T+L+R width 6
        do !i to 5
          button .toAvailOptions$!i  toggle    at xmin.toExplicitDefinition          pixmap     callback '!this.modifyOption('                      width 16 height 16
          vdist .1
          button .lkAvailOptions$!i  linklabel at xmin.lkExplicitDefinition ymin    ''          callback '!this.modifyOption('                      width 15
        enddo
        numeric .nuOptions at x2 'Select corner'      tagwidth 12                               callback '!this.toggleOptions()'       anchor T+L+R width 6
      exit

      -- explicit definition
      ---------------------------------------------------------------------------
      frame .frExplicitDefinition  PANEL at xmin.frShapeDefinitions ymin.frShapeDefinitions anchor T+L+R
        para   .paExplicitDefinition                         text 'Explicit definition' width 20
        line   .lnExplicitDefinition  at xmin                ymax-.2 anchor T+L+R HORIZ width 28

        frame .frExplicitAttribute  PANEL at x2 anchor T+L+R
          para   .paExplicitAttribute                          text 'Attributes'
          line   .lnExplicitAttribute   at xmin                ymax-.2 anchor T+L+R HORIZ width 26

          numeric .nuAttribute1 at x2 tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8
          numeric .nuAttribute2       tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8
          numeric .nuAttribute3       tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8
          numeric .nuAttribute4       tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8
        exit

        frame .frExplicitPosition  PANEL 'Origin' anchor T+L+R
          para   .paExplicitPosition                          text 'Origin'
          line   .lnExplicitPosition   at xmin                ymax-.2 anchor T+L+R HORIZ width.lnExplicitAttribute

          option .opReferencePoint 'Position' at x2 tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 5
          button .buPickPosition   pixmap     at xmax ymin      callback '!this.pickExplicitPosition()'     anchor T+R   width 16 height 16
          text   .txEast           ''   at x2 tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8 is REAL format !!distanceFmt
          text   .txNorth          ''          tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8 is REAL format !!distanceFmt
          text   .txUp             ''       tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8 is REAL format !!distanceFmt
          text   .txWrtPos         'wrt'            tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8 is STRING
        exit

        frame .frExplicitOrientation PANEL 'Orientation' anchor T+L+R
          para   .paExplicitOrientation                          text 'Orientation'
          line   .lnExplicitOrientation  at xmin   ymax-.2 anchor T+L+R HORIZ width.lnExplicitAttribute
          text   .txXDir      'X is'     at x2         tagwidth 12 callback '!this.modifyExplicitOrientation(' anchor T+L+R width 8  is STRING
          path right
          button .buXDirAlign pixmap                               callback '!this.alignDirection('            anchor T+R   width 16 height 16
          text   .txYDir      'Y is'     at x2 ymax+.2 tagwidth 12 callback '!this.modifyExplicitOrientation(' anchor T+L+R width 8  is STRING
          button .buYDirAlign pixmap                               callback '!this.alignDirection('            anchor T+R   width 16 height 16
          text   .txWrtOri    'wrt'      at x2 ymax+.2 tagwidth 12 callback '!this.modifyExplicitAttributes()' anchor T+L+R width 8  is STRING
          path down
        exit
      exit
    exit
  exit

  -- modify panel
  ---------------------------------------------------------------------------
  frame .frModifyShape PANEL at xmin.frDefineShape ymin.frDefineShape anchor T+L+R
    para   .paUndo                                            pixmap width 16 height 16
    path right
    button .lkUndo  linklabel  'Undo' callback '!this.undo()'        width 6
    para   .paRedo                                            pixmap width 16 height 16
    button .lkRedo  linklabel  'Redo' callback '!this.redo()'        width 6
    path down

    frame .frModifyShapeTabset TABSET at xmin.paUndo ymax+.1 anchor T+L+R width 30
      frame .frProfile 'Profile' anchor T+L+R
        para    .paProfileAttributes       at                                text 'Attributes'
        line    .lnProfileAttributes       at xmin                   ymax-.2 anchor T+L+R HORIZ width 24
        para    .paProfilePosition         at x2                             text 'Position'
        line    .lnProfilePosition         at xmin                   ymax-.2 anchor T+L+R HORIZ width 22
        text    .teProfilePositionEast    at x4                      ymax+.2 tagwidth 10 '' callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt
        text    .teProfilePositionNorth     at xmin                  ymax    tagwidth 10 '' callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt
        text    .teProfilePositionUp       at xmin                   ymax    tagwidth 10 '' callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt
        text    .teProfilePositionWRT      at xmin                   ymax    tagwidth 10 'WRT'   callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is STRING
        button  .lkProfileRepick linklabel at xmin                   ymax+.2   'Repick position' callback '!this.repickProfile()'            width 16

        para    .paProfileOrientation      at xmin.paProfilePosition ymax+.2 text 'Orientation'
        line    .lnProfileOrientation      at xmin                   ymax-.2 anchor T+L+R HORIZ width.lnProfilePosition
        text    .teProfileOrientationY     at x4                     ymax+.2 tagwidth 10 'Y is ' callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is STRING
        text    .teProfileOrientationZ     at xmin                   ymax    tagwidth 10 'Z is ' callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is STRING
        text    .teProfileOrientationWRT   at xmin                   ymax    tagwidth 10 'WRT'   callback '!this.modifyProfileAttributes(' anchor T+L+R width 6 is STRING

        para    .paProfileTasks            at xmin.paProfileAttributes ymax+.2 text 'Tasks'
        line    .lnProfileTasks            at xmin                     ymax-.2 anchor T+L+R HORIZ width 24
        para    .paProfileMirror           at x2                       ymax    pixmap                                                                 width 16 height 16
        button  .lkProfileMirror linklabel at x5                       ymin   'Mirror on line'            callback '!this.mirrorProfile()'            width 16
        para    .paProfileSplit            at x2                       ymax    pixmap                                                                 width 16 height 16
        button  .lkProfileSplit  linklabel at x5                       ymin   'Split on line'             callback '!this.splitProfile()'             width 16
        para    .paProfileMerge            at x2                       ymax    pixmap                                                                 width 16 height 16
        button  .lkProfileMerge  linklabel at x5                       ymin   'Merge with profile'        callback '!this.mergeProfile()'             width 16
        para    .paProfileRotate           at x2                       ymax    pixmap                                                                 width 16 height 16
        text    .teProfileRotate           at x5                       ymin   'Rotate clockwise by'       callback '!this.rotateProfile(' tagwidth 14 width 4 is REAL format !!distanceFmt
        para    .paProfileExpand           at x2                       ymax    pixmap                                                                 width 16 height 16
        text    .teProfileExpand           at x5                       ymin   'Expand by'                 callback '!this.expandProfile(' tagwidth 14 width 4 is REAL format !!distanceFmt
      exit

      frame .frVertices 'Vertices' at xmin.frProfile ymin.frProfile anchor T+L+R
        numeric .nuVertex                 'Vertex'                           callback '!this.displayVertex()' width 3

        para    .paVertexAttributes        at xmin.nuVertex                   text 'Attributes'
        line    .lnVertexAttributes        at xmin                    ymax-.2 anchor T+L+R HORIZ width 24
        text    .teVertexXPos              at x2                      ymax+.2 tagwidth 10 'X Position' callback '!this.modifyVertexAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt
        text    .teVertexYPos              at xmin                    ymax    tagwidth 10 'Y Position' callback '!this.modifyVertexAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt
        text    .teVertexRadius            at xmin                    ymax    tagwidth 10 'Radius'     callback '!this.modifyVertexAttributes(' anchor T+L+R width 6 is REAL format !!distanceFmt

        para    .paVertexTasks             at xmin.paVertexAttributes ymax+.2 text 'Tasks'
        line    .lnVertexTasks             at xmin                    ymax-.2 anchor T+L+R HORIZ width 24
        para    .paVertexRepick            at x2                      ymax+.2 pixmap                                                             width 16 height 16
        button  .lkVertexRepick  linklabel at x5                      ymin    'Repick position' callback '!this.repickVertex()'                  width 16
        para    .paVertexInsert            at x2                      ymax    pixmap                                                             width 16 height 16
        button  .lkVertexInsert  linklabel at x5                      ymin    'Insert vertex'   callback '!this.insertVertex()'                  width 16
        para    .paVertexMirror            at x2                      ymax    pixmap                                                             width 16 height 16
        button  .lkVertexMirror  linklabel at x5                      ymin    'Mirror on line'  callback '!this.mirrorVertex()'                  width 16
        para    .paVertexDelete            at x2                      ymax    pixmap                                                             width 16 height 16
        button  .lkVertexDelete  linklabel at x5                      ymin    'Delete'          callback '!this.deleteVertex()'                  width 16
        option  .opProfileCentre           at x2                      ymax    'Use as origin'   callback '!this.useVertexAsOrigin()' tagwidth 10 width 4
        option  .opReorderFirst            at x2                      ymax+1  'Reorder'                                              tagwidth 10 width 4
        option  .opReorderSecond           at x2                      ymax    'after'                                                tagwidth 10 width 4
        para    .paAcceptReorder           at x5                                                                                          pixmap width 16 height 16
        button  .lkAcceptReorder linklabel at xmin+3                  ymin    'Accept reorder'  callback '!this.acceptReorder()'                 width 12
      exit

      frame .frGroup    'Group' at xmin.frVertices ymin.frVertices anchor T+L+R
        numeric .nuStartVertex                            'Start vertex'    callback '!this.displayGroup()' tagwidth 13 width 3
        numeric .nuEndVertex               at xmin ymax   'End vertex'      callback '!this.displayGroup()' tagwidth 13 width 3

        para    .paGroupTasks              at xmin ymax+.2 text 'Tasks'
        line    .lnGroupTasks              at xmin ymax-.2 anchor T+L+R HORIZ width 24
        text    .teGroupMoveAlongX         at x2   ymax+.2 'Move along X by' callback '!this.moveGroup('    tagwidth 12 width 6 is REAL format !!distanceFmt
        text    .teGroupMoveAlongY         at x2   ymax    'Move along Y by' callback '!this.moveGroup('    tagwidth 12 width 6 is REAL format !!distanceFmt
        para    .paGroupMirror             at x2   ymax    pixmap                                                       width 16 height 16
        button  .lkGroupMirror   linklabel at x5   ymin    'Mirror on line'  callback '!this.mirrorGroup()'             width 14
        para    .paGroupDelete             at x2   ymax    pixmap                                                       width 16 height 16
        button  .lkGroupDelete   linklabel at x5   ymin    'Delete'          callback '!this.deleteGroup()'             width 14
      exit
    exit
  exit

  -- bottom buttons
  ---------------------------------------------------------------------------
  line   .lnSeparator                at xmin.lnMainShapes ymax form                                                     anchor B+L+R HORIZ  width.lnMainShapes
  para   .paModifyShape              at xmin.paMainShapes ymax+.2                                                       anchor B+L   pixmap width 16 height 16
  button .lkModifyShape    linklabel at xmin+3            ymin   'Modify shape'              callback '!this.modify()'  anchor B+L          width 16
  para   .paDefineShape              at xmin.paMainShapes ymax+.2                                                       anchor B+L   pixmap width 16 height 16
  button .lkDefineShape    linklabel at xmin+3            ymin   'Back to Define Shape Type' callback '!this.create()'  anchor B+L          width 18
  para   .paAcceptChanges            at xmin.paMainShapes ymax+.2                                                       anchor B+L   pixmap width 16 height 16
  button .lkAcceptChanges  linklabel at xmin+3            ymin   'Accept profile'            callback '!this.accept()'  anchor B+L          width 10
  para   .paDiscardChanges           at xmax              ymin                                                          anchor B+L   pixmap width 16 height 16
  button .lkDiscardChanges linklabel at xmin+3            ymin   'Discard profile'           callback '!this.discard()' anchor B+L          width 10

  -- Form Members
  ---------------------------------------------------------------------------
  member .meProfiles           is ARRAY
  member .meVertices           is ARRAY
  member .meRadius             is ARRAY
  member .meGroupIndices       is ARRAY

  member .meCurrentProfile     is STRING

  member .mePickStack          is ARRAY

  -- several options for graphical picks
  member .meOptions            is ARRAY
  member .meCurrentOption      is PROFILEOPTION

  -- stacks for internal undo/redo
  member .meProfilesUndoStack  is ARRAY
  member .meProfilesRedoStack  is ARRAY

  -- callback carried out when apply
  member .meAcceptCallback      is STRING
  member .meDiscardCallback     is STRING

  member .meAidProfileStandard is REAL
  member .meAidAxes            is REAL
  member .meAidText            is REAL
  member .meAidVertex          is REAL
  member .meAidCurrentVertex   is REAL
  member .meAidEdge            is REAL
  member .meAidCurrentEdge     is REAL

exit
-- End of form definition

------------------------------------------------------------------------
--
-- Method:      profileUI
--
-- Description: Constructor
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .profileUI()

  !this.coordinateSettings()
  -- general form data
  !this.autoscroll   = true
  !this.callback     = '!this.setup()'
  !this.formRevision = ' $Revision$ '
--  !this.formTitle    = 'Define Profile'
  !this.quitCall     = '!this.closeForm()'

  -- paragraph pixmaps
  !this.paDefineSquare.addPixmap(!!pml.getPathName('square16.png'))
  !this.paDefineRectangular.addPixmap(!!pml.getPathName('rectangular16.png'))
  !this.paDefinePolygon.addPixmap(!!pml.getPathName('polygon16.png'))
  !this.paDefineCircular.addPixmap(!!pml.getPathName('circular16.png'))
  !this.paDefinePolyhedron.addPixmap(!!pml.getPathName('polyhedron16.png'))

  !this.toGraphicalInteraction.addPixmap(!!pml.getPathName('navigate16.png'))
  !this.toExplicitDefinition.addPixmap(!!pml.getPathName('xyz16.png'))

  !this.buPickPosition.addPixmap(!!pml.getPathName('navigate16.png'))
  !this.buPickPosition.setTooltip('Pick position')
  !this.buXDirAlign.addPixmap(!!pml.getPathName('navigate16.png'))
  !this.buXDirAlign.setTooltip('Align x direction with picked line')
  !this.buYDirAlign.addPixmap(!!pml.getPathName('navigate16.png'))
  !this.buYDirAlign.setTooltip('Align y direction with picked line')
  !this.paRepick.addPixmap(!!pml.getPathName('navigate16.png'))

  -- modify panel
  !this.paUndo.addPixmap(!!pml.getPathName('activeundo16.png'))
  !this.paRedo.addPixmap(!!pml.getPathName('activeredo16.png'))
  !this.frProfile.callback  = '!this.frameTabset('
  !this.frVertices.callback = '!this.frameTabset('
  !this.frGroup.callback    = '!this.frameTabset('
  !this.paProfileMirror.addPixmap(!!pml.getPathName('mirror16.png'))
  !this.paProfileSplit.addPixmap(!!pml.getPathName('split16.png'))
  !this.paProfileMerge.addPixmap(!!pml.getPathName('merge16.png'))
  !this.paProfileRotate.addPixmap(!!pml.getPathName('grouprotateright16.png'))
  !this.paProfileExpand.addPixmap(!!pml.getPathName('groupexpand16.png'))

  !this.paVertexRepick.addPixmap(!!pml.getPathName('navigate16.png'))
  !this.paVertexInsert.addPixmap(!!pml.getPathName('pointinsert16.png'))
  !this.paVertexMirror.addPixmap(!!pml.getPathName('mirror16.png'))
  !this.paVertexDelete.addPixmap(!!pml.getPathName('deletece16.png'))
  !this.paAcceptReorder.addPixmap(!!pml.getPathName('accept.png'))

  !this.paGroupMirror.addPixmap(!!pml.getPathName('mirror16.png'))
  !this.paGroupDelete.addPixmap(!!pml.getPathName('deletece16.png'))

  !this.paModifyShape.addPixmap(!!pml.getPathName('modifyshape16.png'))
  !this.paDefineShape.addPixmap(!!pml.getPathName('back.png'))
  !this.paAcceptChanges.addPixmap(!!pml.getPathName('accept.png'))
  !this.paDiscardChanges.addPixmap(!!pml.getPathName('discard.png'))

  -- must be set to true, so that the callback is carried out when pressing arrow up/down
  !this.nuAttribute1.modifiedEvents = true
  !this.nuAttribute2.modifiedEvents = true
  !this.nuAttribute3.modifiedEvents = true
  !this.nuAttribute4.modifiedEvents = true

  !range[1] = 1
  !range[2] = 1000000
  !range[3] = 1
  !this.nuAttribute1.range  = !range
  !this.nuAttribute2.range  = !range
  !this.nuAttribute3.range  = !range
  !this.nuAttribute4.range  = !range

  !range[1] = 3
  !range[2] = 50
  !range[3] = 1
  !this.nuEdges.range            = !range
  !this.nuEdges.modifiedEvents   = true
  !this.nuOptions.modifiedEvents = true

  -- get a new aid number
  !this.meAidProfileStandard = !!aidNumbers.add('Profile')
  !this.meAidAxes            = !!aidNumbers.add('Profile Axes')
  !this.meAidText            = !!aidNumbers.add('Profile Text')
  !this.meAidVertex          = !!aidNumbers.add('Profile Text')
  !this.meAidCurrentVertex   = !!aidNumbers.add('Profile Text')
  !this.meAidEdge            = !!aidNumbers.add('Profile Text')
  !this.meAidCurrentEdge     = !!aidNumbers.add('Profile Text')

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      accept
--
-- Description: run the callback and close the form
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .accept()

  !this.clearFeedback()

  -- end EDG
  !!edgCntrl.remove('Profile Pick')

  !callback = !this.meAcceptCallback
  $!<callback>
  !this.hide()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      acceptReorder
--
-- Description: run the callback for reorder
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .acceptReorder()

  -- undo marker
  !this.setUndoMarker()

  !firstIdx    = !this.opReorderFirst.val
  !secondIdx   = !this.opReorderSecond.val

  !valueVertex = !this.meVertices.deleteFrom(!firstIdx, 1)
  !valueRadius = !this.meRadius.deleteFrom(!firstIdx, 1)

  !this.meVertices.insert(!secondIdx + 1, !valueVertex.first())
  !this.meRadius.insert(!secondIdx + 1, !valueRadius.first())

  !this.meVertices.compress()
  !this.meRadius.compress()

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      alignDirection
--
-- Description: align xDir or yDir with the picked line
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      calling gadget
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .alignDirection(!gadget is GADGET, !action is STRING)

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify line'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.alignDirectionReturn(' & !gadget.fullName() & ', !this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      alignDirectionReturn
--
-- Description: repositions intermediate landing
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the calling gadget
--    2   R      POSITIONDATA    the picked position
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .alignDirectionReturn(!gadget is GADGET, !positionData is EDGPOSITIONDATA)

  if ( !positionData.line.unset() ) then
    return
  endif

  if ( !gadget.eq(!this.buXDirAlign) ) then
    !directionGadget = !this.txXDir
  elseif ( !gadget.eq(!this.buYDirAlign) ) then
    !directionGadget = !this.txYDir
  endif

  !direction           = !positionData.line.direction().wrt(!this.txWrtOri.val.dbRef())
  !directionGadget.val = !direction.string().trim()

  -- call the explicit attributes callback
  !this.modifyExplicitOrientation(!directionGadget, '')

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      calculateProfile
--
-- Description: calculate the profile from the given vertices and radius
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .calculateProfile()

  !profile = !this.meProfiles[1]

  !edges = ARRAY()
  do !i index !this.meVertices
    if ( !i.eq(1) ) then
      !previousIdx = !this.meVertices.size()
    else
      !previousIdx = !i - 1
    endif
    if ( !i.eq(!this.meVertices.size()) ) then
      !nextIdx = 1
    else
      !nextIdx = !i + 1
    endif

    if ( !this.meRadius[!i].eq(0) ) then
      !edges.append(!this.meVertices[!i])

    elseif ( !this.meRadius[!i].neq(0) ) then
      !arc          = !this.meVertices[!i].arcFillet(!this.meVertices[!previousIdx], !this.meVertices[!nextIdx], !profile.orientation.zDir(), !this.meRadius[!i])
      !previousLine = !this.meVertices[!previousIdx].line(!arc.anglePosition(!arc.startAngle))
      !nextLine     = !arc.anglePosition(!arc.endAngle).line(!this.meVertices[!nextIdx])
      if ( !previousLine.length().gt(0) ) then
--        !edges.append(!previousLine)
      endif
      !edges.append(!arc)
      if ( !nextLine.length().gt(0) ) then
--        !edges.append(!nextLine)
      endif
    endif
  enddo

  if ( !edges[1].objectType().eq('POSITION') ) then
    !edges.append(!edges[1])
  endif

  !this.meProfiles[1] = object PROFILE(!profile.position, !profile.orientation, !edges)
  !this.meProfiles[1].close()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      calculateVertices
--
-- Description: calculate the vertices from the given profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .calculateVertices()

  !this.meVertices = ARRAY()
  !this.meRadius   = ARRAY()
  !profile         = !this.meProfiles[1]

  -- for the circle only use four points
  if ( !profile.isCircle() ) then
    !arc   = !profile.edges().first()
    !line1 = !arc.anglePosition(0).line(!arc.anglePosition(0).offset(!arc.angleTangent(0), 1000))
    !line2 = !arc.anglePosition(90).line(!arc.anglePosition(90).offset(!arc.angleTangent(90), 1000))
    !line3 = !arc.anglePosition(180).line(!arc.anglePosition(180).offset(!arc.angleTangent(180), 1000))
    !line4 = !arc.anglePosition(270).line(!arc.anglePosition(270).offset(!arc.angleTangent(270), 1000))

    !this.meVertices.append(!line1.intersection(!line2))
    !this.meVertices.append(!line2.intersection(!line3))
    !this.meVertices.append(!line3.intersection(!line4))
    !this.meVertices.append(!line4.intersection(!line1))

    !this.meRadius.append(!arc.radius)
    !this.meRadius.append(!arc.radius)
    !this.meRadius.append(!arc.radius)
    !this.meRadius.append(!arc.radius)

  -- for all other polygons take the edges
  else
    !edges       = !profile.edges()
    !currentEdge = !edges[1]

    do !i index !edges
      !currentEdge.delete()
      !currentEdge = !edges[!i]
      if ( !i.eq(1) ) then
        !previousIdx = !edges.size()
      else
        !previousIdx = !i - 1
      endif
      if ( !i.eq(!edges.size()) ) then
        !nextIdx = 1
      else
        !nextIdx = !i + 1
      endif

      -- take start/end of line only if there is no following arc as a fillet
      if ( !currentEdge.objectType().eq('LINE') ) then
        if ( !edges[!previousIdx].objectType().eq('ARC') and $
             !profile.isFillet(!previousIdx).not()       or  $
             !edges[!previousIdx].objectType().eq('LINE') ) then
          !this.meVertices.append(!currentEdge.startPosition)
          !this.meRadius.append(0)
        endif
        if ( !edges[!nextIdx].objectType().eq('ARC') and $
             !profile.isFillet(!nextIdx).not()  ) then
          !this.meVertices.append(!currentEdge.endPosition)
          !this.meRadius.append(0)
        endif
      elseif ( !currentEdge.objectType().eq('ARC') ) then
        !line1 = !currentEdge.anglePosition(!currentEdge.startAngle).line(!currentEdge.anglePosition(!currentEdge.startAngle).offset(!currentEdge.startTangent(), 1000))
        !line2 = !currentEdge.anglePosition(!currentEdge.endAngle).line(!currentEdge.anglePosition(!currentEdge.endAngle).offset(!currentEdge.endTangent(), 1000))
        !this.meVertices.append(!line1.intersection(!line2))
        !this.meRadius.append(!currentEdge.radius)
      endif
    enddo
  endif

  !range[1]                 = 1
  !range[2]                 = !this.meVertices.size()
  !range[3]                 = 1
  !this.nuVertex.range      = !range
  !this.nuStartVertex.range = !range
  !this.nuEndVertex.range   = !range

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      clearFeedback
--
-- Description: draw the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .clearFeedback()

  !!aidNumbers.hide(!this.meAidProfileStandard)
  !!aidNumbers.hide(!this.meAidAxes)
  !!aidNumbers.hide(!this.meAidText)
  !!aidNumbers.hide(!this.meAidVertex)
  !!aidNumbers.hide(!this.meAidCurrentVertex)
  !!aidNumbers.hide(!this.meAidEdge)
  !!aidNumbers.hide(!this.meAidCurrentEdge)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      closeForm
--
-- Description:
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .closeForm()

  -- transfer the control back to the owner form
  !this.discard()

  -- clears the whole graphical feedback
  !this.clearFeedback()

  -- end EDG
  !!edgCntrl.remove('Profile Pick')

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      create
--
-- Description: switches the form appearance in the create mode
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .create()

  !this.frMainShapes.visible  = true
  !this.frDefineShape.visible = false
  !this.frModifyShape.visible = false
--  !this.formTitle             = 'Define Shape Type'

  !this.paModifyShape.active  = !this.meProfiles.empty().not()
  !this.lkModifyShape.active  = !this.meProfiles.empty().not()
  !this.paDefineShape.active  = false
  !this.lkDefineShape.active  = false
  !this.paAcceptChanges.active  = false
  !this.lkAcceptChanges.active  = false
  !this.paDiscardChanges.active = false
  !this.lkDiscardChanges.active = false
endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      deleteGroup
--
-- Description: delete all vertices of the group
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .deleteGroup()

  if ( !!alert.confirm('Do you really want to delete all vertices of the group').neq('YES') ) then
    return
  endif

  -- undo marker
  !this.setUndoMarker()

  do !i value !this.meGroupIndices
    !this.meVertices.deleteFrom(!i, 1)
    !this.meRadius.deleteFrom(!i, 1)
  enddo
  !this.meVertices.compress()
  !this.meRadius.compress()

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      deleteVertex
--
-- Description: delete the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .deleteVertex()

  if ( !!alert.confirm('Do you really want to delete the current vertex').neq('YES') ) then
    return
  endif

  -- undo marker
  !this.setUndoMarker()

  !vertexIdx                   = !this.nuVertex.val
  !this.meVertices.remove(!vertexIdx)
  !this.meRadius.remove(!vertexIdx)

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.displayVertices()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      discard
--
-- Description: run the discard callback and close the form
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .discard()

  !this.clearFeedback()

  -- end EDG
  !!edgCntrl.remove('Profile Pick')

  !callback = !this.meDiscardCallback
  $!<callback>
  !this.hide()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayEdge
--
-- Description: update the gadgets for the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayEdge()

  !profile     = !this.meProfiles[1]
  !edges       = !profile.edges()
  !edgeIdx     = !this.nuEdge.val
  !currentEdge = !edges[!edgeIdx]

  -- frames visible/invisible
  !this.paEdgeType.val           = !currentEdge.objectType()
  !this.frEdgeAttributes.visible = !currentEdge.objectType().eq('LINE')
  !this.frArcAttributes.visible  = !currentEdge.objectType().neq('LINE')

  if ( !currentEdge.objectType().eq('LINE') ) then
    !xyPositionStart          = !profile.plane().xyOffset(!currentEdge.startPosition)
    !this.teEdgeStartXPos.val = !xyPositionStart.x
    !this.teEdgeStartYPos.val = !xyPositionStart.y
    !xyPositionEnd            = !profile.plane().xyOffset(!currentEdge.endPosition)
    !this.teEdgeEndXPos.val   = !xyPositionEnd.x
    !this.teEdgeEndYPos.val   = !xyPositionEnd.y

    !position                 = !currentEdge.proportion(0.5)
  else
    !xyPositionCentre         = !profile.plane().xyOffset(!currentEdge.position)
    !this.teArcCentreXPos.val = !xyPositionCentre.x
    !this.teArcCentreYPos.val = !xyPositionCentre.y
    !this.teArcRadius.val     = !currentEdge.radius
    !this.teArcStartAngle.val = !currentEdge.startAngle
    !this.teArcEndAngle.val   = !currentEdge.endAngle

    !angle    = !currentEdge.endAngle - !currentEdge.startAngle
    !position = !currentEdge.anglePosition(!currentEdge.startAngle + !angle / 2)
  endif

  -- draw the axes system
  !axesLength = !profile.area().sqrt() / 5
  handle ANY
    !axesLength = 1000
  endhandle
  !xDir       = !profile.orientation.xDir()
  !yDir       = !profile.orientation.yDir()
  !zDir       = !profile.orientation.zDir()

  !!aidNumbers.hide(!this.meAidCurrentEdge)
  AID ARROW NUMB $!this.meAidCurrentEdge AT $!position DIR $!xDir HEIGHT $!axesLength
  AID ARROW NUMB $!this.meAidCurrentEdge AT $!position DIR $!yDir HEIGHT $!axesLength
  AID ARROW NUMB $!this.meAidCurrentEdge AT $!position DIR $!zDir HEIGHT $!axesLength

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayEdges
--
-- Description: display all edges
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayEdges()

  -- draw the profile
  !this.draw()

  !edges = !this.meProfiles[1].edges()
  do !i index !edges
    if ( !edges[!i].objectType().eq('LINE') ) then
      !position = !edges[!i].proportion(0.5)
    else
      !angle    = !edges[!i].endAngle - !edges[!i].startAngle
      !position = !edges[!i].anglePosition(!edges[!i].startAngle + !angle / 2)
    endif
    AID TEXT NUMBER $!this.meAidEdge '[$!i]' AT $!position
  enddo

  -- display the current edge and update the gadgets
  !this.displayEdge()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayVertex
--
-- Description: update the gadgets for the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayVertex()

  !profile                 = !this.meProfiles[1]

  !vertexIdx               = !this.nuVertex.val
  !currentVertex           = !this.meVertices[!vertexIdx]

  !xyPosition              = !profile.plane().xyOffset(!currentVertex)
  !this.teVertexXPos.val   = !xyPosition.x
  !this.teVertexYPos.val   = !xyPosition.y
  !this.teVertexRadius.val = !this.meRadius[!vertexIdx]

  -- draw the axes system
  !axesLength = !profile.area().sqrt() / 5
  handle ANY
    !axesLength = 1000
  endhandle
  !xDir       = !profile.orientation.xDir()
  !yDir       = !profile.orientation.yDir()
  !zDir       = !profile.orientation.zDir()

  !!aidNumbers.hide(!this.meAidCurrentVertex)
  AID ARROW NUMB $!this.meAidCurrentVertex AT $!currentVertex DIR $!xDir HEIGHT $!axesLength
  AID ARROW NUMB $!this.meAidCurrentVertex AT $!currentVertex DIR $!yDir HEIGHT $!axesLength
  AID ARROW NUMB $!this.meAidCurrentVertex AT $!currentVertex DIR $!zDir HEIGHT $!axesLength

  !diameter = !axesLength / 2
  AID SPHERE NUMBER $!this.meAidCurrentVertex $!currentVertex DIAM $!diameter

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayVertices
--
-- Description: display all vertices
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayVertices()

  -- draw the profile
  !this.draw()

  !diameter = !this.meProfiles[1].area().sqrt() / 20
  handle ANY
    !diameter = 250
  endhandle
  do !i index !this.meVertices
    !position = !this.meVertices[!i]
    AID TEXT NUMBER $!this.meAidVertex '<$!i>' AT $!position
    AID SPHERE NUMBER $!this.meAidVertex $!position DIAM $!diameter
  enddo

  -- display the current vertex with axes and update the gadgets
  !this.displayVertex()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayVertex
--
-- Description: update the gadgets for the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayGroupVertices()

  !profile                 = !this.meProfiles[1]

  !vertexStartIdx          = !this.nuStartVertex.val
  !vertexEndIdx            = !this.nuEndVertex.val

  -- draw the axes system
  !diameter = !profile.area().sqrt() / 10
  handle ANY
    !diameter = 500
  endhandle
  !!aidNumbers.hide(!this.meAidCurrentVertex)

  !this.meGroupIndices = ARRAY()
  if ( !vertexEndIdx.geq(!vertexStartIdx) ) then
    do !i from !vertexStartIdx to !vertexEndIdx
      !this.meGroupIndices.append(!i)
    enddo

  else
    do !i from 1 to !vertexEndIdx
      !this.meGroupIndices.append(!i)
    enddo
    do !i from !vertexStartIdx to !this.meVertices.size()
      !this.meGroupIndices.append(!i)
    enddo
  endif

  do !i value !this.meGroupIndices
    !position  = !this.meVertices[!i]
    AID SPHERE NUMBER $!this.meAidCurrentVertex $!position DIAM $!diameter
  enddo

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      displayGroup
--
-- Description: display all vertices of the group
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .displayGroup()

  -- draw the profile
  !this.draw()

  !diameter = !this.meProfiles[1].area().sqrt() / 40
  handle ANY
    !diameter = 100
  endhandle
  do !i index !this.meVertices
    !position = !this.meVertices[!i]
    AID TEXT NUMBER $!this.meAidVertex '<$!i>' AT $!position
    AID SPHERE NUMBER $!this.meAidVertex $!position DIAM $!diameter
  enddo

  -- display the current vertex with axes and update the gadgets
  !this.displayGroupVertices()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      draw
--
-- Description: draw the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .draw()

  !this.clearFeedback()

  -- draw the profile
  !this.drawProfile()

  -- draw the axes on the profile
  !this.drawAxes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      drawAxes
--
-- Description: draw the axes system
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .drawAxes()

  -- use the first profile to define the axes
  !profile    = !this.meProfiles[1]

  -- draw the axes system
  !axesLength = !profile.area().sqrt() / 5
  handle ANY
    !axesLength = 1000
  endhandle
  !xDir       = !profile.orientation.xDir()
  !yDir       = !profile.orientation.yDir()
  !position   = !profile.position
  !xPosition  = !position.offset(!xDir, !axesLength)
  !yPosition  = !position.offset(!yDir, !axesLength)

  AID ARROW NUMB $!this.meAidAxes AT $!position DIR $!xDir HEIGHT $!axesLength
  AID TEXT  NUMB $!this.meAidAxes 'X' AT $!xPosition
  AID ARROW NUMB $!this.meAidAxes AT $!position DIR $!yDir HEIGHT $!axesLength
  AID TEXT  NUMB $!this.meAidAxes 'Y' AT $!yPosition

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      drawProfile
--
-- Description: draw the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .drawProfile()

  -- array of positive
  do !profile value !this.meProfiles
    !profile.draw(!this.meAidProfileStandard, 1, 6)
  enddo

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      edgShapePick
--
-- Description: start edg for shape pick
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .edgShapePick()

  --end EDG
  !!edgCntrl.remove('Profile Pick')

  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Pick positions'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.pickShapeReturn(!this.return[1])'

  -- set the description
  !packet.description         = 'Profile Pick'

  -- do not remove
  !packet.remove              = false

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      expand
--
-- Description: Offset edges
--
-- Method Type: Procedure
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     True for expand, false for contract
-- Return:
--   [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .expandProfile(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

--  if ( !gadget.eq(!this.teProfileExpand) ) then
    !distance = !gadget.val
--  else
--    !distance = !gadget.val * -1
--  endif

  do !i index !this.meVertices
    !direction           = !this.meProfiles[1].position.direction(!this.meVertices[!i])
    !this.meVertices[!i] = !this.meVertices[!i].offset(!direction, !distance)
  enddo

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method definition for .offsetEdges(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      frameTabset
--
-- Description: make the tabset frames visible/invisible
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .frameTabset(!gadget is GADGET, !action is STRING)

 !this.coordinateSettings()
  if ( !action.neq('SHOWN') ) then
    return
  endif

  !this.clearFeedback()

  if ( !gadget.eq(!this.frVertices) ) then
    !this.updateVertexGadgets()
  elseif ( !gadget.eq(!this.frProfile) ) then
    !this.draw()
    !!aidNumbers.hide(!this.meAidCurrentVertex)
  elseif ( !gadget.eq(!this.frGroup) ) then
    !this.updateGroupGadgets()
  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      insertVertex
--
-- Description: pick position of new vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .insertVertex()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify position of new vertex'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.insertVertexReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      insertVertexReturn
--
-- Description: position of new vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITIONDATA    the picked position
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .insertVertexReturn(!positionData is EDGPOSITIONDATA)

  -- undo marker
  !this.setUndoMarker()

  !newPosition                 = !positionData.position
  do !i index !this.meVertices
    if ( !i.eq(!this.meVertices.size()) ) then
      !nextVertex = !this.meVertices.first()
    else
      !nextVertex = !this.meVertices[!i + 1]
    endif
    !line         = !this.meVertices[!i].line(!nextVertex)
    !distance[!i] = !line.distance(!newPosition)
  enddo
  !vertexIdx = !distance.sortedIndices().first()

  -- insert the new vertex point
  !this.meVertices.insert(!vertexIdx + 1, !newPosition)
  !this.meRadius.insert(!vertexIdx + 1, 0)

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

  -- update for the new vertex
  !this.nuVertex.val = !vertexIdx + 1
  !this.displayVertex()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mergeProfile
--
-- Description: merge profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mergeProfile()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify profile to be merged with'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdElement('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.mergeProfileReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mergeProfileReturn
--
-- Description: merge profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      pickData   the picked line
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mergeProfileReturn(!pickData is EDGPICKDATA)

  -- collect all elements below the current element that can be used as a profile
  !collection       = object COLLECTION()
  !collection.scope(!pickData.item)
  !collection.type('BOUN')
  !collection.addType('DRAW')
  !collection.addType('LOOP')
  !collection.addType('PALJ')
  !collection.addType('PLOO')
  !collection.addType('POGO')
  !collection.addType('SPINE')
  !allProfileDBRefs = !collection.results()

  if ( !allProfileDBRefs.empty() ) then
    !!alert.warning('Unable to merge with identified item')
    return
  endif

  -- try to get a profile object from the item
  !profile    = object PROFILE(!allProfileDBRefs[1])
  handle ANY
    !!alert.warning('Unable to merge with identified item')
    return
  endhandle

  -- undo marker
  !this.setUndoMarker()

  !this.meProfiles    = !this.meProfiles[1].union(!profile)

  !this.updateProfileGadgets()

  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorGroup
--
-- Description: mirror group
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorGroup()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Pick line to mirror about'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdGraphics('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.mirrorGroupReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorGroupReturn
--
-- Description: repositions vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      pickData   the picked line
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorGroupReturn(!pickData is EDGPICKDATA)

  -- undo marker
  !this.setUndoMarker()

  !line                  = object LINE(!pickData.lines[1], !pickData.lines[2])
  do !i value !this.meGroupIndices
    !vertexPosition        = !this.meVertices[!i]
    !plane                 = object PLANE(!line.startPosition, object ORIENTATION('Y is ' & !line.direction() & ' and Z is ' & !this.meProfiles[1].plane().orientation.zDir()))
    !xyPosition            = !plane.xyOffset(!vertexPosition)
    !plane.orientation     = object ORIENTATION('Y is ' & !plane.orientation.yDir() & ' and Z is ' & !plane.orientation.zDir().opposite())
--    !xyPosition            = !this.meProfiles[1].plane().xyOffset(!plane.threeDPosition(!xyPosition))
    !this.meVertices[!i]   = !plane.threeDPosition(!xyPosition)
  enddo

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorProfile
--
-- Description: mirror profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorProfile()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Pick line to mirror about'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdGraphics('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.mirrorProfileReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorProfileReturn
--
-- Description: mirrors profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      pickData   the picked line
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorProfileReturn(!pickData is EDGPICKDATA)

  -- undo marker
  !this.setUndoMarker()

  !line                  = object LINE(!pickData.lines[1], !pickData.lines[2])
  !this.meProfiles[1]    = !this.meProfiles[1].mirror(!line)

  !this.updateProfileGadgets()

  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorVertex
--
-- Description: mirror position of vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorVertex()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Pick line to mirror about'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdGraphics('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.mirrorVertexReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      mirrorVertexReturn
--
-- Description: repositions vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      pickData   the picked line
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .mirrorVertexReturn(!pickData is EDGPICKDATA)

  -- undo marker
  !this.setUndoMarker()

  !line                  = object LINE(!pickData.lines[1], !pickData.lines[2])
  !vertexIdx             = !this.nuVertex.val
  !vertexPosition        = !this.meVertices[!vertexIdx]
  !plane                 = object PLANE(!line.startPosition, object ORIENTATION('Y is ' & !line.direction() & ' and Z is ' & !this.meProfiles[1].plane().orientation.zDir()))
  !xyPosition            = !plane.xyOffset(!vertexPosition)
  !plane.orientation     = object ORIENTATION('Y is ' & !plane.orientation.yDir() & ' and Z is ' & !plane.orientation.zDir().opposite())
  !xyPosition            = !this.meProfiles[1].plane().xyOffset(!plane.threeDPosition(!xyPosition))

  !this.teVertexXPos.val = !xyPosition.x
  !this.teVertexYPos.val = !xyPosition.y

  !this.modifyVertexAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modify
--
-- Description: switches the form appearance in the modify mode
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modify()

  !this.frMainShapes.visible        = false
  !this.frDefineShape.visible       = false
  !this.frModifyShape.visible       = true
--  !this.formTitle                   = 'Modify Profile'

  -- clear undo/redo stacks
  !this.meProfilesUndoStack.clear()
  !this.meProfilesRedoStack.clear()

  -- update the gadgets of the profile frame
  !this.updateProfileFrame()

  !this.paModifyShape.active       = false
  !this.lkModifyShape.active       = false
  !this.paDefineShape.active       = true
  !this.lkDefineShape.active       = true
  !this.paAcceptChanges.active  	 = true
  !this.lkAcceptChanges.active  	 = true
  !this.paDiscardChanges.active 	 = true
  !this.lkDiscardChanges.active 	 = true


  -- end EDG
  !!edgCntrl.remove('Profile Pick')

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyExplicitAttributes
--
-- Description: callback of frame "Explicit Attributes"
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyExplicitAttributes()

  !position           = object POSITION()
  !position.east      = !this.txEast.val
  !position.north     = !this.txNorth.val
  !position.up        = !this.txUp.val
  !position.origin    = !this.txWrtPos.val.dbRef()

  !positionReference  = !this.opReferencePoint.selection()

  !xDir               = !this.txXDir.val
  !yDir               = !this.txYDir.val
  !orientation        = object ORIENTATION('X IS ' & !xDir & ' AND Y IS ' & !yDir)
  !orientation.origin = !this.txWrtOri.val.dbRef()

  -- callback of the respective object and evaluate the profile
  if ( !this.meCurrentProfile.eq('SQUARE') ) then
    !profile = object PROFILESQUARE(!this.nuAttribute1.val, !position, !positionReference, !orientation)

  elseif ( !this.meCurrentProfile.eq('RECTANGULAR') ) then
    !profile = object PROFILERECTANGULAR(!this.nuAttribute1.val, !this.nuAttribute2.val, !position, !positionReference, !orientation)

  elseif ( !this.meCurrentProfile.eq('EQUALL') ) then
    !profile = object PROFILEEQUALL(!this.nuAttribute1.val, !this.nuAttribute2.val, !position, !positionReference, !orientation)

  elseif ( !this.meCurrentProfile.eq('UNEQUALL') ) then
    !profile = object PROFILEUNEQUALL(!this.nuAttribute1.val, !this.nuAttribute2.val, !this.nuAttribute3.val, !this.nuAttribute4.val, !position, !positionReference, !orientation)

  elseif ( !this.meCurrentProfile.eq('CIRCULAR') ) then
    !profile = object PROFILECIRCULAR(!this.nuAttribute1.val, !position, !positionReference, !orientation)

  elseif ( !this.meCurrentProfile.eq('POLYHEDRON') ) then
    !profile = object PROFILEPOLYHEDRON(!this.nuAttribute1.val, !this.nuAttribute2.val, !position, !positionReference, !orientation)
  endif
  !this.meProfiles[1] = !profile.evaluateProfile()

  -- draw the profile
  !this.draw()
  !this.updateBottomGadgets(!this.meProfiles.set())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyGraphicalAttributes
--
-- Description: callback of frame "Graphical Attributes"
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyGraphicalAttributes()

  -- remove aidlines
  !this.clearFeedback()

  -- clear objects
  !this.mePickStack     = ARRAY()
  !this.meOptions       = ARRAY()
  !this.meCurrentOption = object PROFILEOPTION()

  -- edg start
  !this.edgShapePick()

  -- clear the graphical frame
  !this.updateGraphicalGadgets()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyExplicitOrientation
--
-- Description: select main shape like octagon
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the calling gadget
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyExplicitOrientation(!gadget is GADGET, !action is STRING)

  !profile     = !this.meProfiles[1]

  !currentXDir = !profile.orientation.xDir()
  !currentYDir = !profile.orientation.yDir()
  !currentZDir = !profile.orientation.zDir()

  -- recalculate the new orientations
  if ( !gadget.eq(!this.txXDir) ) then
    !newXDir = !this.txXDir.val.direction().wrt(!this.txWrtOri.val.dbRef())
    if ( !newXDir.angle(!currentYDir).neq(0) ) then
      !newOrientation = object ORIENTATION('X IS ' & !newXDir & ' AND Y IS ' & !currentYDir)
    else
      !newOrientation = object ORIENTATION('X IS ' & !newXDir & ' AND Z IS ' & !currentZDir)
    endif

  elseif ( !gadget.eq(!this.txYDir) ) then
    !newYDir = !this.txYDir.val.direction().wrt(!this.txWrtOri.val.dbRef())
    if ( !newYDir.angle(!currentXDir).neq(0) ) then
      !newOrientation = object ORIENTATION('Y IS ' & !newYDir & ' AND X IS ' & !currentXDir)
    else
      !newOrientation = object ORIENTATION('Y IS ' & !newYDir & ' AND Z IS ' & !currentZDir)
    endif
  endif

  -- refill the gadgets and callback the method
  !this.txXDir.val = !newOrientation.xDir().wrt(!this.txWrtOri.val.dbRef()).string().before('WRT').trim()
  !this.txYDir.val = !newOrientation.yDir().wrt(!this.txWrtOri.val.dbRef()).string().before('WRT').trim()

  !this.modifyExplicitAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyNumberOfEdges
--
-- Description: callback from numeric input gadget
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyNumberOfEdges()

  !profile     = object PROFILEPOLYHEDRON()
  !this.meOptions = !profile.evaluatePicks(!this.mePickStack, !this.nuEdges.val)

  -- update the available options in the list
  !this.updateGraphicalGadgets()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyOption
--
-- Description: callback from toggle/linklabel
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      calling gadget
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyOption(!gadget is GADGET, !action is STRING)

  -- get the respective toggle gadget
  !toggleGadget = !this.attribute('TO' & !gadget.name().subString(3))
  !labelGadget  = !this.attribute('LK' & !gadget.name().subString(3))

  -- if toggle is already switched on then return
  if ( !gadget.neq(!toggleGadget) and $
       !toggleGadget.val          or  $
       !gadget.eq(!toggleGadget)  and $
       !action.eq('UNSELECT') ) then
    !toggleGadget.val     = true
    return
  endif

  -- switch off all install option toggle gadgets
  do !i to 5
    !this.attribute('TOAVAILOPTIONS' & !i).val = false
  enddo

  -- switch on the toggle gadget
  !toggleGadget.val = true

  !optionIdx            = !gadget.name().subString(-1, 1).real()
  !this.meCurrentOption = !this.meOptions[!optionIdx]
  !this.meProfiles.clear()

  -- update the numeric gadget to switch between the Polyhedron options
  if ( !this.meCurrentOption.profileArray ) then
    !range[1]               = 1
    !range[2]               = !this.meCurrentOption.profile.size()
    !range[3]               = 1
    !this.nuOptions.range   = !range
    !this.nuOptions.visible = true
    !this.nuOptions.val     = INT(!this.nuEdges.val / 2)
    handle ANY
    endhandle

    -- toggle between the Polyhedron options
    !this.toggleOptions()
  else
    !this.nuOptions.visible = false
    !this.meProfiles        = !this.meCurrentOption.profile

    -- draw the current option
    !this.draw()
  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyProfileAttributes
--
-- Description: gadget callback, must set the undo marker
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyProfileAttributes(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

  -- callback of the standard method
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyProfileAttributes
--
-- Description: modify the attributes of the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyProfileAttributes()

  !position        = object POSITION()
  !position.north  = !this.teProfilePositionNorth.val
  !position.east   = !this.teProfilePositionEast.val
  !position.up     = !this.teProfilePositionUp.val
  !position.origin = object DBREF(!this.teProfilePositionWRT.val)

  !yDir            = !this.teProfileOrientationY.val
  !zDir            = !this.teProfileOrientationZ.val
  !origin          = !this.teProfileOrientationWRT.val
  !orientation     = object ORIENTATION('Y IS ' & !yDir & ' AND Z IS ' & !zDir & ' WRT ' & !origin)

  !this.meProfiles[1].position    = !position
  !this.meProfiles[1].orientation = !orientation

  -- update the profile frame with the attributes
  !this.updateProfileFrame()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyVertexAttributes
--
-- Description: modify the attributes of the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyVertexAttributes(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

  -- standard callback
  !this.modifyVertexAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      modifyVertexAttributes
--
-- Description: modify the attributes of the current vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .modifyVertexAttributes()

  !vertexIdx                   = !this.nuVertex.val

  !plane                       = !this.meProfiles[1].plane()
  !xyPosition                  = object XYPOSITION()
  !xyPosition.x                = !this.teVertexXPos.val
  !xyPosition.y                = !this.teVertexYPos.val
  !this.meVertices[!vertexIdx] = !plane.threeDPosition(!xyPosition)
  !this.meRadius[!vertexIdx]   = !this.teVertexRadius.val

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      moveGroup
--
-- Description: move group in x or y direction
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .moveGroup(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

  !plane = !this.meProfiles[1].plane()

  do !i value !this.meGroupIndices
    if ( !gadget.eq(!this.teGroupMoveAlongX) ) then
      !this.meVertices[!i] = !this.meVertices[!i].offset(!plane.orientation.xDir(), !gadget.val)
    else
      !this.meVertices[!i] = !this.meVertices[!i].offset(!plane.orientation.yDir(), !gadget.val)
    endif
  enddo

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      moveStart
--
-- Description: move start point one forward or backward
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .moveStart(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

  if ( !gadget.eq(!this.lkMoveStartFor) ) then
    !firstVertex = !this.meVertices.removeFirst()
    !this.meVertices.append(!firstVertex)
    !firstRadius = !this.meRadius.removeFirst()
    !this.meRadius.append(!firstRadius)
  else
    !lastVertex = !this.meVertices.removeLast()
    !this.meVertices.insert(1, !lastVertex)
    !lastRadius = !this.meRadius.removeLast()
    !this.meRadius.insert(1, !lastRadius)
  endif

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      pickExplicitPosition
--
-- Description: select main shape like octagon
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .pickExplicitPosition()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify new position of profile'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.pickExplicitPositionReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      pickExplicitPositionReturn
--
-- Description: repositions intermediate landing
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITIONDATA    the picked position
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .pickExplicitPositionReturn(!positionData is EDGPOSITIONDATA)

  !position          = !positionData.position.wrt(WORLD)
  !this.txEast.val   = !position.east
  !this.txNorth.val  = !position.north
  !this.txUp.val     = !position.up
  !this.txWrtPos.val = 'WORLD'

  -- call the explicit attributes callback
  !this.modifyExplicitAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      pickShapeReturn
--
-- Description: return of the shape pick
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITIONDATA    the picked position
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .pickShapeReturn(!positionData is EDGPOSITIONDATA)

  -- append the current pick to the stack
  !this.mePickStack.append(!positionData)

  -- evaluate the shape for the picks
  -- callback of the respective object and evaluate the profile
  if ( !this.meCurrentProfile.eq('SQUARE') ) then
    !profile = object PROFILESQUARE()

  elseif ( !this.meCurrentProfile.eq('RECTANGULAR') ) then
    !profile = object PROFILERECTANGULAR()

  elseif ( !this.meCurrentProfile.eq('EQUALL') ) then
    !profile = object PROFILEEQUALL()

  elseif ( !this.meCurrentProfile.eq('UNEQUALL') ) then
    !profile = object PROFILEUNEQUALL()

  elseif ( !this.meCurrentProfile.eq('CIRCULAR') ) then
    !profile = object PROFILECIRCULAR()

  elseif ( !this.meCurrentProfile.eq('POLYHEDRON') ) then
    !profile = object PROFILEPOLYHEDRON()

  elseif ( !this.meCurrentProfile.eq('POLYGON') ) then
    !profile = object PROFILEPOLYGON()
  endif
  if ( !this.meCurrentProfile.eq('POLYHEDRON') ) then
    !this.meOptions = !profile.evaluatePicks(!this.mePickStack, !this.nuEdges.val)
  else
    !this.meOptions = !profile.evaluatePicks(!this.mePickStack)
  endif

  -- update the available options in the list
  !this.updateGraphicalGadgets()
  !this.updateBottomGadgets(!this.meProfiles.set())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      redo
--
-- Description: redo the last step
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .redo()

  -- put the current version to the redo stack
  !this.meProfilesUndoStack.append(!this.meProfiles)

  -- take the last element of the undo stack
  !this.meProfiles = !this.meProfilesRedoStack.removeLast()

  -- draw the profile
  !this.updateProfileFrame()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      repickProfile
--
-- Description: repick position of the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .repickProfile()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify new position of profile'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.repickProfileReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      repickProfileReturn
--
-- Description: repositions intermediate landing
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITIONDATA    the picked position
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .repickProfileReturn(!positionData is EDGPOSITIONDATA)

  -- undo marker
  !this.setUndoMarker()

  !position                         = !positionData.position.wrt(WORLD)
  !this.teProfilePositionEast.val   = !position.east
  !this.teProfilePositionNorth.val  = !position.north
  !this.teProfilePositionUp.val     = !position.up
  !this.teProfilePositionWRT.val    = 'WORLD'

  -- call the explicit attributes callback
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      repickVertex
--
-- Description: pick position of vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .repickVertex()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Identify new position of vertex'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.repickVertexReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      repickVertexReturn
--
-- Description: repositions vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITIONDATA    the picked position
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .repickVertexReturn(!positionData is EDGPOSITIONDATA)

  -- undo marker
  !this.setUndoMarker()

  !plane                       = !this.meProfiles[1].plane()
  !xyPosition                  = !plane.xyOffset(!positionData.position)
  !this.teVertexXPos.val       = !xyPosition.x
  !this.teVertexYPos.val       = !xyPosition.y

  !this.modifyVertexAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      reverseProfile
--
-- Description: reverse definition of the vertices
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .reverseProfile()

  -- undo marker
  !this.setUndoMarker()

  !this.meVertices.invert()
  !this.meRadius.invert()

  -- calculate the profile from the given vertex points
  !this.calculateProfile()

  -- mark the vertices
  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      rotateProfile
--
-- Description: rotate profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the calling gadget
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .rotateProfile(!gadget is GADGET, !action is STRING)

  -- undo marker
  !this.setUndoMarker()

--  if ( !gadget.eq(!this.teProfileRotate) ) then
    !this.meProfiles[1]    = !this.meProfiles[1].rotate(!gadget.val * -1, !this.meProfiles[1].position)
--  else
--    !this.meProfiles[1]    = !this.meProfiles[1].rotate(!gadget.val,      !this.meProfiles[1].position)
--  endif

  !this.updateProfileGadgets()

  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      selectMainShape
--
-- Description: select main shape like octagon
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .selectMainShape(!gadget is GADGET, !action is STRING)


--  !this.formTitle                     = 'Define ' & !gadget.tag

  !this.frMainShapes.visible          = false
  !this.frDefineShape.visible         = true
  !this.meCurrentProfile              = !gadget.name().upCase().after('DEFINE')
  !this.toGraphicalInteraction.active = !this.meCurrentProfile.neq('POLYGON')
  !this.lkGraphicalInteraction.active = !this.meCurrentProfile.neq('POLYGON')
  !this.toExplicitDefinition.active   = !this.meCurrentProfile.neq('POLYGON')
  !this.lkExplicitDefinition.active   = !this.meCurrentProfile.neq('POLYGON')

--  -- get the description text from the tag of the respective linklabel
--  !lkLabel                            = !this.attribute('LK' & !gadget.name().subString(3))
--  !this.paDefinitionOptions.val       = 'Defining ' & !lkLabel.tag.subString(1, 1).lowCase() & !lkLabel.tag.subString(2) & ' by'
--
  -- update the gadgets depending on the object (square, octagon, etc)
  !this.updateExplicitGadgets()

  -- update the panel for definition of explicit or graphical definition
  !this.selectDefinitionOption(!this.toGraphicalInteraction, '')

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      selectDefinitionOption
--
-- Description: select explicit or graphical option
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      the gadget to be visible
--    2   R      STRING      action
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .selectDefinitionOption(!gadget is GADGET, !action is STRING)

  -- get the respective toggle gadget
  !toggleGadget = !this.attribute('TO' & !gadget.name().subString(3))
  !labelGadget  = !this.attribute('LK' & !gadget.name().subString(3))

  -- switch off all toggle gadgets
  !this.toGraphicalInteraction.val = false
  !this.toExplicitDefinition.val   = false

  -- switch on the toggle gadget
  !toggleGadget.val = true

  -- make all shape frames invisible
  !this.frGraphicalDefinition.visible = !this.toGraphicalInteraction.val
  !this.frExplicitDefinition.visible  = !this.toGraphicalInteraction.val.not()

  !this.paDefineShape.active 		= true
	!this.lkDefineShape.active 		= true
	
  !this.updateBottomGadgets(!this.meProfiles.set())

  --end EDG
  !!edgCntrl.remove('Profile Pick')

  -- start frame specific method
  if ( !this.toGraphicalInteraction.val ) then
    !this.modifyGraphicalAttributes()
  elseif ( !this.toGraphicalInteraction.val.not() ) then
    !this.modifyExplicitAttributes()
  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setUndoMarker
--
-- Description: set undo marker
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .setUndoMarker()

  -- put current profile into the undo stack
  !this.meProfilesUndoStack.append(!this.meProfiles)

  -- clear the redo stack
  !this.meProfilesRedoStack.clear()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setup
--
-- Description: init callback
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .setup()

  !this.coordinateSettings()
  -- set the default values for position orientation
  !this.txEast.val   = 0
  !this.txNorth.val  = 0
  !this.txUp.val     = 0
  !this.txWrtPos.val = 'WORLD'
  !this.txWrtOri.val = 'WORLD'

  !this.teProfilePositionWRT.val    = 'WORLD'
  !this.teProfileOrientationWRT.val = 'WORLD'

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      splitProfile
--
-- Description: split profile on line
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .splitProfile()

  -- defines packet
  !packet                     = object EDGPACKET()
  !packet.pickPacket.prompt   = 'Pick line to split on'

  -- defines first pick
  !packet.pickPacket.picks[1] = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdGraphics('')

  -- define actions on first pick
  !packet.action              = '!!profileUI.splitProfileReturn(!this.return[1])'

  --set the description
  !packet.description         = 'Profile Pick'

  -- adds packet to EDG system
  !!edgCntrl.add(!packet)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      splitProfileReturn
--
-- Description: repositions vertex
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      pickData   the picked line
--    2   R
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .splitProfileReturn(!pickData is EDGPICKDATA)

  -- undo marker
  !this.setUndoMarker()

  !line            = object LINE(!pickData.lines[1], !pickData.lines[2])
  !this.meProfiles = !this.meProfiles[1].split(!line)

  !this.updateProfileGadgets()

  !this.modifyProfileAttributes()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      toggleOptions
--
-- Description: toggle between the polyhedron options
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .toggleOptions()

  !polyhedronOptionIdx = !this.nuOptions.val
  !this.meProfiles[1]  = !this.meCurrentOption.profile[!polyhedronOptionIdx]

  -- undo marker
  !this.setUndoMarker()

  -- draw the current option
  !this.draw()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      undo
--
-- Description: undo the last step
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .undo()

  -- put the current version to the redo stack
  !this.meProfilesRedoStack.append(!this.meProfiles)

  -- take the last element of the undo stack
  !this.meProfiles = !this.meProfilesUndoStack.removeLast()

  -- update the form
  !this.updateProfileFrame()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateEdgeGadgets
--
-- Description: update the edge gadgets
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateEdgeGadgets()

  !range[1]          = 1
  !range[2]          = !this.meProfiles[1].numberEdges()
  !range[3]          = 1
  !this.nuEdge.range = !range

  -- display all vertices
  !this.displayEdges()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateExplicitGadgets
--
-- Description: update the gadgets depending on the object
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateExplicitGadgets()

  -- fill the attributes depending on the object
  !attributes = ARRAY()
  !defaults   = ARRAY()
  !points     = ARRAY()

  if ( !this.meCurrentProfile.eq('SQUARE') ) then
    !attributes.append('Width')
    !defaults.append(2000)
    !points.append('Centre')
    !points.append('Vtx 1')
    !points.append('Vtx 2')
    !points.append('Vtx 3')
    !points.append('Vtx 4')

  elseif ( !this.meCurrentProfile.eq('RECTANGULAR') ) then
    !attributes.append('Width')
    !defaults.append(2000)
    !attributes.append('Length')
    !defaults.append(3000)
    !points.append('Centre')
    !points.append('Vtx 1')
    !points.append('Vtx 2')
    !points.append('Vtx 3')
    !points.append('Vtx 4')

  elseif ( !this.meCurrentProfile.eq('EQUALL') ) then
    !attributes.append('Width')
    !defaults.append(2000)
    !attributes.append('Thickness')
    !defaults.append(200)
    !points.append('Vtx 1')
    !points.append('Vtx 2')
    !points.append('Vtx 3')
    !points.append('Vtx 4')
    !points.append('Vtx 5')
    !points.append('Vtx 6')

  elseif ( !this.meCurrentProfile.eq('UNEQUALL') ) then
    !attributes.append('Width')
    !defaults.append(2000)
    !attributes.append('Length')
    !defaults.append(3000)
    !attributes.append('Thickness a')
    !defaults.append(200)
    !attributes.append('Thickness b')
    !defaults.append(300)
    !points.append('Vtx 1')
    !points.append('Vtx 2')
    !points.append('Vtx 3')
    !points.append('Vtx 4')
    !points.append('Vtx 5')
    !points.append('Vtx 6')

  elseif ( !this.meCurrentProfile.eq('CIRCULAR') ) then
    !attributes.append('Diameter')
    !defaults.append(2000)
    !points.append('Centre')

  elseif ( !this.meCurrentProfile.eq('POLYHEDRON') ) then
    !attributes.append('Diameter')
    !defaults.append(2000)
    !attributes.append('Number of edges')
    !defaults.append(8)
    !points.append('Centre')
--    !points.append('Vtx 1')
--    !points.append('Vtx 2')
--    !points.append('Vtx 3')
--    !points.append('Vtx 4')
--    !points.append('Vtx 5')
--    !points.append('Vtx 6')
--    !points.append('Vtx 7')
--    !points.append('Vtx 8')
  endif

  do !i to 4
    !this.attribute('NUATTRIBUTE' & !i).visible = false
  enddo
  do !i index !attributes
    !this.attribute('NUATTRIBUTE' & !i).visible = true
    !this.attribute('NUATTRIBUTE' & !i).tag     = !attributes[!i]
    !this.attribute('NUATTRIBUTE' & !i).val     = !defaults[!i]
  enddo
  !this.opReferencePoint.dText = !points

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateGraphicalGadgets
--
-- Description: update the graphicals gadgets depending on the picks
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateGraphicalGadgets()

  !this.nuOptions.visible   = false
  !this.nuEdges.visible     = !this.meCurrentProfile.eq('POLYHEDRON')

  -- treating linklabels
  do !i to !this.meOptions.size()
    !option = !this.meOptions[!i]
    !this.attribute('TOAVAILOPTIONS' & !i).addPixmap(!option.pixmap)
    !this.attribute('LKAVAILOPTIONS' & !i).tag     = !option.description
    !this.attribute('TOAVAILOPTIONS' & !i).visible = true
    !this.attribute('LKAVAILOPTIONS' & !i).visible = true
  enddo
  do !i from (!this.meOptions.size() + 1) to 5
    !this.attribute('TOAVAILOPTIONS' & !i).visible = false
    !this.attribute('LKAVAILOPTIONS' & !i).visible = false
  enddo
  if ( !this.meOptions.empty().not() ) then
    !this.toAvailOptions1.val = false
    !this.modifyOption(!this.toAvailOptions1, '')
  endif

--  !this.lkRepick.active = !this.meOptions.empty().not()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateGroupGadgets
--
-- Description: update the group gadgets
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateGroupGadgets()

  -- calculate the vertex points from the profile
  !this.calculateVertices()

  if ( !this.nuEndVertex.val.gt(!this.meVertices.size()) ) then
    !this.nuEndVertex.val = !this.meVertices.size()
  endif

  -- display all vertices
  !this.displayGroup()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateProfileFrame
--
-- Description: update the profile frame
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateProfileFrame()

  -- update the profile panel
  !this.updateProfileGadgets()

  -- mark the vertices / edges
  if ( !this.frVertices.selected ) then
    -- calculate the vertex points from the profile
    !this.updateVertexGadgets()

  elseif ( !this.frProfile.selected ) then
    !this.draw()
    !!aidNumbers.hide(!this.meAidCurrentVertex)

  elseif ( !this.frGroup.selected ) then
    -- calculate the vertex points from the profile
    !this.updateGroupGadgets()

  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateProfileGadgets
--
-- Description: update the profile gadgets
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateProfileGadgets()

  if ( !this.meProfilesUndoStack.empty() ) then
    !this.paUndo.addPixmap(!!pml.getPathName('inactiveundo16.png'))
    !this.lkUndo.active = false
  else
    !this.paUndo.addPixmap(!!pml.getPathName('activeundo16.png'))
    !this.lkUndo.active = true
  endif
  if ( !this.meProfilesRedoStack.empty() ) then
    !this.paRedo.addPixmap(!!pml.getPathName('inactiveredo16.png'))
    !this.lkRedo.active = false
  else
    !this.paRedo.addPixmap(!!pml.getPathName('activeredo16.png'))
    !this.lkRedo.active = true
  endif

  !this.teProfilePositionNorth.val = !this.meProfiles[1].position.wrt(!this.teProfilePositionWRT.val.dbRef()).north
  !this.teProfilePositionEast.val  = !this.meProfiles[1].position.wrt(!this.teProfilePositionWRT.val.dbRef()).east
  !this.teProfilePositionUp.val    = !this.meProfiles[1].position.wrt(!this.teProfilePositionWRT.val.dbRef()).up

  !this.teProfileOrientationY.val  = !this.meProfiles[1].orientation.wrt(!this.teProfilePositionWRT.val.dbRef()).yDir().string().before(' WRT')
  !this.teProfileOrientationZ.val  = !this.meProfiles[1].orientation.wrt(!this.teProfilePositionWRT.val.dbRef()).zDir().string().before(' WRT')

  !this.teProfileRotate.val      = 0
  !this.teProfileExpand.val        = 0

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateVertexGadgets
--
-- Description: update the profile gadgets
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateVertexGadgets()

  -- calculate the vertex points from the profile
  !this.calculateVertices()

  -- display all vertices
  !this.displayVertices()

  !this.calculateVertices()
  !dText = ARRAY()
  do !i index !this.meVertices
    !dText.append('Vtx' & !i)
  enddo
  !this.opProfileCentre.dText = !dText
  !this.opReorderFirst.dText  = !dText
  !this.opReorderSecond.dText = !dText

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      useVertexAsOrigin
--
-- Description: use vertex point as origin of the profile
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .useVertexAsOrigin()

  -- undo marker
  !this.setUndoMarker()

  !position                         = !this.meVertices[!this.opProfileCentre.val]
  !this.teProfilePositionEast.val   = !position.east
  !this.teProfilePositionNorth.val  = !position.north
  !this.teProfilePositionUp.val     = !position.up
  !this.teProfilePositionWRT.val    = 'WORLD'

  !edges                            = !this.meProfiles[1].edges()
  !orientation                      = !this.meProfiles[1].orientation

  !this.meProfiles[1]               = object PROFILE(!position, !orientation, !edges)

  -- mark the vertices
  !this.displayVertices()

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      updateBottomGadgets
--
-- Description: Updating the status of bottom gadgets.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R      BOOLEAN    Status of the bottom gadgets
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .updateBottomGadgets(!status is BOOLEAN)

	!this.paModifyShape.active 		= !status
	!this.lkModifyShape.active 		= !status
	!this.paAcceptChanges.active	= !status
	!this.lkAcceptChanges.active 	= !status
	!this.paDiscardChanges.active	= !status
	!this.lkDiscardChanges.active = !status

endmethod
-- End of method
------------------------------------------------------------------------
--
-- Method:      coordinateSettings
--
-- Description: Set the value of position gadgets with current coordinate system
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
------------------------------------------------------------------------

define method .coordinateSettings()

  var !coord coord
  if(!coord.eq('ENU'))then
    !this.txEast.tag                  = 'East'
    !this.txNorth.tag                 = 'North'
    !this.txUp.tag                    = 'Up'

    !this.teProfilePositionEast.tag   = 'East'
    !this.teProfilePositionNorth.tag  = 'North'
    !this.teProfilePositionUp.tag     = 'Up'


    !this.teVertexXPos.tag            = 'X Position'
    !this.teVertexYPos.tag            = 'Y Position'

    !this.teGroupMoveAlongX.tag       = 'Move along X by'
    !this.teGroupMoveAlongY.tag       = 'Move along Y by'

    !this.teProfileOrientationY.val   = 'N'
    !this.teProfileOrientationZ.val   = 'U'

     !this.txXDir.val                 = 'E'
     !this.txYDir.val                 = 'N'

  else
    !this.txEast.tag                  = 'X'
    !this.txNorth.tag                 = 'Y'
    !this.txUp.tag                    = 'Z'

    !this.teProfilePositionEast.tag   = 'X'
    !this.teProfilePositionNorth.tag  = 'Y'
    !this.teProfilePositionUp.tag     = 'Z'

    !this.teVertexXPos.tag            = 'U Position'
    !this.teVertexYPos.tag            = 'V Position'

    !this.teGroupMoveAlongX.tag       = 'Move along U by'
    !this.teGroupMoveAlongY.tag       = 'Move along V by'

    !this.teProfileOrientationY.val  = 'Y'
    !this.teProfileOrientationZ.val  = 'Z'

     !this.txXDir.val                = 'X'
     !this.txYDir.val                = 'Y'
  endif
endmethod
-- End of method
