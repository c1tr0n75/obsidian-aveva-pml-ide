------------------------------------------------------------------------
--
-- Method:      positionLinear
--
-- Description: Positioning pick for linear elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Primary Prompt
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .positionLinear(!text is STRING)

  -- Set Data
  !this.description   = 'Linear position pick'
  !this.prompt        = !text
  !this.positioning   = false
  !this.numberOfPicks = 1
  !this.action        = '!this.position()'
  !this.pick.stdLinear()

endmethod
-- End of method definition for .positionLinear(STRING)

