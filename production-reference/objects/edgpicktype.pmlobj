    !positionData.position  = !!edgTypes.attribute(!positionData.item.fullType.upcase()).fraction(!positionData.item, !value, !positionData.pointVector, !!edgPosCntrl.intermediate)
    handle any
      !positionData.position  = !positionData.item.position
    endhandle

  -- Pline Picked
  elseif (!pickType eq 'PLINE') then
