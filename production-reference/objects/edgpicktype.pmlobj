    elseif (!aidType eq 'LINE') then
      !iPosition             = !aidElement.intersection(!positionData.pointVector)
      !line                  = object GMFLINE(!aidElement)
      !positionData.position = !line.fraction(!value, !iPosition)

    -- Plane
    elseif (!aidType eq 'PLANE') then
      !positionData.position = !positionData.pointVector.intersection(!aidElement)

    -- Plant Grid
    elseif (!aidType inset('PLANTGRID','LINEARGRID','RADIALGRID')) then
      !positionData.position = !aidElement.snap(!positionData.pointVector)

    else
      !!alert.error('Unable to derive a fractional position of graphical aid element of type ' &  !aidType & '')
      return error 1 noalert
    endif

  -- Graphic element
  elseif (!pickType eq 'GRAPHICS') then

    -- Determine the "snap" point on the graphic element
    -- Line
    if(!positionData.line.set()) then
      !iPosition             = !positionData.line.intersection(!positionData.pointVector)
      !line                  = object GMFLINE(!positionData.line)
      !positionData.position = !line.fraction(!value, !iPosition)

    -- Plane
    elseif (!positionData.plane.set()) then
      !positionData.position = !positionData.pointVector.intersection(!positionData.plane)
    endif

  -- Pins
  elseif (!pickType eq 'PIN') then

    !pinNumber = !positionData.pPoint
    if (!pinNumber.between(1,10)) then
      var !pinPosition pin $!pinNumber pos
      !positionData.position = !pinPosition.position()

    else
      -- Could be that the picked type is a special pin such as the aid ce arrow
      !!alert.error('Unable to derive snap position of picked element (' &  !pickType & ')')
      return error 1

    endif
  else
    !!alert.error('Unable to derive snap position of picked element (' &  !pickType & ')')
    return error 1

  endif

  -- Map position onto current active plane/grid
  !positionData.position   = !!edgPosCntrl.position(!positionData)

  -- Return
  return !positionData

endmethod
-- End of method definition for .fraction(REAL) ANY

