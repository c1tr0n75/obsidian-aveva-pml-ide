------------------------------------------------------------------------
--
-- Method:      setIntersect
--
-- Description: Pick type for intersection
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setIntersect()

  -- Initialise Variables
  !this.stdPosition(!this.prompt)
  !this.description   = 'Intersect'
  !this.action        = '!this.intersect()'
  !this.numberOfPicks = 1
  !this.pick.prompt   = 'Intersection['' & !this.minor & '']'

endmethod
-- End of method definition for .setIntersect()

------------------------------------------------------------------------
--
-- Method:      setProportion
--
-- Description: Pick type for proportion
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ANY         Proportion (must equate to a REAL)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setProportion(!data is ANY)

  -- Initialise Variables
  !this.stdPosition(!this.prompt)
  !this.description = 'Proportion'
  !this.action      = '!this.proportion(' & !data & ')'
--  !this.pick.prompt = 'proportion'
  !this.pick.prompt   = 'Proportion['' & ' & !data & ' & '']'

endmethod
-- End of method definition for .setProportion(ANY)

