--
------------------------------------------------------------------------

define method .setSnap()

  -- Initialise Variable
  !this.stdPosition(!this.prompt)
  !this.description = 'Snap'
  !this.action      = '!this.snap()'
  !this.pick.prompt = 'Snap'

