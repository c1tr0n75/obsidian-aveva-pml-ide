-- Method:      stdPosition
--
-- Description: Standard positioning pick type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Primary Prompt
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .stdPosition(!text is STRING)

  -- Set Data
  !this.description   = 'Standard Position Pick'
  !this.prompt        = !text
  !this.positioning   = true
  !this.numberOfPicks = 1
  !this.action        = '!this.snap()'
  !this.pick.stdAny()

endmethod
