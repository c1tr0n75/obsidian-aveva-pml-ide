-- End of method definition for .profile() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !profile(BOOLEAN)
--
-- Description: set the profile representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the profile representation]
--
------------------------------------------------------------------------
define method .profile(!value is BOOLEAN)

  !this.profile = !value

  if (!this.global) then
    if (!value) then
      REPRESENTATION PROFILE ON
