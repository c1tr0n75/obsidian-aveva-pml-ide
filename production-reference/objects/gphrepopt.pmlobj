-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the insulation translucency]
--
------------------------------------------------------------------------

define method .tubeTrans(!value is BOOLEAN)

  !this.hvacTubeTransorNot  = !value

endmethod

---------------------------------------------------------------------
-- Method:      !tubeTrans() is BOOLEAN
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the insulation translucency]
--
------------------------------------------------------------------------

define method .tubeTrans() is BOOLEAN

  return !this.hvacTubeTransorNot

endmethod

------------------------------------------------------------------------
--
