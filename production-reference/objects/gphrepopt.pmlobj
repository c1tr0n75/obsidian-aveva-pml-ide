-- Created:         Mon Aug 18 14:12:58 BST 1997
--
--
-- Description:
-- Object to store representation options
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  arcTolerance()                   REAL                get the arc tolerance
--  arcTolerance(REAL)               -                   set the arc tolerance
--  bolts()                          BOOLEAN             get the bolt holes representation state
--  bolts(BOOLEAN)                   -                   set the bolt holes representation state
--  cableCentreline()                BOOLEAN             get the cable centreLine
--  cableCentreline(BOOLEAN)         -
--  cableLevel()                     REAL                get the cableWay elements representation level
--  cableLevel(REAL)                 -
--  cableProfile()                   BOOLEAN             get the cable profile representation
--  cableProfile(BOOLEAN)            -
--  cableProfile(REAL)               -                   set the cable profile representation
--  cableProfileTrans()              REAL                get the cable profile translucency representation
--  cableProfileTrans(REAL)          -                   set the cable profile translucency
--  cableWayCentreline()             BOOLEAN             get the cableWay centreLine
--  cableWayCentreline(BOOLEAN)      -
--  cableWayObst()                   BOOLEAN             get the cableWay obstruction representation
--  cableWayObst(BOOLEAN)            -
--  cableWayObst(REAL)               -                   set the cableWay obstruction representation
--  cableWayObstTrans()              REAL                get the cableWay obstruction translucency representation
--  cableWayObstTrans(REAL)          -                   set the cableWay obstruction translucency
--  centreLine()                     BOOLEAN             get the centreLine representation
--  centreLine(BOOLEAN)              -                   set the centreLine representation
--  copyToCurrent()                  -                   copy the object to the current drawlist
--  copyToGlobal()                   -                   copy the object to the global instance
--  coreSettings()                   -                   Align all core settings with the member values
--  default(BOOLEAN)                 -                   Default options settings
--  edit()                           -                   edit the options via the GUI
--  generalLevel()                   REAL                get the general representation level
--  generalLevel(REAL)               -                   set the general representation level
--  getCoreSettings()                -                   Get all core settings and store in member values
--  globalInstance()                 -                   create a global instance of the object
--  gphRepOpt()                      -                   Constructor
--  gphRepOpt(BOOLEAN)               -                   Constructor
--  hAttas()                         BOOLEAN             get the hAttas representation state
--  hAttas(BOOLEAN)                  -                   set the hAttas representation state
--  hAttasColour()                   COLOUR              get the hAttas representation colour
--  hAttasColour(COLOUR)             -                   set the hAttas representation colour
--  hAttasColour(REAL)               -                   set the hAttas representation colour
--  hAttasColour(STRING)             -                   set the hAttas representation colour
--  hAttasSize()                     REAL                get the hAttas representation size
--  hAttasSize(REAL)                 -                   set the hAttas representation size
--  holes()                          BOOLEAN             get the holes representation state
--  holes(BOOLEAN)                   -                   set the holes representation state
--  hvacLevel()                      REAL                get the HVAC level representation
--  hvacLevel(REAL)                  -                   set the HVAC level representation
--  insulation()                     BOOLEAN             get the insulation representation
--  insulation(BOOLEAN)              -                   set the insulation representation
--  insulation(REAL)                 -                   set the insulation representation
--  insulationTrans()                REAL                get the insulation translucency representation
--  insulationTrans(REAL)            -                   set the insulation translucency
--  load()                           -                   Load options from system and user files
--  localCopy()                      GPHREPOPT           return a local copy of the object
--  massArcTolerance()               REAL                get the mass arc tolerance
--  massArcTolerance(REAL)           -                   set the mass arc tolerance
--  massLevel()                      REAL                get the mass representation level
--  massLevel(REAL)                  -                   set the mass representation level
--  monochrome()                     BOOLEAN             get monochrome state
--  monochrome(BOOLEAN)              -                   set monochrome state
--  nozzLevel()                      REAL                get the nozzle representation level
--  nozzLevel(REAL)                  -                   set the nozzle representation level
--  obstruction()                    BOOLEAN             get the obstruction representation
--  obstruction(BOOLEAN)             -                   set the obstruction representation
--  obstruction(REAL)                -                   set the obstruction representation
--  obstructionTrans()               REAL                get the obstruction translucency representation
--  obstructionTrans(REAL)           -                   set the obstruction translucency
--  pLines()                         BOOLEAN             get the pLines representation state
--  pLines(BOOLEAN)                  -                   set the pLines representation state
--  pLinesLength()                   REAL                get the pLines representation length
--  pLinesLength(REAL)               -                   set the pLines representation length
--  pLinesPkey()                     BOOLEAN             get the pLines pkey representation state
--  pLinesPkey(BOOLEAN)              -                   set the pLines pkey representation state
--  pNodes()                         BOOLEAN             get the pNodes representation state
--  pNodes(BOOLEAN)                  -                   set the pNodes representation state
--  pNodesColour()                   COLOUR              get the pNodes representation colour
--  pNodesColour(COLOUR)             -                   set the pNodes representation colour
--  pNodesColour(REAL)               -                   set the pNodes representation colour
--  pNodesColour(STRING)             -                   set the pNodes representation colour
--  pNodesSize()                     REAL                get the pNodes representation size
--  pNodesSize(REAL)                 -                   set the pNodes representation size
--  pPoints()                        BOOLEAN             get the pPoint representation state
--  pPoints(BOOLEAN)                 -                   set the pPoint representation state
--  pPointsLength()                  REAL                get the pPoint representation length
--  pPointsLength(REAL)              -                   set the pPoint representation length
--  pPointsNumbers()                 BOOLEAN             get the pPoint numbers representation state
--  pPointsNumbers(BOOLEAN)          -                   set the pPoint numbers representation state
--  pipeLevel()                      REAL                get the pipe level representation
--  pipeLevel(REAL)                  -                   set the pipe level representation
--  profile()                        BOOLEAN             get the profile representation
--  profile(BOOLEAN)                 -                   set the profile representation
--  profileCl()                      BOOLEAN             get the profile centreLine representation. - The toggle that uses this on the
--  profileCl(BOOLEAN)               -                   set the profile centreLine representation - The toggle that uses this on the
--  profileInsu()                    BOOLEAN             get the profile insulation representation
--  profileInsu(BOOLEAN)             -                   set the profile insulation representation
--  profileObst()                    BOOLEAN             get the profile obstruction representation
--  profileObst(BOOLEAN)             -
--  profileObst(REAL)                -                   set the profile obstruction representation
--  profileObstTrans()               REAL                get the profile obstruction translucency representation
--  profileObstTrans(REAL)           -                   set the profile obstruction translucency
--  rAttas()                         BOOLEAN             get the rAttas representation state
--  rAttas(BOOLEAN)                  -                   set the rAttas representation state
--  rAttasColour()                   COLOUR              get the rAttas representation colour
--  rAttasColour(COLOUR)             -                   set the rAttas representation colour
--  rAttasColour(REAL)               -                   set the rAttas representation colour
--  rAttasColour(STRING)             -                   set the rAttas representation colour
--  rAttasSize()                     REAL                get the rAttas representation size
--  rAttasSize(REAL)                 -                   set the rAttas representation size
--  rNodes()                         BOOLEAN             get the rNodes representation state
--  rNodes(BOOLEAN)                  -                   set the rNodes representation state
--  rNodesColour()                   COLOUR              get the rNodes representation colour
--  rNodesColour(COLOUR)             -                   set the rNodes representation colour
--  rNodesColour(REAL)               -                   set the rNodes representation colour
--  rNodesColour(STRING)             -                   set the rNodes representation colour
--  rNodesSize()                     REAL                get the rNodes representation size
--  rNodesSize(REAL)                 -                   set the rNodes representation size
--  save()                           -                   Save options settings to %AVEVA_DESIGN_USER%
--  snodes()                         BOOLEAN             get the snodes representation state
--  snodes(BOOLEAN)                  -                   set the snodes representation state
--  snodesColour()                   COLOUR              get the snodes representation colour
--  snodesColour(COLOUR)             -                   set the snodes representation colour
--  snodesColour(REAL)               -                   set the snodes representation colour
--  snodesColour(STRING)             -                   set the snodes representation colour
--  snodesSize()                     REAL                get the snodes representation size
--  snodesSize(REAL)                 -                   set the snodes representation size
--  struLevel()                      REAL                get the structure representation level
--  struLevel(REAL)                  -                   set the structure representation level
--  tracing()                        BOOLEAN             get the tracing representation state
--  tracing(BOOLEAN)                 -                   set the tracing representation state
--  tube()                           BOOLEAN             get the tube representation
--  tube(BOOLEAN)                    -                   set the tube representation
--  tubeTrans()                      BOOLEAN
--  tubeTrans(BOOLEAN)               -                   set the insulation representation
--  tubeTrans(REAL)                  -
--  tubeTranslation()                REAL
--  tubeTranslation(REAL)            -                   set the insulation representation
--  update()                         -                   update all graphics representation
--  volumeOption()                   STRING              get volume option representation
--  volumeOption(STRING)             -                   set volume option representation
--  volumeOptionGlobal()             STRING              get volume global setting
--
------------------------------------------------------------------------

-- Define object
define object GPHREPOPT

  -- current options file name for this object
  member .filename         is STRING

  -- global object flag, if set then global core options are also set
  member .global           is BOOLEAN

  -- members to store pipe representation settings
  member .centreLine       is BOOLEAN
  member .tube             is BOOLEAN
  member .obstruction      is BOOLEAN
  member .insulation       is BOOLEAN
  --for tube translucency
  member .hvacTubeTransorNot   is BOOLEAN

  -- members to store profile representation settings
  member .profile          is BOOLEAN
  member .profileCl        is BOOLEAN
  member .profileObst      is BOOLEAN
  member .profileObstTrans is REAL
  member .profileInsu      is BOOLEAN

  -- members to store cable way options
  member .cableWayCentreline  is BOOLEAN
  member .cableWayObst        is BOOLEAN
  member .cableWayObstTrans   is REAL
 -- old members for upwards compatibility
  member .cableObst        is BOOLEAN
  member .cableObstTrans   is REAL

  -- members to store cable options
  member .cableCentreline   is BOOLEAN
  member .cableProfile      is BOOLEAN
  member .cableProfileTrans is REAL

  -- members to store pNode representation settings
  member .pNodes           is BOOLEAN
  member .pNodesSize       is REAL
  member .pNodesColour     is COLOUR

  -- members to store snode representation settings
  member .snodes           is BOOLEAN
  member .snodesSize       is REAL
  member .snodesColour     is COLOUR

  -- members to store hAtta representation settings
  member .hAttas           is BOOLEAN
  member .hAttasSize       is REAL
  member .hAttasColour     is COLOUR

  -- members to store rAtta representation settings
  member .rAttas           is BOOLEAN
  member .rAttasSize       is REAL
  member .rAttasColour     is COLOUR

  -- members to store rNode representation settings
  member .rNodes           is BOOLEAN
  member .rNodesSize       is REAL
  member .rNodesColour     is COLOUR

  -- members to store pPoint representation settings
  member .pPoints          is BOOLEAN
  member .pPointsLength    is REAL
  member .pPointsNumbers   is BOOLEAN

  -- members to store pLine representation settings
  member .pLines           is BOOLEAN
  member .pLinesPkey       is BOOLEAN
  member .pLinesLength     is REAL

  -- members to store drawing levels
  member .pipeLevel        is REAL
  member .nozzLevel        is REAL
  member .struLevel        is REAL
  member .generalLevel     is REAL
  member .massLevel        is REAL
  member .cableLevel       is REAL
  member .hvacLevel        is REAL

  -- members to store other representation settings
  member .holes            is BOOLEAN
  member .bolts            is BOOLEAN
  member .tracing          is BOOLEAN
  member .arcTolerance     is REAL
  member .massArcTolerance is REAL
  member .volumeOption     is STRING

  -- Translucency for insulation and obstruction
  member .insulationTrans  is REAL
  member .obstructionTrans is REAL

  --added for tube translucency
  member .hvacTubeTrans is REAL

  member .monochrome is BOOLEAN

endobject
-- End of object definition for GPHREPOPT

------------------------------------------------------------------------
--
-- Method:      !gphRepOpt()
--
-- Description: Constructor
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .gphRepOpt()

  -- set file name
  !module = !!module()
  !this.filename = !module.appKey + '-rep.pmldat'

  -- initialise the global flag
  !this.global = false

  !this.hvacTubeTransorNot = false
  !this.hvacTubeTrans = 0
  -- set the default values
  !this.default(false)


endmethod
-- End of method definition for .gphRepOpt()

------------------------------------------------------------------------
--
-- Method:      !gphRepOpt(BOOLEAN)
--
-- Description: Constructor
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [flag to indicate global instance of object]
--
------------------------------------------------------------------------
define method .gphRepOpt(!globalValue is BOOLEAN)

  -- set file name
  !module = !!module()
  !this.filename = !module.appKey + '-rep.pmldat'

  -- initialise the global flag
  !this.global = !globalValue

  !this.hvacTubeTransorNot = false
  -- set the default values
  !this.default(!globalValue)

endmethod
-- End of method definition for .gphRepOpt(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !default(BOOLEAN)
--
-- Description: Default options settings
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [flag to indicate global instance of object]
--
------------------------------------------------------------------------
define method .default(!setCore is BOOLEAN)

  -- define default settings here
  !this.centreLine     = FALSE
  !this.tube           = TRUE
  !this.obstruction    = FALSE
  !this.insulation     = FALSE
  --for tube translucency
  !this.hvacTubeTransorNot = FALSE

  !this.profile        = TRUE
  !this.profileCl      = FALSE
  !this.profileObst    = FALSE
  !this.profileInsu    = FALSE

  !this.cableProfile       = FALSE
  !this.cableCentreline    = TRUE
  !this.cableWayObst       = FALSE
  !this.cableObst          = FALSE
  !this.cableWayCentreline = FALSE
  !this.pNodes             = TRUE
  !this.pNodesSize         = 100mm
  !this.pNodesColour.colour('brightred')

  !this.snodes         = TRUE
  !this.snodesSize     = 50mm
  !this.snodesColour.colour('gold')

  !this.hAttas         = TRUE
  !this.hAttasSize     = 50mm
  !this.hAttasColour.colour('gold')

  !this.rAttas         = TRUE
  !this.rAttasSize     = 50mm
  !this.rAttasColour.colour('gold')

  !this.rNodes         = TRUE
  !this.rNodesSize     = 50mm
  !this.rNodesColour.colour('gold')

  !this.pPoints        = FALSE
  !this.pPointsLength  = 50mm
  !this.pPointsNumbers = FALSE

  !this.pLines         = FALSE
  !this.pLinesLength   = 50mm
  !this.pLinesPkey     = FALSE

  !this.pipeLevel      = 6
  !this.nozzLevel      = 6
  !this.struLevel      = 6
  !this.generalLevel   = 6
  !this.massLevel      = 6
  !this.cableLevel     = 6
  !this.hvacLevel      = 6

  !this.holes          = TRUE
  !this.bolts          = FALSE
  !this.tracing        = FALSE
  !this.volumeOption   = 'Hull Production'

  !this.monochrome = FALSE

  --  var !arcTol REPRE DARCTOL
  --  !this.arcTolerance = !arcTol.real(!!distancefmt)
  !this.arcTolerance     = 1mm

  var !marctol REPRE MARCTOL
  !this.massArcTolerance = !marctol.real(!!distancefmt)

  -- use different defaults if the units are imperial
  if (!!isImperialLength('DIST')) then
    !this.pNodesSize     = 4in
    !this.snodesSize     = 2in
    !this.pPointsLength  = 2in
    !this.pLinesLength   = 2in
    !this.arcTolerance   = 1/16in
  endif

  if (!setCore) then
    !this.coreSettings()
  endif

endmethod
-- End of method definition for .default(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !globalInstance()
--
-- Description: create a global instance of the object
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .globalInstance()

  -- create the global instance of this object
  !!gphRepOpt = !this
  !!gphRepOpt.global = true

  -- load the options
  !!gphRepOpt.load()

endmethod
-- End of method definition for .globalInstance()

------------------------------------------------------------------------
--
-- Method:      !localCopy()
--
-- Description: return a local copy of the object
--
-- Method Type: Function
-- Return:
--   [GPHREPOPT] [local copy of object]
--
------------------------------------------------------------------------
define method .localCopy() is GPHREPOPT

  -- update object with core settings before creating local copy
  !this.getCoreSettings()

  -- copy this object to a local variable and unset the global flag
  !tempObject = !this
  !tempObject.global = false

  return !tempObject

endmethod
-- End of method definition for .localCopy() GPHREPOPT

------------------------------------------------------------------------
--
-- Method:      !copyToGlobal()
--
-- Description: copy the object to the global instance
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .copyToGlobal()

  !!gphRepOpt = !this
  !!gphRepOpt.global = true
  !!gphRepOpt.coreSettings()

endmethod
-- End of method definition for .copyToGlobal()

------------------------------------------------------------------------
--
-- Method: .coreSettings()
--
-- Description: Align all core settings with the member values
--
-- Method Type: Procedure
--
-- *** OLD STYLE PML ***
-- *** COMMAND LINE SYNTAX ***
--
------------------------------------------------------------------------
define method .coreSettings()

  if (!this.centreLine) then
    REPRESENTATION CENTRELINE ON
  else
    REPRESENTATION CENTRELINE OFF
  endif

  if (!this.tube) then
    REPRESENTATION TUBE ON
  else
    REPRESENTATION TUBE OFF
  endif

  if (!this.obstruction) then
    if(!this.obstructionTrans.set()) then
      REPRESENTATION OBSTRUCTION ON TRANSLUCENCY $!<this.obstructionTrans>
    else
      REPRESENTATION OBSTRUCTION ON
    endif
  else
    REPRESENTATION OBSTRUCTION OFF
  endif

  if (!this.insulation) then
    if(!this.insulationTrans.set()) then
      REPRESENTATION INSULATION ON TRANSLUCENCY $!<this.insulationTrans>
    else
      REPRESENTATION INSULATION ON
    endif
  else
    REPRESENTATION INSULATION OFF
  endif

  if(!this.hvacTubeTransorNot) then
    REPRESENTATION HTUBE ON TRANSLUCENCY $!<this.hvacTubeTrans>
  else
    REPRESENTATION HTUBE OFF TRANSLUCENCY 0
  endif


  if (!this.profile) then
    REPRESENTATION PROFILE ON
  else
    REPRESENTATION PROFILE OFF
  endif

  if (!this.profileCl) then
    REPRESENTATION PROFILE CENTRELINE ON
  else
    REPRESENTATION PROFILE CENTRELINE OFF
  endif

  if (!this.profileObst) then
    if(!this.profileObstTrans.set()) then
      REPRESENTATION PROFILE OBSTRUCTION ON TRANSLUCENCY $!<this.profileObstTrans>
    else
      REPRESENTATION PROFILE OBSTRUCTION ON
    endif
  else
    REPRESENTATION PROFILE OBSTRUCTION OFF
  endif

  if (!this.profileInsu) then
    REPRESENTATION PROFILE INSULATION ON
  else
    REPRESENTATION PROFILE INSULATION OFF
  endif

  if (!this.cableWayObst) then
    if(!this.cableWayObstTrans.set()) then
      REPRESENTATION CABLEWAY OBSTRUCTION ON TRANSLUCENCY $!<this.cableWayObstTrans>
    else
      REPRESENTATION CABLEWAY OBSTRUCTION ON
    endif
  else
    REPRESENTATION CABLEWAY OBSTRUCTION OFF
  endif

  -- maintain old settings files

  if (!this.cableObst) then
    if(!this.cableObstTrans.set()) then
      REPRESENTATION CABLEWAY OBSTRUCTION ON TRANSLUCENCY $!<this.cableObstTrans>
    else
      REPRESENTATION CABLEWAY OBSTRUCTION ON
    endif
  endif

  if (!this.cableWayCentreline) then
    REPRESENTATION CABLEWAY CL ON
  else
    REPRESENTATION CABLEWAY CL OFF
  endif

  -- cable

  if (!this.cableCentreline) then
    REPRESENTATION CABLE CL ON
  else
    REPRESENTATION CABLE CL OFF
  endif

  if (!this.cableProfile) then
    if(!this.cableProfileTrans.set()) then
      REPRESENTATION CABLE PROFILE ON TRANSLUCENCY $!<this.cableProfileTrans>
    else
      REPRESENTATION CABLE PROFILE ON
    endif
  else
    REPRESENTATION CABLE PROFILE OFF
  endif

  REPRESENTATION LEVEL PIPE $!<this.pipeLevel>
  REPRESENTATION LEVEL NOZZLE $!<this.nozzLevel>
  REPRESENTATION LEVEL STRUCTURE $!<this.struLevel>
  REPRESENTATION LEVEL  $!<this.generalLevel>
  REPRESENTATION MASS $!<this.massLevel>
  REPRESENTATION LEVEL CABLE $!<this.cableLevel>
  REPRESENTATION LEVEL HVAC $!<this.hvacLevel>

  if (!this.pPoints) then
    REPRESENTATION PPOINTS ON
  else
    REPRESENTATION PPOINTS OFF
  endif

  !tempSize = !this.pPointsLength.queryString()
  REPRESENTATION PPOINTS LENGTH  $!<tempSize>

  if (!this.pPointsNumbers) then
    REPRESENTATION PPOINTS NUMBERS ON
  else
    REPRESENTATION PPOINTS NUMBERS OFF
  endif
  if (!this.pNodes) then
    REPRESENTATION PNODES ON
  else
    REPRESENTATION PNODES OFF
  endif

  !tempSize = !this.pNodesSize.queryString()
  REPRESENTATION PNODES SIZE $!<tempSize>

  !colString = !this.pNodesColour.string()
  REPRESENTATION PNODES COLOUR $!<colString>

  if (!this.snodes) then
    REPRESENTATION SNODES ON
  else
    REPRESENTATION SNODES OFF
  endif

  !tempSize = !this.snodesSize.queryString()
  REPRESENTATION SNODES SIZE $!<tempSize>

  !colString = !this.snodesColour.string()
  REPRESENTATION SNODES COLOUR $!<colString>

  if (!this.hAttas) then
    REPRESENTATION HATTA ON
  else
    REPRESENTATION HATTA OFF
  endif

  REPRESENTATION HATTA SIZE $!<this.hAttasSize>

  !colString = !this.hAttasColour.string()
  REPRESENTATION HATTA COLOUR $!<colString>

  if (!this.rAttas) then
    REPRESENTATION RATTA ON
  else
    REPRESENTATION RATTA OFF
  endif

  REPRESENTATION RATTA SIZE $!<this.rAttasSize>

  !colString = !this.rAttasColour.string()
  REPRESENTATION RATTA COLOUR $!<colString>

  if (!this.rNodes) then
    REPRESENTATION RNODE ON
  else
    REPRESENTATION RNODE OFF
  endif

  REPRESENTATION RNODE SIZE $!<this.rNodesSize>

  !colString = !this.rNodesColour.string()
  REPRESENTATION RNODE COLOUR $!<colString>


  if (!this.pLines) then
    REPRESENTATION PLINES ON
  else
    REPRESENTATION PLINES OFF
  endif

  !tempSize = !this.pLinesLength.queryString()
  REPRESENTATION PLINES LENGTH $!<tempSize>

  if (!this.pLinesPkey) then
    REPRESENTATION PLINES PKEY ON
  else
    REPRESENTATION PLINES PKEY OFF
  endif
  if (!this.holes) then
    REPRESENTATION HOLES ON
  else
    REPRESENTATION HOLES OFF
  endif
  if (!this.bolts) then
    REPRESENTATION BOLTS ON
  else
    REPRESENTATION BOLTS OFF
  endif
  if (!this.tracing) then
    REPRESENTATION TRACING ON
  else
    REPRESENTATION TRACING OFF
  endif
  -- this arctol is in current units
  !tempSize = !this.arcTolerance.queryString()
  REPRESENTATION DARCTOLERANCE $!<tempSize>
  handle (61,176)
    -- minimum value is 0.1mm
    REPRESENTATION DARCTOLERANCE 1mm
  endhandle
  !tempSize = !this.massArcTolerance.queryString()
  REPRESENTATION MASS ARCTOLERANCE $!<tempSize>
  handle (61,177)
    -- minimum value is 0.25mm
    REPRESENTATION MASS ARCTOLERANCE 1mm
  endhandle

  if (!!ce.dbType.eq('DESI')) then
    !hvacTubeTrans = !this.tubeTranslation()
    if(!hvacTubeTrans.gt(0)) then
      REPRESENTATION HTUBE ON TRANSLUCENCY $!<hvacTubeTrans>
    else
      REPRESENTATION HTUBE OFF TRANSLUCENCY 0
    endif
  endif

  -- Volume Option

  if (!this.volumeOption.eq('Hull Design')) then
    VOLUMEOPTION HULL PRODUCTION OFF
    VOLUMEOPTION HULL DESIGN ON
  elseif (!this.volumeOption.eq('Hull Production')) then
    VOLUMEOPTION HULL DESIGN OFF
    VOLUMEOPTION HULL PRODUCTION ON
  endif

  -- Set all drawLists
  do !drawlist val !!gphDrawlists.drawlists

    -- Ignore any drawList where the value has already been set (by REPR above)
    skip if (!drawlist.holes().eq(!this.holes))

    -- Holes
    !drawlist.holes(!this.holes)

    -- Update
    !drawlist.update()

  enddo

  !module = !!module().fullName
  handle any
  elsehandle none
    if (!module.upCase().eq('DESIGN')) then
      --supports needs to track session levels to ensure that rest elements are displayed correctly
      --if the supports object exists then reset the levels members in the object to the new ones set in core appware
      if (defined(!!supportsRepLevelObject)) then
        !!supportsRepLevelObject.resetSessionLevels()
        handle any
        endhandle
      endif
    endif
  endhandle
endmethod
-- End of method definition for .coreSettings()

------------------------------------------------------------------------
--
-- Method: !getCoreSettings()
--
-- Description: Get all core settings and store in member values
--
-- Method Type: Procedure
--
-- *** OLD STYLE PML IF NOT IN DES***
-- *** PML2 DRAWLIST IF IN DES***
-- *** COMMAND LINE SYNTAX ***
--
------------------------------------------------------------------------
define method .getCoreSettings()

  !mod = !!module().appKey.upCase()
  if (!mod eq 'DES') then
    !form = !!fmSys.currentDocument()
    if( !form.set() ) then
      !gphView  = !!fmSys.currentDocument().view
      !drawlist = !!gphDrawlists.drawlist(!gphView)

      !this.centreLine =  !drawlist.centreLine()
      !this.tube = !drawlist.tube()
      !this.obstruction = !drawlist.obstruction()
      if (!this.obstruction) then
        !this.obstructionTrans = !drawlist.obstructionTrans()
      else
        !this.obstructionTrans = REAL()
      endif

      !this.insulation = !drawlist.insulation()
      if (!this.insulation) then
        !this.insulationTrans = !drawlist.insulationTrans()
      else
        !this.insulationTrans = REAL()
      endif
      !hvacTube = !drawlist.hvacTube()
      if (!hvacTube ) then
        !this.hvacTubeTrans = !drawlist.hvacTubeTrans()
      else
        !this.hvacTubeTrans = 0
      endif
      !this.holes = !drawlist.holes()
      !this.bolts = !drawlist.bolts()

      !this.tracing = !drawlist.tracing()

      !this.pPoints = !drawlist.pPoints()
      !this.pPointsLength = !drawlist.pPointsLength()
      !this.pPointsNumbers = !drawlist.pPointNumbers()

      !this.pipeLevel = !drawlist.pipeLevel()
      !this.nozzLevel = !drawlist.nozzLevel()
      !this.struLevel = !drawlist.struLevel()
      !this.generalLevel = !drawlist.level()
      !this.massLevel = !drawlist.massLevel()
      !this.cableLevel = !drawlist.cableLevel()
      !this.hvacLevel = !drawlist.hvacLevel()

      !this.arcTolerance = !drawlist.arcTol()
      !this.massArcTolerance = !drawlist.massArcTol()

      !this.pNodes = !drawlist.pNode()
      !this.pNodesSize = !drawlist.pNodeSize()
      !this.pNodesColour.colour(!drawlist.pNodeColour())

      !this.snodes = !drawlist.snode()
      !this.snodesSize = !drawlist.snodeSize()
      !this.snodesColour.colour(!drawlist.snodeColour())

      !this.pLines = !drawlist.pLine()
      !this.pLinesLength = !drawlist.pLineLength()
      !this.pLinesPkey = !drawlist.pkey()

      !this.hAttas = !drawlist.hAtta()
      !this.hAttasSize = !drawlist.hAttaSize()
      !this.hAttasColour.colour(!drawlist.hAttaColour())

      !this.rAttas = !drawlist.rAtta()
      !this.rAttasSize = !drawlist.rAttaSize()
      !this.rAttasColour.colour(!drawlist.rAttaColour())

      !this.rNodes = !drawlist.rNode()
      !this.rNodesSize =!drawlist.rNodeSize()
      !this.rNodesColour.colour(!drawlist.rNodeColour())
      !this.cableWayCentreline = !drawlist.cableWayCentreline()
      !this.cableCentreline = !drawlist.cableCentreline()

      !this.profile = !drawlist.profile()
      !this.profileCl = !drawlist.profileCentreLine()
      !this.profileObst = !drawlist.profileObst()
      !this.profileInsu = !drawlist.profileInsu()
      if (!this.profileObst) then
        !this.profileObstTrans = !drawlist.profileObstTrans()
      else
        !this.profileObstTrans = REAL()
      endif

      !this.cableWayObst = !drawlist.cableWayObst()
      if (!this.cableWayObst) then
        !this.cableWayObstTrans = !drawlist.cableWayObstTrans()
      else
        !this.cableWayObstTrans = REAL()
      endif

      !this.cableProfile = !drawlist.cableProfile()
      if (!this.cableProfile) then
        !this.cableProfileTrans = !drawlist.cableProfileTrans()
      else
        !this.cableProfileTrans = REAL()
      endif
      !token = !!gphDrawlists.token(!gphView)
      
      !this.monochrome = define(!!gphDrawlists.monoControl[!token])
    
    else
      !!alert.error('Please create a graphical view for this function to operate on')
    endif
  else
    -- get core representation settings into an array
    var !cs split REPRESENTATION
    -- go through array and assign values to object members
    !this.centreLine = !cs[1].boolean()
    !this.tube = !cs[2].boolean()
    !this.obstruction = !cs[3].boolean()
    if (!this.obstruction) then
      !this.obstructionTrans = !cs[4].real()
    else
      !this.obstructionTrans = REAL()
    endif

    !this.insulation = !cs[5].boolean()
    if (!this.insulation) then
      !this.insulationTrans = !cs[6].real()
    else
      !this.insulationTrans = REAL()
    endif

    !this.holes = !cs[7].boolean()

    var !bolts REPRE BOLTS
    !this.bolts = !bolts.boolean()

    var !tracing REPRE tracing
    !this.tracing = !tracing.boolean()

    !this.pPoints = !cs[8].boolean()
    !this.pPointsLength = REAL(!cs[9], !!distancefmt)
    !this.pPointsNumbers = !cs[10].boolean()

    !this.pipeLevel = !cs[12].real()
    !this.nozzLevel = !cs[13].real()
    !this.struLevel = !cs[14].real()
    !this.generalLevel = !cs[11].real()
    !this.massLevel = !cs[15].real()
    !this.cableLevel = !cs[16].real()
    !this.hvacLevel = !cs[17].real()

    var !arcTol REPRE DARCTOL
    !this.arcTolerance = REAL(!arcTol, !!distancefmt)

    var !marctol REPRE MARCTOL
    !this.massArcTolerance = REAL(!marctol, !!distancefmt)

    !this.pNodes = !cs[20].boolean()
    !this.pNodesSize = REAL(!cs[21], !!distancefmt)
    !this.pNodesColour.colour(!cs[22].real())

    !this.snodes = !cs[23].boolean()
    !this.snodesSize = REAL(!cs[24], !!distancefmt)
    !this.snodesColour.colour(!cs[25].real())

    !this.pLines = !cs[27].boolean()
    !this.pLinesLength = REAL(!cs[28], !!distancefmt)
    !this.pLinesPkey = !cs[29].boolean()

    !this.hAttas = !cs[30].boolean()
    !this.hAttasSize = REAL(!cs[31], !!distancefmt)
    !this.hAttasColour.colour(!cs[32].real())

    !this.rAttas = !cs[33].boolean()
    !this.rAttasSize = REAL(!cs[34], !!distancefmt)
    !this.rAttasColour.colour(!cs[35].real())

    !this.rNodes = !cs[36].boolean()
    !this.rNodesSize = REAL(!cs[37], !!distancefmt)
    !this.rNodesColour.colour(!cs[38].real())
    var !ccl repre cableway CL
    !this.cableWayCentreline = !ccl.boolean()
    var !ccl repre cable CL
    !this.cableCentreline = !ccl.boolean()

    -- profile settings not output with 'var !cs split REPRESENTATION' command
    -- clear array before populating with new values
    !cs = ARRAY()
    var !cs split REPRESENTATION PROFILE
    !this.profile = !cs[2].boolean()
    !this.profileCl = !cs[1].boolean()
    !this.profileObst = !cs[3].boolean()
    !this.profileInsu = !cs[4].boolean()
    if (!this.profileObst) then
      var !tmp REPRESENTATION PROFILE OBSTRUCTION TRANSLUCENCY
      !this.profileObstTrans = !tmp.real()
    else
      !this.profileObstTrans = REAL()
    endif

    !cs = ARRAY()
    var !cs split REPRESENTATION CABLEWAY
    !this.cableWayObst = !cs[1].boolean()
    if (!this.cableWayObst) then
      var !tmp REPRESENTATION CABLEWAY OBSTRUCTION TRANSLUCENCY
      !this.cableWayObstTrans = !tmp.real()
    else
      !this.cableWayObstTrans = REAL()
    endif

    !cs = ARRAY()
    var !cs split REPRESENTATION CABLE
    !this.cableProfile = !cs[1].boolean()
    if (!this.cableProfile) then
      var !tmp REPRESENTATION CABLE PROFILE TRANSLUCENCY
      !this.cableProfileTrans = !tmp.real()
    else
      !this.cableProfileTrans = REAL()
    endif
  endif

endmethod
-- End of method definition for .getCoreSettings()
------------------------------------------------------------------------
--
-- Method: !load()
--
-- Description: Load options from system and user files
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .load()

  -- get the locations of system options file and user options file
  !optionFiles = !!comGetOptFiles(!this.filename)
  -- create a temporary global variable to store the data
  if (defined(!!tmpGphRepOpt)) then
    !!tmpGphRepOpt.delete()
  endif
  !!tmpGphRepOpt = !this

  -- if a system options file has been found, load the data
  if (defined(!optionFiles[1])) then
    -- load options file
    !localName = !optionFiles[1].fullName()
    $m "$!<localName>"
    handle any
      !!messageFile.warning(146, 31, !optionFiles[1].fullName())
      !this.default(false)
    endhandle
  endif

  -- if a user options file has been found, load the options
  if (defined(!optionFiles[2])) then
    -- load options file
    !localName = !optionFiles[2].fullName()
    $m "$!<localName>"
    handle any
      !!messageFile.warning(146, 32, !optionFiles[2].fullName())
      !this.default(false)
    endhandle
  endif

  !this = !!tmpGphRepOpt
  !this.coreSettings()

  !!tmpGphRepOpt.delete()

endmethod
-- End of method definition for .load()

------------------------------------------------------------------------
--
-- Method: !save()
--
-- Description: Save options settings to %AVEVA_DESIGN_USER%
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .save()

  -- initialise array to contain strings for options file
  !saveContents = ARRAY()

  -- write header information
  !saveContents.append('-- Data file for graphical representation options')
  !saveContents.append('')

  ----------------------------------------------------------------------
  -- user options are saved for all users
  ----------------------------------------------------------------------
  !saveContents.append('!!tmpGphRepOpt.centreLine = ' & !this.centreLine)
  !saveContents.append('!!tmpGphRepOpt.tube = ' & !this.tube)
  !saveContents.append('!!tmpGphRepOpt.obstruction = ' & !this.obstruction)
  if (!this.obstructionTrans.set()) then
    !saveContents.append('!!tmpGphRepOpt.obstructionTrans = ' & !this.obstructionTrans)
  endif

  !saveContents.append('!!tmpGphRepOpt.insulation = ' & !this.insulation)
  if (!this.insulationTrans.set()) then
    !saveContents.append('!!tmpGphRepOpt.insulationTrans = ' & !this.insulationTrans)
  endif

  !saveContents.append('!!tmpGphRepOpt.profile = ' & !this.profile)
  !saveContents.append('!!tmpGphRepOpt.profileCl = ' & !this.profileCl)

  !saveContents.append('!!tmpGphRepOpt.profileObst = ' & !this.profileObst)
  if (!this.profileObstTrans.set()) then
    !saveContents.append('!!tmpGphRepOpt.profileObstTrans = ' & !this.profileObstTrans)
  endif

  !saveContents.append('!!tmpGphRepOpt.profileInsu = ' & !this.profileInsu)
  !saveContents.append('!!tmpGphRepOpt.pNodes = ' & !this.pNodes)
  !saveContents.append('!!tmpGphRepOpt.pNodesSize = ' + !this.pNodesSize.queryString())
  !saveContents.append('!!tmpGphRepOpt.pNodesColour(' & !!comQuoteIfString(!this.pNodesColour.key()) & ')')

  !saveContents.append('!!tmpGphRepOpt.snodes = ' & !this.snodes)
  !saveContents.append('!!tmpGphRepOpt.snodesSize = ' + !this.snodesSize.queryString())
  !saveContents.append('!!tmpGphRepOpt.snodesColour.colour(' & !!comQuoteIfString(!this.snodesColour.key()) & ')')

  !saveContents.append('!!tmpGphRepOpt.pPoints = ' & !this.pPoints)
  !saveContents.append('!!tmpGphRepOpt.pPointsLength = ' + !this.pPointsLength.queryString())
  !saveContents.append('!!tmpGphRepOpt.pPointsNumbers = ' & !this.pPointsNumbers)

  !saveContents.append('!!tmpGphRepOpt.pLines = ' & !this.pLines)
  !saveContents.append('!!tmpGphRepOpt.pLinesLength = ' + !this.pLinesLength.queryString())
  !saveContents.append('!!tmpGphRepOpt.pLinesPkey = ' & !this.pLinesPkey)

  !saveContents.append('!!tmpGphRepOpt.pipeLevel = ' & !this.pipeLevel)
  !saveContents.append('!!tmpGphRepOpt.nozzLevel = ' & !this.nozzLevel)
  !saveContents.append('!!tmpGphRepOpt.struLevel = ' & !this.struLevel)
  !saveContents.append('!!tmpGphRepOpt.generalLevel = ' & !this.generalLevel)
  !saveContents.append('!!tmpGphRepOpt.massLevel = ' & !this.massLevel)
  !saveContents.append('!!tmpGphRepOpt.cableLevel = ' & !this.cableLevel)
  !saveContents.append('!!tmpGphRepOpt.hvacLevel = ' & !this.hvacLevel)

  !saveContents.append('!!tmpGphRepOpt.cableWayObst = ' & !this.cableWayObst)
  if (!this.cableWayObst.set() and !this.cableWayObstTrans.set()) then
    !saveContents.append('!!tmpGphRepOpt.cableWayObstTrans = ' & !this.cableWayObstTrans)
  endif

  !saveContents.append('!!tmpGphRepOpt.cableWayCentreline = ' & !this.cableWayCentreline)

  !saveContents.append('!!tmpGphRepOpt.cableProfile = ' & !this.cableProfile)
  if (!this.cableProfile.set() and !this.cableProfileTrans.set()) then
    !saveContents.append('!!tmpGphRepOpt.cableProfileTrans = ' & !this.cableProfileTrans)
  endif

  !saveContents.append('!!tmpGphRepOpt.cableCentreline = ' & !this.cableCentreline)

  !saveContents.append('!!tmpGphRepOpt.hAttas = ' & !this.hAttas)
  !saveContents.append('!!tmpGphRepOpt.hAttasSize = ' & !this.hAttasSize)
  !saveContents.append('!!tmpGphRepOpt.hAttasColour.colour(' & !!comQuoteIfString(!this.hAttasColour.key()) & ')')

  !saveContents.append('!!tmpGphRepOpt.rAttas = ' & !this.rAttas)
  !saveContents.append('!!tmpGphRepOpt.rAttasSize = ' & !this.rAttasSize)
  !saveContents.append('!!tmpGphRepOpt.rAttasColour.colour(' & !!comQuoteIfString(!this.rAttasColour.key()) & ')')

  !saveContents.append('!!tmpGphRepOpt.rNodes = ' & !this.rNodes)
  !saveContents.append('!!tmpGphRepOpt.rNodesSize = ' & !this.rNodesSize)
  !saveContents.append('!!tmpGphRepOpt.rNodesColour.colour(' & !!comQuoteIfString(!this.rNodesColour.key()) & ')')

  !saveContents.append('!!tmpGphRepOpt.holes = ' & !this.holes)
  !saveContents.append('!!tmpGphRepOpt.bolts = ' & !this.bolts)

  !saveContents.append('!!tmpGphRepOpt.arcTolerance = ' + !this.arcTolerance.queryString())
  !saveContents.append('!!tmpGphRepOpt.massArcTolerance = ' + !this.massArcTolerance.queryString())

  !saveContents.append('!!tmpGphRepOpt.tracing = ' & !this.tracing)
  !saveContents.append('!!tmpGphRepOpt.hvacTubeTrans = ' & !this.hvacTubeTrans)

  !saveContents.append('!!tmpGphRepOpt.volumeOption = ' & !!comQuoteIfString(!this.volumeOption) )

  !!writeFile('%AVEVA_DESIGN_USER%/' + !this.filename, 'OVERWRITE', !saveContents)

endmethod
-- End of method definition for .save()

------------------------------------------------------------------------
--
-- Method:      !edit()
--
-- Description: edit the options via the GUI
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .edit()

  -- show the main edit form
  loadform !!gphsettings
  !!gphsettings.showForm('REPRESENTATION')

endmethod
-- End of method definition for .edit()

------------------------------------------------------------------------
--
-- Method:      !centreLine()
--
-- Description: get the centreLine representation
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the centreLine representation]
--
------------------------------------------------------------------------
define method .centreLine() is BOOLEAN

  return !this.centreLine

endmethod
-- End of method definition for .centreLine() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !centreLine(BOOLEAN)
--
-- Description: set the centreLine representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the centreLine representation]
--
------------------------------------------------------------------------
define method .centreLine(!value is BOOLEAN)

  !this.centreLine = !value

  if (!this.global) then
    if (!value) then
      REPRESENTATION CENTRELINE ON
    else
      REPRESENTATION CENTRELINE OFF
    endif
  endif

endmethod
-- End of method definition for .centreLine(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !tube()
--
-- Description: get the tube representation
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the tube representation]
--
------------------------------------------------------------------------
define method .tube() is BOOLEAN

  return !this.tube

endmethod
-- End of method definition for .tube() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !tube(BOOLEAN)
--
-- Description: set the tube representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the tube representation]
--
------------------------------------------------------------------------
define method .tube(!value is BOOLEAN)

  !this.tube = !value

  if (!this.global) then
    if (!value) then
      REPRESENTATION TUBE ON
    else
      REPRESENTATION TUBE OFF
    endif
  endif

endmethod
-- End of method definition for .tube(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !obstruction()
--
-- Description: get the obstruction representation
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the obstruction representation]
--
------------------------------------------------------------------------
define method .obstruction() is BOOLEAN

  return !this.obstruction

endmethod
-- End of method definition for .obstruction() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !obstruction(BOOLEAN)
--
-- Description: set the obstruction representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the obstruction representation]
--
-- *** COMMAND LINE SYNTAX ***
--
------------------------------------------------------------------------
define method .obstruction(!value is BOOLEAN)

  !this.obstruction      = !value
  !this.obstructionTrans = REAL()

  if (!this.global) then
    if (!value) then
      REPRESENTATION OBSTRUCTION ON
    else
      REPRESENTATION OBSTRUCTION OFF
    endif
  endif

endmethod
-- End of method definition for .obstruction(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !obstruction(REAL)
--
-- Description: set the obstruction representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the obstruction translucency]
--
------------------------------------------------------------------------
define method .obstruction(!value is REAL)

  if (!value lt 0) then
    !this.obstruction(false)
  elseif (!value eq 0) then
    !this.obstruction(true)
  elseif (!value ge 0) then
    !this.obstructionTrans(!value)
  endif

endmethod
-- End of method definition for .obstruction(REAL)

------------------------------------------------------------------------
--
-- Method:      !insulation()
--
-- Description: get the insulation representation
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the insulation representation]
--
------------------------------------------------------------------------
define method .insulation() is BOOLEAN

  return !this.insulation

endmethod
-- End of method definition for .insulation() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !insulation(BOOLEAN)
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the insulation representation]
--
------------------------------------------------------------------------
define method .insulation(!value is BOOLEAN)

  !this.insulation      = !value
  !this.insulationTrans = REAL()

  if (!this.global) then
    if (!value) then
      REPRESENTATION INSULATION ON
    else
      REPRESENTATION INSULATION OFF
    endif
  endif

endmethod
-- End of method definition for .insulation(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !insulation(REAL)
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the insulation translucency]
--
------------------------------------------------------------------------
define method .insulation(!value is REAL)

  if (!value lt 0) then
    !this.insulation(false)
  elseif (!value eq 0) then
    !this.insulation(true)
  elseif (!value ge 0) then
    !this.insulationTrans(!value)
  endif

endmethod
-- End of method definition for .insulation(REAL)


------------------------------------------------------------------------
--
-- Method:      !tubeTrans(REAL)
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the insulation translucency]
--
------------------------------------------------------------------------
define method .tubeTrans(!value is REAL)

  if (!value le 0) then
    !this.tubeTrans(false)
    !this.hvacTubeTrans = 0
  elseif (!value gt 0) then
    !this.tubeTranslation(!value)
  endif
endmethod

------------------------------------------------------------------------
--
-- Method:      !tubeTranslation(REAL)
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the tube translucency]
--
------------------------------------------------------------------------
define method .tubeTranslation(!value is REAL)

  -- set the value of the tube  translucency
  !this.hvacTubeTransorNot  = true
  !this.hvacTubeTrans = !value

endmethod
-- End of method definition for .insulationTrans(REAL)

------------------------------------------------------------------------
--
-- Method:      !tubeTranslation() is REAL
--
-- Description: set the insulation representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [REAL] [value for the insulation translucency]
----------------------------------------------------------------------

define method .tubeTranslation() is REAL
  return !this.hvacTubeTrans
endmethod
-- End of method definition for .insulationTrans(REAL)

---------------------------------------------------------------------
