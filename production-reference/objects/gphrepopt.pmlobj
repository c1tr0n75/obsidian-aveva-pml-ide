      REPRESENTATION PROFILE OFF
    endif
  endif

endmethod
-- End of method definition for .profile(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !profileCl()
--
-- Description: get the profile centreLine representation. - The toggle that uses this on the
--              Graphics setting Representation form has been removed.
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the profile centreLine representation]
--
------------------------------------------------------------------------
define method .profileCl() is BOOLEAN

  return !this.profileCl

endmethod
-- End of method definition for .profileCl() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !profileCl(BOOLEAN)
--
-- Description: set the profile centreLine representation - The toggle that uses this on the
--              Graphics setting Representation form has been removed.
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the profile centreLine representation]
--
------------------------------------------------------------------------
define method .profileCl(!value is BOOLEAN)

  !this.profileCl = !value

  if (!this.global) then
    if (!value) then
      REPRESENTATION PROFILE CENTRELINE ON
    else
      REPRESENTATION PROFILE CENTRELINE OFF
    endif
  endif

endmethod
-- End of method definition for .profileCl(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      !profileObst()
--
-- Description: get the profile obstruction representation
--
-- Method Type: Function
-- Return:
--   [BOOLEAN] [value of the profile obstruction representation]
--
------------------------------------------------------------------------
define method .profileObst() is BOOLEAN

  return !this.profileObst

endmethod
-- End of method definition for .profileObst() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      !profileObst(BOOLEAN)
--
-- Description: set the profile obstruction representation
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [BOOLEAN] [value for the profile obstruction representation]
--
------------------------------------------------------------------------
define method .profileObst(!value is BOOLEAN )

