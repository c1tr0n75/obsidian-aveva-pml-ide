------------------------------------------------------------------------
--
-- Method:      !volumeOption()
--
-- Description: get the volume option representation state
--
-- Method Type: Function
-- Return:
--   [STRING] [value of the volume option representation state]
--
------------------------------------------------------------------------
define method .volumeOption() is STRING

  return !this.volumeOption

endmethod
-- End of method definition for .volumeOption() STRING

------------------------------------------------------------------------
--
-- Method:      !volumeOption(STRING)
--
-- Description: set the volume option representation state
--
-- Method Type: Procedure
-- Arguments:
--   [1] [R] [STRING] [value for the volume option representation state]
--
------------------------------------------------------------------------
define method .volumeOption(!value is STRING)

  !this.volumeOption = !value

  if (!this.global) then
      if (!this.volumeOption.eq('Hull Design')) then
          VOLUMEOPTION HULL DESIGN ON
          VOLUMEOPTION HULL PRODUCTION OFF
      elseif (!this.volumeOption.eq('Hull Production')) then
          VOLUMEOPTION HULL DESIGN OFF
          VOLUMEOPTION HULL PRODUCTION ON
      endif
  endif

endmethod
-- End of method definition for .volumeOption(STRING)

------------------------------------------------------------------------
--
-- Method:      !volumeOptionGlobal()
--
-- Description: get the volume global setting
--
-- Method Type: Function
-- Return:
--   [STRING] [global value of the volume option representation state]
--
------------------------------------------------------------------------
define method .volumeOptionGlobal() is STRING

  var !hullDes VOLUMEOPTION HULL DESIGN
  var !hullPro VOLUMEOPTION HULL PRODUCTION
  var !hull = ''
  if (!hullDes.after(': ').eq('ON')) then
    !hull = 'Hull Design'
  elseif (!hullPro.after(': ').eq('ON')) then
    !hull = 'Hull Production'
  else
    !!alert.error('Unknown VOLUMEOPTION value')
    -- It should never happen
  endif

  return !hull

endmethod
-- End of method definition for .volumeOptionGlobal() STRING

------------------------------------------------------------------------
--
-- Method:      !copyToCurrent()
--
-- Description: copy the object to the current drawlist
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .copyToCurrent()

  -- Get current drawlist
  !form = !!fmSys.currentDocument()

  if( !form.set() ) then

    !gphView  = !!fmSys.currentDocument().view
    !drawlist = !!gphDrawlists.drawlist(!gphView)

    !drawlist.centreLine( !this.centreLine )

    !drawlist.tube( !this.tube )


    !drawlist.obstruction( !this.obstruction )
    if (!this.obstruction) then
      if (!this.obstructionTrans.set()) then
        !drawlist.obstructionTrans( $!<this.obstructionTrans> )
      else
        !drawlist.obstructionTrans( 100 )
      endif
    endif


    !drawlist.insulation( !this.insulation )
    if (!this.insulation) then
      if(!this.insulationTrans.set()) then
        !drawlist.insulationTrans( $!<this.insulationTrans> )
      else
        !drawlist.insulationTrans( 100 )
      endif
    endif


    !drawlist.profile( !this.profile )

    !drawlist.profileCentreLine( !this.profileCl )


    !drawlist.profileObst( !this.profileObst )
    if (!this.profileObst) then
      if(!this.profileObstTrans.set()) then
        !drawlist.profileObstTrans( $!<this.profileObstTrans> )
      else
        !drawlist.profileObstTrans( 100 )
      endif
    endif


    !drawlist.profileInsu( !this.profileInsu )


    !drawlist.cableWayObst( !this.cableWayObst )
    if (!this.cableWayObst) then
      if(!this.cableWayObstTrans.set()) then
        !drawlist.cableWayObstTrans( $!<this.cableWayObstTrans> )
      else
        !drawlist.cableWayObstTrans( 100 )
      endif
    endif


    if (!this.cableObst) then
      !drawlist.cableWayObst ( !this.cableObst )
      if(!this.cableObstTrans.set()) then
        !drawlist.cableWayObstTrans( $!<this.cableWayObstTrans> )
      else
        !drawlist.cableWayObstTrans( 100 )
      endif
    endif


    !drawlist.cableWayCentreline( !this.cableWayCentreline )

    !drawlist.cableCentreline( !this.cableCentreline )


    !drawlist.cableProfile( !this.cableProfile )
    if (!this.cableProfile) then
      if(!this.cableProfileTrans.set()) then
        !drawlist.cableProfileTrans( $!<this.cableProfileTrans> )
      else
        !drawlist.cableProfileTrans( 100 )
      endif
    endif


    !drawlist.pipeLevel( $!<this.pipeLevel> )
    !drawlist.nozzLevel( $!<this.nozzLevel> )
    !drawlist.struLevel( $!<this.struLevel> )
    !drawlist.level( $!<this.generalLevel> )
    !drawlist.massLevel( $!<this.massLevel> )
    !drawlist.cableLevel( $!<this.cableLevel> )
    !drawlist.hvacLevel( $!<this.hvacLevel> )

    !drawlist.ppoints( !this.pPoints )

    !tempSize = !this.pPointsLength.queryString()
    !drawlist.ppointsLength( $!<tempSize> )

    !drawlist.ppointNumbers( !this.pPointsNumbers )

    !drawlist.pnode( !this.pNodes )

    !tempSize = !this.pNodesSize.queryString()
    !drawlist.pnodeSize ($!<tempSize> )

    !drawlist.pNodeColour( !this.pNodesColour.code )

    !drawlist.snode( !this.snodes )

    !tempSize = !this.snodesSize.queryString()
    !drawlist.snodeSize( $!<tempSize> )

    !drawlist.sNodeColour( !this.sNodesColour.code )

    !drawlist.hatta( !this.hAttas )

    !drawlist.hattaSize( $!<this.hAttasSize> )

    !drawlist.hAttaColour( !this.hAttasColour.code )

    !drawlist.ratta( !this.rAttas )

    !drawlist.rattaSize( $!<this.rAttasSize> )

    !drawlist.rAttaColour( !this.rAttasColour.code )

    !drawlist.rnode( !this.rnodes )

    !tempSize = !this.rNodesSize.queryString()
    !drawlist.rnodeSize( $!<tempSize> )

    !drawlist.rNodeColour( !this.rNodesColour.code )

    !drawlist.pline( !this.pLines )

    !tempSize = !this.pLinesLength.queryString()
    !drawlist.plineLength( $!<tempSize> )

    !drawlist.pkey( !this.pLinesPkey )

    !drawlist.holes( !this.holes )

    !drawlist.bolts( !this.bolts )

    !drawlist.tracing( !this.tracing )

    -- this arcTol is in current units
    !tempSize = !this.arcTolerance.queryString()
    !drawlist.arcTol( $!<tempSize> )

    !tempSize = !this.massArcTolerance.queryString()
    !drawlist.massArcTol( $!<tempSize> )

    !hvacTubeTrans = !this.tubeTranslation()
    !drawlist.hvacTube( !hvacTubeTrans.gt(0) )
    !drawlist.hvacTubeTrans( $!<hvacTubeTrans> )

    !this.volumeOption ( !this.volumeOption() )

    !drawlist.update()

    !token = !!gphDrawlists.token(!gphView)
    if( !this.monochrome) then
      if (undefined(!!gphDrawlists.monoControl[!token])) then
        !viewGadgets   = !!gphDrawlists.views(!token)
        !drawlistControl = object GPHMONOCONTROL(!viewGadgets)
        !!gphDrawlists.monoControl[!token] = !drawlistControl
        !!gphDrawlists.monoControl[!token].monochrome()
      endif
    else
      if (defined(!!gphDrawlists.monoControl[!token])) then
        !!gphDrawlists.controlMonochrome(false)
      endif
    endif


    !module = !!module().fullName
    handle any
    elsehandle none
      if (!module.upCase().eq('DESIGN')) then
        --supports needs to track session levels to ensure that rest elements are displayed correctly
        --if the supports object exists then reset the levels members in the object to the new ones set in core appware
        if (defined(!!supportsRepLevelObject)) then
          !!supportsRepLevelObject.resetSessionLevels()
          handle any
          endhandle
        endif
      endif
    endhandle

  else
    !!alert.error('Please create a graphical view for this function to operate on')
  endif 
  -- END OF: if( !form.set() )

endmethod

-- End of method definition for .copyToCurrent()
