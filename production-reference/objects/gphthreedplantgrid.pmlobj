-- End of method definition for .orientation(ORIENTATION)

------------------------------------------------------------------------
--
-- Method:      derive
--
-- Description: Derive from passed lines or positions
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       List of positions
-- Return:
--   [Data Type] [Description]
--    PLANTGRID   Returns plant grid from passed data
--
------------------------------------------------------------------------

define method .derive(!passedData is ARRAY) is PLANTGRID

  -- Initialise Variables
  !positions = ARRAY()
  !plane     = object PLANE(!this.position, !this.orientation)
  !data      = !passedData
  !data.unique()

  -- Lines passed
  if(!data.first().objectType() eq 'LINE') then

    -- Determine intersection with the plane
    do !i indices !data
      !positions[!i] = !plane.intersection(!data[!i])
      handle any
        skip
      endhandle
    enddo

  -- Positions passed
  elseif (!data.first().objectType() eq 'POSITION') then

    -- Project position onto the plane
    do !i indices !data
      !positions[!i] = !plane.near(!data[!i])
    enddo

  endif

  -- Remove duplications
  !positions.unique()

  -- Define the grid
  return !this.deriveGrid(!positions)

endmethod
-- End of method definition for .derive(ARRAY) PLANTGRID

------------------------------------------------------------------------
--
-- Method:      deriveGrid
--
-- Description: Derive the grid passed positions
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Array of positions on the current grid plane
-- Return:
--   [Data Type] [Description]
--    PLANTGRID   Returns plant grid from passed positions
--
------------------------------------------------------------------------

define method .deriveGrid(!positions is ARRAY) is PLANTGRID

  -- Initialise Variables
  !xSpacings = ARRAY()
  !ySpacings = ARRAY()
  !plane     = object PLANE(!this.position, !this.orientation)

  -- Get all X spacings of the positions
  do !i indices !positions
    !xyPosition = !plane.xyOffset(!positions[!i])
    !xSpacings[!i] = !xyPosition.x
    !ySpacings[!i] = !xyPosition.y
  enddo

  -- Sort spacings
  !xSpacings.unique()
  !xSpacings.sort()
  !ySpacings.unique()
  !ySpacings.sort()

  -- Derive the X spacings
  do !i from 2 to !xSpacings.size()
    !x[!i - 1] = !xSpacings[!i] - !xSpacings[!i - 1]
  enddo
  -- Derive the Y spacings
  do !i from 2 to !ySpacings.size()
    !y[!i - 1] = !ySpacings[!i] - !ySpacings[!i - 1]
  enddo

  -- Derive origin
  !xyPosition = object XYPOSITION(!xSpacings[1], !ySpacings[1])

  -- Grid
  !grid             = object PLANTGRID()
  !grid.position    = !plane.threeDPosition(!xyPosition)
  !grid.orientation = !plane.orientation
  !grid.xSpacings   = !x
  !grid.ySpacings   = !y

  -- Assign to member
  return !grid

endmethod
-- End of method definition for .deriveGrid(ARRAY) PLANTGRID

------------------------------------------------------------------------
--
-- Method:      definition
--
-- Description: Return definition of object for writing to file
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .definition() is ARRAY

  -- Initialise Variables
  !return      = ARRAY()

  !return.append('!definition                  = object gphThreeDPlantGrid()')
  if(!this.description.set()) then
    !return.append('!definition.description      = ''' & !this.description & '''')
  endif
  !return.append('!definition.tag              = '   & !this.tag)
  !return.append('!definition.detail           = '   & !this.detail)
  !return.append('!definition.visible          = '   & !this.visible)
  !return.append('!definition.basic            = '   & !this.basic)
  !return.append('!definition.labelType        = '''   & !this.labelType & '''')
  !return.append('!definition.colour           = ' & !this.colour)
  !return.append('!definition.style            = ' & !this.style)
  !return.append('!definition.position         = '   & !this.position)
  !return.append('!definition.orientation      = '   & !this.orientation)
  !return.append('!definition.xAxisLabel       = ''' & !this.xAxisLabel & '''')
  !return.append('!definition.yAxisLabel       = ''' & !this.yAxisLabel & '''')
  !return.append('!definition.zAxisLabel       = ''' & !this.zAxisLabel & '''')
  if(!this.gridSystem.set()) then
    !return.append('!definition.gridSystem     = ''' & !this.gridSystem & '''')
  endif

  -- IDs
  do !i indices !this.xAxisIDs
    !return.append('!definition.xAxisIDs.append(' & !this.xAxisIDs[!i] & ')')
  enddo
  do !i indices !this.yAxisIDs
    !return.append('!definition.yAxisIDs.append(' & !this.yAxisIDs[!i] & ')')
  enddo
  do !i indices !this.zAxisIDs
    !return.append('!definition.zAxisIDs.append(' & !this.zAxisIDs[!i] & ')')
  enddo

  -- Offsets
  do !i indices !this.xOffsets
    !return.append('!definition.xOffsets.append(' & !this.xOffsets[!i] & ')')
  enddo
  do !i indices !this.yOffsets
    !return.append('!definition.yOffsets.append(' & !this.yOffsets[!i] & ')')
  enddo
  do !i indices !this.zOffsets
    !return.append('!definition.zOffsets.append(' & !this.zOffsets[!i] & ')')
  enddo

  return !return

endmethod
-- End of method definition for .definition() ARRAY

------------------------------------------------------------------------
--
-- Method:      saveAsGridSystem
--
-- Description: Save grid to database as grid system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Grid System Name
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .saveAsGridSystem(!gridSystemName is STRING)
  -- Store db position
  !dbpos = !!ce
  !reuse = false

  -- Object is bound to a grid system dbref so this is modification mode
  if (!this.gridSystem.set()) then

    -- Overwrite existing grid system with new definition
    !!ce = !this.gridSystem
    if (!!alert.confirm(|OK to replace existing grid?|) eq |NO|) then
      return error 1 noalert
    else
      -- Get an Array all ref numbers for re-use
      !arrayGRIDAX = ARRAY()
      !arrayGRIDLN = ARRAY()
      !reuse = true

      var !arrayGRIDAX COLLECT ALL GRIDAX FOR CE
      do !i indices !arrayGRIDAX
        !element = object DBREF(!arrayGRIDAX[!i])
        !arrayGRIDLN[!i] = !element.members
      enddo

      DELETE GRIDSY MEMBERS
      !gridSys = !this.gridSystem.name
    endif

  -- Object is not bound to a grid system dbref so this is creation mode
  else

    -- Check name
    if (!gridSystemName.trim().empty()) then
      return error 1 |Grid System name required|
    endif

    -- Find a grid world - first see if we are below one
    GRIDWL
    handle (2,111) $* Cannot access element from this level
      -- Not below a grid world so try to find one
      var !gridWorlds collect all GRIDWL
      if (!gridWorlds.empty()) then
        -- No grid worlds so try to create one (leave it up to user to rename if desired later)
        WORLD
        NEW GRIDWL
        handle ANY
          return error 1 |Unable to create GRIDWL: $!!error.text|
        endhandle
      else
        -- Use first grid world
        $!gridWorlds[1]
      endif
    endhandle

    -- Now at a grid world so create grid system
--    !gridWorld = !!ce
    !gridSys = !!checkName(!gridSystemName, |NEW|)
    if (!gridSys.unset()) then
      -- Error in name already reported
      return
    endif
    NEW GRIDSY $!gridSys
    PURPOSE AXIS
    endif
    POSITION $!<this.position>
    ORIENTATION $!<this.orientation>
    !this.gridSystem = !!ce

  !countUsedGRIDAXrefs = 0
  !countUsedGRIDLNrefsX = 0
  !countUsedGRIDLNrefsY = 0
  !countUsedGRIDLNrefsZ = 0
  -- X axis
  !axisLabel = !this.xAxisLabel.trim()
  if (!axisLabel eq ||) then
    !axisLabel = |X|
  endif
  if (!reuse.not()) then
    NEW GRIDAX $!<gridSys>$!<axisLabel>
  else
    !countUsedGRIDAXrefs = !countUsedGRIDAXrefs + 1
    NEW GRIDAX $!<gridSys>$!<axisLabel> REF $!arrayGRIDAX[$!countUsedGRIDAXrefs]
    handle ANY
      NEW GRIDAX $!<gridSys>$!<axisLabel>
    endhandle
  endif
  !!ce.grdaxe = |X|
  !!ce.grdlbl = !this.xAxisLabel
  !grdid = 0
  do !i indices !this.xOffsets
    !lineLabel = !this.xAxisIDs[!i].trim()
    if (!lineLabel eq ||) then
      !lineLabel = !grdid.string()
    endif
    if (!reuse.not()) then
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
    else
      !countUsedGRIDLNrefsX = !countUsedGRIDLNrefsX + 1
      !ref = !arrayGRIDLN[!countUsedGRIDAXrefs][!countUsedGRIDLNrefsX]
      handle ANY
        !ref = NULREF
      endhandle
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel> REF $!ref
      handle ANY
        NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
      endhandle
    endif
    !!ce.grdoff = !this.xOffsets[!i]
    !!ce.grdid  = !this.xAxisIDs[!i]
    !grdid = !grdid + 1
  enddo

  -- Y axis
  !axisLabel = !this.yAxisLabel.trim()
  if (!axisLabel eq ||) then
    !axisLabel = |Y|
  endif
  if (!reuse.not()) then
    NEW GRIDAX $!<gridSys>$!<axisLabel>
  else
    !countUsedGRIDAXrefs = !countUsedGRIDAXrefs + 1
    NEW GRIDAX $!<gridSys>$!<axisLabel> REF $!arrayGRIDAX[$!countUsedGRIDAXrefs]
    handle ANY
      NEW GRIDAX $!<gridSys>$!<axisLabel>
    endhandle
  endif
  !!ce.grdaxe = |Y|
  !!ce.grdlbl = !this.yAxisLabel
  !grdid = 0
  do !i indices !this.yOffsets
    !lineLabel = !this.yAxisIDs[!i].trim()
    if (!lineLabel eq ||) then
      !lineLabel = !grdid.string()
    endif
    if (!reuse.not()) then
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
    else
      !countUsedGRIDLNrefsY = !countUsedGRIDLNrefsY + 1
      !ref = !arrayGRIDLN[!countUsedGRIDAXrefs][!countUsedGRIDLNrefsY]
      handle ANY
        !ref = NULREF
      endhandle
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel> REF $!ref
      handle ANY
        NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
      endhandle
    endif
    !!ce.grdoff = !this.yOffsets[!i]
    !!ce.grdid  = !this.yAxisIDs[!i]
    !grdid = !grdid + 1
  enddo

  -- Z axis
  !axisLabel = !this.zAxisLabel.trim()
  if (!axisLabel eq ||) then
    !axisLabel = |Z|
  endif
  if (!reuse.not()) then
    NEW GRIDAX $!<gridSys>$!<axisLabel>
  else
    !countUsedGRIDAXrefs = !countUsedGRIDAXrefs + 1
    NEW GRIDAX $!<gridSys>$!<axisLabel> REF $!arrayGRIDAX[$!countUsedGRIDAXrefs]
    handle ANY
      NEW GRIDAX $!<gridSys>$!<axisLabel>
    endhandle
  endif
  !!ce.grdaxe = |Z|
  !!ce.grdlbl = !this.zAxisLabel
  !grdid = 0
  do !i indices !this.zOffsets
    !lineLabel = !this.zAxisIDs[!i].trim()
    if (!lineLabel eq ||) then
      !lineLabel = !grdid.string()
    endif
    if (!reuse.not()) then
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
    else
      !countUsedGRIDLNrefsZ = !countUsedGRIDLNrefsZ + 1
      !ref = !arrayGRIDLN[!countUsedGRIDAXrefs][!countUsedGRIDLNrefsZ]
      handle ANY
        !ref = NULREF
      endhandle
      NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel> REF $!ref
      handle ANY
        NEW GRIDLN $!<gridSys>$!<axisLabel>$!<lineLabel>
      endhandle
    endif
    !!ce.grdoff = !this.zOffsets[!i]
    !!ce.grdid  = !this.zAxisIDs[!i]
    !grdid = !grdid + 1
  enddo

  -- Restore db position
  !!ce = !dbpos

endmethod
-- End of method definition for .saveAsGridSystem(ARRAY)

------------------------------------------------------------------------
--
-- Method:      setLimits
--
-- Description: Set view limits for grid system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .setLimits()

   -- Discover the currently selected form
   !form = !!fmsys.currentDocument()
   -- Set the limit on the view
   if (!form.set()) then
     !!gphViews.limits(!form.view, !this.volume())
   endif

endmethod
-- End of method definition for .setLimits()

------------------------------------------------------------------------
--
-- Method:      volume
--
-- Description: Return volume encompassed by grid system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    VOLUME      Volume encompassed by grid system
--
------------------------------------------------------------------------

-- Define method
define method .volume() is VOLUME

  -- This could be replaced by pseudo attribute wvol if implemented in core

  -- Orientation directions
  !xDir = !this.orientation.xDir()
  !yDir = !this.orientation.yDir()
  !zDir = !this.orientation.zDir()

  -- Get dimensions of grid
  !minMaxs = !this.localLimits()
  !xMin = !minMaxs[1]
  !xMax = !minMaxs[2]
  !yMin = !minMaxs[3]
  !yMax = !minMaxs[4]
  !zMin = !minMaxs[5]
  !zMax = !minMaxs[6]

  -- Check for zero size
  if (abs(!xMax - !xMin) lt 1000mm) then
    !xMin = !xMin - 500mm
    !xMax = !xMin + 500mm
  endif
  if (abs(!yMax - !yMin) lt 1000mm) then
    !yMin = !yMin - 500mm
    !yMax = !yMin + 500mm
  endif
  if (abs(!zMax - !zMin) lt 1000mm) then
    !zMin = !zMin - 500mm
    !zMax = !zMin + 500mm
  endif

  -- Use offsets to set from and to positions
  !fromPos = !this.position.offset(!xDir, !xMin).offset(!yDir, !yMin).offset(!zDir, !zMin)
  !toPos   = !this.position.offset(!xDir, !xMax).offset(!yDir, !yMax).offset(!zDir, !zMax)

  -- Return volume
  return object VOLUME(!fromPos, !toPos)

endmethod
-- End of method definition for .volume() is VOLUME

------------------------------------------------------------------------
--
-- Method:      clippingPlanes
--
-- Description: Return clipping plane data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       grid lines and offsets
--    2   R      REAL        Aid number to draw box
--    3   R      BOOLEAN     Draw box if true
-- Return:
--   [Data Type] [Description]
--    ARRAY       Position and direction data for clipping planes
--
------------------------------------------------------------------------

-- Define method
define method .clippingPlanes(!data is ARRAY, !aidNumber is REAL, !draw is BOOLEAN) is ARRAY

  -- Get grid offsets
  !xfrom = !this.xOffsets[!data[1]] + !data[7]
  !yfrom = !this.yOffsets[!data[2]] + !data[8]
  !zfrom = !this.zOffsets[!data[3]] + !data[9]
  !xto   = !this.xOffsets[!data[4]] + !data[10]
  !yto   = !this.yOffsets[!data[5]] + !data[11]
  !zto   = !this.zOffsets[!data[6]] + !data[12]

  -- Swap if from is greater than to
  if (!xfrom gt !xto) then
    !buffer = !xfrom
    !xfrom  = !xto
    !xto    = !buffer
  endif
  if (!yfrom gt !yto) then
    !buffer = !yfrom
    !yfrom  = !yto
    !yto    = !buffer
  endif
  if (!zfrom gt !zto) then
    !buffer = !zfrom
    !zfrom  = !zto
    !zto    = !buffer
  endif

  -- Get mid points
  !xmid  = (!xfrom + !xto) / 2
  !ymid  = (!yfrom + !yto) / 2
  !zmid  = (!zfrom + !zto) / 2

  -- Get grid directions
  !xDir = !this.orientation.xDir()
  !yDir = !this.orientation.yDir()
  !zDir = !this.orientation.zDir()

  -- Draw a box
  if (!draw) then
    !box = object GPHBOX()
    !box.box.position    = !this.position.offset(!xDir, !xmid).offset(!yDir, !ymid).offset(!zDir, !zmid)
    !box.box.orientation = !this.orientation
    !box.box.xLength     = !xto - !xfrom
    !box.box.yLength     = !yto - !yfrom
    !box.box.zLength     = !zto - !zfrom
    !box.draw(!aidNumber)
  endif

  -- Set plane positions
  !return     = ARRAY()
  !return[1]  = !this.position.offset(!xDir, !xfrom).offset(!yDir, !ymid).offset(!zDir, !zmid)
  !return[3]  = !this.position.offset(!xDir, !xto).offset(!yDir, !ymid).offset(!zDir, !zmid)
  !return[5]  = !this.position.offset(!xDir, !xmid).offset(!yDir, !yfrom).offset(!zDir, !zmid)
  !return[7]  = !this.position.offset(!xDir, !xmid).offset(!yDir, !yto).offset(!zDir, !zmid)
  !return[9]  = !this.position.offset(!xDir, !xmid).offset(!yDir, !ymid).offset(!zDir, !zfrom)
  !return[11] = !this.position.offset(!xDir, !xmid).offset(!yDir, !ymid).offset(!zDir, !zto)

  -- Set plane directions
  !return[2]  = !xDir
  !return[4]  = !xDir.opposite()
  !return[6]  = !yDir
  !return[8]  = !yDir.opposite()
  !return[10] = !zDir
  !return[12] = !zDir.opposite()

  return !return

endmethod
-- End of method definition for .clippingPlanes() is ARRAY

------------------------------------------------------------------------
--
-- Method:      list
--
-- Description: Return selection list for given axis
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      axis X, Y or Z
-- Return:
--   [Data Type] [Description]
--    ARRAY       texts to populate selection list for given axis
--
------------------------------------------------------------------------

-- Define method
define method .list(!axis is STRING) is ARRAY

  -- Return list of axis label and ids
  !texts = ARRAY()
  if (!axis eq |X|) then
    do !i indices !this.xOffsets
      !texts.append(!this.xAxisLabel & !this.xAxisIDs[!i])
    enddo
  elseif (!axis eq |Y|) then
    do !i indices !this.yOffsets
      !texts.append(!this.yAxisLabel & !this.yAxisIDs[!i])
    enddo
  elseif (!axis eq |Z|) then
    do !i indices !this.zOffsets
      !texts.append(!this.zAxisLabel & !this.zAxisIDs[!i])
    enddo
  endif
  return !texts

endmethod
-- End of method definition for .list(STRING) is ARRAY

------------------------------------------------------------------------
--
-- Method:      coreGrids
--
-- Description: Create core grids for displayed axes of grid system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .coreGrids()

  -- Maximum/Minimum x/y/z values
  !xDirection = !this.orientation.xDir()
  !yDirection = !this.orientation.yDir()
  !zDirection = !this.orientation.zDir()
  !minMaxs    = !this.localLimits()
  !xMin       = !minMaxs[1]
  !xMax       = !minMaxs[2]
  !yMin       = !minMaxs[3]
  !yMax       = !minMaxs[4]
  !zMin       = !minMaxs[5]
  !zMax       = !minMaxs[6]

  -- Offsets for selected planes
  if (!this.xOffsetThru gt 0) then
    !xOff = !this.xOffsets[!this.xOffsetThru]
  else
    !xOff = 0
  endif
  if (!this.yOffsetThru gt 0) then
    !yOff = !this.yOffsets[!this.yOffsetThru]
  else
    !yOff = 0
  endif
  if (!this.zOffsetThru gt 0) then
    !zOff = !this.zOffsets[!this.zOffsetThru]
  else
    !zOff = 0
  endif

  -- Spacings
  !xSpacings = ARRAY()
  !ySpacings = ARRAY()
  !zSpacings = ARRAY()
  do !i indices !this.xOffsets
    skip if (!i eq 1)






    !xSpacings.append(!this.xOffsets[!i] - !this.xOffsets[!i - 1])
  enddo
  do !i indices !this.yOffsets
    skip if (!i eq 1)






    !ySpacings.append(!this.yOffsets[!i] - !this.yOffsets[!i - 1])
  enddo
  do !i indices !this.zOffsets
    skip if (!i eq 1)






    !zSpacings.append(!this.zOffsets[!i] - !this.zOffsets[!i - 1])
  enddo

  -- Construct xy plane plant grid object
  !plantGrid = object PLANTGRID()
  !plantGrid.position    = !this.position.offset(!xDirection, !xMin).offset(!yDirection, !yMin).offset(!zDirection, !zOff)
  !plantGrid.orientation = !this.orientation
  !plantGrid.xSpacings = !xSpacings
  !plantGrid.ySpacings = !ySpacings
  !this.gridxy = object GPHPLANTGRID(!plantGrid)

  -- Construct xz plane plant grid object
  !plantGrid = object PLANTGRID()
  !plantGrid.position    = !this.position.offset(!xDirection, !xMin).offset(!zDirection, !zMin).offset(!yDirection, !yOff)
  !plantGrid.orientation = object ORIENTATION(|X is | & !xDirection & | and Y is | & !zDirection)
  !plantGrid.xSpacings = !xSpacings
  !plantGrid.ySpacings = !zSpacings
  !this.gridxz = object GPHPLANTGRID(!plantGrid)

  -- Construct zy plane plant grid object
  !plantGrid = object PLANTGRID()
  !plantGrid.position    = !this.position.offset(!yDirection, !yMin).offset(!zDirection, !zMin).offset(!xDirection, !xOff)
  !plantGrid.orientation = object ORIENTATION(|X is | & !zDirection & | and Y is | & !yDirection)
  !plantGrid.xSpacings = !zSpacings
  !plantGrid.ySpacings = !ySpacings
  !this.gridzy = object GPHPLANTGRID(!plantGrid)

endmethod
-- End of method definition for .coreGrids()

------------------------------------------------------------------------
--
-- Method:      drawForEDG
--
-- Description: Set drawForEDG flag
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     drawForEDG flag
--    2   R      REAL        aidNumber for plantGrid
--    3   R      REAL        aidNumber for plantGrid
--    4   R      REAL        aidNumber for plantGrid
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawForEDG(!drawForEDG is BOOLEAN, !aidNumberGridxy is REAL, !aidNumberGridxz is REAL, !aidNumberGridzy is REAL)

  -- Set EDG flag and aidNumbers
  !this.drawForEDG = !drawForEDG
  !this.aidNumberGridxy  = !aidNumberGridxy
  !this.aidNumberGridxz  = !aidNumberGridxz
  !this.aidNumberGridzy  = !aidNumberGridzy

endmethod
-- End of method definition for .drawForEDG(BOOLEAN, REAL, REAL, REAL)
