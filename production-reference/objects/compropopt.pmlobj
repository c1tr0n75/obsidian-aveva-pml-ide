--
-- Method:      .dimTextDesc()
--
-- Description: Get the dimTextDesc value
--
-- Method Type: Function
--
-- Return:
--   [BOOLEAN] [Current value]
--
------------------------------------------------------------------------
define method .dimTextDesc() is BOOLEAN

  return !this.dimTextDesc

endmethod
-- End of method definition for .dimTextDesc() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      .dimTextDesc(BOOLEAN)
--
-- Description: Set the dimTextDesc value
--
-- Method Type: Procedure
--
