endmethod
-- End of method definition for .displayPlotfile() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      .displayPlotfile(BOOLEAN)
--
-- Description: Set the displayPlotfile value
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN] [New value]
--
------------------------------------------------------------------------
define method .displayPlotfile(!value is BOOLEAN)

  !this.displayPlotfile = !value

endmethod
-- End of method definition for .displayPlotfile(BOOLEAN)

