  !packet.input[1]       = !grid
  !packet.initialisation = '!!linearGrids.setup(''Reference Linear Grid'',''!!aidConstructors.add(!!linearGrids.grid)'',!this.input[1])'
  !packet.description    = 'Reference Linear Grid'
  !packet.form           = !!linearGrids
  !packet.close          = '!!linearGrids.tidy()'

  !packet.priority       = 2
  !packet.remove         = false
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .linearGridPacket(GPHLINEARGRID) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      plantGridPacket
--
-- Description: Plant Grid Definition Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      PLANTGRID  Grid definition to setup with
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .plantGridPacket(!grid is GPHPLANTGRID) is EDGPACKET

  -- Initialise Variables

  -- Check radial grid form is defined
  if(undefined(!!plantGrids)) then
    pml reload form !!plantGrids
  endif

  -- Define Packet Data
  !packet                = object EDGPACKET()
  !packet.positionLink('!!plantGrids.position', 'Define Plant Grid')
  !packet.key            = 'plantGridPacket'
  !packet.type           = 'construct'
  !packet.input[1]       = !grid
  !packet.initialisation = '!!plantGrids.setup(''Reference Plant Grid'',''!!aidConstructors.add(!!plantGrids.grid)'',!this.input[1])'
  !packet.description    = 'Reference Plant Grid'
  !packet.form           = !!plantGrids
  !packet.close          = '!!plantGrids.tidy()'

  !packet.priority       = 2
  !packet.remove         = false
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .plantGridPacket(GPHPLANTGRID) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      editPacket
--
-- Description: Edit Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      PLANTGRID  Grid definition to setup with
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .editPacket() is EDGPACKET

  -- Initialise Variables

  -- Define Packet Data
  !packet                = object EDGPACKET()
  !packet.aidPick('Pick aid to be modified')
  !packet.key            = 'editPacket'
  !packet.type           = 'construct'
  !packet.action         = '!!aidConstructors.edit(!this.return)'
  !packet.priority       = 2
--  !packet.remove         = !this.recursive.not()
  !packet.remove         = true
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .editPacket() EDGPACKET
