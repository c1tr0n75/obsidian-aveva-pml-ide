--
-- Description:
-- Aid Constructor list.
--
-- NOTE : All packet methods will be actioned in the edgPacket object
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  add(ARC)                         REAL                Add circle to list
--  add(ARRAY)                       ARRAY               Add array definition to list
--  add(GPHCIRCLE)                   REAL                Add graphic circle to list
--  add(GPHLINE)                     REAL                Add graphic line to list
--  add(GPHLINEARGRID)               REAL                Add linear grid to list
--  add(GPHPLANE)                    REAL                Add graphic plane to list
--  add(GPHPLANTGRID)                REAL                Add plant grid to list
--  add(GPHPOSITION)                 REAL                Add graphic working point to list
--  add(GPHRADIALGRID)               REAL                Add radial grid to list
--  add(LINE)                        REAL                Add line to list
--  add(PLANE)                       REAL                Add plane to list
--  add(POSITION)                    REAL                Add working point to list
--  aidConstructors()                -                   Constructor
--  blobSize(REAL,STRING)            -                   Change all blob sizes
--  circlePacket(STRING)             EDGPACKET           Circle Construction packet
--  copy(EDGPICKDATA)                -                   Copy an aid element
--  copyPacket()                     EDGPACKET           Copy Packet
--  definedNumbers(STRING)           ARRAY               Returns current definitions for the passed aid items (type must be the same as the ARRAY holding the aid definitions in the object)
--  definedText(STRING)              ARRAY               Returns string definition of current definitions for the passed aid items (type must be the same as the ARRAY holding the aid definitions in the object)
--  delete(EDGPICKDATA)              -                   Delete an aid element
--  deletePacket()                   EDGPACKET           Delete Packet
--  edit(ARRAY)                      -                   Edit a constructor.
--  editPacket()                     EDGPACKET           Edit Packet
--  explicit(STRING)                 -                   Create aid item using the edit form
--  globalInstance()                 -                   Create global instance of object
--  length(ARRAY)                    -                   Extend length of a line, through a position
--  linePacket(STRING)               EDGPACKET           Line Construction packet
--  linearGridPacket(GPHLINEARGRID)  EDGPACKET           Linear Grid Definition Packet
--  load(FILE)                       -                   Load from file
--  modifyPacket(STRING)             EDGPACKET           Modify Construction packet
--  orientate(EDGPICKDATA)           -                   Orientate picked aid with current working plane
--  orientatePacket(STRING)          EDGPACKET           Orientation Packet
--  paste(EDGPOSITIONDATA)           -                   Copy an aid element
--  pastePacket()                    EDGPACKET           Paste Packet
--  planePacket(STRING)              EDGPACKET           Plane Construction packet
--  plantGridPacket(GPHPLANTGRID)    EDGPACKET           Plant Grid Definition Packet
--  pointPacket(STRING)              EDGPACKET           Working Point Construction packet
--  position(ARRAY)                  -                   Changes position
--  radialGridPacket(GPHRADIALGRID)  EDGPACKET           Radial Grid Definition Packet
--  radius(ARRAY)                    -                   Changes radius (this should only ever have arc definitions applied to it via the results list)
--  recursion(BOOLEAN)               -                   Set recursion flag for creation/modifications
--  refresh()                        -                   Refresh all known construction aid element
--  remove()                         -                   Remove all graphic entries from system
--  remove(REAL)                     -                   Remove specified "aid number" entry
--  remove(STRING)                   -                   Remove all graphic entries from system of a given type
--  remove(STRING,ARRAY)             -                   Remove specified "aid numbers" from passed store type
--  save(FILE)                       -                   Save to file
--  store(STRING)                    STRING              Returns store name for passed graphic aid
--  stores()                         ARRAY               Returns a list of the storage members of the object (ARRAYs)
--
------------------------------------------------------------------------

-- Define object
define object AIDCONSTRUCTORS

  -- Line Definitions (pointers to aid Numbers)
  member .lines         is ARRAY
  -- Circle Definitions
  member .circles       is ARRAY
  -- Plane Definitions
  member .planes        is ARRAY
  -- Working Point Definitions
  member .points        is ARRAY
  -- Radial Grids
  member .radialGrids   is ARRAY
  -- Linear Grids
  member .linearGrids   is ARRAY
  -- Plane Grids
  member .plantGrids    is ARRAY

  -- Creation/Modification is Recursive
  member .recursive     is BOOLEAN

  -- Current "Copy/Cut" element
  member .copy          is ARRAY
  -- Selected Group of elements
  member .group         is ARRAY

  -- Aid Blob Size
  member .blobSize      is REAL

endobject
-- End of object definition for AIDCONSTRUCTORS

------------------------------------------------------------------------
------------------------------------------------------------------------
--                                                                    --
--                >>>>>> Processing Methods <<<<<<                    --
--                                                                    --
------------------------------------------------------------------------
------------------------------------------------------------------------

------------------------------------------------------------------------
--
-- Method:      aidConstructors
--
-- Description: Constructor
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .aidConstructors()

  -- Set recursion flag
  !this.recursive = false
  !this.blobSize  = 200mm

endmethod
-- End of method definition for .aidConstructors()

------------------------------------------------------------------------
--
-- Method:      globalInstance
--
-- Description: Create global instance of object
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .globalInstance()

  -- Create Global Variable
  !!aidConstructors    = !this

endmethod
-- End of method definition for .globalInstance()

------------------------------------------------------------------------
--
-- Method:      save
--
-- Description: Save to file
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FILE        Save file
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .save(!file is FILE)

  -- Initialise Variables
  -- Get list of storages areas of current objects
  !stores = !this.stores()

  -- If their is no .pmldat extension, then add it to the name
  if(!file.entry().part(-1, '.') ne 'pmldat') then
    !filename = !file.name() & '.pmldat'
    !file.file(!filename)
  endif

-- Just prompt user for overwriting an existing file
-- automatically overwriting a file was considered dangerous, as the file may contain
-- several hundred aid constructs.

-- code removed 15/9/98 (csb)

  -- If file exists, the make sure that it is a graphic definition file
  -- if not, then don't allow it to overwrite it
  --   if(!file.exists()) then
  --
  --     -- Make sure file is a graphics definition file
  --     !file.open('READ')
  --     !header   = !file.readRecord()
  --     !file.close()
  --
  --     -- Check header
  --     if(!header ne '------------------- Graphic Definition file ---------------') then
  --       !!alert.error('Unable to overwrite file (' & !file.entry() & '). Only existing "Graphic Definition File" can be overwritten.')
  --       return
  --     endif
  --   endif

  !fileData = ARRAY()
  !date     = object DATETIME()

  -- File heading
  !fileData.append('------------------- Graphic Definition file ---------------')
  !fileData.append('--')
  !fileData.append('--   Created by : ' & !!sessionSettings.user)
  !fileData.append('--         Date : ' & !date)
  !fileData.append('--')
  !fileData.append('-----------------------------------------------------------')
  !fileData.append('')

  -- Loop through each of the lists and write to the current file
  do !i indices !stores

    -- Loop through each aid definition store
    !list = !this.attribute(!stores[!i].upcase())

    -- Process List
    if(!list.empty().not()) then
      !fileData.append('')
      !fileData.append('-- Graphic "' & !stores[!i] & '" definitions.')
      !fileData.append('')
      do !j indices !list
        !dataOk = TRUE
        do !data values !!aidNumbers.numbers[!list[!j]].definition()
          if (!data.matchWild('*Unset*')) then
            !dataOk = FALSE
            break
          endif
        enddo
        skip if (!dataOk.not())
        !fileData.appendArray(!!aidNumbers.numbers[!list[!j]].definition())
        !fileData.append('!aidNumber = !!aidNumbers.add(!definition)')
        !fileData.append('!!aidConstructors.' & !stores[!i] & '.append(!aidNumber)')
        !fileData.append('!definition.delete()')
        !fileData.append('')
      enddo

      -- Common for no definitions
    else
      !fileData.append('-- No "' & !stores[!i] & '" defined.')
      !fileData.append('')
    endif

  enddo

  -- Write fileData to file
  !fileData.append('-- End of Graphic Definitions ')
  !file.writeFile('WRITE', !fileData)

endmethod
-- End of method definition for .save(FILE)

------------------------------------------------------------------------
--
-- Method:      load
--
-- Description: Load from file
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FILE        Load file
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .load(!file is FILE)

  -- If their is no .pmldat extension, then add it to the name
  if(!file.entry().part(-1, '.') ne 'pmldat') then
    !filename = !file.name() & '.pmldat'
    !file.file(!filename)
  endif

  -- Make sure file is a graphics definition file
  !file.open('READ')
  !header   = !file.readRecord()
  !file.close()

  -- Check header
  if(!header ne '------------------- Graphic Definition file ---------------') then
    !!alert.error('File (' & !file.entry() & ' ) is not a graphics a graphic definition file.')
    return
  endif

  -- Load file
  !fullName = !file.fullName()
  $m "$!fullName"
  handle any
    !!alert.error('Graphic definition file (' & !file.entry() & ') is corrupt.')
  endhandle

endmethod
-- End of method definition for .load(FILE)

------------------------------------------------------------------------
--
-- Method:      stores
--
-- Description: Returns a list of the storage members of the object (ARRAYs)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       Name of storage members
--
------------------------------------------------------------------------

define method .stores() is ARRAY

  -- Initialise Variables
  !stores = ARRAY()

  -- Get all members of object
  !list   = !this.attributes()

  -- Loop through all
  do !i indices !list
    -- Ignore no array items
    skip if(!this.attribute(!list[!i]).objectType() ne 'ARRAY')

    -- Special case ignores of arrays
    skip if(!list[!i].upcase() inset('COPY','GROUP'))

    -- Add to store list
    !stores.append(!list[!i])
  enddo

  -- Return
  return !stores

endmethod
-- End of method definition for .stores() ARRAY

------------------------------------------------------------------------
--
-- Method:      store
--
-- Description: Returns store name for passed graphic aid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Aid graphic object type
-- Return:
--   [Data Type] [Description]
--    STRING      Store name
--
------------------------------------------------------------------------

define method .store(!gphType is STRING) is STRING

  -- Initialise Variables
  !type = !gphType.upcase()

  -- Line Definitions
  if(!type eq 'GPHLINE') then
    return 'LINES'

  -- Circle Definitions
  elseif(!type eq 'GPHCIRCLE') then
     return 'CIRCLES'

  -- Plane Definitions
  elseif(!type eq 'GPHPLANE') then
    return 'PLANES'

  -- Working Point Definitions
  elseif(!type eq 'GPHPOSITION') then
    return 'POINTS'

  -- Radial Grids
  elseif(!type eq 'GPHRADIALGRID') then
    return 'RADIALGRIDS'

  -- Linear Grids
  elseif(!type eq 'GPHLINEARGRID') then
    return 'LINEARGRIDS'

  -- Plane Grids
  elseif(!type eq 'GPHPLANTGRID') then
    return 'PLANTGRIDS'
  endif

  return STRING()

endmethod
-- End of method definition for .store(STRING) STRING

------------------------------------------------------------------------
--
-- Method:      definedText
--
-- Description: Returns string definition of current definitions for the passed aid items (type must be the same as the ARRAY holding the aid definitions in the object)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Aid type
-- Return:
--   [Data Type] [Description]
--    ARRAY       Descriptions of items
--
------------------------------------------------------------------------

define method .definedText(!option is STRING) is ARRAY

  -- Initialise Variables
  !array       = ARRAY()

  -- Load selected list into array
  !realArray   = !this.attribute(!option.upcase())
  handle any
  endhandle
  do !i indices !realArray
    !array[!i] = !realArray[!i].string()
  enddo

  return !array

endmethod
-- End of method definition for .definedText(STRING) ARRAY

------------------------------------------------------------------------
--
-- Method:      definedNumbers
--
-- Description: Returns current definitions for the passed aid items (type must be the same as the ARRAY holding the aid definitions in the object)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Aid type
-- Return:
--   [Data Type] [Description]
--    ARRAY       Currently define
--
------------------------------------------------------------------------

define method .definedNumbers(!option is STRING) is ARRAY

  -- Return aid element list
  return !this.attribute(!option.upcase())

endmethod
-- End of method definition for .definedNumbers(STRING) ARRAY

------------------------------------------------------------------------
--
-- Method:      recursion
--
-- Description: Set recursion flag for creation/modifications
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     State
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .recursion(!state is BOOLEAN)

  -- Don't do anything if the state is the same
  if(!state eq !this.recursive) then
    return
  endif

  -- Set state
  !this.recursive = !state

  -- Set any constructor packet on the edg system to be recursive
  !!edgCntrl.setRemoveState('aidConstructors', !state.not())

endmethod
-- End of method definition for .recursion(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      refresh
--
-- Description: Refresh all known construction aid element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .refresh()

  -- Get all store
  !stores = !this.stores()

  -- Loop through
  do !i indices !stores
    do !j indices !this.attribute(!stores[!i])
      !!aidNumbers.draw(!this.attribute(!stores[!i])[!j])
    enddo
  enddo

endmethod
-- End of method definition for .refresh()

------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add working point to list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITION    Position of working point
-- Return:
--   [Data Type] [Description]
--    REAL        Aid number constructor has been add into the system with
--
------------------------------------------------------------------------

define method .add(!position is POSITION) is REAL

  -- Define Graphic Position
  !gphPosition          = object GPHPOSITION(!position)
  !gphPosition.diameter = !this.blobSize

  -- Get next aid number
  !aidNumber = !!aidNumbers.add(!gphPosition)

  -- Add to list
  !this.points.append(!aidNumber)

  -- Return aid number
  return !aidNumber

endmethod
-- End of method definition for .add(POSITION) REAL

