------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add array definition to list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Array of definition
-- Return:
--   [Data Type] [Description]
--    ARRAY       Aid numbers constructor has been add into the system with
--
------------------------------------------------------------------------

define method .add(!array is ARRAY) is ARRAY

  -- Initialise Variables
  !returnArray = ARRAY()

  -- Loop through array of lines
  do !i indices !array
    !returnArray.append(!this.add(!array[!i]))
  enddo

  -- Return aid number
  return !returnArray

endmethod
-- End of method definition for .add(ARRAY) ARRAY

------------------------------------------------------------------------
