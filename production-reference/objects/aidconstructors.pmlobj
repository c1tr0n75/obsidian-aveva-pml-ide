------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove all graphic entries from system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .remove()

  -- Check if we really want to remove all entries
  if(!!alert.confirm('Are you sure you want to remove all graphical aids from the system?').boolean().not()) then
    return
  endif

  -- Get available Stores
  !stores = !this.stores()

  -- Loop through all stores
  do !i indices !stores

    -- Loop through each entry
    do !j values !this.attribute(!stores[!i])
      !!aidNumbers.remove(!j)
    enddo

    -- Empty store
    !this.attribute(!stores[!i]).clear()
  enddo

endmethod
-- End of method definition for .remove()

------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove specified "aid number" entry
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Reference number
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .remove(!number is REAL)

  -- Get available Stores
  !stores = !this.stores()

  -- Loop through all stores
  do !i indices !stores

    -- Skip if not is current store
    skip if(!this.attribute(!stores[!i]).findFirst(!number).unset())

    -- Remove from aid number system
    !!aidNumbers.remove(!number)

    -- Remove from store
    !this.attribute(!stores[!i]).remove(!this.attribute(!stores[!i]).findFirst(!number))
    return
  enddo

  !!alert.error('Graphical aid (' & !number & ') is not registered in the aid construction system.')

endmethod
-- End of method definition for .remove(REAL)

------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove all graphic entries from system of a given type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Type of graphic item
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .remove(!type is STRING)

  -- Loop through each entry
  do !i values !this.attribute(!type)
    !!aidNumbers.remove(!i)
  enddo

  -- Empty store
  !this.attribute(!type).clear()

endmethod
-- End of method definition for .remove(STRING)

------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove specified "aid numbers" from passed store type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Type of graphic item
--    1   R      ARRAY       List of "aid numbers" to be removed
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .remove(!type is STRING, !entries is ARRAY)

  -- Initialise Variables
  !list = !this.attribute(!type.upcase())

  -- Remove entries from system
  do !i indices !entries
    !!aidNumbers.remove(!entries[!i].real())
  enddo

  -- Remove entries from the list
  do !i indices !entries
    !this.attribute(!type.upcase()).remove(!this.attribute(!type.upcase()).findFirst(!entries[!i].real()))
  enddo

endmethod
-- End of method definition for .remove(STRING, ARRAY)

------------------------------------------------------------------------
--
-- Method:      position
--
-- Description: Changes position
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Array of data from picked
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .position(!results is ARRAY)

  -- Initialise Variables
  !aidPicked    = !results[1][1]
  !positionData = !results[1][2]
  !aidNumber    = !aidPicked.point

  -- Check the aid element is registers
  if(!!aidNumbers.numbers[!aidNumber].unset()) then
    !!alert.error('Unknown aid element')
    return error 1 no alert
  endif

  -- Get aid type (we always talk in terms of the object associated with
  -- the aid number not the actual aid type itself

  -- Reposition position
  if(!!aidNumbers.numbers[!aidNumber].objectType() inset ('GPHPOSITION','GPHCIRCLE','GPHPLANE', 'GPHPLANTGRID', 'GPHRADIALGRID', 'GPHLINEARGRID')) then
    !!aidNumbers.numbers[!aidNumber].position(!positionData.position)

  --Reposition line
  elseif (!!aidNumbers.numbers[!aidNumber].objectType() eq 'GPHLINE') then

    -- Determine if we want to move start/end or whole line
    !line          = !!aidNumbers.numbers[!aidNumber].line

    -- Intersection of line and pickline
    !iPosition     = !line.intersection(!aidPicked.pickLine)

    -- Determine which end we are nearest to
    !length        = !line.length()
    !startDistance = !line.startPosition.distance(!iPosition)
    !endDistance   = !line.endPosition.distance(!iPosition)

    -- if within 10% of end, then move the end
    -- Move start
    if(!startDistance le !length / 10) then
      !line.startPosition = !positionData.position

    -- Move end
    elseif (!endDistance le !length / 10) then
      !line.endPosition   = !positionData.position

    -- Offset through position
    else

      -- Get mid point of line
      !newLine   = !line.parallel(!positionData.position)
      !distance  = !newLine.proportion(0.5).distance(!positionData.position)

      if(!distance ne 0) then
        !direction = !newLine.proportion(0.5).line(!positionData.position).direction()
        !line      = !newLine.offset(!direction, !distance)
      else
        !line      = !newLine
      endif

    endif
    !!aidNumbers.numbers[!aidNumber].line = !line

  -- Don't know how to reposition item
  else
    !!alert.error('unable to reposition ' & !!aidNumbers.numbers[!aidNumber].objectType())
    return
  endif

  -- Draw new representation of aid item
  !!aidNumbers.numbers[!aidNumber].draw(!aidNumber)

endmethod
-- End of method definition for .position(ARRAY)

------------------------------------------------------------------------
--
-- Method:      radius
--
-- Description: Changes radius (this should only ever have arc definitions applied to it via the results list)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Array of data from picked
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .radius(!results is ARRAY)

  -- Initialise Variables
  !aidPicked    = !results[1][1]
  !positionData = !results[1][2]
  !aidNumber    = !aidPicked.point

  -- Check the aid element is registers
  if(!!aidNumbers.numbers[!aidNumber].unset()) then
    !!alert.error('Unknown aid element')
    return error 1 no alert
  endif

  -- Convert arc into plane
  !plane = object PLANE(!!aidNumbers.numbers[!aidNumber].circle.position, !!aidNumbers.numbers[!aidNumber].circle.orientation)

  -- New radius
  !!aidNumbers.numbers[!aidNumber].circle.radius = !!aidNumbers.numbers[!aidNumber].circle.position.distance(!plane.near(!positionData.position))

  -- Draw new representation of aid item
  !!aidNumbers.numbers[!aidNumber].draw(!aidNumber)

endmethod
-- End of method definition for .radius(ARRAY)

------------------------------------------------------------------------
--
-- Method:      length
--
-- Description: Extend length of a line, through a position
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Array of data from picked
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .length(!results is ARRAY)

  -- Initialise Variables
  !aidPicked    = !results[1][1]
  !positionData = !results[1][2]
  !aidNumber    = !aidPicked.point

  -- Check the aid element is registers
  if(!!aidNumbers.numbers[!aidNumber].unset()) then
    !!alert.error('Unknown aid element')
    return error 1 no alert
  endif

  -- Determine if we want to move start/end or whole line
  !line          = !!aidNumbers.numbers[!aidNumber].line

  -- Intersection of line and pickline
  !iPosition     = !line.intersection(!positionData.pointVector)

  -- Determine which end we are nearest to
  !length        = !line.length()
  !startDistance = !line.startPosition.distance(!iPosition)
  !endDistance   = !line.endPosition.distance(!iPosition)

  -- Extend Start
  if(!startDistance le !endDistance) then
    !line = !line.setLengthStart(!line.endPosition.distance(!iPosition))

  -- Extend End
  else
    !line = !line.setLengthEnd(!line.startPosition.distance(!iPosition))

  endif

  -- Re-define line
  !!aidNumbers.numbers[!aidNumber].line = !line

  -- Draw new representation of aid item
  !!aidNumbers.numbers[!aidNumber].draw(!aidNumber)

endmethod
-- End of method definition for .length(ARRAY)

------------------------------------------------------------------------
--
-- Method:      edit
--
-- Description: Edit a constructor.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       All pick data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .edit(!results is ARRAY)

  -- Pick Data
  !pickData  = !results[1]
  !results   = ARRAY()

  -- Check we have picked a registered design aid
  !!aidNumbers.registered(!pickData.point)

  -- Determine the type of edit
  !aidNumber = !pickData.point
  !aidItem   = !!aidNumbers.get(!aidNumber)

  -- Edit aid element
  !aidItem.edit(!aidNumber)
  handle any
    !!alert.error('Unable to find edit method for "' & !!aidNumbers.numbers[!aidNumber].objectType() & '"')
    return
  endhandle

  -- Put packet into edg system
  if(defined(!packet)) then
    !!edgCntrl.add(!packet)
  endif

endmethod
-- End of method definition for .edit(ARRAY)

------------------------------------------------------------------------
--
-- Method:      explicit
--
-- Description: Create aid item using the edit form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Item to be created
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .explicit(!type is STRING)

  -- Initialise Variable

  -- Explicit Line
  if(!type.upcase() eq 'LINE') then
    !aidNumber = !!aidNumbers.add(object GPHLINE())
    !this.lines.append(!aidNumber)

  -- Explicit Circle
  elseif (!type.upcase() eq 'CIRCLE') then
    !aidNumber = !!aidNumbers.add(object GPHCIRCLE())
    !this.circles.append(!aidNumber)

  -- Explicit Plane
  elseif (!type.upcase() eq 'PLANE') then
    !aidNumber = !!aidNumbers.add(object GPHPLANE())
    !this.planes.append(!aidNumber)

  -- Explicit Point
  elseif (!type.upcase() eq 'POINT') then
    !aidNumber = !!aidNumbers.add(object GPHPOSITION())
    !this.points.append(!aidNumber)

    -- Unhandled Explicit definition
  else
    !!alert.error('Unable to define "' & !type & '" explicitly.')
    return

  endif

  -- Edit new object
  !!aidNumbers.numbers[!aidNumber].edit(!aidNumber)

endmethod
-- End of method definition for .explicit(STRING)

------------------------------------------------------------------------
--
-- Method:      copy
--
-- Description: Copy an aid element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      EDGPICKDATA Pick Data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .copy(!pickData is EDGPICKDATA)

  -- Copy item into cut stack
  !this.copy.clear()
  !this.copy[1]   = !!aidNumbers.get(!pickData.point)

endmethod
-- End of method definition for .copy(EDGPICKDATA)

------------------------------------------------------------------------
--
-- Method:      delete
--
-- Description: Delete an aid element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      EDGPICKDATA Pick Data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .delete(!pickData is EDGPICKDATA)

  -- Copy item into cut stack
  !this.copy.clear()
  !this.copy[1]   = !!aidNumbers.get(!pickData.point)

  -- Remove from list
  !this.remove(!pickData.point)

endmethod
-- End of method definition for .delete(EDGPICKDATA)

------------------------------------------------------------------------
--
-- Method:      paste
--
-- Description: Copy an aid element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      EDGPICKDATA Pick Data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .paste(!pickData is EDGPOSITIONDATA)

  -- Get Copied item
  !aidElement = !this.copy[1]

  -- Reposition it
  !aidElement.position(!pickData.position)

  -- Add to the system
  !this.add(!aidElement)

endmethod
-- End of method definition for .paste(EDGPOSITIONDATA)

------------------------------------------------------------------------
--
-- Method:      orientate
--
-- Description: Orientate picked aid with current working plane
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      EDGPICKDATA Pick Data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .orientate(!pickData is EDGPICKDATA)

  -- Initialise Variables
  !aidNumber  = !pickData.point
  !aidElement = !!aidNumbers.get(!aidNumber)

  --Orientate item into the plane of the current working plane
  -- Special case for lines, there orientation is derived and the line
  -- is assumed to run in the Z axes
  if(!aidElement.objectType() eq 'GPHLINE') then
    !aidElement.onToPlane(!!edgPosCntrl.workPlane)
  else
    !aidElement.orientation(!!edgPosCntrl.workPlane.orientation)
  endif

  -- Set position onto nearest point from it "origin" to the working plane
  !aidElement.position(!!edgPosCntrl.workPlane.near(!aidElement.position()))

  -- Replace definition
  !!aidNumbers.replace(!aidNumber, !aidElement)

endmethod
-- End of method definition for .orientate(EDGPICKDATA)

------------------------------------------------------------------------
--
-- Method:      blobSize
--
-- Description: Change all blob sizes
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        New blob size
--    2   R      STRING      How do we apply the new blob size ALL or NEW
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .blobSize(!diameter is REAL, !option is STRING)

  -- Get Copied item
  !this.blobSize = !diameter

  -- If option is ALL, then update all existing blobs
  if(!option.upcase() eq 'ALL') then

    -- Loop through all points
    do !i indices !this.points
      !gphPosition = !!aidNumbers.get(!this.points[!i])
      !gphPosition.diameter(!diameter)
      !!aidNumbers.replace(!this.points[!i], !gphPosition)
    enddo
  endif

endmethod
-- End of method definition for .blobSize(REAL, STRING)

------------------------------------------------------------------------
------------------------------------------------------------------------
--                                                                    --
--                >>>>>> Processing Methods <<<<<<                    --
--                                                                    --
------------------------------------------------------------------------
------------------------------------------------------------------------

------------------------------------------------------------------------
--
-- Method:      circlePacket
--
-- Description: Circle Construction packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Construction method
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .circlePacket(!constructMethod is STRING) is EDGPACKET

  -- Initialise Variables
  !packet                = object EDGPACKET()
  !packet.defineCircle(!constructMethod)
  !packet.input[1]       = 'CIRCLE'
  !packet.action         = '!!aidConstructors.add(!this.return[1])'
  !packet.priority       = 2
  !packet.remove         = !this.recursive.not()
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .circlePacket(STRING) EDGPACKET

