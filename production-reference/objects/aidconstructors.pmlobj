------------------------------------------------------------------------
--
-- Method:      add
--
-- Description:  Add circle to list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARC         Circle definition
-- Return:
--   [Data Type] [Description]
--    REAL        Aid number constructor has been add into the system with
--
------------------------------------------------------------------------

define method .add(!arc is ARC) is REAL

  -- Check if arc definition is unset
  if(!arc.unset()) then
    return REAL()
  endif

  -- Define Graphic Arc
  !gphCircle = object GPHCIRCLE(!arc)

  -- Get next aid number
  !aidNumber = !!aidNumbers.add(!gphCircle)

  -- Add to list
  !this.circles.append(!aidNumber)

  -- Return aid number
  return !aidNumber

endmethod
-- End of method definition for .add(ARC) REAL

------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add graphic circle to list
