------------------------------------------------------------------------
--
-- Method:      modifyPacket
--
-- Description: Modify Construction packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Option
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .modifyPacket(!option is STRING) is EDGPACKET

  -- Initialise Variables
  !packet                = object EDGPACKET()

  -- Option
  -- Reposition
  if(!option.upcase() eq 'POSITION') then
    !packet.defineAid('Re-position Aid -')
    !packet.pickPacket.picks[1].prompt        = 'pick aid element'
    -- Defines extract pick for position
    !packet.pickPacket.picks[2] = object EDGPICKTYPE()
    !packet.pickPacket.picks[2].stdPosition('new position')
    !packet.action         = '!!aidConstructors.position(!this.return)'

  -- Change Radius
  elseif (!option.upcase() eq 'RADIUS') then
    !packet.defineAid('Change Radius -')
    -- Restricts the picking to only aid arcs
    !packet.pickPacket.picks[1].prompt        = 'pick aid circle'
    !packet.pickPacket.picks[1].pick.input[4] = 'ARC'
    -- Define extract pick for radius
    !packet.pickPacket.picks[2] = object EDGPICKTYPE()
    !packet.pickPacket.picks[2].stdPosition('radius position')
    !packet.action         = '!!aidConstructors.radius(!this.return)'

  -- Extend length
  elseif (!option.upcase() eq 'LENGTH') then
    !packet.defineAid('Change Length -')
    -- Restricts the picking to only aid lines
    !packet.pickPacket.picks[1].prompt        = 'pick aid line'
    !packet.pickPacket.picks[1].pick.input[4] = 'LINE'
    -- Define extract pick for radius
    !packet.pickPacket.picks[2] = object EDGPICKTYPE()
    !packet.pickPacket.picks[2].stdPosition('extend through position')
    !packet.action         = '!!aidConstructors.length(!this.return)'
  endif

  !packet.priority       = 2
  !packet.remove         = !this.recursive.not()
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .modifyPacket(STRING) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      copyPacket
--
-- Description: Copy Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .copyPacket() is EDGPACKET

  -- Initialise Variables
  !packet                        = object EDGPACKET()
  !packet.key                    = 'copy'
  !packet.description            = 'Copy aid item'
  !packet.type                   = 'aidConstructors'
  !packet.priority               = 2
  !packet.remove                 = !this.recursive.not()
  !packet.type                   = 'aidConstructors'
  !packet.action                 = '!!aidConstructors.copy(!this.return[1])'
  !packet.pickPacket.key         = 'copy'
  !packet.pickPacket.prompt      = 'Copy - '
  !packet.pickPacket.description = 'Copy'

  -- Pick Packet
  !packet.pickPacket.picks.clear()
  !packet.pickPacket.picks[1]    = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdAid('pick aid item')
  !packet.pickPacket.picks[1].pick.cursor = 'doublecross'

  -- Return
  return !packet

endmethod
-- End of method definition for .copyPacket() EDGPACKET

------------------------------------------------------------------------
--
-- Method:      orientationPacket
--
-- Description: Orientation Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Method of grid construction
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .orientatePacket(!dummyMethod is STRING) is EDGPACKET

  -- Initialise Variables
  if(!!edgPosCntrl.activePlane().not()) then
    !!alert.error('There is no active working plane.')
    return error 1 noalert
  endif

  -- Initialise Variables
  !packet                = object EDGPACKET()
  !packet.key            = 'orientate'
  !packet.description    = 'Orientate aid item'
  !packet.priority       = 2
  !packet.remove         = !this.recursive.not()
  !packet.type           = 'aidConstructors'

  -- Pick Packet
  !packet.pickPacket.picks.clear()
  !packet.pickPacket.picks[1]    = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdAid('pick aid item')
  !packet.pickPacket.picks[1].pick.cursor = 'doublecross'

  -- Method of orientation
--  if(!method eq 'workingPlane') then
    !packet.action                 = '!!aidConstructors.orientate(!this.return[1])'
    !packet.pickPacket.key         = 'copy'
    !packet.pickPacket.prompt      = 'Orientate - '
    !packet.pickPacket.description = 'Orientate'
--  endif

  -- Return
  return !packet

endmethod
-- End of method definition for .orientatePacket(STRING) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      deletePacket
--
-- Description: Delete Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .deletePacket() is EDGPACKET

   -- Initialise Variables
  !packet                = object EDGPACKET()

  -- Delete a graphical aid
  !packet.defineAid('Delete Aid -')
  !packet.pickPacket.picks[1].pick.cursor = 'exchange'
  !packet.action         = '!!aidConstructors.delete(!this.return[1])'
  !packet.priority       = 2
  !packet.remove         = !this.recursive.not()
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .deletePacket() EDGPACKET

------------------------------------------------------------------------
--
-- Method:      pastePacket
--
-- Description: Paste Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .pastePacket() is EDGPACKET

  -- Check that there is an item in the "copy" stack
  if(!this.copy.empty()) then
    !!alert.warning('No element currently in the copy buffer.')
    return error 1 noalert
  endif

  -- Define Packet
  !packet = object EDGPACKET()
  !packet.definePosition('Position')
  !packet.action         = '!!aidConstructors.paste(!this.return[1])'
  !packet.priority       = 2
  !packet.type           = 'aidConstructors'
  !packet.remove         = !this.recursive.not()

  return !packet

endmethod
-- End of method definition for .pastePacket() EDGPACKET

------------------------------------------------------------------------
--
-- Method:      radialGridPacket
--
-- Description: Radial Grid Definition Packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      RADIALGRID  Grid definition to setup with
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .radialGridPacket(!grid is GPHRADIALGRID) is EDGPACKET

  -- Initialise Variables

  -- Check radial grid form is defined.form
  if(undefined(!!radialGrids)) then
    pml reload form !!radialGrids
  endif

  -- Define Packet Data
  !packet                = object EDGPACKET()
  !packet.positionLink('!!radialGrids.position', 'Define Plant Grid')
  !packet.key            = 'radialGridPacket'
  !packet.type           = 'construct'
  !packet.input[1]       = !grid
  !packet.initialisation = '!!radialGrids.setup(''Reference Radial Grid'',''!!aidConstructors.add(!!radialGrids.grid)'',!this.input[1])'
  !packet.description    = 'Reference Radial Grid'
  !packet.form           = !!radialGrids
  !packet.close          = '!!radialGrids.tidy()'

  !packet.priority       = 2
  !packet.remove         = false
  !packet.type           = 'aidConstructors'

  -- Return
  return !packet

endmethod
-- End of method definition for .radialGridPacket(GPHRADIALGRID) EDGPACKET

