------------------------------------------------------------------------
--
-- Method:      getDesParamNumber
--
-- Description: return the design parameter index corresponding to the key
-- provided
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Key/name of design parameter (e.g. HTHK)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getDesParamNumber(!key is STRING) is REAL

  -- go through the table and see if there's a matching entry to the one requested
  !table = !this.designParamTable
  do !des values !table
    if (!des[1].upCase().trim() eq !key.upCase().trim()) then
    	 --found a match so return the string representing which DESP is needed
    	 !resStr = !des[4]
    	 break
    endif
  enddo
  if (undefined(!resStr)) then
  	return 0
  endif
  -- extract the index of the DESP array and return it as a REAL
  !res = !resStr.after('[').before(']')
  handle any
    return 0
  endhandle
  return !res.real()
  handle any
    return 0
  endhandle
endmethod
-- End of method definition
