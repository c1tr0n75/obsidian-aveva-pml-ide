------------------------------------------------------------------------
--
-- Method:      .edgSettings
--
-- Description: Control display of EDG settings form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .edgSettings()

  -- EDG settings is mutually exclusive with EDG offset
  !checked = !!appDesMain.offsetToggle.val
  if( !checked ) then
    !!appDesMain.offsetToggle.val = false
    !!edgPositionOffset.hide()
  endif

  show !!edgSettings

endmethod
-- End of method definition for .edgSettings

------------------------------------------------------------------------
--
-- Method:      .setOffset
--
-- Description: Control display of EDG settings form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setOffset(!offset is POSITION)

  !this.offsetXyz = !offset

endmethod
-- End of method definition for .edgSettings

------------------------------------------------------------------------
--
-- Method:      .offsetToggle
--
-- Description: Switch on/off offset positioning
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     Switch active offset on/off
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetToggle(!checked is BOOLEAN)

  !!appDesMain.offsetToggle.val = !checked

  if( !checked ) then
    -- if EDG settings shown, reset it to no offset and close
    if(defined(!!edgSettings)) then
      !this.offsetType = 'NONE'
      !!edgSettings.initialise()
      if( !!edgSettings.shown() ) then
        !!edgSettings.hide()
      endif
    endif
    -- set offset to XYZ and show the offset form
    !this.offsetType = 'ENU'
    if( defined(!!edgPositionOffset) ) then
      show !!edgPositionOffset free
    else
      -- initial position away from top right corner when fist shown
      show !!edgPositionOffset free at xr.2 yr.2
    endif
  else
    -- switch off offset
    !this.offsetType = 'NONE'
    !!edgPositionOffset.hide()
    !resetPosition = object POSITION('E0')
    !this.setOffset(!resetPosition)
  endif

endmethod
-- End of method definition for .offsetToggle

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    STRING      String definition of offset type
--
------------------------------------------------------------------------

define method .offsetType() is STRING

  return !this.offsetType

endmethod
-- End of method definition for .offsetType() STRING

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Set offset type to passed name
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetType(!type is STRING)

  -- Set offset type
  !this.offsetType = !type.upcase()

  -- Get offset type index number
  !typeIndex = !this.offsetTypes.findFirst(!type)

  -- Don't do anything for unset index
  if(!typeIndex.unset()) then
    return
  endif

  -- If there a form
  if(!this.offsetForms[!typeIndex].set()) then

    -- Carry out forms action
    $!<this.offsetForms[$!<typeIndex>]>
    handle ANY
      !!alert.warning(!!error.text)
      return
    endhandle
  endif

  -- If offset Type is NONE, then switch offset flag to false
  if(!this.offsetType eq 'NONE') then
    !this.offset   = false
  else
    !this.offset   = true
  endif

  -- Set prompt
  !!edgCntrl.state.updatePrompt()

endmethod
-- End of method definition for .offsetType(STRING)

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset position
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITION    Set offset position
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetType(!position is POSITION)

  -- Set offset
  !this.offsetXyz       = !position

endmethod
-- End of method definition for .offsetType(POSITION)

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset xyPosition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      XYPOSITION  Set offset position
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetType(!xyPosition is XYPOSITION)

  -- Set offset
  !this.offsetXy        = !xyPosition

endmethod
-- End of method definition for .offsetType(XYPOSITION)

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset Direction and distance
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DIRECTION   Direction of offset
--    1   R      REAL        Offset distance
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetType(!direction is DIRECTION, !distance is REAL)

  -- Set offset
  !this.offsetDistance  = !distance
  !this.offsetDirection = !direction
  !this.offsetSurface   = 0

endmethod
-- End of method definition for .offsetType(DIRECTION, REAL)

------------------------------------------------------------------------
--
-- Method:      offsetType
--
-- Description: Set offset Distance from surface
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Offset distance from surface
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .offsetType(!distance is REAL)

  -- Set offset
  !this.offsetSurface   = !distance

endmethod
-- End of method definition .offsetType(REAL)

------------------------------------------------------------------------
--
-- Method:      displayPlane
--
-- Description: Set working plane to passed plane
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .displayPlane()

  -- Remove aid graphics, but not definition
  !!aidNumbers.hide(!this.aidNumber)

  -- Redraw plane
  if(!this.activePlane and !this.visiblePlane) then
    !!aidNumbers.draw(!this.aidNumber)
  endif

  -- Update the prompt
  !!edgCntrl.state.updatePrompt()

  -- Action
  !this.wpMethods()

endmethod
-- End of method definition for .displayPlane()

------------------------------------------------------------------------
--
-- Method:      wpMethod
--
-- Description: Executes all working plane methods
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .wpMethods()

  -- Update Main Form
  if(!this.type eq 'MAINBAR') then

    -- Update "Main Bar Menu"
    !form                   = !!fmsys.main()
    !form.wp.val            = !this.activePlane
  elseif(!this.type eq 'STANDARD') then
    if( not defined(!!edgPositioning) ) then
      !this.active = false
      !this.showActive()
    endif
    !!edgPositioning.wp.val = !this.activePlane
  else
    if( not defined(!!edgNewPositioning) ) then
      !this.active = false
      !this.showActive()
    endif
    !!edgNewPositioning.wp.val = !this.activePlane
  endif

  -- Loop through wpMethods
  do !i indices !this.wpMethods
    $!<this.wpMethods[$!<i>]>
    handle ANY
    endhandle
  enddo

endmethod
-- End of method definition for .wpMethods()

------------------------------------------------------------------------
--
-- Method:      wpMethod
--
-- Description: Adds new method to be executed to wp method list
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Action to be carried out each time wp is turned on/off
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .wpMethod(!action is STRING)

  -- Add to list
  !this.wpMethods.append(!action)

endmethod
-- End of method definition for .wpMethod(STRING)

------------------------------------------------------------------------
--
-- Method:      setPick
--
-- Description: Set pick method
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setPick(!index is REAL)

  -- Initialise Variables
  !this.pickIndex     = !index
  !newPick            = !this.picks[!index]

  -- Merge new pick into existing pick
  !newPick.prompt = !this.pick.prompt
  !this.pick      = !newPick

  -- Replace pick of pick type with new pick
  !this.pickType.pick = !this.pick

  -- Push mode to current state
  !!edgCntrl.state.setPick(!this.pick)

endmethod
-- End of method definition for .setPick(REAL)

------------------------------------------------------------------------
--
-- Method:      setPickType
--
-- Description: Set pick type method
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setPickType(!index is REAL)

  -- Initialise Variables

  -- Make input gadget active/inactive
  if(!this.pickTypesInput[!index]) then

    -- Set edg format object
    !!edgFormat = $!<this.pickTypesFormat[$!<index>]>

    -- Update input gadget with current settings
      !this.inputGadget.val        = !this.pickTypesValue[!index]

    -- Make input gadget active
    !this.inputGadget.active = true

  -- No input gadget required
  else
    !this.inputGadget.active = false
  endif

  -- Set pickType to new pickType
  !this.pickTypeIndex = !index
  !this.pickType      = !this.pickTypes[!index]

  -- Apply prompt from "pickType" to pick
  !this.pick.prompt   = !this.pickType.pick.prompt

  -- Apply current pick to pick type
  !this.pickType.pick = !this.pick

  -- Update pick type
  !!edgCntrl.state.setPickType(!this.pickType)

endmethod
-- End of method definition .setPickType(REAL)

------------------------------------------------------------------------
--
-- Method:      setInput
--
-- Description: Accepts the pick input data and process the information
--
-- Method Type: Function/Procedure
-- Arguments:
--    1   R      GADGET      Gadget to update
--    2   R      STRING      Selection
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setInput(!gadget is GADGET, !select is STRING)

  -- Initialise Variables
  !this.inputGadget    = !gadget

  -- Set new value
  !this.pickTypesValue[!this.pickTypeIndex] = !gadget.val

  -- Update pick type
  !!edgCntrl.state.setPickType(!this.pickType)

endmethod
-- End of method definition for .setPickType(EDGPICKTYPE)

------------------------------------------------------------------------
--
-- Method:      position
--
-- Description: Map position onto active plane/snap to grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITION    Reference position
-- Return:
--   [Data Type] [Description]
--    POSITION    Mapped position
--
------------------------------------------------------------------------

define method .position(!refPosition is POSITION) is POSITION

  -- Initialise Variables
  !newPosition = !refPosition

  -- Position onto active working plane
  if(!this.activePlane) then

    -- Snap to active grid
    if(!this.activeGrid) then
      !grid        = !this.attribute(!this.gridType.upcase()).coreObject()
      !newPosition = !grid.snap(!refPosition)

    -- Snap to active grid centre
    elseif (!this.activeGridC) then
      !grid        = !this.attribute(!this.gridType.upcase()).coreObject()
      !newPosition = !grid.snapToCentre(!refPosition)

    -- Project onto plane
    else
      !newPosition = !this.workPlane.near(!refPosition)
    endif

  endif

  return !newPosition

endmethod
-- End of method definition for .position(POSITION) POSITION

------------------------------------------------------------------------
--
-- Method:      position
--
-- Description: Map position onto active plane/snap to grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      EDGPOSITIONDATA    Reference position
-- Return:
--   [Data Type] [Description]
--    POSITION    Mapped position
--
------------------------------------------------------------------------

define method .position(!data is EDGPOSITIONDATA) is POSITION

  -- Initialise Variables
  !newPosition = !data.position

  -- Position onto active working plane
  if(!this.activePlane) then

    -- Snap to active grid
    if(!this.activeGrid) then
      !grid        = !this.attribute(!this.gridType.upcase()).coreObject()
      !newPosition = !grid.snap(!newPosition)

    -- Snap to active grid centre
    elseif (!this.activeGridC) then
      !grid        = !this.attribute(!this.gridType.upcase()).coreObject()
      !newPosition = !grid.snapToCentre(!newPosition)

    -- Project onto plane
    else
      !newPosition = !this.workPlane.near(!newPosition)
    endif

  endif

  -- Offset position
  if(!this.offsetType ne 'NONE') then

    -- Offset positioning in specified distance & direction
    if(!this.offsetType eq 'DIST&DIR') then

      !newPosition = !newPosition.offset(!this.offsetDirection, !this.offsetDistance)

    elseif( !this.offsetType eq 'ENU') then

      !newPosition       = !newPosition.wrt( world )
      !newPosition.east  = !newPosition.east  + !this.offsetXyz.east
      !newPosition.north = !newPosition.north + !this.offsetXyz.north
      !newPosition.up    = !newPosition.up    + !this.offsetXyz.up

    elseif( !this.offsetType eq 'PLANE') then

      -- If there is either an plane set or an active plane, then we'll use it
      if(!data.plane.set() or !this.activePlane) then

        -- Working plane takes priority
        if(!this.activePlane) then
          !plane = !this.workPlane
        else
          !plane = !data.plane
        endif

        -- Position plane about the reference position
        !plane.position = !newPosition

        -- Convert position into an xyOffset on the plane
        !newPosition    = !plane.threeDPosition(!this.offsetXy)

      endif

    elseif( !this.offsetType eq  'SURFACE') then

      -- If there is either an plane set or an active plane, then we'll use it
      if(!data.plane.set() or !this.activePlane) then

        -- Working plane takes priority
        if(!this.activePlane) then
          !newPosition = !newPosition.offset(!this.workPlane.orientation.zDir(), !this.offsetSurface)
        else
          !newPosition = !newPosition.offset(!data.plane.orientation.zDir(), !this.offsetSurface)
        endif
      endif
    endif
  endif

  return !newPosition

endmethod
-- End of method definition for .position(EDGPOSITIONDATA) POSITION

------------------------------------------------------------------------
--
-- Method:      position
--
-- Description: Position of intersection of point vector mapped onto active plane/grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POINTVECTOR Point vector
-- Return:
--   [Data Type] [Description]
--    POSITION    Mapped position
--
------------------------------------------------------------------------

define method .position(!pointVector is POINTVECTOR) is POSITION

  -- Initialise Variables
  !newPosition = !pointVector.position

  -- Position onto active working plane
  if(!this.activePlane) then
    !newPosition = !pointVector.intersection(!this.workPlane)
  endif

  return !this.position(!newPosition)

endmethod
-- End of method definition for .position(POINTVECTOR) POSITION

------------------------------------------------------------------------
--
-- Method:      position
--
-- Description: Position of intersection of line mapped onto active plane/grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      LINE        Line
-- Return:
--   [Data Type] [Description]
--    POSITION    Mapped position
--
------------------------------------------------------------------------

define method .position(!line is LINE) is POSITION

  -- Initialise Variables
  !newPosition = !line.startPosition

  -- Position onto active working plane
  if(!this.activePlane) then
    !newPosition = !line.point().intersection(!this.workPlane)
  endif

  return !this.position(!newPosition)

endmethod
-- End of method definition for .position(LINE) POSITION

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Returns true if in 2D mode
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True is active 2d plane
--
------------------------------------------------------------------------

define method .activePlane() is BOOLEAN

 -- Initialise Variables
  return !this.activePlane

endmethod
-- End of method definition for .activePlane() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      planeDefined
--
-- Description: Returns true if there is a plane defined
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True is active 2d plane
--
------------------------------------------------------------------------

define method .planeDefined() is BOOLEAN

 -- Initialise Variables
  return !this.workPlane.set()

endmethod
-- End of method definition for .planeDefined() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      rePosition
--
-- Description: Repositions active plane
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      POSITION    New position
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rePosition(!position is POSITION)

  -- Initialise Variables

  -- Get current plane object
  !plane = !this.getPlane()

  -- Modify position
  !plane.position(!position)

  -- Re-define the plen
  !this.setPlane(!plane)

endmethod
-- End of method definition .rePosition(POSITION)

------------------------------------------------------------------------
--
-- Method:      setActive
--
-- Description: Set current activity of positioning gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .showActive()

  -- Set explicit form
  if(undefined(!!edgEPosition)) then
    pml reload form !!edgEPosition
  endif
  !!edgEPosition.setActive(!this.active)

  !useToolbar = false

   -- Update Main Form
  if(!this.type eq 'MAINBAR') then
    -- doesn't matter that we're not showing !!edgPositioning any more -
    -- the global variables it sets (!!realFmt and !!integerFmt) are set by COMFORMATS object
    !form = !!fmsys.main()

    -- Allow for modules that do not use toolbars
    !useToolbar =  defined( !form.edgPositioningToolbar )

  endif

  if( !useToolbar ) then

    -- set activity of toolbar
    !form.edgPositioningToolbar.active = !this.active

    -- set activity of input gadget
    !form.input.active = !this.pickTypesInput[!this.pickTypeIndex]
    -- make sure toolbar is visible if we're activating it
    if (!form.edgPositioningToolbar.visible.not() and !this.active) then
      !form.edgPositioningToolbar.visible = true
    endif

  -- Update positioning form
  else

    if( !this.type eq 'STANDARD' ) then

      if(undefined(!!edgPositioning)) then
        pml load form !!edgPositioning
      endif
      !form                 = !!edgPositioning
      if(!form.shown().not() and !this.active) then
        !form.show('FREE')
      endif

    else
      -- force docked form
      !this.type = 'PAD1'
      !firstShown = undefined(!!edgNewPositioning)
      if(!firstShown) then
        pml load form !!edgNewPositioning
      endif
      !form                 = !!edgNewPositioning
      if(!form.shown().not() and !this.active) then
        !form.show('FREE')
      endif

    endif
    !form.setActive(!this.active)

  endif

  -- Populate the positioning gadgets if they are empty
  if( !this.type neq 'PAD1' ) then
    if(!form.pick.dtext.empty()) then
      !this.picks(!form.pick)
      !this.pickTypes(!form.pickType)
      !this.pickInput(!form.input)
      !this.workingPlane(!form.wp)
    endif
  else
    if(!firstShown) then
      !this.pickInput(!form.input)
      !this.workingPlane(!form.wp)
    endif
  endif

  -- Update input
  if(!this.pickTypesInput[!this.pickTypeIndex]) then
    !form.input.val         = !this.pickTypesValue[!this.pickTypeIndex]
  endif

  -- Select current items
  if( !this.type eq 'PAD1' ) then
    !form.setPickGadgets(!this.pickIndex)
    !form.setPickTypeGadgets(!this.pickTypeIndex)
  else
    !form.pick.val          = !this.pickIndex
    !form.pickType.val      = !this.pickTypeIndex
  endif

  -- Working Plane setting
  !form.wp.val            = !this.activePlane

endmethod
-- End of method definition .showActive()

------------------------------------------------------------------------
--
-- Method:      setActive
--
-- Description: Set state of positioning control gadgets
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     State to set gadgets to
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setActive(!active is BOOLEAN)

  -- If return ignore if already current active and passed are the same
  if(!active.eq(!this.active)) then
    return
  endif

  -- Initialise Variables
  !this.active = !active

  -- If being set to active, then we must be in use.
  if(!active) then
    !this.inUse = true
  endif

  -- Setup position control gadgets/forms
  !this.showActive()


endmethod
-- End of method definition .setActive(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      hide
--
-- Description: Remove the positioning control form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .hide()

  -- Set forms to inactive
  !this.setActive(false)
  !this.active = false
  !this.inUse  = false

  -- Remove positioning control form
  if(!this.type eq 'MAINBAR') then
    !!fmsys.main().edgPositioningToolbar.visible = false
  elseif(!this.type eq 'STANDARD') then
    !!edgPositioning.hide()
  else
    !!edgNewPositioning.hide()
  endif

  -- hide explicit position if shown
  !shown = !!edgEPosition.shown()
  handle any
    !shown = false
  endhandle
  if(!shown) then
    !!edgEPosition.hide()
  endif

endmethod
-- End of method definition .hide()
