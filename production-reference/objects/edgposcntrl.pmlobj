-- Created:         Tue Jan 27 15:16:23 WAT 1998
--
--
-- Description:
-- Control form for edg positioning tool kit.
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  activePlane()                    BOOLEAN             Returns true if in 2D mode
--  activePlane(BOOLEAN)             -                   Make currently defined working plane active/inactive
--  activePlane(BOOLEAN,BOOLEAN)     -                   Make currently defined working plane active/inactive
--  activePlane(GADGET,STRING)       -                   Make currently defined working plane active/inactive
--  activePlane(GPHLINEARGRID)       -                   Set working plane to passed linear grid and make it active
--  activePlane(GPHPLANE)            -                   Set working plane to passed plane and make it active
--  activePlane(GPHPLANTGRID)        -                   Set working plane to passed plant grid and make it active
--  activePlane(GPHRADIALGRID)       -                   Set working plane to passed radial grid and make it active
--  displayPlane()                   -                   Set working plane to passed plane
--  edgPosCntrl()                    -                   Constructor
--  edgSettings()                    -                   Control display of EDG settings form
--  getPlane()                       ANY                 Returns the current GPH<object> plane definition
--  globalInstance()                 -                   Create global instance of object
--  hide()                           -                   Remove the positioning control form
--  loadOffsets()                    -                   Load offset data
--  loadPicks()                      -                   Load picking data
--  loadWorkingPlane()               -                   Load working plane data
--  offsetToggle(BOOLEAN)            -                   Switch on/off offset positioning
--  offsetType()                     STRING              Set offset type
--  offsetType(DIRECTION,REAL)       -                   Set offset Direction and distance
--  offsetType(POSITION)             -                   Set offset position
--  offsetType(REAL)                 -                   Set offset Distance from surface
--  offsetType(STRING)               -                   Set offset type
--  offsetType(XYPOSITION)           -                   Set offset xyPosition
--  pickInput(GADGET)                -                   Load passed text input gadget with callback data
--  pickList()                       ARRAY               Available Picks for positioning package
--  pickTypeList()                   ARRAY               Available Pick Types for positioning package
--  pickTypes(GADGET)                -                   Load passed list gadget with pick types and set its callback
--  picks(GADGET)                    -                   Load passed list gadget with picks and set its callback
--  planeDefined()                   BOOLEAN             Returns true if there is a plane defined
--  position(EDGPOSITIONDATA)        POSITION            Map position onto active plane/snap to grid
--  position(LINE)                   POSITION            Position of intersection of line mapped onto active plane/grid
--  position(POINTVECTOR)            POSITION            Position of intersection of point vector mapped onto active plane/grid
--  position(POSITION)               POSITION            Map position onto active plane/snap to grid
--  rePosition(POSITION)             -                   Repositions active plane
--  setActive(BOOLEAN)               -                   Set state of positioning control gadgets
--  setInput(GADGET,STRING)          -                   Accepts the pick input data and process the information
--  setOffset(POSITION)              -                   Control display of EDG settings form
--  setPick(REAL)                    -                   Set pick method
--  setPickType(REAL)                -                   Set pick type method
--  setPlane(GPHLINEARGRID)          -                   Set working plane to passed linear grid
--  setPlane(GPHPLANE)               -                   Set working plane to passed plane
--  setPlane(GPHPLANTGRID)           -                   Set working plane to passed plant grid
--  setPlane(GPHRADIALGRID)          -                   Set working plane to passed radial grid
--  showActive()                     -                   Set current activity of positioning gadgets
--  visiblePlane(BOOLEAN)            -                   Make currently defined working plane visible
--  workingPlane(GADGET)             -                   Load passed toggle gadget with callback data
--  wpMethod(STRING)                 -                   Adds new method to be executed to wp method list
--  wpMethods()                      -                   Executes all working plane methods
--
------------------------------------------------------------------------

-- Define object
define object EDGPOSCNTRL

  -- Positioning control is active?
  member .active          is BOOLEAN

  -- Positioning control is in use
  member .inUse           is BOOLEAN

  -- Current positioning pick type (snap, distance, ...)
  member .pickType        is EDGPICKTYPE
  member .pickTypeIndex   is REAL

  -- Current pick filter type (element, ppoint, ...)
  member .pick            is EDGPICK
  member .pickIndex       is REAL

  -- Intermediate Snap in action (significant point)
  member .intermediate    is BOOLEAN

  -- Offset
  member .offset          is BOOLEAN
  member .offsetType      is STRING
  member .offsetXyz       is POSITION
  member .offsetXy        is XYPOSITION
  member .offsetDistance  is REAL
  member .offsetDirection is DIRECTION
  member .offsetSurface   is REAL

  -- Offset settings
    -- Display
    member .offsetDisplays is ARRAY
    -- Associated form
    member .offsetForms    is ARRAY
    -- Type of offset
    member .offsetTypes    is ARRAY

  -- Current Option Gadget
  member .gadget          is GADGET

  -- Working Plane (2D) if grid active, then
  -- this MUST be the same as the grid plane
  member .workPlane       is PLANE

  -- Working Grid
  member .referencePlane  is GPHPLANE
  member .linearGrid      is GPHLINEARGRID
  member .radialGrid      is GPHRADIALGRID
  member .plantGrid       is GPHPLANTGRID

  -- Is the plane active
  member .activePlane     is BOOLEAN
  -- Is there a grid to consider
  member .activeGrid      is BOOLEAN
  member .activeGridC     is BOOLEAN
  -- Which grid type do we use
  member .gridType        is STRING

  -- Is the plane/grid visible
  member .visiblePlane    is BOOLEAN

  -- Aid Element Number for Plane
  member .aidNumber       is REAL

  -- Available Picks
  member .picks           is ARRAY
  -- Available Pick Types
  member .pickTypes       is ARRAY

  -- Pick Type requiring an input
  member .pickTypesInput  is ARRAY
  -- Input gadget
  member .inputGadget     is GADGET

  -- Default setting
  member .pickTypesValue  is ARRAY
  -- Format form input
  member .pickTypesFormat is ARRAY

  -- List of methods to be actioned when working
  -- plane is actioned
  member .wpMethods       is ARRAY

  -- Type of positioning control mechanism (temporary)
  member .type            is STRING

endobject
-- End of object definition

------------------------------------------------------------------------
--
-- Method:      edgPosCntrl
--
-- Description: Constructor
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .edgPosCntrl()

  -- Initialise Variables
  $(
  var !mainBar evar PDMSPOSITIONMAINBAR
  if(!mainBar.empty().not()) then
    !this.type      = 'MAINBAR'
  else
    !this.type      = 'STANDARD'
  endif
  $)
  -- use toolbar by default
--  !this.type        = 'MAINBAR'
--  !this.type        = 'STANDARD'
  !this.type        = 'PAD1'

  !this.active      = false
  !this.inUse       = false

  -- Aid Number
  !this.aidNumber   = !!aidNumbers.add(object PLANE())

  -- Load default pick
  !this.loadPicks()

  -- Load default working plane
  !this.loadWorkingPlane()

  -- Load offset data
  !this.loadOffsets()

endmethod
-- End of method definition .edgPosCntrl()

------------------------------------------------------------------------
--
-- Method:      globalInstance
--
-- Description: Create global instance of object
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .globalInstance()

  -- If the global instance exits, don't reload it
  if(not defined(!!edgPosCntrl)) then
    -- Create Global Variable
    !!edgPosCntrl = !this
  endif

--   -- Show active states
--   !!edgPosCntrl.showActive()

endmethod
-- End of method definition for .globalInstance()

------------------------------------------------------------------------
--
-- Method:      loadOffsets
--
-- Description: Load offset data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .loadOffsets()

  -- Load Offset Data

  -- OffsetForms MUST contain the action for setting up the form

  -- Offset Definitions
  !this.offsetDisplays.append('None')
  !this.offsetForms.append('!!edgSettings.editNone()')
  !this.offsetTypes.append('NONE')

  !this.offsetDisplays.append('East/North/Up')
  !this.offsetForms.append('!!edgSettings.editENU(!!edgPosCntrl.offsetXyz, ''!!edgPosCntrl.offsetType(!!edgSettings.positionENU.position())'')')
  !this.offsetTypes.append('ENU')

  !this.offsetDisplays.append('On plane')
  !this.offsetForms.append('!!edgSettings.editPlane(!!edgPosCntrl.offsetXy, ''!!edgPosCntrl.offsetType(!!edgSettings.positionPlane.xyPosition())'')')
  !this.offsetTypes.append('PLANE')

  !this.offsetDisplays.append('Distance Direction')
  !this.offsetForms.append('!!edgSettings.editDD(!!edgPosCntrl.offsetDirection, !!edgPosCntrl.offsetDistance, ''!!edgPosCntrl.offsetType(!!edgSettings.directionDD.val, !!edgSettings.distanceDD.val)'')')
  !this.offsetTypes.append('DIST&DIR')

  !this.offsetDisplays.append('From surface')
  !this.offsetForms.append('!!edgSettings.editSurface(!!edgPosCntrl.offsetSurface, ''!!edgPosCntrl.offsetType(!!edgSettings.distanceSurface.val)'')')
  !this.offsetTypes.append('SURFACE')

  -- Set default offset type to NONE
  !this.offset          = false
  !this.offsetType      = 'NONE'

  -- Offset Default information
  !this.offsetXyz       = N0
  !this.offsetXy        = object XYPOSITION(0,0)
  !this.offsetDistance  = 0
  !this.offsetDirection = N
  !this.offsetSurface   = 0

endmethod
-- End of method definition for .loadOffsets()

------------------------------------------------------------------------
--
-- Method:      loadWorkingPlane
--
-- Description: Load working plane data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .loadWorkingPlane()

  -- Grid and Plane Data
  !this.gridType     = 'NONE'
  !this.activeGrid   = false
  !this.activeGridC  = false
  !this.visiblePlane = false
  !this.activePlane  = false

endmethod
-- End of method definition for .loadWorkingPlane()

------------------------------------------------------------------------
--
-- Method:      loadPicks
--
-- Description: Load picking data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .loadPicks()

  -- Populate Permissible Pick Types
  !this.picks[1]        = object EDGPICK()
  !this.picks[1].stdAny()

  !this.picks[2]        = object EDGPICK()
  !this.picks[2].stdElement()

  !this.picks[3]        = object EDGPICK()
  !this.picks[3].stdAid()

  !this.picks[4]        = object EDGPICK()
  !this.picks[4].stdPline()

  !this.picks[5]        = object EDGPICK()
  !this.picks[5].stdPpoint()

  !this.picks[6]        = object EDGPICK()
  !this.picks[6].stdScreen()

  !this.picks[7]        = object EDGPICK()
  !this.picks[7].stdGraphics()

  !this.picks[8]        = object EDGPICK()
  !this.picks[8].stdExternal()

  -- Populate Permissible Pick Options
  !this.pickTypes[1]       = object EDGPICKTYPE()
  !this.pickTypes[1].setSnap()
  !this.pickTypesInput[1]  = false

  !this.pickTypes[2]       = object EDGPICKTYPE()
  !this.pickTypes[2].setDistance('!!edgPosCntrl.pickTypesValue[2]')
  !this.pickTypesInput[2]  = true
  !this.pickTypesValue[2]  = 0
  !this.pickTypesFormat[2] = '!!distanceFmt'

  !this.pickTypes[3]       = object EDGPICKTYPE()
  !this.pickTypes[3].setProportion(0.5)
  !this.pickTypes[3].description = 'Mid-Point'
  !this.pickTypes[3].pick.prompt = 'Mid-Point'
  !this.pickTypesInput[3]  = false

  !this.pickTypes[4]       = object EDGPICKTYPE()
  !this.pickTypes[4].setFraction('!!edgPosCntrl.pickTypesValue[4]')
  !this.pickTypesInput[4]  = true
  !this.pickTypesValue[4]  = 2
  !this.pickTypesFormat[4] = '!!integerFmt'

  !this.pickTypes[5]       = object EDGPICKTYPE()
  !this.pickTypes[5].setProportion('!!edgPosCntrl.pickTypesValue[5]')
  !this.pickTypesInput[5]  = true
  !this.pickTypesValue[5]  = 0.5
  !this.pickTypesFormat[5] = '!!realFmt'

  !this.pickTypes[6]       = object EDGPICKTYPE()
  !this.pickTypes[6].setIntersect()
  !this.pickTypesInput[6]  = false

  !this.pickTypes[7]       = object EDGPICKTYPE()
  !this.pickTypes[7].setExact()
  !this.pickTypesInput[7]  = false

  -- Current snap flag
  !this.intermediate  = true

  -- Set default pick and pick type
  !this.pickTypeIndex      = 1
  !this.pickType           = !this.pickTypes[!this.pickTypeIndex]
  !this.pickIndex          = 2
  !this.pickType.pick      = !this.pickTypes[!this.pickIndex].pick
  !this.pick          = !this.pickType.pick

endmethod
-- End of method definition .loadPicks()

------------------------------------------------------------------------
--
-- Method:      picks
--
-- Description: Load passed list gadget with picks and set its callback
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Gadget to update
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .picks(!gadget is GADGET)

  -- Initialise Variables
  !gadget.dtext    = !this.pickList()

  -- Set callback
  !gadgetName      = !gadget.name()
  !gadget.callback = '!!edgPosCntrl.setPick(!this.' & !gadgetName & '.val)'

endmethod
-- End of method definition .picks(GADGET)

------------------------------------------------------------------------
--
-- Method:      pickTypes
--
-- Description: Load passed list gadget with pick types and set its callback
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Gadget to update
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .pickTypes(!gadget is GADGET)

  -- Initialise Variables
  !gadget.dtext    = !this.pickTypeList()

  -- Set callback
  !gadgetName      = !gadget.name()
  !gadget.callback = '!!edgPosCntrl.setPickType(!this.' & !gadgetName & '.val)'

endmethod
-- End of method definition .pickTypes(GADGET)

------------------------------------------------------------------------
--
-- Method:      pickInput
--
-- Description: Load passed text input gadget with callback data
--
-- Method Type: Function/Procedure
-- Arguments:
--    1   R      GADGET      Gadget to update
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .pickInput(!gadget is GADGET)

  -- Remember input gadget
  !this.inputGadget    = !gadget

  -- Set callback
  !gadgetName       = !gadget.name()
  !gadget.callback  = '!!edgPosCntrl.setInput(!this.' & !gadgetName & ',||)'

endmethod
-- End of method definition .pickInput(GADGET)

------------------------------------------------------------------------
--
-- Method:      workingPlane
--
-- Description: Load passed toggle gadget with callback data
--
-- Method Type: Function/Procedure
-- Arguments:
--    1   R      GADGET      Gadget to update
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .workingPlane(!gadget is GADGET)

  -- Set callback
  !gadgetName       = !gadget.name()
--  !gadget.callback  = '!!edgPosCntrl.activePlane(!this.' & !gadgetName & '.val.boolean())'
  !gadget.callback  = '!!edgPosCntrl.activePlane('

endmethod
-- End of method definition .workingPlane(GADGET)

------------------------------------------------------------------------
--
-- Method:      pickList
--
-- Description: Available Picks for positioning package
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      PLANE       Plane definition
-- Return:
--   [Data Type] [Description]
--    ARRAY       List of defined picks (descriptions)
--
------------------------------------------------------------------------

define method .pickList() is ARRAY

  -- Initialise variables
  !returnArray       = ARRAY()

  -- Loop through picks
  do !i indices !this.picks
    !returnArray[!i] = !this.picks[!i].description
  enddo

  return !returnArray

endmethod
-- End of method definition .pickList() ARRAY

------------------------------------------------------------------------
--
-- Method:      pickTypeList
--
-- Description: Available Pick Types for positioning package
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      PLANE       Plane definition
-- Return:
--   [Data Type] [Description]
--    ARRAY       List of defined pick types (descriptions)
--
------------------------------------------------------------------------

define method .pickTypeList() is ARRAY

  -- Initialise variables
  !returnArray       = ARRAY()

  -- Loop through picks
  do !i indices !this.pickTypes
    !returnArray[!i] = !this.pickTypes[!i].description
  enddo

  return !returnArray

endmethod
-- End of method definition for .pickTypeList() ARRAY

------------------------------------------------------------------------
--
-- Method:      getPlane
--
-- Description: Returns the current GPH<object> plane definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ANY         Plane definition
--
------------------------------------------------------------------------

define method .getPlane() is ANY

  -- Return linear grid
  if(!this.gridType.upcase() eq 'LINEARGRID') then
    return !this.linearGrid

  -- Return radial grid
  elseif (!this.gridType.upcase() eq 'RADIALGRID') then
    return !this.radialGrid

  -- Return plant grid
  elseif (!this.gridType.upcase() eq 'PLANTGRID') then
    return !this.plantGrid

  -- Return plane
  else
    return !this.referencePlane
  endif

  -- If there is no reference plane, the define a default
  if(!this.referencePlane.unset()) then
    !this.referencePlane = object PLANE(N0, Y is N)
  endif

  return !this.referencePlane

endmethod
-- End of method definition for .getPlane() ANY

------------------------------------------------------------------------
--
-- Method:      visiblePlane
--
-- Description: Make currently defined working plane visible
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     true to plane is visible be visible
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .visiblePlane(!visible is BOOLEAN)

  -- Initialise Variables
  !this.visiblePlane = !visible
  !this.displayPlane()

endmethod
-- End of method definition .visiblePlane(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Make currently defined working plane active/inactive
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Gadget active is set from
--    2   R      STRING      Selection
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!gadget is GADGET, !select is STRING)

  -- Check if there is a working plane defined
  if(!this.workPlane.unset()) then

    -- If button has been used, the push it out
    if(!gadget.type() eq 'BUTTON') then
      !gadget.val = false
    endif

    -- Give warning
    !!alert.warning('No working plane has been defined.')
    return
  endif

  -- Set active plane
  !this.activePlane(!this.activePlane.not())

endmethod
-- End of method definition .activePlane(GADGET, STRING)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Make currently defined working plane active/inactive
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     true to activate plane
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!active is BOOLEAN)

  -- Initialise Variables
  !this.activePlane = !active
  !this.displayPlane()

endmethod
-- End of method definition for .activePlane(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Make currently defined working plane active/inactive
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     true to activate plane
--    1   R      BOOLEAN     true to make plane visible
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!active is BOOLEAN, !visible is BOOLEAN)

  -- Initialise Variables
  !this.activePlane  = !active
  !this.visiblePlane = !visible
  !this.displayPlane()

endmethod
-- End of method definition for .activePlane(BOOLEAN, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Set working plane to passed plane and make it active
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHPLANE    Plane definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!plane is GPHPLANE)

  -- Initialise Variables
  !this.activePlane = true

  -- Add grid to relevant member
  !this.setPlane(!plane)

  -- Update the prompt
  !!edgCntrl.state.updatePrompt()

  -- Action any associated update methods
  !this.wpMethods()

endmethod
-- End of method definition for .activePlane(GPHPLANE)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Set working plane to passed linear grid and make it active
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHLINEARGRID  Grid Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!grid is GPHLINEARGRID)

  -- Initialise Variables
  !this.activePlane = true

  -- Add grid to relevant member
  !this.setPlane(!grid)

  -- Update the prompt
  !!edgCntrl.state.updatePrompt()

  -- Action any associated update methods
  !this.wpMethods()

endmethod
-- End of method definition for .activePlane(GPHLINEARGRID)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Set working plane to passed radial grid and make it active
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHRADIALGRID  Grid Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!grid is GPHRADIALGRID)

  -- Initialise Variables
  !this.activePlane = true

  -- Add grid to relevant member
  !this.setPlane(!grid)

  -- Update the prompt
  !!edgCntrl.state.updatePrompt()

  -- Action any associated update methods
  !this.wpMethods()

endmethod
-- End of method definition for .activePlane(GPHRADIALGRID)

------------------------------------------------------------------------
--
-- Method:      activePlane
--
-- Description: Set working plane to passed plant grid and make it active
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHPLANTGRID  Grid Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .activePlane(!grid is GPHPLANTGRID)

  -- Initialise Variables
  !this.activePlane = true

  -- Add grid to relevant member
  !this.setPlane(!grid)

  -- Update the prompt
  !!edgCntrl.state.updatePrompt()

  -- Action any associated update methods
  !this.wpMethods()

endmethod
-- End of method definition for .activePlane(GPHPLANTGRID)

------------------------------------------------------------------------
--
-- Method:      setPlane
--
-- Description: Set working plane to passed plane
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHPLANE    Plane definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setPlane(!newPlane is GPHPLANE)

  -- Set plane
  !this.workPlane      = !newPlane.plane()
  !this.referencePlane = !newPlane
  !this.gridType       = 'NONE'

  -- Disable active grid
  !this.activeGrid  = false
  !this.activeGridC = false

  -- Replace current definition
  if(!this.visiblePlane and !this.activePlane) then
    !!aidNumbers.replace(!this.aidNumber, !newPlane)
  else
    !!aidNumbers.replaceNoUpdate(!this.aidNumber, !newPlane)
  endif

endmethod
-- End of method definition for .setPlane(GPHPLANE)

------------------------------------------------------------------------
--
-- Method:      setPlane
--
-- Description: Set working plane to passed linear grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHLINEARGRID  Grid Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setPlane(!grid is GPHLINEARGRID)

  -- Define working plane as plane of grid
  !this.workPlane   = !grid.plane()

  -- Define Grid
  !this.linearGrid  = !grid
  !this.gridType    = 'linearGrid'

  -- Replace current definition
  if(!this.visiblePlane and !this.activePlane) then
    !!aidNumbers.replace(!this.aidNumber, !grid)
  else
    !!aidNumbers.replaceNoUpdate(!this.aidNumber, !grid)
  endif

endmethod
-- End of method definition for .setPlane(GPHLINEARGRID)

------------------------------------------------------------------------
--
-- Method:      setPlane
--
-- Description: Set working plane to passed radial grid
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GPHRADIALGRID  Grid Definition
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setPlane(!grid is GPHRADIALGRID)

  -- Define working plane as plane of grid
  !this.workPlane  = !grid.plane()

  -- Define Grid
  !this.radialGrid = !grid
  !this.gridType   = 'radialGrid'

  -- Replace current definition
  if(!this.visiblePlane and !this.activePlane) then
    !!aidNumbers.replace(!this.aidNumber, !grid)
  else
    !!aidNumbers.replaceNoUpdate(!this.aidNumber, !grid)
  endif

endmethod
-- End of method definition for .setPlane(GPHRADIALGRID)

------------------------------------------------------------------------
--
-- Method:      setPlane
--
-- Description: Set working plane to passed plant grid
--
