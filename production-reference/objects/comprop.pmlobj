------------------------------------------------------------------------
--
-- Method:      .getPropertyTable()
--
-- Description: Query the properties - returning a COMPROPTABLE result
--
-- Method Type: Function
--
-- Return:
--   [COMPROPTABLE] [Contains tables of properties for the current element]
--
------------------------------------------------------------------------
define method .getPropertyTable() is COMPROPTABLE

  -- use new API to get table without hidden properties. Retain this method for compatibility
  return !this.getPropertyTable(false)

endmethod
-- End of method definition for .getPropertyTable()

