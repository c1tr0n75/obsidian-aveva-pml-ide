------------------------------------------------------------------------
--
-- Method:      .copyTo()
--
-- Description: Copy this objects data to the passed COMPROP objects data
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [COMPROP] [object to copy data to]
--
------------------------------------------------------------------------
define method .copyTo(!toObject is COMPROP)

  -- Check for bad pointer on this object
  !this.checkPointer()
  handle any
    !this.link()
  endhandle

  -- Check for bad pointer on passed object
  !toObject.checkPointer()
  handle any
    !toObject.link()
  endhandle

  -- copy the data
  !!comPropCntrl.data[!toObject.pointer] = !!comPropCntrl.data[!this.pointer]

  -- unset the edit and plot form references on the new object
  !!comPropCntrl.data[!toObject.pointer].editForm = object FORM()
  !!comPropCntrl.data[!toObject.pointer].plotForm = object FORM()

  -- copy the linked data
  do !i indices !!comPropCntrl.data[!this.pointer].linkedElements
    !!comPropCntrl.data[!this.pointer].linkedElements[!i].copyTo(!!comPropCntrl.data[!toObject.pointer].linkedElements[!i])
  enddo

endmethod
-- End of method definition for .copyTo(COMPROP)

------------------------------------------------------------------------
--
-- Method:      .copyFrom()
--
-- Description: Copy the passed COMPROP objects data to this objects data
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [COMPROP] [object to copy data from]
--
------------------------------------------------------------------------
define method .copyFrom(!fromObject is COMPROP)

  -- Check for bad pointer on this object
  !this.checkPointer()
  handle any
    !this.link()
  endhandle

  -- Check for bad pointer on passed object
  !fromObject.checkPointer()
  handle any
    !fromObject.link()
  endhandle

  -- copy the data
  !!comPropCntrl.data[!this.pointer] = !!comPropCntrl.data[!fromObject.pointer]

  -- unset the edit and plot form references on the new object
  !!comPropCntrl.data[!this.pointer].editForm = object FORM()
  !!comPropCntrl.data[!this.pointer].plotForm = object FORM()

  -- copy the linked data
  do !i indices !!comPropCntrl.data[!fromObject.pointer].linkedElements
    !!comPropCntrl.data[!this.pointer].linkedElements[!i].copyFrom(!!comPropCntrl.data[!fromObject.pointer].linkedElements[!i])
  enddo

endmethod
-- End of method definition for .copyFrom(COMPROP)


--**********************************************************************
