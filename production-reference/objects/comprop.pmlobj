------------------------------------------------------------------------
--
-- Method:      .propagateChanges()
--
-- Description: Update this instance from the master definition
--
-- Method Type: Procedure
--
-- Return:
--   [COMPROPERROR]  [Common properties error object]
--
------------------------------------------------------------------------
define method .propagateChanges() is COMPROPERROR

  -- tell this Object to force changes to the Design
  -- Template definition to be made to the instance
  !this.forceUpdate(true)
  -- Update the instance
  !this.setProperties()
  -- query the result
  !result = !!comPropCntrl.data[!this.pointer].getErrorLog()
  -- destructor for this object
  !this.deleteObject()
  return !result

endmethod
-- End of method

