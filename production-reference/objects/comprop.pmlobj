-- File:            comprop.pmlobj
--   Type:          Object Definition
--   Group:         General Application
--     Keyword:     PROP
--   Module:        common
--   Replaces:
--
-- Author:          C.Brown
-- Created:         Tue Feb 2 08:52:51 GMT 1999
--
-- Description:
-- Properties object
--
-- *** OLD STYLE PML ***
-- *** COMMAND LINE SYNTAX ***
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  autoCacheValues(BOOLEAN)         -                   Set the autoCacheValues flag
--  autoDelete(BOOLEAN)              -                   Set the auto delete mode
--  cacheValues()                    -                   Cache the current values of this object
--  cancelCall(STRING)               -                   Set the cancelCall member of the data object
--  checkPlot()                      BOOLEAN             Check if this object has a plotfile associated with it
--  checkPointer()                   -                   Check the pointer member
--  clearObject()                    -                   clear the contents of this object
--  comProp(DBREF)                   -                   Constructor
--  comProp(DBREF,ARRAY)             -                   Constructor
--  comProp(DBREF,STRING,STRING)     -                   Constructor
--  comProp(REAL)                    -                   Construct comProp object to reference existing COMPROPDATA object
--  copyFrom(COMPROP)                -                   Copy the passed COMPROP objects data to this objects data
--  copyTo(COMPROP)                  -                   Copy this objects data to the passed COMPROP objects data
--  currentValues(STRING,ARRAY)      -                   Set the current property values
--  currentValues(STRING,ARRAY,ARRAY) -                   Set the current property values
--  dKeyList(STRING)                 ARRAY               List DKEYS for DATA/DDAT of a given purpose
--  defaultDesignElement(DBREF)      -                   Set the default design element
--  deleteAllDims()                  -                   Delete all dimensions
--  deleteDesi()                     -                   Delete the design element
--  deleteLinks()                    -                   Delete the design element
--  deleteObject()                   -                   Delete this object
--  deleteObject(BOOLEAN)            -                   Delete this object
--  deleteTmpl()                     -                   Delete the template element
--  designElement(DBREF)             -                   Set the design element
--  displayAllDims()                 -                   Display all dimensions
--  displayDimension(REAL,BOOLEAN)   -                   Display the dimension for a design parameter
--  displayPlot()                    -                   Display the plotfile for this object
--  displayPlot(STRING,STRING,STRING) -                   Display the plotfile for this object
--  editFormApply(BOOLEAN)           -                   Set the edit form apply/ok flag
--  editFormAutoCall(STRING)         -                   Set the editFormAutoCall flag
--  editFormBlockOwn(BOOLEAN)        -                   Set the edit form owner blocking flag
--  editFormBlocking(BOOLEAN)        -                   Set the edit form blocking flag
--  editFormName(STRING)             -                   Set the edit form name
--  editFormTitle(STRING)            -                   Set the edit form title
--  editMode(STRING)                 -                   Set the edit mode
--  editProperties()                 -                   Edit the properties using the GUI
--  editable()                       BOOLEAN             Check if this object has properties that can be edited
--  findDimensions()                 -                   Find all dimension points for this object
--  forceHiddenDesignParameters(BOOLEAN) -                   Set the flag to force hidden design parameter current values
--  forceUpdate(BOOLEAN)             -                   Set the force update flag
--  getCatalogueReference()          DBREF               Query the properties using the GUI
--  getCurrentDesignParameter(STRING) REAL                Get the current design parameter for a given key
--  getCurrentDesignParameters()     ARRAY               Get the current design parameters
--  getPropertyTable()               COMPROPTABLE        Query the properties - returning a COMPROPTABLE result
--  getPropertyTable(BOOLEAN)        COMPROPTABLE        Query the properties - returning a COMPROPTABLE result
--  hideAllDims()                    -                   Hide all dimensions
--  hidePlot()                       -                   Hide the plotfile for this object
--  initialise(DBREF)                -                   Initialise an existing COMPROP object
--  initialise(DBREF,BOOLEAN)        -                   Initialise an existing COMPROP object, force object initialisation
--  initialise(DBREF,DBREF)          -                   Initialise an existing COMPROP object
--  link()                           -                   Link this object to global data store
--  linkedTemplate(BOOLEAN)          -                   Set the linked template flag
--  okCall(STRING)                   -                   Set the okCall member of the data object
--  propagateChanges()               COMPROPERROR        Update this instance from the master definition
--  queryFormTitle(STRING)           -                   Set the query form Title
--  queryProperties()                -                   Query the properties using the GUI
--  setCurrentDesignParameters(ARRAY) -                   Set the current design parameters
--  setProperties()                  -                   Set the parameters for the stored element
--  setProperties(DBREF)             -                   Set the parameters for the passed element
--  unsetDefaultDesignElement()      -                   Unset the default design element
--  unsetDesiElement()               -                   Unset the design element
--  unsetLinks()                     -                   Delete the design element
--  updateAllDims()                  -                   Update all dimensions
--  updateLinks()                    -                   Update (propagate) the linked templates
--
------------------------------------------------------------------------

define object COMPROP

  -- Array index for corresponding instance of COMPROPDATA object
  member .pointer is REAL

endobject
-- End of object definition for COMPROP



--**************************************************************
--***                                                        ***
--***                 CONSTRUCTORS                           ***
--***                                                        ***
--**************************************************************

------------------------------------------------------------------------
--
-- Method:      .comProp(REAL)
--
-- Description: Construct comProp object to reference existing COMPROPDATA object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [REAL] [Pointer to existing COMPROPDATA object]
--
------------------------------------------------------------------------
define method .comProp(!index is REAL)

  if (defined(!!comPropCntrl.data[!index])) then
    !this.pointer = !index
  endif

endmethod
-- End of method definition for .comProp(REAL)

------------------------------------------------------------------------
--
-- Method:      .comProp(DBREF)
--
-- Description: Constructor
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--
------------------------------------------------------------------------
define method .comProp(!element is DBREF)

  -- Initialise variables
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].comPropData(!element)
  !!comPropCntrl.data[!this.pointer].setDesignElementsArray(object ARRAY())

endmethod
-- End of method definition for .comProp(DBREF)

------------------------------------------------------------------------
--
-- Method:      .comProp(DBREF)
--
-- Description: Constructor
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Design element]
--   [2] [R] [ARRAY] [Array of like Design elements]
--
------------------------------------------------------------------------
define method .comProp(!element is DBREF, !elementsArray is ARRAY)

  -- Initialise variables
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].comPropData(!element)
  !!comPropCntrl.data[!this.pointer].setDesignElementsArray(!elementsArray)

endmethod
-- End of method definition for .comProp(DBREF, ARRAY)

------------------------------------------------------------------------
--
-- Method:      .comProp(DBREF, STRING, STRING)
--
-- Description: Constructor
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]  [SPCO or Design element]
--   [2] [R] [STRING] [Edit Form Title]
--   [3] [R] [STRING] [Query Form Title]
--
------------------------------------------------------------------------
define method .comProp(!element is DBREF, !editFormTitle is STRING, !queryFormTitle is STRING)

  -- Initialise variables
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].comPropData(!element, !editFormTitle, !queryFormTitle)
  !!comPropCntrl.data[!this.pointer].setDesignElementsArray(object ARRAY())

endmethod
-- End of method definition for .comProp(DBREF, STRING, STRING)



--***********************************************************************************
--***                                                                             ***
--***  PUBLIC METHODS                                                             ***
--***                                                                             ***
--***  THESE METHODS DEFINE THE OBJECT INTERFACE FOR THE APPLICATION PROGRAMMER.  ***
--***  THEY MUST BE MAINTAINED AS THEY WILL BE CALLED EXTERNALLY.                 ***
--***                                                                             ***
--***********************************************************************************

------------------------------------------------------------------------
--
-- Method:      .initialise(DBREF)
--
-- Description: Initialise an existing COMPROP object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--
------------------------------------------------------------------------
define method .initialise(!element is DBREF)

  !this.deleteObject()
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].setDefaults()
  !!comPropCntrl.data[!this.pointer].setElementRefs(!element)

endmethod
-- End of method definition for .initialise(DBREF)

------------------------------------------------------------------------
--
-- Method:      .initialise(DBREF, DBREF)
--
-- Description: Initialise an existing COMPROP object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--   [2] [R] [DBREF] [Default Design element]
--
------------------------------------------------------------------------
define method .initialise(!element is DBREF, !defaultDesignElement is DBREF)

  !this.deleteObject()
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].setDefaults()
  !!comPropCntrl.data[!this.pointer].defaultDesignElement(!defaultDesignElement)
  !!comPropCntrl.data[!this.pointer].setElementRefs(!element)

endmethod
-- End of method definition for .initialise(DBREF, DBREF)

------------------------------------------------------------------------
--
-- Method:      .initialise(DBREF, BOOLEAN)
--
-- Description: Initialise an existing COMPROP object, force object initialisation
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--   [2] [R] [BOOLEAN] [Flag to force re-initialisation of object]
--
------------------------------------------------------------------------
define method .initialise(!element is DBREF, !forceInit is BOOLEAN)

  !this.deleteObject()
  !this.link()

  -- Call global method
  !!comPropCntrl.data[!this.pointer].setDefaults()
  !!comPropCntrl.data[!this.pointer].setElementRefs(!element, !forceInit)

endmethod
-- End of method definition for .initialise(DBREF, BOOLEAN)

