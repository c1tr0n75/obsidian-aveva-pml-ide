--*** THESE METHODS WILL ONLY BE CALLED FROM:                        ***
--***      comPropData.pmlobj                                        ***
--***      comProp.pmlfnc                                            ***
--***      comPropEdit.pmlfnc                                        ***
--***      comPropQuery.pmlfrm                                       ***
--***                                                                ***
--**********************************************************************

------------------------------------------------------------------------
--
-- Method:      .link()
--
-- Description: Link this object to global data store
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .link()

  -- Create global variable to store COMPROP object control
  if (undefined(!!comPropCntrl)) then
    !!comPropCntrl = object COMPROPCNTRL()
  endif

  if (!this.pointer.set()) then
    !this.deleteObject(true)
  endif
  !number = !!comPropCntrl.addData()

  -- Create new COMPROPDATA object and get index
  !this.pointer = !number

endmethod
-- End of method definition for .link()

