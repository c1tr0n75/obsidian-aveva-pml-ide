--
------------------------------------------------------------------------
define method .getPropertyTable(!includeHidden is BOOLEAN) is COMPROPTABLE

  -- Check for bad pointer
  !this.checkPointer()

  -- Call global method
  !table = !!comPropCntrl.data[!this.pointer].getPropertyTable(!includeHidden)
  return !table

endmethod
-- End of method definition for .getPropertyTable()

