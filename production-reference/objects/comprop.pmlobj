------------------------------------------------------------------------
--
-- Method:      .deleteObject(BOOLEAN)
--
-- Description: Delete this object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN] [Flag to indicate if data is deleted or marked for deletion]
--
------------------------------------------------------------------------
define method .deleteObject(!removeData is BOOLEAN)

  -- Check for bad pointer
  !this.checkPointer()
  handle any
    return
  endhandle

  !this.deleteAllDims()

  !tempArray = !!comPropCntrl.data[!this.pointer].linkedTemplates
  if (!removeData) then
    -- remove linked templates
    do !i indices !tempArray
      !!comPropCntrl.removeData(!!comPropCntrl.data[!this.pointer].linkedTemplates[!i].pointer)
    enddo
    !!comPropCntrl.removeData(!this.pointer)
   else
    -- remove linked templates
    do !i indices !tempArray
      !!comPropCntrl.markData(!!comPropCntrl.data[!this.pointer].linkedTemplates[!i].pointer)
    enddo
    !!comPropCntrl.markData(!this.pointer)
  endif

  -- Remove edg measure operation
  !!edgCntrl.remove('Edit Property Measurement')

  kill !!comPropEdit$!<this.pointer>
  kill !!comPropPlot$!<this.pointer>

  !this.pointer = REAL()

endmethod
-- End of method definition for .deleteObject(BOOLEAN)


--**************************************************************
--***                                                        ***
--***                 PRIVATE METHODS                        ***
--***                                                        ***
--**************************************************************

------------------------------------------------------------------------
--
-- Method:      .checkPointer()
--
-- Description: Check the pointer member
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .checkPointer()

  if (!this.pointer.unset() or undefined(!!comPropCntrl.data[!this.pointer])) then
    return error 1 'Properties data object has been deleted'
  endif

endmethod
-- End of method definition for .checkPointer()
