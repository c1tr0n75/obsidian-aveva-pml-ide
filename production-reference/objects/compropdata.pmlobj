--
-- Method:      .cancelCall(STRING)
--
-- Description: Set the cancelCall member of the data object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING]  [Cancel Callback string]
--
------------------------------------------------------------------------
define method .cancelCall(!cancelCall is STRING)

  !this.cancelCall = !cancelCall

  -- If the edit form has already been built,
  -- then set the form's cancel callback
  if (!this.editForm.set()) then
    !this.editForm.cancelCall = !this.cancelCall
  endif

endmethod
-- End of method definition for .cancelCall(STRING)

