------------------------------------------------------------------------
--
-- Method:      .okCall(STRING)
--
-- Description: Set the okCall member of the data object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING]  [OK Callback string]
--
------------------------------------------------------------------------
define method .okCall(!okCall is STRING)

  !this.okCall = !okCall

  -- If the edit form has already been built,
  -- then set the form's ok button callback
  if (!this.editForm.set()) then
    if (!this.editFormApply) then
      !this.editForm.ok.callback = !this.okCall
    else
      !this.editForm.okCall     = !this.okCall
    endif
  endif

endmethod
-- End of method definition for .okCall(STRING)

