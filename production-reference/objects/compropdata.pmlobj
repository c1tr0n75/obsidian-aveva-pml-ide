-- Description:
-- Properties data object
--
-- *** OLD STYLE PML ***
-- *** COMMAND LINE SYNTAX ***
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  autoCacheValues(BOOLEAN)         -                   Set the autoCacheValues flag
--  autoDelete(BOOLEAN)              -                   Set the auto delete mode
--  buildEditForm()                  -                   Build the edit form
--  cancelCall(STRING)               -                   Set the cancelCall member of the data object
--  cancelEditForm()                 -                   Cancel the edit form
--  cancelLinks()                    -                   Cancel the edit form
--  checkPlot()                      BOOLEAN             check for plotfile
--  clearPropData()                  -                   Clear the property data storage
--  comPropData(DBREF)               -                   Constructor
--  comPropData(DBREF,STRING,STRING) -                   Constructor
--  createTmpl(DBREF,DBREF)          DBREF               Create Design Template
--  currentUnitsVal(STRING,DBREF,DBREF,STRING) REAL                return the current value as a REAL in the current units
--  dKeyList(STRING)                 ARRAY               List DKEY for DATA/DDAT of a given purpose
--  defaultDesignElement(DBREF)      -                   Set the default design Element for this object
--  deleteAllDims()                  -                   Delete all dimensions
--  deleteDesi()                     -                   Delete the design element
--  deleteLinks()                    -                   Delete the linked templates
--  deleteTmpl(DBREF)                -                   Delete the template element
--  designElement(DBREF)             -                   Set the design Element for this object
--  displayAllDims()                 -                   Display all dimensions
--  displayDimension(REAL,BOOLEAN)   -                   Display the dimension for a design parameter
--  displayPlot()                    -                   Display the plotfile for this object
--  displayPlot(STRING,STRING,STRING) -                   Display the plotfile for this object
--  editFormApply(BOOLEAN)           -                   Set the edit form apply/ok flag
--  editFormAutoCall(STRING)         -                   Set the editFormAutoCall flag
--  editFormBlockOwn(BOOLEAN)        -                   Set the edit form blocking flag
--  editFormBlocking(BOOLEAN)        -                   Set the edit form blocking flag
--  editFormName(STRING)             -                   Set the editFormName member of the data object
--  editFormTitle(STRING)            -                   Set the formTitle member of the data object
--  editListEntry(GADGET)            -                   Edit a list gadget entry using appropriate entry form
--  editMode(STRING)                 -                   Set the edit mode for this object
--  editProperties()                 -                   Edit the properties using the GUI
--  editSbre(REAL)                   -                   Edit the properties for a linked template
--  editable()                       BOOLEAN             Check there are properties to edit
--  errorLogAppend(STRING,STRING,STRING,STRING,STRING) -                   Add new message to the error log
--  evaluateRules()                  -                   Evaluate all rules for the element
--  findDimensions()                 -                   Find all dimension points for this object
--  findProperties()                 -                   Find the datasets for the current catalogueElement
--  forceHiddenDesignParameters(BOOLEAN) -                   Set the flag to force hidden design parameter current values
--  forceUpdate(BOOLEAN)             -                   Set the force update flag
--  genRepeat(DBREF)                 -                   Do the template repeats
--  getAdjSpcos(DBREF)               ARRAY               Get adjacent spco elements or vvalues
--  getCurrentDesignParameter(STRING) REAL                Get the current design parameter for a given key
--  getCurrentDesignParameters()     ARRAY               Get the current design parameters
--  getDataValues(DBREF,DBREF,DBREF) ARRAY               Get the default or actual property values for DATA elements
--  getDdatValues(DBREF,DBREF,DBREF) ARRAY               Get the default or actual property values
--  getElementSbre(DBREF,STRING,STRING,DBREF) DBREF               Get the current value for a SBRE data type
--  getElementSpre(DBREF,STRING)     DBREF               Get the current value for a SPRE data type
--  getErrorLog()                    COMPROPERROR        Add new message to the error log
--  getFormattedString(ANY,STRING)   STRING              Get a string with units qualifiers according to the current
--  getPlotFile()                    STRING              Get the plotfile name for this object
--  getProperties()                  -                   Get the properties for the passed element
--  getPropertyTable()               COMPROPTABLE        get table of properties
--  getPropertyTable(BOOLEAN)        COMPROPTABLE        get table of properties with or without hidden properties
--  getPropertyValues(DBREF)         ARRAY
--  getVValues(DBREF)                ARRAY               Get valid values for a data set
--  getVValuesString(DBREF)          ARRAY               Get valid value strings from valid values
--  hideAllDims()                    -                   Hide all dimensions
--  hidePlot()                       -                   Hide the plotfile for this object
--  initEditForm(STRING,BOOLEAN)     -                   Initialise the gadget values on the edit form
--  initQueryForm()                  -                   Initialise the gadget values on the query form
--  inputMeasure(GADGET,REAL)        -                   Set a value when input from an option gadget
--  inputValue(STRING,REAL,STRING,GADGET,BOOLEAN) -                   Set a value when input from an option gadget
--  linkedTemplate(BOOLEAN)          -                   Set the linked template flag
--  okCall(STRING)                   -                   Set the okCall member of the data object
--  okDelHier(DBREF)                 BOOLEAN             Can hierarchy be deleted
--  okEditForm()                     -                   Ok the edit form
--  queryFormTitle(STRING)           -                   Set the formTitle member of the data object
--  queryProperties()                -                   Query the properties using the GUI
--  replaceTmpl(DBREF)               STRING              Replace the template element
--  setCurrentDesignParameters(ARRAY) -                   Set the current design parameters
--  setDefaults()                    -                   Set members to default values
--  setDesignElementsArray(ARRAY)    -                   Set an Array of similar design elements to get the same properties
--  setElementRefs(DBREF)            -                   Set the element reference members
--  setElementRefs(DBREF,BOOLEAN)    -                   Set the element reference members
--  setGadget(GADGET,REAL)           -                   Set a gadget value and run gadget callbacks
--  setListMenu(GADGET)              -                   Set edit list popup menu based on current selection
--  setProperties()                  -                   Set the parameters for the object's design element
--  setProperties(DBREF)             -                   Set the parameters for the passed element
--  setPurposeList()                 -                   Set list of valid purposes to search for
--  setValue(STRING,REAL,ANY)        -                   Set a value when input from gadget
--  storeQueryValues()               -                   Store default, initial and current values for query form
--  storeValues()                    -                   Store default, initial and current values for edit form
--  unsetLinks()                     -                   Unset the linked templates
--  updateAllDims()                  -                   Update all the dimensions
--  updateInstance()                 -                   Update the object's design element template instance
--  updateLinks()                    -                   Update (propagate) the linked templates
--  updateStructuralWelds()          -                   Create or Update STWELD elements for the Design Element. Calls C# classes to perform
--  updateTmpl(DBREF)                STRING              Update the template element
--  validateValue(STRING,REAL,STRING,GADGET,REAL,REAL,BOOLEAN) -
--
------------------------------------------------------------------------

define object COMPROPDATA

  -- Index to global instance of this object
  member .pointer is REAL

  -- Spec component referenced by design element (SPREF)
  member .spcoElement is DBREF

  -- Flag to indicate setting requirement for design element spref
  member .setDesiSpref is BOOLEAN

  -- Design element, used if properties are being modified
  member .designElement  is DBREF
  member .designElementsArray  is ARRAY
  member .defaultDesignElement is DBREF

  -- Form title and callbacks for Edit form
  member .editFormTitle is STRING
  member .okCall        is STRING
  member .cancelCall    is STRING
  member .editFormName  is STRING

  -- Edit form setup parameters
  member .editMode         is STRING
  member .editFormBlocking is BOOLEAN
  member .editFormApply    is BOOLEAN
  member .editFormBlockOwn is BOOLEAN

  -- Auto callback to be run on execution of .okEditForm method
  member .editFormAutoCall is STRING

  -- Flag to indicate is values are cached
  member .autoCacheValues is BOOLEAN

  -- Form title for query form
  member .queryFormTitle is STRING

  -- Form references
  member .editForm  is FORM
  member .queryForm is FORM
  member .plotForm  is FORM

  -- Index array for Property purposes
  member .purposeList is ARRAY

  -- Cache of regularly accessed purpose index values
  member .attrIndex is REAL
  member .despIndex is REAL
  member .spreIndex is REAL
  member .sbreIndex is REAL
  member .paraIndex is REAL
  member .dataIndex is REAL
  member .exprIndex is REAL
  member .plotIndex is REAL
  member .allIndex  is REAL

  -- Data storage for property elements
  -- 2 dimensional ARRAY where first dimension order is controlled by
  -- the contents of .purposeList, second dimension holds a DBREF for
  -- each property that matches the purpose in .purposeList
  member .propertyData is ARRAY

  -- Dimension point data storage
  member .dimPoints is ARRAY
  member .dimGraphics is ARRAY
  member .dimDisplay is ARRAY

  -- Storage for data values
  member .currentValues is ARRAY
  member .defaultValues is ARRAY
  member .initialValues is ARRAY

  -- Flag to indicate if properties are taken from a catalogue component
  member .dataType  is STRING

  -- DBREF of TMPL or catalogue component from which the properties will be taken
  member .catalogueElement is DBREF

  -- Array of linked templates
  member .linkedTemplates is ARRAY
  member .isLinked is BOOLEAN
  member .linkedElements  is ARRAY
  member .initialLinkVals is ARRAY

  -- Array of sub templates
  member .subTemplates is ARRAY

  -- Flag to indicate if edit values have been stored
  member .editValuesStored is BOOLEAN
  -- Flag to indicate if query values have been stored
  member .queryValsStored is BOOLEAN

  -- Flag to indicate a single local instance of this object that should be killed
  -- when an edit or query operation has been completed
  member .autoDelete is BOOLEAN

  -- Flag to indicate forced update mode
  member .forceUpdate is BOOLEAN

  -- flag to force hidden design parameters to be set to the current value
  member .forceHiddenDesignParameters is BOOLEAN

  -- Error logging object
  member .error            is COMPROPERROR

  member .okFromForm       is BOOLEAN

endobject
-- End of object definition for COMPROPDATA


--**********************************************************************
--***                                                                ***
--***                        CONSTRUCTORS                            ***
--***                                                                ***
--**********************************************************************

------------------------------------------------------------------------
--
-- Method:      .comPropData(DBREF)
--
-- Description: Constructor
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--
------------------------------------------------------------------------
define method .comPropData(!element is DBREF)

  -- Initialise variables
  !this.setDefaults()

  -- Check the element type and set .tmplOwner, .spco members accordingly
  !this.setElementRefs(!element)
  handle any
    -- if the setting of element references fails, the property object
    -- must be deleted from the global object store
    !temp = object COMPROP(!this.pointer)
    !temp.deleteObject(false)
    return error 1 'This element does not have properties'
  endhandle

endmethod
-- End of method definition for .comPropData(DBREF)

------------------------------------------------------------------------
--
-- Method:      .comPropData(DBREF, STRING, STRING)
--
-- Description: Constructor
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]  [SPCO or Design element]
--   [2] [R] [STRING] [Edit Form Title]
--   [3] [R] [STRING] [Query Form Title]
--
------------------------------------------------------------------------
define method .comPropData(!element is DBREF, !editFormTitle is STRING, !queryFormTitle is STRING)

  -- Initialise variables
  !this.setDefaults()

  -- Set form data
  !this.editFormTitle(!editFormTitle)
  !this.queryFormTitle(!queryFormTitle)

  -- Check the element type and set .tmplOwner, .spco members accordingly
  !this.setElementRefs(!element)
  handle any
    -- if the setting of element references fails, the property object
    -- must be deleted from the global object store
    !temp = object COMPROP(!this.pointer)
    !temp.deleteObject(false)
    return error 1 '$!!error.text'
  endhandle

endmethod
-- End of method definition for .comPropData(DBREF, STRING, STRING)



--**********************************************************************
--***                                                                ***
--*** THESE METHODS WILL ONLY BE CALLED FROM:                        ***
--***      comProp.pmlfnc                                            ***
--***      comPropEdit.pmlfnc                                        ***
--***      comPropQuery.pmlfrm                                       ***
--***                                                                ***
--**********************************************************************

------------------------------------------------------------------------
--
-- Method:      .setElementRefs(DBREF)
--
-- Description: Set the element reference members
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [SPCO or Design element]
--
------------------------------------------------------------------------
define method .setElementRefs(!element is DBREF)

  !this.setElementRefs(!element, false)

endmethod
-- End of method definition for .setElementRefs(DBREF)

------------------------------------------------------------------------
--
-- Method:      .setElementRefs(DBREF, BOOLEAN)
--
-- Description: Set the element reference members
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]   [SPCO, TABITE, GPART or Design element]
--   [2] [R] [BOOLEAN] [Flag to force re-initialisation of object]
--
------------------------------------------------------------------------
define method .setElementRefs(!element is DBREF, !forceInit is BOOLEAN)

  -- Check for nulref
  if (!element.badref()) then
    !this.setDefaults()
    return
  endif

  -- Initialise variables
  !updateProperties   = false
  !removeLinks        = false
  !designElement    = object DBREF()
  !spcoElement      = object DBREF()
  !partElement      = object DBREF()
  !catalogueElement = object DBREF()
  !elementHardType  = !element.hardType

  ---   Find the element references by analysing the chain of reference pointers -----

  -- Handle TMPL element
  if ( !elementHardType eq 'TMPL' and !element.owner.hardType eq 'TMAR' ) then

    -- element is a TMPL element definition (in a TPWL) ------------
      if (!element eq !this.catalogueElement and !forceInit.not()) then
        return
    endif

        !this.designElement = object DBREF()
        !this.catalogueElement = !element
        !this.spcoElement = object DBREF()
        !removeLinks = true
        !updateProperties = true
        !this.dataType = 'TMPL'

  else

    -- Element is not a TMPL element definition
    if (!elementHardType inset(|SPCO|, |TABITE|, |GPART|) ) then

      --- Element is a catalogue element definition  --------------

      if (!element eq !this.spcoElement and !forceInit.not()) then
        return
      endif

      -- Element is a SPCO, TABITE or GPART, construct object without a design element reference
      !this.designElement = object DBREF()
      !spcoElement = !element
      -- check for TABITEM. Need to follow prtref first to get part element
      if( !elementHardType eq |TABITE| ) then
        !partElement   = !spcoElement.prtReference
        if( !partElement.badref() ) then
          !partElement = object DBREF()
        endif
      else
        -- element referenced by the Design element is the same as the element referencing the catalogue element
        !partElement   = !spcoElement
      endif

      -- Find the catalogue element from the part reference
      if( !partElement.set() ) then
        -- Check for catalogue component or TMPL
        if (!partElement.catRef.set()) then
          --------------------------------------------------------------------
          -- check for tmpref set as well for new Template parameterised by SCOM/SFIT
          if(not badref(!partElement.tmpRef)) then
            -- Element has a valid tmpref, assume that this has properties
            !catalogueElement = !partElement.tmpRef
            !this.dataType    = 'TMPL'
          else
          -- Element has a valid catRef.
            !catalogueElement = !partElement.catRef
            !this.dataType    = 'CATA'
          endif
          --------------------------------------------------------------------

        elseif (!partElement.tmpRef.set()) then
          -- Element has a valid tmpref, assume that this has properties
          !catalogueElement = !partElement.tmpRef
          !this.dataType = 'TMPL'

        else
          -- Spref doesn't point to anything with properties
          !catalogueElement = object DBREF()
        endif

      endif

      if (!catalogueElement.unset()) then
        -- Spref doesn't point to anything
        !spcoElement      = object DBREF()
        !partElement      = object DBREF()
      endif

      if (!spcoElement.unset()) then
        -- return error 1 'No Dataset Found'
        return
      else
        -- It is a different spco element so, set the flags to update the properties
        !this.spcoElement = !spcoElement
        !removeLinks = true
        !updateProperties = true
        !this.catalogueElement = !catalogueElement
      endif

  else

      ---  Element is a Design element  --------------

    -- Check that the design element
    --  1.  Has a spref that is set to a catalogue component or tmpl that has properties
    --  2.  Owns a template that has properties
      !elementOwnerList    = ARRAY()
      !elementOwnerList[1] = !element
      !elementOwnerList.appendArray(!element.ownLst.invert())

      -- loop through element hierarchy from given element up to the top to find actual Design element
      do !testElement values !elementOwnerList

        if (!testElement.attributes().findFirst('Spref').set() or !testElement.hardType inset('NOZZ','ELCONN') ) then
        -- The element has a spref
          !spcoElement         = !testElement.spref
          handle any
            !spcoElement = object DBREF()
            !partElement = object DBREF()
          endhandle

          if (!spcoElement.set() and !spcoElement.badref().not()) then

            !designElement       = !testElement
            -- check for TABITEM. Need to follow prtref first to get part element
            if( !spcoElement.hardType eq |TABITE| ) then
              !partElement   = !spcoElement.prtReference
              if( !partElement.badref() ) then
                !partElement = object DBREF()
              endif
            else
              -- element referenced by the Design element is the same as the element referencing the catalogue element
              !partElement   = !spcoElement
            endif

            -- Find the catalogue element from the part reference
            if( !partElement.set() ) then
              if( !partElement.hardType eq 'SCOM' ) then
                -- allow for NOZZ and ELCONN with direct reference to SCOM
                !catalogueElement = !partElement
                !this.dataType    = 'CATA'
              elseif (!partElement.catRef.set()) then
              -- Check for catalogue component or TMPL
                --------------------------------------------------------------------
                -- check for tmpref set as well for new Template parameterised by SCOM/SFIT
                -- In this case it is assumed that the catref component provides parameters for the Template
                if(not badref(!partElement.tmpRef)) then
                  -- Element has a valid tmpref, assume that this has properties
                  !catalogueElement = !partElement.tmpRef
                  !this.dataType    = 'TMPL'
                else
                -- Element has a valid catRef.
                  !catalogueElement = !partElement.catRef
                  !this.dataType    = 'CATA'
                endif
                --------------------------------------------------------------------

              elseif (!partElement.tmpRef.set()) then
                -- Element has a valid tmpref, assume that this has properties
                !catalogueElement = !partElement.tmpRef
                !this.dataType = 'TMPL'

              else
                -- Spref doesn't point to anything with properties
                !catalogueElement = object DBREF()
              endif

          if( !catalogueElement.unset() ) then
            -- Spref doesn't point to anything
                !spcoElement      = object DBREF()
                !partElement      = object DBREF()
                !designElement    = object DBREF()
              endif
            endif

          else

          -- Spref is not set, check for member that is a TMPL
          !tmplElement = !!dtbMemberOfType(!testElement, 'TMPL', 1)
          if (!tmplElement.set() and !testElement.hardType ne 'TMAR') then
            -- element owns a TMPL, assume that it has properties
            !designElement    = !testElement
            !spcoElement      = object DBREF()
              !partElement      = object DBREF()
            !catalogueElement = !tmplElement
            !this.dataType = 'TMPL'
          else
            -- Element does not own a tmpl
            !designElement    = object DBREF()
            !spcoElement      = object DBREF()
              !partElement      = object DBREF()
            !catalogueElement = object DBREF()
          endif

          endif

        else

        -- Element does not have a spref attribute, check if it owns a tmpl
        if (!testElement.hardType eq 'TMPL' and !testElement.owner.hardType eq 'TMAR') then
          -- Element is in the template area
          !designElement = object DBREF()
          !spcoElement = object DBREF()
            !partElement = object DBREF()
          !catalogueElement = !testElement
          !this.dataType = 'TMPL'
          break

        else
          !tmplElement = !!dtbMemberOfType(!testElement, 'TMPL', 1)
          if (!tmplElement.set()) then
            -- Element owns a TMPL, assume that it has properties
            !designElement    = !testElement
            !spcoElement      = object DBREF()
              !partElement      = object DBREF()
            !catalogueElement = !tmplElement
            !this.dataType = 'TMPL'
              break

          else
            -- Element does not own a tmpl
            !designElement    = object DBREF()
            !spcoElement      = object DBREF()
              !partElement      = object DBREF()
            !catalogueElement = object DBREF()
          endif
        endif
      endif

        -- Finish climbing the hierarchy if a valid design element found
        break if (!designElement.set())

        break if (!this.isLinked)

    enddo

    if (!designElement.unset() and !spcoElement.unset() and !catalogueElement.unset()) then
      return error 1 'No Dataset Found'
      endif

      if ( !designElement.set() ) then
      -- Set the design element
      !this.designElement(!designElement)

      -- Check for change in spco element and set update flag
        if (!this.spcoElement ne !spcoElement or !forceInit) then
        !this.spcoElement = !spcoElement
        !removeLinks = true
        !updateProperties = true
      endif

      -- Check for change in catalogue element and set update flag
        if (!this.catalogueElement ne !catalogueElement or !forceInit) then
        !this.catalogueElement = !catalogueElement
        if (!spcoElement.unset()) then
          !removeLinks = true
          !updateProperties = true
        endif
      endif

      endif

      --- End of processing a Design element

    endif

  endif

  ----- Element references set - now perform required updates --------

  -- Remove linked templates
  if (!removeLinks) then
    !this.unsetLinks()
  endif

  -- Set the  edit mode
  if (!this.designElement.set() and !this.editMode eq 'STORE') then
    if (!!comPropOpt.dynamicUpdate()) then
      !this.editMode = 'DYNAMIC'
    else
      !this.editMode = 'UPDATE'
    endif
  elseif (!this.designElement.unset() or !this.designElement.badref()) then
    !this.editMode = 'STORE'
  endif

  -- Update property data storage if required
  if (!updateProperties) then
    if (!this.editForm.set()) then
      !fname = !this.editForm.fullName()
      !this.editForm = object FORM()
      kill $!<fname>
    endif
    if (!this.plotForm.set()) then
      !fname = !this.plotForm.fullName()
      !this.plotForm = object FORM()
      kill $!<fname>
    endif
    !this.getProperties()
  endif

  if (!this.designElement.set()) then
    !this.defaultDesignElement = !this.designElement
  endif

endmethod
-- End of method definition for .setElementRefs(DBREF, BOOLEAN)

-------------------------------------------------------------------------
--
-- Method:      .designElement(DBREF)
--
-- Description: Set the design Element for this object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Element to set as design element]
--
------------------------------------------------------------------------
define method .designElement(!element is DBREF)

  if (!element.unset()) then
    !valid = true
    !this.editMode('STORE')

  elseif (!element.dbType eq 'DESI') then
    if (!element.attributes().findFirst('Spref').set() or !element.list.findFirst('TMPL').set()) then
      !valid = true
    else
      !valid = false
      !errorText = !element.type + ' element does not have a Spref attribute and cannot own a TMPL element'
    endif

  else
    !valid = false
    !errorText = !element.type + ' element is not defined in the DESI database type'
  endif

  if (!valid) then
    !this.designElement = !element
    do !i indices !this.linkedTemplates
      !this.linkedTemplates[!i].unsetDesiElement()
    enddo
  else
    !this.errorLogAppend('FAIL',  !errorText, 'Instance element', '', '')
    return error 1 '$!<errorText>'
  endif

endmethod
-- End of method definition for .designElement(DBREF)

-------------------------------------------------------------------------
--
-- Method:      .defaultDesignElement(DBREF)
--
-- Description: Set the default design Element for this object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Element to set as default design element]
--
------------------------------------------------------------------------
define method .defaultDesignElement(!element is DBREF)

  !this.defaultDesignElement = !element

endmethod
-- End of method definition for .defaultDesignElement(DBREF)

------------------------------------------------------------------------
--
-- Method:      .setProperties()
--
-- Description: Set the parameters for the object's design element
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .setProperties()

  if (!this.designElementsArray.size().gt(0)) then
    do !i indices !this.designElementsArray
      !this.setProperties(!this.designElementsArray[!i])
      handle ANY
      elsehandle NONE
        !!ce = !this.designElementsArray[!i]
        RULE REXE
      endhandle
    enddo
    return
  endif

  !this.setProperties(!this.designElement)

endmethod
-- End of method definition for .setProperties()

------------------------------------------------------------------------
--
-- Method:      .setProperties(DBREF)
--
-- Description: Set the parameters for the passed element
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]  [Design element]
--
------------------------------------------------------------------------
define method .setProperties(!element is DBREF)

  -- Store the current database position
  !dbPos = !!ce

  -- Check the element exists
  if (!element.badref()) then
    !this.errorLogAppend('FAIL','Invalid design element reference','Set Properties','','')
    return
  endif

  if (!this.spcoElement.unset() and !this.catalogueElement.unset()) then
    return
  endif

  -- check for valid reference elements. Is Spref is not set use the TMPL if there is one.
  if (!this.spcoElement.badref() or !this.catalogueElement.badref()) then
    !this.spcoElement = !!dtbMemberOfType(!element, 'TMPL', 1)
    if(!this.spcoElement.unset()) then
      !this.errorLogAppend('FAIL','Invalid spec reference or does not own a Template element','Set Properties','','')
      return
    else
      !this.catalogueElement = !this.spcoElement
    endif
  endif

  -------------------------------------------------------------------
  -- Set the object's design element and update the template instance
  !this.designElement(!element)
  !this.updateInstance()
  -------------------------------------------------------------------

  -- Set any attributes for ATTR data elements
  do !i indices !this.propertyData[!this.attrIndex]
    !data = !this.propertyData[!this.attrIndex][!i]

    -- Variable !value needs to be deleted each time as the data type may change
    if (defined(!value)) then
      !value.delete()
    endif

    -- Get the current value for the attribute
    !value = !this.currentValues[!this.attrIndex][!i]
    -- Set the attribute value
    $!<data.dKey> $!value
    handle any
      $!<data.dKey> '$!value'
      handle any
        !!alert.warning('Cannot set attribute ' + !data.dKey + ' to ' + !value.string())
      endhandle
    endhandle
  enddo

  -- Initialise variables used for setting design parameters
  !dataElements = ARRAY()
  !despValues = ARRAY()
  !errorCount = 0

  -- Set design parameters for DESP data elements
  do !i indices !this.propertyData[!this.despIndex]
    !data = !this.propertyData[!this.despIndex][!i]

    -- Variable !value needs to be deleted each time as the data type may change
    if (defined(!value)) then
      !value.delete()
    endif

    -- Get the current value for the design parameter
    -- If the user wishes to use a default value in place of a design parameter,
    -- he can hide the property.

      -- Check for hidden design parameter properties
      -- DDAT elements use ldisp attribute, DATA elements use lhide attribute
      if (!data.hardType eq 'DDAT') then
        !hidden = !data.ldisp.not()
      else
        !hidden = !data.lhide
      endif

    if (!hidden and !this.forceHiddenDesignParameters.not()) then
      !value = !this.defaultValues[!this.despIndex][!i]
    else
      if( not defined(!this.currentValues[!this.despIndex][!i]) ) then
        -- replace missing design parameters by default values
        !value = !this.defaultValues[!this.despIndex][!i]
      else
        !value = !this.currentValues[!this.despIndex][!i]
      endif
    endif

    -- Store design parameter value in array using the number attribute
    -- of the property element to indicate array position
    if (!data.number eq 0) then
      -- If the property number is 0 then append the design parameter value
      -- to the array, this is likely to cause problems, but is the safest way to
      -- handle incorrect dataset definition.
      !dataElements.append(!data)
      !despValues.append(!value)
      -- Output a warning to alert user to dataset definition problems
      !!alert.warning('Data set member ' + !data.fullName + ' has incorrect value for the number attribute')
    else
      !dataElements[!data.number] = !data
      !despValues[!data.number]   = !value
    endif
  enddo

  if (!despValues.set()) then

    do !i indices !despValues

      -- Check for hidden design parameter properties
      -- DDAT elements use ldisp attribute, DATA elements use lhide attribute
      if (!dataElements[!i].hardType eq 'DDAT') then
        !hidden = !dataElements[!i].ldisp.not()
      else
        !hidden = !dataElements[!i].lhide
      endif

      -- If the design parameter property is hidden then maintain its current value unless
      -- there is a default value on the data element.
      -- In the case where the design parameters are not set, initialise the value to 0 unless
      -- there is a default value on the data element.
      -- These design parameters should be set when the rules are evaluated
      if (!hidden and !this.forceHiddenDesignParameters.not()) then
        if (defined(!this.designElement.desp[!i])) then
          !tempValue[!i] = !this.designElement.desp[!i]
        else
          !tempValue[!i] = 0
        endif
      endif

      if(!despValues[!i].set()) then

        -- Design parameter properties of type DIST or BORE need to have
        -- units conversion applied to the value prior to setting the DESP attribute
        -- as the DESP attribute always stores values in metric
          !tempValue[!i] = !despValues[!i]
          handle (2,761)
            !errorCount = !errorCount + 1
            -- Only output this error once
            if (!errorCount eq 1) then
            endif
          	-- Type matching up the variable REAL to STRING
          	!originalObjectType = !tempValue[!i].objectType()
            !tempValue[!i].delete()
            !objectType = !despValues[!i].objectType()
            if (!objectType eq 'REAL') then
              !tempValue[!i] = object REAL()
            elseif (!objectType eq 'STRING') then
              !tempValue[!i] = object STRING()
            else
              -- make an object matching the original object type
              !block = object BLOCK('OBJECT ' + !originalObjectType + '()')
              !tempValue[!i] = !block.evaluate()
              handle ANY
              endhandle
            endif
            --Try again
            !tempValue[!i] = !despValues[!i]
            handle ANY
            endhandle
          endhandle
      else
        !tempValue[!i] = REAL()
      endif
      if (!tempValue[!i].unset()) then
        !tempValue[!i].delete()
        !tempValue[!i] = 0
      elseif (!tempValue[!i].string().trim() eq '') then
        !tempValue[!i].delete()
        !tempValue[!i] = 0
      endif
    enddo

    -- Navigate to design element to set the design parameters
    !!ce = !this.designElement
    -- Unset the DESP attribute, in case the number of design parameters has changed
    DESP UNSET
    handle any
      !this.errorLogAppend('FAIL',!!error.text,'Set Design Parameters',!!error.command,!!error.line)
      return
    endhandle

    do !i indices !tempValue
      !dimensionedValue = !tempValue[!i].queryString()
      handle any
        !dimensionedValue = !tempValue[!i]
      endhandle
      DESP NUM $!<i> $!<dimensionedValue>
    enddo

  else

    -- no design parameters for the selected component. Clear any existing DESP
    -- Navigate to design element to unset the design parameters
    !!ce = !this.designElement
    DESP UNSET
    handle any
      !this.errorLogAppend('FAIL',!!error.text,'Set Design Parameters',!!error.command,!!error.line)
      return
    endhandle

  endif

  -- Set the element spref if required
  if(!this.spcoElement.hardType.neq('TMPL')) then
    if (!this.setDesiSpref) then
      !!ce = !this.designElement
-- Nozz does not have a spref it has a CATREF
      if ( !!ce.hardType inset('NOZZ','ELCONN') ) then
       CATR $!<this.spcoElement>
        handle any
          !this.errorLogAppend('CRITICAL',!!error.text,'Set Catalogue Reference',!!error.command,!!error.line)
        endhandle
      else
       SPREF $!<this.spcoElement>
        handle any
          !this.errorLogAppend('CRITICAL',!!error.text,'Set Specification Reference',!!error.command,!!error.line)
        endhandle
      endif
           !this.setDesiSpref = false
    endif
  endif

  -- Set values for SPRE data elements
  do !i indices !this.propertyData[!this.spreIndex]
    !data = !this.propertyData[!this.spreIndex][!i]

    -- Variable !value needs to be deleted each time as the data type may change
    if (defined(!value)) then
      !value.delete()
    endif
    -- Get the current value of the SPRE dataset
    !value = !this.currentValues[!this.spreIndex][!i]

    -- Check for a dataset under the design element
    var !datasets COLLECT MEMBERS OF $!<this.designElement> WITH ( TYPE EQ 'DDSE' )
    if (!datasets.size() lt 1) then
      -- Create a dataset is none exist
      NEW DDSE
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Create Data Set',!!error.command,!!error.line)
      endhandle
    else
      -- Navigate to the first dataset
      !!ce = !datasets[1].dbref()
    endif

    -- Check for SPRE data element under dataset, create one if necessary
    do !j indices !datasets
      -- Collect ddat elements with dkey value equal to the SPRE template ddat element
      var !tmpDataElements COLLECT MEMBERS OF $!<datasets[$!<j>]> WITH ( DKEY EQ '$!<data.dKey>' )
      if (!tmpDataElements.set()) then
        -- There should only be one matching ddat
        !ddat = !tmpDataElements[1].dbref()
        break
      endif
    enddo

    -- If no DDAT element has been found then create a copy of the template dataset
    if (undefined(!ddat)) then
      NEW DDAT COPY $!<data>
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Create data element',!!error.command,!!error.line)
      endhandle
    else
      !!ce = $!<ddat>
    endif

    -- Set value for SPRE data element
    DDPR $!<value>
    handle any
      !this.errorLogAppend('CRITICAL',!!error.text,'Set data property',!!error.command,!!error.line)
    endhandle
  enddo

  if (!this.okFromForm) then
    !!ce = !dbPos
    -- Check we have read/write access to execute the rules
    if( not !!dbRefUpdate(!this.designElement) ) then
      -- Navigate to original database position
      if (!dbPos.badref().not()) then
        !!ce = !dbPos
      endif
      return error 1 |Unable to modify read-only data.|
    endif

    !!ce = !this.designElement
    -- Find the first level template
    !tmpl = !!dtbMemberOfType(!this.designElement, 'TMPL', 1)
    if (!tmpl.unset()) then
      -- No template, but still evaluate the rule
      RULE REXE
      handle any
        !this.errorLogAppend('FAIL',!!error.text,'Evaluate rules',!!error.command,!!error.line)
      endhandle
    else
      -- Set the correct lock levels
      UNLOCK ALL
      RULE REXE
      handle any
        !this.errorLogAppend('FAIL',!!error.text,'Evaluate rules',!!error.command,!!error.line)
      endhandle
      -- Re lock the template
      !!ce = !tmpl
      LOCK
    endif
    -- Navigate to original database position
    if (!dbPos.badref().not()) then
      !!ce = !dbPos
    endif
  else
    -- Execute all rules prior to defining linked templates
    !this.evaluateRules()
  endif

  -- Set values for SBRE data elements
  do !i indices !this.propertyData[!this.sbreIndex]
    !data = !this.propertyData[!this.sbreIndex][!i]

    -- Variable !value needs to be deleted each time as the data type may change
    if (defined(!value)) then
      !value.delete()
    endif
    -- Get the current value of the SBRE dataset
    !value = !this.currentValues[!this.sbreIndex][!i]


    -- Check for !data.ptyp type element under the design element, create one if necessary
    var !sube COLLECT MEMBERS OF $!<this.designElement> WITH ( TYPE EQ '$!<data.ptyp>' AND PURP EQ '$!<data.dKey>')
    if (!sube.unset()) then
      var !sube COLLECT MEMBERS OF $!<this.designElement> WITH ( TYPE EQ '$!<data.ptyp>' AND DESC EQ '$!<data.dKey>')
    endif

    -- skip if the current value is nulref
    if (!value.badref()) then
      if (!sube.set()) then
        !!ce = !sube[1].dbref()
        UNLOCK ALL
        DELETE $!<data.ptyp>
        handle (2,500) (2,501) (2,502) (2,503) (2,504)
          -- DAC errors
          !dataPType = !data.ptyp
          !!alert.warning(!dataPType & ' not deleted - ' & !!error.text)
          handle ANY
            -- Just in case the concatenated text is too long
            !!alert.warning(!!error.text)
          endhandle
        elsehandle any
        elsehandle none
          !this.linkedElements[!i] = object DBREF()
        endhandle
      endif
      skip
    endif

    if (!sube.size() lt 1) then
      -- AK always create the subs's at the bottom of the equipment list
      if (!!ce.members.size() ge 1) then
        !!ce = !!ce.members[!!ce.members.size()]
      endif

      -- Create a new sub element
      NEW $!<data.ptyp>
      handle (2,500) (2,501) (2,502) (2,503) (2,504)
        -- DAC errors
        !!alert.error(!!error.text)
        return
      elsehandle any
        skip
      endhandle

      -- Set the purpose to match the ddat element's dkey value
      PURP $!<data.dKey>
      handle any
        DESC '$!<data.dKey>'
      endhandle

      -- Set any rules on sub element
      var !attrRls COLLECT MEMBERS OF $!<data> WITH ( TYPE EQ 'ATTRRL' )
      do !j indices !attrRls
        !attrRl = !attrRls[!j].dbref()
        RULE SET $!<attrRl.attNam> ( $!<attrRl.attRule> )
        handle any
          !!alert.error('Error in template rule definition - rule set $!<attrRl.attName> ( $!<attrRl.attRule> )')
        endhandle
      enddo

    else
      -- Linked template design element already exists
      !!ce = !sube[1].dbref()
      -- Rules should be updated and re-applied on existing sub elements, this is called via the Update Template form.
      var !attrRls COLLECT MEMBERS OF $!<data> WITH ( TYPE EQ 'ATTRRL' )

      !attributeRule = object ATTRIBUTERULE()     
      !attDef        = object ATTDEFINITION()

      !diffArray     = object ARRAY()
      !tmplRuleNames = object ARRAY()
      !attRuleNames  = object ARRAY()

      !rList = !!ce.rlist

      do !value values !rList
        !attDef.attlibGet(!value)
        !tmplRuleNames.append(!attDef.name)
      enddo

      do !ind indices !attrRls
        !attr = !attrRls[!ind].dbref()
        !attDef.attlibGet(!attr.attNam)
        !attRuleNames.append(!attDef.name)
      enddo

      -- Find the differences for those that have been deleted
      !diffArray = !tmplRuleNames.difference(!attRuleNames)

      do !names values !diffArray
        !attributeRule.getRule(!!ce, !names)
        -- give setRule an empty string to delete rule for the attribute
        !string = '' 
        !attributeRule.setRule(!string)
      enddo

      -- Set the rules which have been changed
      do !j indices !attrRls
        !attrRl = !attrRls[!j].dbref()
        !attributeRule.getRule(!!ce, !attrRl.attNam)
        !rule = !attrRl.attRule 
        !attributeRule.setRule(!rule)
        handle any
            !!alert.error('Error in template rule definition - rule set $!<rule> ( $!<attrRl.attRule> )')
        endhandle
      enddo
    endif

    -- Set the properties for the linked template
    !this.linkedTemplates[!i].setProperties(!!ce)
    !this.linkedElements[!i] = !!ce
  enddo

  -- Create or Update Structural Welds for the element if required
  !this.updateStructuralWelds()

  -- Navigate to original database position
  if (!dbPos.badref().not()) then
    !!ce = !dbPos
  endif

endmethod
-- End of method definition for .setProperties(DBREF)

------------------------------------------------------------------------
--
-- Method:      .editable()
--
-- Description: Check there are properties to edit
--
-- Method Type: Function
--
-- Return:
--   [BOOLEAN] [True if object has properties that can be edited]
--
------------------------------------------------------------------------
define method .editable() is BOOLEAN

  -- Check there are properties to set
  if (!this.propertyData[!this.attrIndex].empty() and !this.propertyData[!this.despIndex].empty() and $
        !this.propertyData[!this.spreIndex].empty() and !this.propertyData[!this.sbreIndex].empty()) then
    !result = false

  else
    !result = true
  endif

  return !result

endmethod
-- End of method definition for .editable() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      .editProperties()
--
-- Description: Edit the properties using the GUI
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .editProperties()

  if (!this.designElement.set() and !this.isLinked.not()) then
    -- check that the design element is not already being edited by another
    -- COMPROPDATA object edit form
    !check = !!comPropCntrl.addElementList(!this.designElement, !this.pointer)

    if (!check.not()) then
      -- Clean up and don't show the edit form
      if (!this.autoDelete) then
        -- Object needs to be deleted, as edit operation has finished
        !temp = object COMPROP(!this.pointer)
        !temp.deleteObject(false)
      endif
      return
    endif
  endif

  -- Check there are properties to set
  if (!this.editable().not()) then
    return error 1 'There are no properties to set'
  endif

  -- Build the edit form if it is not already defined
  if (!this.editForm.unset()) then
    !this.buildEditForm()
    handle any
      -- There has been a problem building the edit form,
      -- so remove the design element from the object cache
      !!comPropCntrl.remElementList(!this.designElement)
      !!alert.error(!!error.text)
      return
    endhandle
  endif

  -- Set the initial values to match the current values
  !this.initialValues = !this.currentValues

  -- Initialise the edit form
  !this.initEditForm('CURRENT', false)
  handle any
    -- There has been a problem initialising the edit form,
    -- so remove the design element from the object cache
    !!comPropCntrl.remElementList(!this.designElement)
    !!alert.error(!!error.text)
    return
  endhandle

  -- Initialise the list menu if in list edit mode
  if (!this.editForm.listEdit) then
    !this.setListMenu(!this.editForm.properties)
  endif

  -- Show the edit form and block the forms owner if required
  !this.editForm.show()
  if (!this.editFormBlockOwn) then
    !this.editForm.mainForm = !this.editForm.owner()
    !this.editForm.mainForm.setActive(false)
  endif

endmethod
-- End of method definition for .editProperties()

------------------------------------------------------------------------
--
-- Method:      .queryProperties()
--
-- Description: Query the properties using the GUI
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .queryProperties()

  -- Load the query properties form if it is undefined
  if (undefined(!!comPropQuery)) then
    pml load form !!comPropQuery
  endif

  -- Set the object query form pointer
  if (!this.queryForm.unset()) then
    !this.queryForm = !!comPropQuery
  endif

  -- Check if the query form is already displaying properties for an object
  if (!this.queryForm.comProp.set()) then
    if (!this.queryForm.autoDelete) then
      -- Delete the object if auto delete mode is set
      !this.queryForm.comProp.deleteObject(false)
      !this.queryForm.comProp = object COMPROP()
    endif
  endif

  -- Initialise the query form members
  !this.queryForm.pointer = !this.pointer
  !this.queryForm.comProp = object COMPROP(!this.pointer)
  !this.queryForm.formTitle = !this.queryFormTitle
  !this.queryForm.autoDelete = !this.autoDelete

  -- Store the query values if not already stored
  if (!this.queryValsStored.not()) then
    !this.storeQueryValues()
  endif

  -- Initialise and show the query form
  !this.initQueryForm()
  !this.queryForm.show()

endmethod
-- End of method definition for .queryProperties()

------------------------------------------------------------------------
--
-- Method:      .editFormAutoCall(STRING)
--
-- Description: Set the editFormAutoCall string
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING]  [value for editFormAutoCall]
--
------------------------------------------------------------------------
define method .editFormAutoCall(!value is STRING)

  !this.editFormAutoCall = !value

endmethod
-- End of method definition for .editFormAutoCall(STRING)

------------------------------------------------------------------------
--
-- Method:      .autoCacheValues(BOOLEAN)
--
-- Description: Set the autoCacheValues flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate cached values]
--
------------------------------------------------------------------------
define method .autoCacheValues(!value is BOOLEAN)

  !this.autoCacheValues = !value

endmethod
-- End of method definition for .autoCacheValues(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .editMode(STRING)
--
-- Description: Set the edit mode for this object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING] [Edit mode value]
--
------------------------------------------------------------------------
define method .editMode(!value is STRING)

  !this.editMode = !value

  -- Dynamic edit mode uses ok/cancel buttons only
  if (!this.editMode eq 'DYNAMIC') then
    -- Force edit form action buttons to be ok/cancel
    !this.editFormApply(false)
  endif

endmethod
-- End of method definition for .editMode(STRING)

------------------------------------------------------------------------
--
-- Method:      .editFormBlocking(BOOLEAN)
--
-- Description: Set the edit form blocking flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate blocking form]
--
------------------------------------------------------------------------
define method .editFormBlocking(!value is BOOLEAN)

  -- If the edit form has already been built then it will need to be
  -- rebuilt if the blocking value has changed
  if (!this.editForm.unset()) then
    !this.editFormBlocking = !value

  elseif (!this.editFormBlocking ne !value) then
    !this.editFormBlocking = !value

    -- If the edit form is already shown, it should be re-shown
    if (!this.editForm.shown()) then
      !this.buildEditForm()
      !this.editProperties()

    else
      !this.buildEditForm()
    endif
  endif

endmethod
-- End of method definition for .editFormBlocking(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .editFormApply(BOOLEAN)
--
-- Description: Set the edit form apply/ok flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate apply/ok form]
--
------------------------------------------------------------------------
define method .editFormApply(!value is BOOLEAN)

  -- If the edit form has already been built then it will need to be
  -- rebuilt if the apply value has changed
  if (!this.editForm.unset()) then
    !this.editFormApply = !value

  elseif (!this.editFormApply ne !value) then
    !this.editFormApply = !value

    -- If the edit form is already shown, it should be re-shown
    if (!this.editForm.shown()) then
      !this.buildEditForm()
      !this.editProperties()

    else
      !this.buildEditForm()
    endif
  endif

endmethod
-- End of method definition for .editFormApply(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .editFormBlockOwn(BOOLEAN)
--
-- Description: Set the edit form blocking flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate blocking owner form]
--
------------------------------------------------------------------------
define method .editFormBlockOwn(!value is BOOLEAN)

  -- If the edit form has already been built then it will need to be
  -- rebuilt if the block owner value has changed
  if (!this.editForm.unset()) then
    !this.editFormBlockOwn = !value

  elseif (!this.editFormBlockOwn ne !value) then
    !this.editFormBlockOwn = !value

    -- If the edit form is already shown, it should be re-shown
    if (!this.editForm.shown()) then
      !this.buildEditForm()
      !this.editProperties()

    else
      !this.buildEditForm()
    endif
  endif

endmethod
-- End of method definition for .editFormBlockOwn(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .forceUpdate(BOOLEAN)
--
-- Description: Set the force update flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate force update mode]
--
------------------------------------------------------------------------
define method .forceUpdate(!value is BOOLEAN)

  !this.forceUpdate = !value

endmethod
-- End of method definition for .forceUpdate(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .forceHiddenDesignParameters(BOOLEAN)
--
-- Description: Set the flag to force hidden design parameter current values
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [flag to indicate force update mode]
--
------------------------------------------------------------------------
define method .forceHiddenDesignParameters(!value is BOOLEAN)

  !this.forceHiddenDesignParameters = !value

endmethod
-- End of method definition for .forceHiddenDesignParameters(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .checkPlot()
--
-- Description: check for plotfile
--
-- Method Type: Function
--
-- Return:
--   [BOOLEAN] [True if plot exists]
--
------------------------------------------------------------------------
define method .checkPlot() is BOOLEAN

  if (!this.propertyData[!this.plotIndex].set()) then
    return true
  else
    return false
  endif

endmethod
-- End of method definition for .checkPlot() BOOLEAN

------------------------------------------------------------------------
--
-- Method:      .getPlotFile()
--
-- Description: Get the plotfile name for this object
--
-- Method Type: Functions
--
-- Return:
--   [STRING] [Plot file name]
--
------------------------------------------------------------------------
define method .getPlotFile() is STRING

  if (!this.checkPlot()) then
    !dKey = !this.propertyData[!this.plotIndex][1].dKey

    if (!this.dataType eq 'TMPL') then
      if (!this.catalogueElement.badref().not()) then
        !plotFile = !this.catalogueElement.depr.attribute(!dKey)
      else
        !plotFile = !this.propertyData[!this.plotIndex][1].ddpr
        !plotFile = !plotFile.after(|'|).before(|'|)
      endif
      !plotDir  = !this.propertyData[!this.plotIndex][1].dddf

    else
      if (!this.spcoElement.badref().not()) then
        !plotFile = !this.spcoElement.prop.attribute(!dKey)
      else
        !plotFile = !this.propertyData[!this.plotIndex][1].ddpr
        !plotFile = !plotFile.after(|'|).before(|'|)
      endif
      !plotDir  = !this.propertyData[!this.plotIndex][1].dpro
    endif

    if (!plotFile.subString(1, 1) eq '/') then
      !plotFile = !plotFile.subString(2)
    endif

    !plotDir  = !plotDir.after(|'|).before(|'|)

    -- check for plot file
    !plotF = object FILE('%AVEVA_DESIGN_PLOTS%/' + !plotDir + '/' + !plotFile)
    if (!plotF.exists()) then
      !plotFile = !plotF.fullName()
      !returnString = !plotFile
    else
      !returnString = STRING()
    endif
  else
    !returnString = STRING()
  endif

  return !returnString

endmethod
-- End of method definition for .getPlotFile() STRING

------------------------------------------------------------------------
--
-- Method:      .displayPlot()
--
-- Description: Display the plotfile for this object
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .displayPlot()

  !plotFile = !this.getPlotFile()
  if (!plotFile.set()) then
    !ptyp = !this.propertyData[!this.plotIndex][1].ptyp
    !dTitle = !this.propertyData[!this.plotIndex][1].dTitle
    !this.displayPlot(!plotFile, !ptyp, !dTitle)
  else
    !!alert.error('Plotfile does not exist')
  endif

endmethod
-- End of method definition for .displayPlot()

------------------------------------------------------------------------
--
-- Method:      .displayPlot(STRING, STRING, STRING)
--
-- Description: Display the plotfile for this object
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING] [Plotfile string]
--   [2] [R] [STRING] [Portrait or landscape]
--   [3] [R] [STRING] [Plot file form title]
--
------------------------------------------------------------------------
define method .displayPlot(!plotFile is STRING, !ptyp is STRING, !dTitle is STRING)

  -- build the plotfile display form
  if (!this.plotForm.unset()) then
    !this.plotForm = !!comPropPlot(!plotFile, !ptyp, !this.pointer)
    handle any
      return
    endhandle
  endif

  !this.plotForm.formTitle = !dTitle

  !this.plotForm.show()

endmethod
-- End of method definition for .displayPlot(STRING, STRING, STRING)

------------------------------------------------------------------------
--
-- Method:      .hidePlot()
--
-- Description: Hide the plotfile for this object
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .hidePlot()

  if (!this.plotForm.set()) then
    if (!this.plotForm.shown()) then
      !this.plotForm.hide()
    endif
  endif

endmethod
-- End of method definition for .hidePlot()

------------------------------------------------------------------------
--
-- Method:      .displayDimension(REAL, BOOLEAN)
--
-- Description: Display the dimension for a design parameter
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [REAL]    [design parameter number]
--   [2] [R] [BOOLEAN] [Show/Hide flag]
--
------------------------------------------------------------------------
define method .displayDimension(!value is REAL, !show is BOOLEAN)

  if (!show.not()) then
    if (!this.dimDisplay[!value]) then
      !!aidNumbers.hide(!this.dimGraphics[!value])
      !this.dimDisplay[!value] = false
    endif
    return
  endif

  if (defined(!this.dimPoints[!value]) and defined(!this.propertyData[!this.despIndex][!value])) then
    -- Get text for dimension
    do !i indices !this.propertyData[!this.despIndex]
      if (!this.propertyData[!this.despIndex][!i].number eq !value) then
        !data = !this.propertyData[!this.despIndex][!i]
        !valueIndex = !i
        break
      endif
    enddo

    if (undefined(!valueIndex)) then
      return
    endif

    if (!data.ptyp eq 'DIST') then
      -- Convert to current distance units
      !vText = !this.currentValues[!this.despIndex][!valueIndex].string(!!distanceFmt)
    elseif (!data.ptyp eq 'BORE') then
      -- Convert to current bore units
      !vText = !this.currentValues[!this.despIndex][!valueIndex].string(!!boreFmt)
    else
      return
    endif

    !p1 = !this.dimPoints[!value][1]
    !p2 = !this.dimPoints[!value][2]

    -- Define dimension line
    !dimLine = object LINE(!p1.position.wrt(WORLD), !p2.position.wrt(WORLD))

    -- Define projection lines
    !pVector1   = object POINTVECTOR(!p1.position.wrt(WORLD), !p1.dDirection)
    !projLine1  = !pVector1.line(!p1.radius).extendStart(25mm)
    handle any
      -- return
      !projLine1  = !pVector1.line(!p1.radius)
    endhandle
    !pVector2   = object POINTVECTOR(!p2.position.wrt(WORLD), !p2.dDirection)
    !projLine2  = !pVector2.line(!p2.radius).extendStart(25mm)
    handle any
      -- return
      !projLine2  = !pVector2.line(!p2.radius)
    endhandle

    if (defined(!this.dimGraphics[!value])) then
      !!aidNumbers.hide(!this.dimGraphics[!value])
    endif

    if (undefined(!this.dimDisplay[!value])) then
      !this.dimDisplay[!value] = false
    endif

    if (undefined(!this.dimGraphics[!value])) then
      !this.dimGraphics[!value] = !!aidNumbers.add('Dimension')
    endif

    !number = !this.dimGraphics[!value]

    !textPos = !dimLine.proportion(0.5)
    handle any
      -- return
      !textPos = !dimLine.startPosition
    endhandle
    AID LINE NUMBER $!<number> $!<projLine1.startPosition> TO $!<projLine1.endPosition>
    AID LINE NUMBER $!<number> $!<projLine2.startPosition> TO $!<projLine2.endPosition>
    AID LINE NUMBER $!<number> $!<dimLine.startPosition> TO $!<dimLine.endPosition>
    !dimText = ''
    if (!!comPropOpt.dimTextDesc()) then
      !dimText = !data.dTitle
    endif
    if (!!comPropOpt.dimTextValue()) then
      if (!dimText.trim().empty()) then
        !dimText = !vText
      else
        !dimText = !dimText + ' (' + !vText + ')'
      endif
    endif
    AID TEXT NUMBER $!<number> |$!<dimText>| AT $!<textPos>

    !this.dimDisplay[!value] = true

  endif

endmethod
-- End of method definition for .displayDimension(REAL, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .displayAllDims()
--
-- Description: Display all dimensions
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .displayAllDims()

  do !i indices !this.propertyData[!this.despIndex]
    !this.displayDimension(!this.propertyData[!this.despIndex][!i].number, true)
  enddo

endmethod
-- End of method definition for .displayAllDims()

------------------------------------------------------------------------
--
-- Method:      .hideAllDims()
--
-- Description: Hide all dimensions
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .hideAllDims()

  do !i indices !this.dimGraphics
    !this.dimDisplay[!i] = false
    !!aidNumbers.hide(!this.dimGraphics[!i])
  enddo

endmethod
-- End of method definition for .hideAllDims()

------------------------------------------------------------------------
--
-- Method:      .deleteAllDims()
--
-- Description: Delete all dimensions
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .deleteAllDims()

  !this.dimPoints = ARRAY()
  do !i indices !this.dimGraphics
    !!aidNumbers.remove(!this.dimGraphics[!i])
  enddo
  !this.dimGraphics = ARRAY()
  !this.dimDisplay = ARRAY()

endmethod
-- End of method definition for .deleteAllDims()

------------------------------------------------------------------------
--
-- Method:      .updateAllDims()
--
-- Description: Update all the dimensions
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .updateAllDims()

  do !i indices !this.dimDisplay
    if (!this.dimDisplay[!i]) then
      !this.displayDimension(!i, true)
    endif
  enddo

endmethod
-- End of method definition for .updateAllDims()

------------------------------------------------------------------------
--
-- Method:      .dKeyList(STRING)
--
-- Description:  List DKEY for DATA/DDAT of a given purpose
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [STRING] [Purpose of property]
--
-- Return:
--   [ARRAY] [Array of dkey for the given purpose]
--
------------------------------------------------------------------------
define method .dKeyList(!purpose is STRING) is ARRAY

  !dKeys = ARRAY()

  -- get index for purpose
  !index = !this.purposeList.findFirst(!purpose)

  if (!index.set()) then
    do !i indices !this.propertyData[!index]
      !dKeys.append(!this.propertyData[!index][!i].dKey)
    enddo
  endif

  return !dKeys

endmethod
-- End of method definition for .dKeyList(STRING) ARRAY

------------------------------------------------------------------------
--
-- Method:      .currentValues(STRING, ARRAY, ARRAY)
--
-- Description: Set the current property values
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING]  [Type of values to set (ATTR, DESP, SPRE...)]
--   [2] [R] [ARRAY]   [Array of strings corresponding to dkey]
--   [3] [R] [ARRAY]   [Array of values]
--
------------------------------------------------------------------------
 define method .currentValues(!type is STRING, !keys is ARRAY, !values is ARRAY)

  !dKeyList = !this.dKeyList(!type)
  !value = object REAL()
  do !index indices !keys
    !paramIndex = !dKeyList.findFirst(!keys[!index])
    skip if( !paramIndex.unset() )
    !value.delete()
    !value     = !values[!index]
    !this.setValue(!type,!paramIndex ,!value)
  enddo

endmethod
-- End of method definition

------------------------------------------------------------------------
--
-- Method:      .currentValues(STRING, ARRAY)
--
-- Description: Set the current property values
--
-- Method Type: Procedure
--
--   [1] [R] [STRING]  [Type of values to set (ATTR, DESP, SPRE...)]
--   [2] [R] [ARRAY]   [Array of values]
--
------------------------------------------------------------------------
-- define method .currentValues(!dummyType is STRING, !dummyValues is ARRAY)

  -- No requirement for this method yet

-- endmethod
-- End of method definition for .dKeyList(STRING) ARRAY

