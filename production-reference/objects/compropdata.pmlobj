------------------------------------------------------------------------
--
-- Method:      .linkedTemplate(BOOLEAN)
--
-- Description: Set the linked template flag
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN]  [linked template flag]
--
------------------------------------------------------------------------
define method .linkedTemplate(!value is BOOLEAN)

  !this.isLinked = !value

endmethod
-- End of method definition for .linkedTemplate(BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .unsetLinks()
--
-- Description: Unset the linked templates
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .unsetLinks()

  do !i indices !this.linkedTemplates
    -- This action is recursive
    !this.linkedTemplates[!i].unsetLinks()
    -- Mark each linked template object for deletion
    !this.linkedTemplates[!i].deleteObject(false)
  enddo

  -- Clear the linked templates data store
  !this.linkedTemplates.clear()
  !this.linkedElements.clear()
  !this.initialLinkVals.clear()

endmethod
-- End of method definition for .unsetLinks()

------------------------------------------------------------------------
--
-- Method:      .deleteDesi()
--
-- Description: Delete the design element
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .deleteDesi()

  !this.deleteLinks()
  if (!this.designElement.badref().not()) then
    !!ce = !this.designElement
    UNLOCK ALL
    DELETE $!!<ce.type>
    !this.designElement(object DBREF())
  endif

endmethod
-- End of method definition for .deleteDesi()

------------------------------------------------------------------------
--
-- Method:      .deleteTmpl(DBREF)
--
-- Description: Delete the template element
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Template element to delete]
--
------------------------------------------------------------------------
define method .deleteTmpl(!tmpl is DBREF)

  -- create temporary COMPROP object
  !tempProp = object COMPROP(!this.designElement)

  -- remove linked templates
  !tempProp.deleteLinks()
  !tempProp.deleteObject(false)

  -- Navigate to the template
  !!ce = !tmpl
  UNLOCK ALL
  DELETE TMPL

  -- Delete any DDSE elements under the design element, that may own SPRE type DDATs
  do !element values !this.designElement.members
    if (!element.hardType eq 'DDSE') then
      !!ce = !element
      UNLOCK ALL
      DELETE DDSE
    endif
  enddo

endmethod
-- End of method definition for .deleteTmpl(DBREF)

------------------------------------------------------------------------
--
-- Method:      .updateInstance()
--
-- Description: Update the object's design element template instance
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .updateInstance()

  -- Check for bad element or template area
  if (!this.designElement.badref() or !this.designElement.hardType eq 'TMAR') then
    !this.designElement(object DBREF())
    return
  endif

  -- Store the current database position
  !dbPos = !!ce

  -- Initialise the create flag
  !createFlag = false

  -- Check for tmpl element under the design element
  !tmpl = !!dtbMemberOfType(!this.designElement, 'TMPL', 1)

  -- Navigate to this objects design element
  !!ce = !this.designElement

  if (!this.dataType eq 'CATA') then
    -- The design element will be pointing at a catalogue component
    if (!tmpl.set()) then
      !this.deleteTmpl(!tmpl)
    endif
    -- Set specification reference setting flag
    !this.setDesiSpref = true

--  elseif (!this.designElement.attributes().findFirst('Spref').unset()) then
    -- nothing to do as template has no link back to original

  else
    -- The design element will be pointing to a template definition
    -- Check for a template under the design element, if it is different
    -- from the template that is to be copied, then replace it
    if (!this.designElement.spref ne !this.spcoElement) then
      -- SPREF changed - force the update
      if(!this.spcoElement.hardType.neq('TMPL')) then
        if (!tmpl.set()) then
          !this.deleteTmpl(!tmpl)
        endif

        -- Set specification reference setting flag
        !this.setDesiSpref = true

        -- set the create flag, as template needs to be copied under the design element
        !createFlag = true
      endif

    else

      -- spref the same - check for forced update
      if(!this.forceUpdate) then
        if(!this.spcoElement.hardType.neq('TMPL')) then
          if (!tmpl.set()) then
            --  propagate changes from the master Template to the instance  ------
            if( !!dbrefUpdatable(!this.designElement) and !this.okDelHier(!tmpl) ) then
              !unusedStatus = !this.updateTmpl(!tmpl)
            else
              !this.errorLogAppend('FAIL','No write permission','Update Template','','')
              return
            endif
            -- set the create flag false, as template already updated under the design element
            !createFlag = false
          else
            -- set the create flag true, as template under the design element is not found
            !createFlag = true
          endif

          -- Set specification reference setting flag
          !this.setDesiSpref = true

        endif

      else

        -- If no template was found under the design element the object's template
        -- needs to be copied under the design element
        if (!tmpl.unset()) then
          !createFlag = true
        endif

      endif

    endif

    -- Create the template if necessary
    if (!createFlag) then
      !temp = !!ce
      !newTemplate = !this.createTmpl( !temp, !this.catalogueElement )
      if (!newTemplate.badref()) then
        -- if an error occurs in the above method then an object DBREF() is returned
        !!alert.error('An error occurred in this template')
        write 'Template Errors:'
        do !error values !this.error.errorText
          write !error
        enddo
        -- Navigate to original database position
        if (!dbPos.badref().not()) then
          !!ce = !dbPos
        endif
        return
      endif
      !!ce = !newTemplate
      -- Lock the template
      LOCK
      !this.findDimensions()
    endif
  endif

  -- Navigate to original database position
  if (!dbPos.badref().not()) then
    !!ce = !dbPos
  endif

endmethod
-- End of method definition for .updateInstance()

------------------------------------------------------------------------
--
-- Method:      .updateTmpl(DBREF)
--
-- Description: Update the template element
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Template element to update]
--
-- Return:
--   [STRING] [Return status] 'OK'; 'UNLINKED'; 'FAIL'; 'ABORT'
--
------------------------------------------------------------------------
define method .updateTmpl(!tmpl is DBREF) is STRING


  -- create temporary COMPROP object
  !tempProp = object COMPROP(!this.designElement)

  -- remove linked templates
  !tempProp.updateLinks()
  handle any
    !this.errorLogAppend('CRITICAL', !!error.text, 'Delete Linked Templates',!!error.command,!!error.line)
    return 'FAIL'
  endhandle
  !tempProp.deleteObject(false)

  -- replace the old TMPL with the new TMPL
  !return = !this.replaceTmpl(!tmpl)
  if( !return neq 'OK' ) then
    return !return
  endif

  -- Deal with displayed dimensions if defined
  !this.findDimensions()

  -- Delete any DDSE elements under the design element, that may own SPRE type DDATs
  do !element values !this.designElement.members
    if (!element.hardType eq 'DDSE') then
      !!ce = !element
      UNLOCK ALL
      DELETE DDSE
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Delete Design Element Data Set',!!error.command,!!error.line)
        return 'ABORT'
      endhandle
    endif
  enddo

  return 'OK'

endmethod
-- End of method definition for .updateTmpl(DBREF)

------------------------------------------------------------------------
--
-- Method:      .replaceTmpl(DBREF)
--
-- Description: Replace the template element
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Template element to update]
--
-- Return:
--   [STRING] [Return status] 'OK'; 'UNLINKED'; 'FAIL'; 'ABORT'
--
------------------------------------------------------------------------
define method .replaceTmpl(!tmpl is DBREF) is STRING

  -- Navigate to the template
  !!ce = !tmpl
  UNLOCK ALL
  !tmplOwner = !tmpl.owner
  if( !this.okDelHier(!tmpl).not() ) then
    LOCK
    !this.errorLogAppend('FAILED', 'Cannot delete original Template', 'Delete Original Template Instance', '', 'In comPropData.replaceTmpl()')
  endif

  -- search old template for connections outside of the TMPL
  -- Check Nozzles
  VAR !oldConnectionElements COLLECT ALL NOZZ WITH ( NOT badref(CREF) ) FOR $!<tmpl>
  -- Connections found to be resolved
  VAR !unlinkedConnectionElements COLLECT ALL NOZZ WITH ( badref(ORRF) ) FROM !oldConnectionElements
  -- Cannot update a Template where the original Template contains an external link with an element not in the new Template
  if( !unlinkedConnectionElements.empty().not()) then
    !!ce = !tmpl
    LOCK
    !this.errorLogAppend('FAILED','Connection to original Template not found in new Template','Connection element','','replaceTmpl')
    return 'ABORT'
  endif

  -------------------------- TODO
  -- Check ELCONN

------------------------------------------------------------------------
  -- Create new TMPL
  !newTmpl = !this.createTmpl(!tmplOwner, !this.catalogueElement)
  if( badref( !newTmpl ) ) then
    -- create failed - keep old TMPL - error logged in createTmpl method
    return 'ABORT'
  endif
  -- BEWARE We now have two copies of the TMPL - must tidy this
------------------------------------------------------------------------

  if (!oldConnectionElements.empty()) then
    -- No connections to deal with - simply create a new Template
    -- delete old TMPL - should not fail - DACDEL tested
    !!ce = !tmpl
    DELETE TMPL
    handle any
      !this.errorLogAppend('CRITICAL', !!error.text, 'Delete Original Template Instance', !!error.command, !!error.line)
      return 'FAIL'
    endhandle
    -- Lock just the template element - not its children
    !!ce = !newTmpl
    LOCK
    handle any
    endhandle
    return 'OK'
  endif

------------------------------------------------------------------------
    -- old connections to deal with
--!oldConnectionElements = ARRAY()

  !!ce = !newTmpl
  UNLOCK ALL
  -- find all Nozzles in the new template
  VAR !newConnectionElements COLLECT ALL NOZZ FOR $!<newTmpl>
  -- get the ORRF link to the template original for each connection element
  !block   = object BLOCK('!newConnectionElements[!evalIndex].dbref().orrf')
  !orrfArray = !newConnectionElements.evaluate(!block)

  -- First pass through connected elements to test for possible errors
  -- and build a table of equivalent old and new connection elements
  !checkFailed = false
  !equivalentConnElement = ARRAY()
  do !connIndex indices !oldConnectionElements

    !connElement     = !oldConnectionElements[!connIndex].dbref()
    !equivalentConnElement[!connIndex] = object DBREF()
    -- Using ORRF, find equivalent element in the new TMPL
    !tmplConnElement = !connElement.orrf
    !index = !orrfArray.findFirst(!tmplConnElement)
    if( !index.set() ) then
      -- equivalent new connection element found
      if( !newConnectionElements[!index].dbref().dacdel.not() ) then
        !this.errorLogAppend('FAILED','Cannot move to new Template','Connection element: Move old connections','','replaceTmpl')
        !checkFailed = true
        break
      endif
      !equivalentConnElement[!connIndex] = !newConnectionElements[!index].dbref()
    else
      -- fail update because previously connected element has been removed
      !this.errorLogAppend('FAILED','Connection to original Template not found in new Template','Connection element: Move old connections','','replaceTmpl')
      !checkFailed = true
      break
    endif

  enddo

  if( !checkFailed ) then
    -- get rid of new TMPL - keep old TMPL
    !!ce = !newTmpl
    DELETE TMPL
    return 'ABORT'
  endif

  -- Second pass through connection elements
  -- For each outside connection to the old template, find the equivalent element
  -- in the new TMPL and replace it while preserving the connection
  !newConnectionOK    = true
  do !connIndex indices !oldConnectionElements

    !oldConnElement     = !oldConnectionElements[!connIndex].dbref()
    !newConnElement     = !equivalentConnElement[!connIndex]

    -- copy attributes from the new connection element into the old element
    -- this does not overwrite the cref
    !!ce = !oldConnElement
    COPY ATTRIBUTES OF $!<newConnElement>
    handle any
      !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: Copy attributes',!!error.command,!!error.line)
      !newConnectionOK    = false
      break
    endhandle

    !!ce = !newConnElement.owner
    -- Bring old element back from old TMPL into the new TMPL
    INCLUDE $!<oldConnElement> BEFORE $!<newConnElement>
    handle any
      !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: Restore saved connections',!!error.command,!!error.line)
      !newConnectionOK    = false
      break
    endhandle

    -- save local name of the new element
    !newConnElementLname = !newConnElement.lname
    -- now remove the new element
    !!ce = !newConnElement
    DELETE $!!<ce.type>
    handle any
      !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: Remove duplicate',!!error.command,!!error.line)
      !newConnectionOK    = false
      break
    endhandle

    !!ce = !oldConnElement
    -- Set the local name if the new element has one
    if(!newConnElementLname.set()) then
      -- unset orrf to allow lname to be set
      ORRF NULREF
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: unset ORRF',!!error.command,!!error.line)
        !newConnectionOK    = false
        break
      endhandle
      LNAME $!<newConnElementLname>
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: set local name',!!error.command,!!error.line)
        !newConnectionOK    = false
        break
      endhandle
      ORRF $!<tmplConnElement>
      handle any
        !this.errorLogAppend('CRITICAL',!!error.text,'Connection element: set ORRF',!!error.command,!!error.line)
        !newConnectionOK    = false
        break
     endhandle

    endif

  enddo

  if( !newConnectionOK ) then
    -- new connection element update succeeded - get rid of old TMPL - keep new TMPL
    !!ce = !tmpl
    DELETE TMPL
    handle any
      !this.errorLogAppend('CRITICAL', !!error.text, 'Delete Original Template Instance', !!error.command, !!error.line)
      -- cannot delete old template - try to remove new template
      !!ce = !newTmpl
      DELETE TMPL
      !!ce = !tmpl
      LOCK
      handle any
      endhandle
      return 'ABORT'
    endhandle
    !!ce = !newTmpl
    LOCK
    handle any
    endhandle
  else
    -- new connection element update failed - get rid of new TMPL - keep old TMPL
    !!ce = !newTmpl
    DELETE TMPL
    !!ce = !tmpl
    LOCK
    handle any
    endhandle
    return 'ABORT'
  endif

  return 'OK'

endmethod
-- End of method definition for .updateTmpl(DBREF)

------------------------------------------------------------------------
--
-- Method:      .deleteLinks()
--
-- Description: Delete the linked templates
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .deleteLinks()

  do !i indices !this.linkedTemplates
    !this.linkedTemplates[!i].deleteLinks()
    -- delete the design element for each linked template
    !this.linkedTemplates[!i].deleteDesi()
  enddo
  !this.linkedElements.clear()

endmethod
-- End of method definition for .deleteLinks()

------------------------------------------------------------------------
--
-- Method:      .updateLinks()
--
-- Description: Update (propagate) the linked templates
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .updateLinks()

  do !i indices !this.linkedTemplates
    !this.linkedTemplates[!i].propagateChanges()
  enddo

endmethod
-- End of method definition for .deleteLinks()

------------------------------------------------------------------------
--
-- Method:      .getVValuesString(DBREF)
--
-- Description: Get valid value strings from valid values
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Range of valid value strings]
--
------------------------------------------------------------------------
define method .getVValuesString(!data is DBREF) is ARRAY

  if (!data.purp eq 'SPRE' or !data.purp eq 'SBRE') then
    !returnArray = !this.getAdjSpcos(!data)
  else
    !returnArray[1] = ARRAY()
    !returnArray[2] = ARRAY()

    -- Get the valid values
    !vvalues = !this.getVValues(!data)

    -- Convert valid values to strings
    do !i indices !vvalues
      !returnArray[1].append(!this.getFormattedString(!vvalues[!i], !data.ptyp))
      !returnArray[2].append(!vvalues[!i].string())
    enddo
  endif

  -- if there are valid values with descriptions, use the descriptions
  -- in the dtext return array
  !vvalueIndex = 0
  do !element values !data.members
    if (!element.hardType eq 'VVALUE') then
      !vvalueIndex = !vvalueIndex + 1
      if (!element.description.trim() ne '' and !element.description.lowcase().trim() ne 'unset') then
        !returnArray[1][!vvalueIndex] = !element.description
      endif
    endif
  enddo

  return !returnArray

endmethod
-- End of method definition for .getVValuesString(DBREF) ARRAY

------------------------------------------------------------------------
--
-- Method:      .getFormattedString(ANY,STRING)
--
-- Description: Get a string with units qualifiers according to the current
--              global format object for this PTYP (dimension)
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [ANY] [Value to query (real or bore)]
--   [2] [R] [STRING] [Valid DATA PTYP or dimension(units) e.g. !realValue.dimension()]
-- Return:
--   [STRING] [Value qualified by units in the appropriate current global format]
--
------------------------------------------------------------------------
define method .getFormattedString(!value is ANY, !pType is STRING) is STRING

  !format           = !!comFormats.getGlobalUnitsFormat(!pType)

  if( !format.unset() ) then
    !stringValue    = !value.queryString()
    handle any
      !stringValue  = !value.string()
    endhandle
  else
    !stringValue    = !value.string(!format)
    handle (2,812)
      !stringValue  = !value.queryString()
    endhandle
  endif

  return !stringValue

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      .inputValue(STRING, REAL, STRING, GADGET, BOOLEAN)
--
-- Description: Set a value when input from an option gadget
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R]   [STRING]  [Property purpose]
--   [2] [R]   [REAL]    [Property Index]
--   [3] [R]   [STRING]  [Selected display text]
--   [4] [R/W] [GADGET]  [Edit gadget]
--   [5] [R]   [BOOLEAN] [True is main form is updated]
--
------------------------------------------------------------------------
define method .inputValue(!type is STRING, !index is REAL, !ptyp is STRING, !gadget is GADGET, !updateMain is BOOLEAN)

  if (!gadget.type() eq 'TEXT') then
    if(!gadget.val.string().trim().empty()) then
       !gadget.val = !this.currentValues[!this.purposeList.findFirst(!type)][!index]
       return
    endif
    -- set the object value
    !this.setValue(!type, !index, !gadget.val)

  elseif (!gadget.type() eq 'TOGGLE') then
    -- set the object value
    !this.setValue(!type, !index, !gadget.val)

  else
    if (!type eq 'SBRE' or !type eq 'SPRE') then
      if (!updateMain and !this.editForm.listEdit.not()) then
        !this.editForm.$!<type>$!<index>.val = !gadget.selection('DTEXT')
      endif
      !this.setValue(!type, !index, !gadget.selection().dbref())

    elseif (!ptyp eq 'LOG') then
      if (!updateMain and !this.editForm.listEdit.not()) then
        !this.editForm.$!<type>$!<index>.val = !gadget.selection('DTEXT')
      endif
      !this.setValue(!type, !index, !gadget.selection().boolean())

    else
      if (!updateMain and !this.editForm.listEdit.not()) then
        !this.editForm.$!<type>$!<index>.val = !gadget.selection('DTEXT')
      endif
      !testReal = !gadget.selection().real()
      handle any
      !this.setValue(!type, !index, !gadget.selection())
      elsehandle none
        !this.setValue(!type, !index, !testReal)
      endhandle

    endif
  endif

  if (!this.editForm.listEdit) then
    !listPos = !this.editForm.properties.val
    !this.initEditForm('CURRENT', true)
    !this.editForm.properties.val = !listPos
  else
    -- set gadget focus to the next edit gadget
    -- Order of gadget types - ATTR, DESP, SPRE, SBRE
    !typeList[1] = 'ATTR'
    !typeList[2] = 'DESP'
    !typeList[3] = 'SPRE'
    !typeList[4] = 'SBRE'

    !startIndex = !typeList.findFirst(!type)
    !gadgetIndex = !index + 1

    do !typeIndex from !startIndex to 4
      !currentType = !typeList[!typeIndex]
      if (defined(!this.editForm.$!<currentType>$!<gadgetIndex>)) then
        if (defined(!this.editForm.$!<currentType>$!<gadgetIndex>select)) then
          !nextGadget = !this.editForm.$!<currentType>$!<gadgetIndex>select
        else
          !nextGadget = !this.editForm.$!<currentType>$!<gadgetIndex>
        endif
        break
      else
        -- try the next group of gadgets
        !gadgetIndex = 1
      endif
    enddo

    if (defined(!nextGadget)) then
      if (!nextGadget.type() eq 'TEXT' or !nextGadget.type() eq 'BUTTON') then
        !nextGadget.setFocus()
      endif
    endif
  endif

endmethod
-- End of method definition for .inputValue(STRING, REAL, STRING, GADGET, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .validateValue(STRING, REAL, STRING, GADGET, REAL, REAL, BOOLEAN)
--
-- Description: Set and validate a value when input from gadget
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R]   [STRING]  [Property purpose]
--   [2] [R]   [REAL]    [Property Index]
--   [3] [R]   [STRING]  [Property ptype]
--   [4] [R/W] [GADGET]  [Edit gadget]
--   [5] [R]   [REAL]    [Maximum value]
--   [6] [R]   [REAL]    [Minimum value]
--   [7] [R]   [BOOLEAN] [True if main form is updated]
--
------------------------------------------------------------------------
define method .validateValue(!type is STRING, !index is REAL, !ptyp is STRING, !gadget is GADGET, !max is REAL, !min is REAL, !updateMain is BOOLEAN)

  !value = !gadget.val

  if(!value.set()) then
  -- Check the value is between the specified range
  !!comValidateRange(!value, !max, !min, !ptyp)
  handle any
    !!alert.error(!!error.text)
    !gadget.val = !this.currentValues[!this.purposeList.findFirst(!type)][!index]
    return error 1 noalert
  endhandle
  endif
  -- Set the current value
  !this.inputValue(!type, !index, !ptyp, !gadget, !updateMain)

endmethod
-- End of method definition for .validateValue(STRING, REAL, STRING, GADGET, REAL, REAL, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .inputMeasure(GADGET, REAL)
--
-- Description: Set a value when input from an option gadget
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [GADGET] [Main List Gadget]
--   [2] [R] [REAL]   [Property Value]
--
------------------------------------------------------------------------
define method .inputMeasure(!gadget is GADGET, !value is REAL)

  !purp = !gadget.selection().part(1)
  !index = !gadget.selection().part(2).real()

  !data = !this.propertyData[!this.purposeList.findFirst(!purp)][!index]

  if (!data.attributes().findFirst('Maxmin').set()) then
    if (!data.maxmin.set()) then
      -- Check the value is between the specified range
      !!comValidateRange(!value, !data.maxmin[1], !data.maxmin[2], !data.ptyp)
      handle any
        !!alert.error(!!error.text)
        return
      endhandle
    endif
  endif

  !this.setValue(!purp, !index, !value)

  if (!this.editForm.listEdit) then
    !listPos = !this.editForm.properties.val
    !this.initEditForm('CURRENT', true)
    !this.editForm.properties.val = !listPos
  endif

endmethod
-- End of method definition for .inputMeasure(GADGET, REAL)

------------------------------------------------------------------------
--
-- Method:      .setGadget(GADGET, REAL)
--
-- Description: Set a gadget value and run gadget callbacks
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [GADGET] [Form gadget]
--   [2] [R] [REAL]   [Gadget value]
--
------------------------------------------------------------------------
define method .setGadget(!gadget is GADGET, !value is REAL)

  -- Get the gadget value
  !storeValue = !gadget.val

  -- Validate the gadget contents
  !gadget.val = !value
  if (defined(!gadget.validateCall)) then
    -- run validate callback
    !validateCall = !gadget.validateCall.replace('!this.', !gadget.owner().fullName() + '.')
    $!<validateCall>
    handle any
      !gadget.val = !storeValue
    elsehandle none
      -- Execute gadget callback
      !callback = !gadget.callback.replace('!this.', !gadget.owner().fullName() + '.')
      $!<callback>
      handle any
        !gadget.val = !storeValue
      endhandle
    endhandle

  else
    -- Execute gadget callback
    !callback = !gadget.callback.replace('!this.', !gadget.owner().fullName() + '.')
    $!<callback>
    handle any
      !gadget.val = !storeValue
    endhandle
  endif

endmethod
-- End of method definition for .setGadget(GADGET, REAL)

------------------------------------------------------------------------
--
-- Method:      .editSbre(REAL)
--
-- Description: Edit the properties for a linked template
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [REAL] [SBRE property index]

------------------------------------------------------------------------
define method .editSbre(!index is REAL)

  !this.linkedTemplates[!index].autoCacheValues(!this.autoCacheValues)
  !this.linkedTemplates[!index].linkedTemplate(true)
  !this.linkedTemplates[!index].editFormBlockOwn(true)
  !this.linkedTemplates[!index].editMode(!this.editMode)
  !this.linkedTemplates[!index].editFormName(!this.propertyData[!this.sbreIndex][!index].dTitle)
  !this.linkedTemplates[!index].editProperties()

endmethod
-- End of method definition for .editSbre(REAL)

------------------------------------------------------------------------
--
-- Method:      .setListMenu(GADGET)
--
-- Description: Set edit list popup menu based on current selection
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [GADGET] [Form gadget]
--
------------------------------------------------------------------------
define method .setListMenu(!gadget is GADGET)

--  The following lines are commented out for P-36302 where the wrong form is shown for a SBRE right-click
--  Need to revisit this and refactor to use the grid with in-place editing or edit in a panel on the form.
--  if (!gadget.owner().lastSelection eq !gadget.val) then
--    !!comPropCntrl.data[!this.pointer].editListEntry(!gadget.owner().properties)
--    !gadget.owner().lastSelection = REAL()
--
--  else
    -- Get data purpose and index
    !purpose = !gadget.selection().part(1)
    !index   = !gadget.selection().part(2).real()
    -- Get the corresponding data element
    !data = !this.propertyData[!this.purposeList.findFirst(!purpose)][!index]

    !dimension = false

    if (!purpose eq 'ATTR' or !purpose eq 'DESP') then
      !contents = !this.getVValuesString(!data)
      if (!contents[1].set()) then
        !measure = false
      else
        if (!data.ptyp eq 'DIST' or !data.ptyp eq 'BORE') then
          !measure = true
          if (defined(!this.dimPoints[!data.number]) and !this.designElement.set()) then
            if (!this.designElement.attributes().findFirst('Spref').set()) then
              if (!this.designElement.spref eq !this.spcoElement) then
                !dimension = true
              endif
            endif
          endif
        else
          !measure = false
        endif
      endif
      !properties = false

    elseif (!purpose eq 'SPRE') then
      !measure = false
      !properties = false

    elseif (!purpose eq 'SBRE') then
      !measure = false
      !properties = true
    endif

    !this.editForm.editMenu.clear()

    !this.editForm.editMenu.add('callback', 'Edit...', '!!comPropCntrl.data[!this.pointer].editListEntry(!this.properties)')
    if (!measure) then
      !callback = '!!comGadgetMeasure(|!!comPropCntrl.data[$!<this.pointer>].inputMeasure(|, !this.properties, |Edit Property Measurement|, |Measure property dimension|)'
      !this.editForm.editMenu.add('callback', 'Measure', !callback)
    endif
    if (!properties) then
      !this.editForm.editMenu.add('separator')
      !this.editForm.editMenu.add('callback', 'Properties...', '!!comPropCntrl.data[!this.pointer].editSbre($!<index>)')
    endif
    if (!dimension and !this.designElement.set()) then
      !this.editForm.editMenu.add('separator')
      !this.editForm.editMenu.add('toggle', 'Dimension', '!!comPropCntrl.data[!this.pointer].displayDimension($!<data.number>, !this.editMenu.selected(|Dimension|))')
      !this.editForm.editMenu.select('Dimension', !this.dimDisplay[!data.number])
    endif

    !gadget.owner().lastSelection = !gadget.val

--  endif

endmethod
-- End of method definition for .setListMenu(GADGET)

------------------------------------------------------------------------
--
-- Method:      .editListEntry(GADGET)
--
-- Description: Edit a list gadget entry using appropriate entry form
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [GADGET] [Form gadget]
--
------------------------------------------------------------------------
define method .editListEntry(!gadget is GADGET)

  -- Get data purpose and index
  !purpose = !gadget.selection().part(1)
  !index   = !gadget.selection().part(2).real()
  !purpIndex = !this.purposeList.findFirst(!purpose)

  -- Get the corresponding data element
  !data = !this.propertyData[!purpIndex][!index]

  -- Check for Valid values
  !contents = !this.getVValuesString(!data)
  if (!contents[1].unset() and !data.ptyp eq 'LOG') then
    !contents[1][1] = 'True'
    !contents[1][2] = 'False'
    !contents[2][1] = 'TRUE'
    !contents[2][2] = 'FALSE'
  endif
  if (!contents[1].set()) then
    !listHeight = MIN(10, MAX(3, !contents[1].size()))
    if (!this.currentValues[!purpIndex][!index].objectType() eq 'DBREF') then
      if (!this.currentValues[!purpIndex][!index].badref()) then
        !valueString = 'NONE'
      else
        !valueString = !contents[1][!contents[2].findFirst(!this.currentValues[!purpIndex][!index].string())]
      endif
    else
      !valueString = !contents[1][!contents[2].findFirst(!this.currentValues[!purpIndex][!index].string())]
    endif

    -- show list selection form
    !!comPropList(!data.purp, !index, !data.ptyp, !data.dTitle, !listHeight, !contents, !valueString, !this.pointer)
  else
    !value = !this.currentValues[!purpIndex][!index]

    if (!data.attributes().findFirst('Maxmin').set()) then
      if (!value.objectType() eq 'REAL' and !data.maxmin.set()) then
        !max = !data.maxmin[1]
        !min = !data.maxmin[2]
      else
        !max = REAL()
        !min = REAL()
      endif
    else
      !max = REAL()
      !min = REAL()
    endif

    -- show text input form
    !!comPropText(!data.purp, !index, !data.ptyp, !data.dTitle, !value, !max, !min, !this.pointer)
  endif

endmethod
-- End of method definition for .editListEntry(GADGET)

------------------------------------------------------------------------
--
-- Method:      .okEditForm()
--
-- Description: Ok the edit form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .okEditForm()

  if (!this.isLinked) then
    !this.hideAllDims()
    !this.editForm.mainForm.setActive(true)
    return
  endif

  if (!this.editForm.listEdit) then
    !this.editForm.lastSelection = REAL()
  endif

  -- Store the current edit mode for this object
  !mode = !this.editMode

  -- Check for unset design element
  if (!this.designElement.badref()) then
    -- Mode is forced to be 'STORE'
    !mode = 'STORE'
  endif

  if (!this.autoCacheValues) then
    -- add the values to the cache
    !!comPropCntrl.addToCache(!this.pointer)
  endif

  -- In update mode the properties need to be set
  -- Other edit modes require no ok action
  !this.okFromForm = true
  if (!mode eq 'UPDATE') then
    !this.setProperties()
  endif
  !this.okFromForm = false

  !this.initialValues = !this.currentValues

  -- Tidy up after hiding a linked template form that blocked the owning form
  if (!this.editFormBlockOwn and !this.editForm.set()) then
    if (!this.editForm.mainForm.set()) then
      !this.editForm.mainForm.setActive(true)
    endif
  endif

  -- Remove edg measure operation
  !!edgCntrl.remove('Edit Property Measurement')

  -- Check for autoDelete flag and delete object if required
  if (!this.autoDelete and !this.editFormApply.not()) then
    !this.hideAllDims()
    !temp = object COMPROP(!this.pointer)
    !temp.deleteObject(false)
  endif

  -- Remove design element from element cache
  if (!this.designElement.set()) then
    !!comPropCntrl.remElementList(!this.designElement)
  endif

  -- run the autoCall action if set
  if (!this.editFormAutoCall.set()) then
    if (!this.editFormAutoCall.trim() ne '') then
      $!<this.editFormAutoCall>
      handle any
      endhandle
    endif
  endif

endmethod
-- End of method definition for .okEditForm()

------------------------------------------------------------------------
--
-- Method:      .cancelEditForm()
--
-- Description: Cancel the edit form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .cancelEditForm()

  -- Revert current values to initial values
  !this.currentValues = !this.initialValues

  -- Run cancel method for all linked templates
  do !i indices !this.linkedTemplates
    if (!this.currentValues[!this.sbreIndex][!i].badref()) then
      !this.linkedTemplates[!i].clearObject()
    else
      !this.linkedTemplates[!i].initialise(!this.currentValues[!this.sbreIndex][!i])
      if (defined(!this.linkedElements[!i])) then
        if (!this.linkedElements[!i].badref().not()) then
          !this.linkedTemplates[!i].designElement(!this.linkedElements[!i])
        endif
      endif
      !!comPropCntrl.data[!this.linkedTemplates[!i].pointer].currentValues = !this.initialLinkVals[!i]
      !!comPropCntrl.data[!this.linkedTemplates[!i].pointer].cancelLinks()
    endif
    !this.linkedTemplates[!i].linkedTemplate(true)
  enddo

  -- Tidy up after hiding a linked template form that blocked the owning form
  if (!this.editFormBlockOwn and !this.editForm.set()) then
    if (!this.editForm.mainForm.set()) then
      !this.editForm.mainForm.setActive(true)
    endif
  endif

  if (!this.editForm.listEdit) then
    !this.editForm.lastSelection = REAL()
  endif

  -- Remove edg measure operation
  !!edgCntrl.remove('Edit Property Measurement')

  !this.hideAllDims()

  -- In DYNAMIC mode the properties need to be reset to the original values
  if (!this.editMode eq 'DYNAMIC') then
    !this.setProperties()
  endif

  -- Remove design element from element cache
  if (!this.designElement.set()) then
    !!comPropCntrl.remElementList(!this.designElement)
  endif

  -- Check for autoDelete flag and delete object if required
  if (!this.autoDelete) then
    !temp = object COMPROP(!this.pointer)
    !temp.deleteObject(false)
  endif

endmethod
-- End of method definition for .cancelEditForm()

------------------------------------------------------------------------
--
-- Method:      .cancelLinks()
--
-- Description: Cancel the edit form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .cancelLinks()

  -- Run cancel method for all linked templates
  do !i indices !this.linkedTemplates
    if (!this.currentValues[!this.sbreIndex][!i].badref()) then
      !this.linkedTemplates[!i].clearObject()
    else
      !this.linkedTemplates[!i].initialise(!this.currentValues[!this.sbreIndex][!i])
      if (defined(!this.linkedElements[!i])) then
        if (!this.linkedElements[!i].badref().not()) then
          !this.linkedTemplates[!i].designElement(!this.linkedElements[!i])
        endif
      endif
      !!comPropCntrl.data[!this.linkedTemplates[!i].pointer].currentValues = !this.initialLinkVals[!i]
    endif
    !this.linkedTemplates[!i].linkedTemplate(true)
  enddo

  -- Tidy up after hiding a linked template form that blocked the owning form
  if (!this.editFormBlockOwn and !this.editForm.set()) then
    if (!this.editForm.mainForm.set()) then
      !this.editForm.mainForm.setActive(true)
    endif
  endif

endmethod
-- End of method definition for .cancelLinks()

------------------------------------------------------------------------
--
-- Method:      .initQueryForm()
--
-- Description: Initialise the gadget values on the query form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .initQueryForm()

  -- Initialise variables
  !dtext  = ARRAY()
  !rText  = ARRAY()

  -- Get the current values
  !values = !this.currentValues

  -- Compose list gadget contents
  !headings = ARRAY()
  !headings[1] = 'Type'
  !headings[2] = 'No.'
  !headings[3] = 'Key'
  !headings[4] = 'Description'
  !headings[5] = 'Data'
  !this.queryForm.list.setHeadings(!headings)

  do !i indices !this.purposeList
    -- get data type purpose and set displayed data type
    !dataType = !this.purposeList[!i]
        !useNum = false
    if (!dataType eq 'ATTR') then
      !displayDataType = 'Attribute'
    elseif (!dataType eq 'DESP') then
      !displayDataType = 'Design Param'
      !useNum = true
    elseif (!dataType eq 'PARA') then
      !displayDataType = 'Catalogue Param'
      !useNum = true
    elseif (!dataType eq 'SPRE') then
      !displayDataType = 'Specification Ref'
    elseif (!dataType eq 'SBRE') then
      !displayDataType = 'Sub Component'
    elseif (!dataType eq 'EXPR') then
      !displayDataType = 'Expression'
    elseif (!dataType eq 'DATA') then
      !displayDataType = 'Data'
    elseif (!dataType eq 'PLOT') then
      !displayDataType = 'Plotfile'
    else
      !displayDataType = 'Property'
    endif

    !countEntries = 0
    do !j indices !this.propertyData[!i]

      !data = !this.propertyData[!i][!j]

      -- Don't show hidden properties
      if (!data.hardType eq 'DDAT') then
        skip if (!data.ldisp.not())
      else
        skip if (!data.lhide)
      endif

      !countEntries = !countEntries + 1

      if (!data.purp eq 'SPRE' or !data.purp eq 'SBRE') then
        if (!values[!i][!j].set()) then
          !vText = !values[!i][!j].fullName
        else
          !vText = 'NONE'
        endif
      else
        !vText = !this.getFormattedString(!values[!i][!j], !data.ptyp)
      endif

      -- build a row to add to the table
      !row = ARRAY()
      -- add data type only to the first row of a given type
      if (!countEntries eq 1 ) then
        !row[1] = !displayDataType
      else
        !row[1] = ' '
      endif
      -- add number for array data types
      if (!useNum) then
        !row[2] = '[' + !data.number.string() + ']'
      else
        !row[2] = ' '
      endif
        -- Build display string for DESP properties
      !row[3] = !data.dKey
      !row[4] = !data.dTitle
      !row[5] = !vText

      !dtext.append(!row)
      if (!data.purp eq 'PLOT') then
        if (!this.dataType eq 'TMPL') then
          !plotFile = !data.ddpr
          !plotDir  = !data.dddf
        else
          !plotFile = !data.ppro
          !plotDir  = !data.dpro
        endif
        !plotFile = !plotFile.after(|'|).before(|'|)
        if( !plotDir.unset() ) then
          !plotDir = |'.'|
        endif
        !plotDir  = !plotDir.after(|'|).before(|'|)
        -- check for plot file
        !plotF = object FILE('%AVEVA_DESIGN_PLOTS%/' + !plotDir + '/' + !plotFile)
        if (!plotF.exists()) then
          !plotFile = !plotF.fullName()
          !rText.append('PLOT ' + !plotFile + ' ' + !data.ptyp + ' ' + !data.dTitle)
        else
          !rText.append('NO ACTION')
        endif
      else
        !rText.append('NO ACTION')
      endif
    enddo
  enddo

--  if (!dtext.empty()) then
--    !dtext.append('No Properties')
--    !rText.append('NO ACTION')
--  endif
  !this.queryForm.list.setRows(!dtext)
  !this.queryForm.list.rText = !rText

  -- Set the design element prompt
  if (!this.designElement.set()) then
    !nameString = !this.designElement.fullName
  else
    if (!this.catalogueElement.desc.empty().not()) then
      !nameString = !this.catalogueElement.desc
    elseif (!this.catalogueElement.name.subString(1, 1) ne '=') then
      !nameString = !this.catalogueElement.name
    else
      -- look for GPART description and name if available
      !partReference   = !this.spcoElement.prtReference
      handle any
        !partReference = object DBREF()
      endhandle
      if( !partReference.badref() ) then
        !partReference = !this.spcoElement
      endif
      !nameString = !partReference.description
      handle any
        -- handles SPCO case
        !nameString = ''
      endhandle
      if (!nameString.empty()) then
        !nameString = !this.spcoElement.name
      endif
    endif
  endif

  !this.queryForm.displayName(!nameString.subString(1, 55))

endmethod
-- End of method definition for .initQueryForm()

------------------------------------------------------------------------
--
-- Method:      .getPropertyTable()
--
-- Description: get table of properties
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .getPropertyTable() is COMPROPTABLE

  -- return table of properties without hidden properties (retained for API compatibility)
  return !this.getPropertyTable(false)

endmethod
-- End of method definition for .getPropertyTable()

------------------------------------------------------------------------
--
-- Method:      .getPropertyTable(boolean)
--
-- Description: get table of properties with or without hidden properties
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [BOOLEAN] [true to include hidden items, false to ignore them]
--
------------------------------------------------------------------------
define method .getPropertyTable(!includeHidden is BOOLEAN) is COMPROPTABLE

  !propTables = object COMPROPTABLE()

  -- Get the current values
  !this.storeQueryValues()
  !values = !this.currentValues

  -- Compose table contents
  !headings = ARRAY()
  !headings[1] = 'Key'
  !headings[2] = 'Description'
  !headings[3] = 'Data'
  !headings[4] = 'No.'
  !propTables.setHeadings(!headings)

  -- for each property type - extract the properties
  do !i indices !this.purposeList

    -- get data type purpose
    !dataType = !this.purposeList[!i]
    !useNum   = (!dataType eq 'DESP' or !dataType eq 'PARA')
    !tempTable = ARRAY()

    -- loop through all properties of this type
    do !j indices !this.propertyData[!i]

      !data = !this.propertyData[!i][!j]

      -- Don't show hidden properties
      if (!data.hardType eq 'DDAT') then
        !hidden =!data.ldisp.not()
      else
        !hidden = !data.lhide
      endif
      skip if( !hidden and !includeHidden.not())

      if (!data.purp eq 'SPRE' or !data.purp eq 'SBRE') then
        if (!values[!i][!j].set()) then
          !vText = !values[!i][!j].fullName
        else
          !vText = 'NONE'
        endif
      else
        !vText = !this.getFormattedString(!values[!i][!j], !data.ptyp)
      endif

      -- build a row to add to the table
      !row = ARRAY()

      -- add number for array data types
      if (!useNum) then
        !row[4] = '[' + !data.number.string() + ']'
      else
        !row[4] = ' '
      endif

      -- Build display string for DESP properties
      !row[1] = !data.dKey
      !row[2] = !data.dTitle
      !row[3] = !vText

      -- add new row to the table
      !tempTable.append(!row)

    enddo

    -- add to COMPROPTABLE object
    if (!dataType eq 'ATTR') then
      !propTables.addAttributes(!tempTable)
    elseif (!dataType eq 'DESP') then
      !propTables.addDesPar(!tempTable)
    elseif (!dataType eq 'PARA') then
      !propTables.addCatPar(!tempTable)
    elseif (!dataType eq 'SPRE') then
      !propTables.addSpec(!tempTable)
    elseif (!dataType eq 'SBRE') then
      !propTables.addsbre(!tempTable)
    elseif (!dataType eq 'EXPR') then
      !propTables.addExpressions(!tempTable)
    elseif (!dataType eq 'DATA') then
      !propTables.addData(!tempTable)
    elseif (!dataType eq 'PLOT') then
      !propTables.addPlot(!tempTable)
    endif

  enddo

  -- Set the design element
  if (!this.designElement.set()) then
    !propTables.setDesignElement(!this.designElement)
  elseif (!this.catalogueElement.set()) then
    !propTables.setCatalogueElement(!this.spcoElement, !this.catalogueElement)
  endif

  return !propTables

endmethod
-- End of method definition

--**************************************************************
--***                                                        ***
--***                 PRIVATE METHODS                        ***
--***                                                        ***
--**************************************************************

------------------------------------------------------------------------
--
-- Method:      .setDefaults()
--
-- Description: Set members to default values
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .setDefaults()

  -- initialise variables
  !this.spcoElement   = object DBREF()
  !this.designElement = object DBREF()

  !this.setDesiSpref  = false
  !this.okFromForm    = false

  !this.editFormTitle  = 'Modify Properties'
  !this.editFormName   = ''
  !this.okCall         = '!!comPropCntrl.data[!this.pointer].okEditForm()'
  !this.cancelCall     = '!!comPropCntrl.data[!this.pointer].cancelEditForm()'

  if (!this.editMode.unset()) then
    !this.editMode = 'STORE'
  endif
  if (!this.editFormBlocking.unset()) then
    !this.editFormBlocking = false
  endif
  if (!this.editFormApply.unset()) then
    !this.editFormApply    = false
  endif
  if (!this.editFormBlockOwn.unset()) then
    !this.editFormBlockOwn = false
  endif

  !this.autoCacheValues = false

  !this.queryFormTitle = 'Design Property Information'

  if (!this.editForm.set()) then
    !fname = !this.editForm.fullName()
    !this.editForm = object FORM()
    kill $!<fname>
  endif
  if (!this.plotForm.set()) then
    !fname = !this.plotForm.fullName()
    !this.plotForm = object FORM()
    kill $!<fname>
  endif
  !this.queryForm  = object FORM()

  !this.editValuesStored = false
  !this.queryValsStored = false

  !this.setPurposeList()

  !this.dataType    = 'CATA'
  !this.catalogueElement = object DBREF()

  if (!this.isLinked.unset()) then
  !this.isLinked = false
  endif

  !this.autoDelete = false

  !this.forceUpdate = false
  !this.forceHiddenDesignParameters = false

  !this.error = object COMPROPERROR()

endmethod
-- End of method definition for .setDefaults()

------------------------------------------------------------------------
--
-- Method:      .setPurposeList()
--
-- Description: Set list of valid purposes to search for
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .setPurposeList()

  -- initialise variables
  !this.purposeList = ARRAY()

  -- Set the purpose list
  !this.purposeList.append('ATTR')
  !this.purposeList.append('PARA')
  !this.purposeList.append('DESP')
  !this.purposeList.append('SPRE')
  !this.purposeList.append('SBRE')
  !this.purposeList.append('EXPR')
  !this.purposeList.append('DATA')
  !this.purposeList.append('PLOT')
  !this.purposeList.append('ALL')

  -- Clear existing property data
  !this.clearPropData()

  -- Set values for index pointers
  !this.attrIndex = !this.purposeList.findFirst('ATTR')
  !this.paraIndex = !this.purposeList.findFirst('PARA')
  !this.despIndex = !this.purposeList.findFirst('DESP')
  !this.spreIndex = !this.purposeList.findFirst('SPRE')
  !this.sbreIndex = !this.purposeList.findFirst('SBRE')
  !this.exprIndex = !this.purposeList.findFirst('EXPR')
  !this.dataIndex = !this.purposeList.findFirst('DATA')
  !this.plotIndex = !this.purposeList.findFirst('PLOT')
  !this.allIndex  = !this.purposeList.findFirst('ALL')

endmethod
-- End of method definition for .setPurposeList()

------------------------------------------------------------------------
--
-- Method:      .clearPropData()
--
-- Description: Clear the property data storage
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .clearPropData()

  -- Initialise variables
  !this.propertyData  = ARRAY()
  !this.currentValues = ARRAY()
  !this.defaultValues = ARRAY()
  !this.initialValues = ARRAY()

  -- Initialise propertyData member
  do !i indices !this.purposeList
    !this.propertyData[!i]  = ARRAY()
    !this.currentValues[!i] = ARRAY()
    !this.defaultValues[!i] = ARRAY()
    !this.initialValues[!i] = ARRAY()
  enddo

  -- Initialise linked template members
  !this.linkedTemplates = ARRAY()
  !this.linkedElements  = ARRAY()
  !this.initialLinkVals = ARRAY()
  !this.subTemplates    = ARRAY()

endmethod
-- End of method definition for .clearPropData()

-----------------------------------------------------------------------
--
-- Method:      .getProperties()
--
-- Description: Get the properties for the passed element
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .getProperties()

  -- Clear the property data storage
  !this.clearPropData()

  -- Find all properties
  !this.findProperties()

  -- Get all values
  !this.storeValues()

endmethod
-- End of method definition for .getProperties()

------------------------------------------------------------------------
--
-- Method:      .findProperties()
--
-- Description: Find the datasets for the current catalogueElement
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .findProperties()

  -- Initialise variables
  !datasets = ARRAY()

  if (!this.dataType eq 'TMPL') then
    -- Collect all datasets
    var !tmpDataSets COLLECT MEMBERS OF $!<this.catalogueElement> WITH ( TYPE EQ 'DDSE' )
    -- Convert array from strings to dbref objects
    do !i indices !tmpDataSets
      !datasets[!i] = !tmpDataSets[!i].dbref()
    enddo

    -- Add default data areas
    !datasets.appendArray(!this.catalogueElement.ddrfa)

    -- Check that there are some datasets
    if (!datasets.size() lt 1) then
      -- !error = 'No datasets for item ' + !this.catalogueElement.fullName
      -- return error 1 |$!<error>|
      return
    endif
    !dataElements = ARRAY()
    -- Collect all data elements for each dataset
    do !i indices !datasets
      if( !datasets[!i].badref().not() ) then
      var !tmpDataElements COLLECT MEMBERS OF $!<datasets[$!<i>]> WITH ( ( PURP NE 'DESP' AND LDISP ) or ( PURP EQ 'DESP' ) )
      !dataElements.appendArray(!tmpDataElements)
      endif
    enddo
  else
    -- Check catalogue component for bad dtref
    if (!this.catalogueElement.dtRef.badref()) then
      -- !error = 'No dataset for item ' + !this.catalogueElement.fullName
      -- return error 1 |$!<error>|
      return
    endif

    -- Collect all data elements
    var !dataElements COLLECT MEMBERS OF $!<this.catalogueElement.dtRef> WITH ( ( PURP NE 'DESP' AND not( LHIDE ) ) or ( PURP EQ 'DESP' ) )

  endif

  -- Loop through the array of data elements and reference
  -- each element from the propertyData member.
  do !i indices !dataElements
    !data = !dataElements[!i].dbref()

    -- Get index number for first dimension of propertyData member
    !firstIndex = !this.purposeList.findFirst(!data.purpose)
    if (!firstIndex.set()) then
      -- The data element is a known type
      !this.propertyData[!firstIndex].append(!data)

    else
      -- The data element is an unknown type
      !this.propertyData[!this.allIndex].append(!data)
    endif
  enddo

  -- Initialise data storage for all linked templates
  do !i indices !this.propertyData[!this.sbreIndex]
    !this.linkedTemplates[!i] = object COMPROP()
    !this.linkedTemplates[!i].link()
    !this.linkedTemplates[!i].linkedTemplate(true)
  enddo

  !this.findDimensions()

endmethod
-- End of method definition for .findProperties()

------------------------------------------------------------------------
--
-- Method:      .findDimensions()
--
-- Description: Find all dimension points for this object
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .findDimensions()

  -- initialise dimension members
  !this.deleteAllDims()

  -- get the dimension points
  if (!this.designElement.badref()) then
    var !dimPoints COLLECT ALL DPSP with ( PURP eq 'DIM' ) for $!<this.catalogueElement>
  else
    !tmpl = !!dtbMemberOfType(!this.designElement, 'TMPL', 1)
    if (!tmpl.set()) then
      var !dimPoints COLLECT ALL DPSP with ( PURP eq 'DIM' ) for $!<tmpl>
    else
      var !dimPoints COLLECT ALL DPSP with ( PURP eq 'DIM' ) for $!<this.catalogueElement>
    endif
  endif

  !tempDimPoints = ARRAY()
  do !i indices !dimPoints
    !point = !dimPoints[!i].dbref()
    !index = !point.function.real()
    if (undefined(!tempDimPoints[!index])) then
      !tempDimPoints[!index] = ARRAY()
    endif
    -- only two points allowed per dimension
    if( !tempDimPoints[!index].size() lt 2 ) then
      !tempDimPoints[!index].append(!point)
    endif
  enddo

  -- remove incomplete/over complete dimension point pairs
  do !i indices !tempDimPoints
    skip if (!tempDimPoints[!i].size() lt 2)
    !this.dimPoints[!i]  = !tempDimPoints[!i]
    !this.dimDisplay[!i] = false
  enddo

endmethod
-- End of method definition for .findDimensions()

------------------------------------------------------------------------
--
-- Method:      .storeValues()
--
-- Description: Store default, initial and current values for edit form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .storeValues()

  !noCachedValues = true
  if (!this.designElement.badref()) then
    -- Check for cached values
    !cachedValues = !!comPropCntrl.getCacheValues(!this.pointer)
    if (!cachedValues.set()) then
      !this.defaultValues = !cachedValues[1]
      !this.initialValues = !cachedValues[2]
      !this.currentValues = !cachedValues[3]
      !noCachedValues = false
    endif
  endif

  if (!noCachedValues) then
    -- Set local index pointers
    !indexPointers[1] = !this.attrIndex
    !indexPointers[2] = !this.despIndex
    !indexPointers[3] = !this.spreIndex
    !indexPointers[4] = !this.plotIndex

    -- For each index pointer type COLLECT the property values
    do !index values !indexPointers
      do !i indices !this.propertyData[!index]
        !data = !this.propertyData[!index][!i]

        -- Get the default and initial values
        !values = !this.getPropertyValues(!data)
        !this.defaultValues[!index][!i] = !values[1]
        !this.initialValues[!index][!i] = !values[2]

      enddo
      -- Set the current values
      !this.currentValues[!index] = !this.initialValues[!index]
    enddo
  endif

  -- 'SBRE' data elements
  do !i indices !this.propertyData[!this.sbreIndex]
    !data = !this.propertyData[!this.sbreIndex][!i]

    -- Get the default and initial values, including design element for linked template
    !values = !this.getDdatValues(!this.designElement, !this.catalogueElement, !data)
    !desiElement = !values[3]

    if (!noCachedValues or !desiElement.badref().not()) then
      !this.defaultValues[!this.sbreIndex][!i] = !values[1]
      !this.initialValues[!this.sbreIndex][!i] = !values[2]
      !this.currentValues[!this.sbreIndex][!i] = !this.initialValues[!this.sbreIndex][!i]
    endif

    -- Initialise the linked template
    !spcoElement = !this.currentValues[!this.sbreIndex][!i]
    if (!spcoElement eq !this.spcoElement) then
      !!alert.error('Property ' + !data.dTitle + ' is a recursive sub reference')
      return
    else
      if (!desiElement.set()) then
        !this.linkedTemplates[!i].initialise(!desiElement)
        handle any
        elsehandle none
          !this.linkedElements[!i] = !desiElement
        endhandle
      else
        !this.linkedTemplates[!i].initialise(!spcoElement)
        handle any
        endhandle
      endif
    endif
    !this.initialLinkVals[!i] = !!comPropCntrl.data[!this.linkedTemplates[!i].pointer].initialValues
    !this.linkedTemplates[!i].linkedTemplate(true)
  enddo

  if (!noCachedValues) then
    -- Set the current values
    !this.currentValues[!this.sbreIndex] = !this.initialValues[!this.sbreIndex]
  endif

  -- Set flag to indicate that edit values have been stored
  !this.editValuesStored = true

endmethod
-- End of method definition for .storeValues()

------------------------------------------------------------------------
--
-- Method:      .storeQueryValues()
--
-- Description: Store default, initial and current values for query form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .storeQueryValues()

  -- Store edit values if not already stored
  if (!this.editValuesStored.not()) then
    !this.storeValues()
  endif

  -- Set local index pointers
  !indexPointers[1] = !this.exprIndex
  !indexPointers[2] = !this.dataIndex
  !indexPointers[3] = !this.paraIndex
  !indexPointers[4] = !this.allIndex

  -- For each index pointer type COLLECT the property values
  do !index values !indexPointers
    do !i indices !this.propertyData[!index]
      !data = !this.propertyData[!index][!i]

      -- Get the default and initial values
      !values = !this.getPropertyValues(!data)
      !this.defaultValues[!index][!i] = !values[1]
      !this.initialValues[!index][!i] = !values[2]

    enddo
    -- Set the current values
    !this.currentValues[!index] = !this.initialValues[!index]
  enddo

  -- Set flag to indicate that query values have been stored
  !this.queryValsStored = true

endmethod
-- End of method definition for .storeQueryValues()

------------------------------------------------------------------------
--
-- Method:      .getPropertyValues(DBREF)
--
-- Description: Get the default and actual property values for DATA or DDAT elements
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Default and current values]
--
------------------------------------------------------------------------
define method .getPropertyValues( !data is DBREF ) is ARRAY

  -- Get the default and initial values
  if (!this.dataType eq 'CATA') then
    !values = !this.getDataValues(!this.designElement, !this.catalogueElement, !data)
  else
    !values = !this.getDdatValues(!this.designElement, !this.catalogueElement, !data)
  endif

  return !values

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      .getDataValues(DBREF, DBREF, DBREF)
--
-- Description: Get the default or actual property values for DATA elements
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Design element]
--   [2] [R] [DBREF] [Catalogue element]
--   [3] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Default and current values]
--
------------------------------------------------------------------------
define method .getDataValues(!designElement is DBREF, !catalogueElement is DBREF, !data is DBREF) is ARRAY

  !dataPurp  = !data.purp
  !dataKey   = !data.dKey
  !dataPType = !data.ptyp
   -- Get the default value
  -- find out if this is a numeric property
    -- test for special case where hash is used
  if (!data.dprop.match('HASH') gt 0 ) then
    !hashString = !data.dprop
    var !hash $!hashString
    !hashReal = !hash.real()
    -- Change for 12.1.1 because the core no longer interprets large numbers (6 figure) as hash codes.
    -- We have to unhash it, in the PML. (This avoids extensive data changes)
    var !unhash (unhash($!hashReal))
    !default = !unhash
  elseif (!data.ptyp eq 'LOG') then
    -- Check for logical data type and convert to BOOLEAN if required
    !defaultValue = !catalogueElement.prde.attribute(!dataKey)
    !default = !defaultValue.boolean()
    handle any
      !default = true
    endhandle
  else
    !defaultValue = !catalogueElement.fprde.attribute(!dataKey)
    !realVal      = !defaultValue.real()
    handle any
      -- this is not a numeric type
      !default = !defaultValue
    elsehandle none
      if (!designElement.set()) then
        !default = !designElement.fprde.attribute(!dataKey).real()
        handle any
          !default = !realVal
        endhandle
      elseif (!this.defaultDesignElement.set()) then
        !default = !this.defaultDesignElement.fprde.attribute(!dataKey).real()
      else
        !default = !realVal
      endif
      if (!default.unset()) then
        !default = 0
    endif
    endhandle

  endif

  -- Get the current value
  if (!designElement.set()) then

    if (!data.ptyp eq 'LOG') then
      -- Check for logical data type and convert to BOOLEAN if required
      !currentValue = !designElement.prop.attribute(!dataKey)
        !current = !currentValue.boolean()
        handle any
        !current    = !default
        endhandle
      else
      !currentValue = !designElement.fProp.attribute(!dataKey)
      handle any
        !current    = !default
      elsehandle none
        if( !currentValue.unset() ) then
          !current  = !default
        else
          !current = !currentValue
        endif
      endhandle
    endif


  else
    -- There is no design element, set current value to default value
    !current = !default
  endif

  -- Return values
  --   [1] Default values
  --   [2] Current Values
  !returnArray[1] = !default
  !returnArray[2] = !current

  return !returnArray

endmethod
-- End of method definition for .getDataValues(DBREF, DBREF, DBREF) ARRAY

------------------------------------------------------------------------
--
-- Method:      .getDdatValues(DBREF, DBREF, DBREF)
--
-- Description: Get the default or actual property values
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Design element]
--   [2] [R] [DBREF] [Catalogue element]
--   [3] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Default and current values + reference of linked design element]
--
------------------------------------------------------------------------
define method .getDdatValues(!designElement is DBREF, !catalogueElement is DBREF, !data is DBREF) is ARRAY

  !dataPurp  = !data.purp
  !dataKey   = !data.dKey
  !dataPType = !data.ptyp
  -- Get the default value
  if (!dataPurp inset('SBRE','SPRE')) then
    -- Convert value to DBREF object
    !default = !catalogueElement.lfdp.attribute(!dataKey)
    handle any
      !default = object DBREF()
    endhandle
  elseif(!dataPType eq 'LOG') then
    -- Check for logical data type and convert to BOOLEAN if required
    !default = !catalogueElement.depd.attribute(!dataKey).boolean()
    handle any
      !default = true
    endhandle
  elseif(!dataPType eq 'TEXT') then
    -- Check for text data type and return text result
    !default = !catalogueElement.depd.attribute(!dataKey)
    handle any
      !default = ''
    endhandle
  else
    -- find out if this is a numeric property
    !defaultValue = !catalogueElement.fdepd.attribute(!dataKey)
    handle (2,423)
      -- default dimension does not match the PTYP
      !defaultValue = '0'
    endhandle
    !realVal      = !defaultValue.real()
    handle any
      -- this is not a numeric type
      !default    = !defaultValue
    elsehandle none
      if (!designElement.set()) then
        !default = !designElement.fprde.attribute(!dataKey).real()
        handle any
          -- could be a missing parameter - design element parameter list not matching template parameter list
          !default    = !defaultValue
        endhandle
      elseif (!this.defaultDesignElement.set()) then
        !default = !this.defaultDesignElement.fprde.attribute(!dataKey).real()
        handle any
          -- could be a missing parameter - design element parameter list not matching template parameter list
          !default    = !defaultValue
        endhandle
      else
        -- evaluate data element locally which will return the default unless the DDPRO delivers a valid result
        -- DEPD does not return a string with units
        !default = !realVal
      endif
      if (!default.unset()) then
        !default = 0
      endif
    endhandle

  endif

  !desiElement  = object DBREF()

  -- get the current value
  if (!designElement.set()) then

    if (!dataPurp eq 'SPRE') then
      -- Get current value for SPRE data type
      !current = !this.getElementSpre(!designElement, !dataKey)
      -- Set current value to default if not found
      if (!current.unset()) then
        !current = !default
      endif

    elseif (!dataPurp eq 'SBRE') then
      -- Get current value for SBRE data type
      !current = !this.getElementSbre(!designElement, !dataPType, !dataKey, !desiElement)
      -- Set current value to default if not found
      -- three lines of this block were commented out, which is the reason why NONE was not selected in the list (AK)
      !checkVvalues = !this.getVValuesString(!data)
     if (!current.unset()) then
        if(!checkVvalues[1].findFirst('NONE').unset()) then
          !current = !default
        endif
      endif

    elseif (!dataPurp eq 'ATTR') then
      !current = !designElement.attribute(!dataKey)

    elseif (!dataPType eq 'WORD') then
      !current = !designElement.prop.attribute(!dataKey)

    else

      !defaultType = !default.objectType()
      if ( !defaultType eq 'REAL' ) then
        -- Real type possibly with units
        !currentValue = !designElement.fProp.attribute(!dataKey).real()
        handle any
          !currentValue = !default
        endhandle
      elseif( !defaultType eq 'BOOLEAN' ) then
        -- Check for logical data type and convert to BOOLEAN if required
        !currentValue = !designElement.prop.attribute(!dataKey).boolean()
        handle any
          !currentValue = !default
        endhandle
      else
        !currentValue = !designElement.prop.attribute(!dataKey)
        handle any
          !currentValue = !default
        endhandle
      endif
      !current = !currentValue

    endif

  else

    -- There is no design element, set current value to default value
    !current = !default

  endif

  -- Return values
  --   [1] Default values
  --   [2] Current Values
  --   [3] Design element if SBRE data type
  !returnArray[1] = !default
  !returnArray[2] = !current
  !returnArray[3] = !desiElement

  return !returnArray

endmethod
-- End of method definition for .getDdatValues(DBREF, DBREF, DBREF) ARRAY

------------------------------------------------------------------------
--
-- Method:      .setValue(STRING, REAL, ANY)
--
-- Description: Set a value when input from gadget
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING] [Property purpose]
--   [2] [R] [REAL]   [Property Index]
--   [3] [R] [ANY]    [Property value]
--
------------------------------------------------------------------------
define method .setValue(!type is STRING, !index is REAL, !value is ANY)

  -- Set the current value
  !this.currentValues[!this.purposeList.findFirst(!type)][!index] = !value

  if (!type eq 'SBRE') then
    !initialSpref = !this.linkedElements[!index].spref
    handle any
      if (!this.currentValues[!this.sbreIndex][!index].badref()) then
        !this.linkedTemplates[!index].clearObject()
      else
        !this.linkedTemplates[!index].initialise(!this.currentValues[!this.sbreIndex][!index])
        handle any
          !this.linkedTemplates[!index].clearObject()
        elsehandle none
          if (defined(!this.linkedElements[!index])) then
            if (!this.linkedElements[!index].badref().not()) then
              !this.linkedTemplates[!index].designElement(!this.linkedElements[!index])
            endif
          endif
        endhandle
      endif
    elsehandle none
      if (!this.currentValues[!this.sbreIndex][!index].badref()) then
        !this.linkedTemplates[!index].clearObject()
      else
        if (!initialSpref eq !value) then
          !this.linkedTemplates[!index].initialise(!this.linkedElements[!index])
        else
          !this.linkedTemplates[!index].initialise(!this.currentValues[!this.sbreIndex][!index])
          !this.linkedTemplates[!index].designElement(!this.linkedElements[!index])
        endif
      endif
    endhandle
    !this.linkedTemplates[!index].linkedTemplate(true)
  endif

  -- Set all properties if edit mode is DYNAMIC
  if (!this.editMode eq 'DYNAMIC') then
    !this.setProperties()
  else
    if (!type eq 'DESP') then
      !dataIndex = !this.propertyData[!this.despIndex][!index].number
      if (defined(!this.dimDisplay[!dataIndex])) then
        if (!this.dimDisplay[!dataIndex]) then
          !this.displayDimension(!dataIndex, true)
        endif
      endif

    endif
  endif

endmethod
-- End of method definition for .setValue(STRING, REAL, ANY)

------------------------------------------------------------------------
--
-- Method:      .buildEditForm()
--
-- Description: Build the edit form
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .buildEditForm()
  -- Build the form
  !!pointer = !this.pointer
  !!purposeList = !this.purposeList
  !!propertyData = !this.propertyData
  !!editFormBlocking = !this.editFormBlocking
  !!editFormApply = !this.editFormApply
  !!dataType = !this.dataType
  !this.editForm = !!comPropEdit(!this.pointer, !this.purposeList, !this.propertyData, !this.editFormBlocking, !this.editFormApply, !this.dataType)

  -- Set the form members
  !this.editForm.formTitle  = !this.editFormTitle
  if (!this.editFormApply) then
    !this.editForm.ok.callback = !this.okCall
  else
    !this.editForm.okCall     = !this.okCall
  endif
  !this.editForm.cancelCall = !this.cancelCall

endmethod
-- End of method definition for .buildEditForm()

------------------------------------------------------------------------
--
-- Method:      .initEditForm(STRING, BOOLEAN)
--
-- Description: Initialise the gadget values on the edit form
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [STRING]  [Type of values to display - DEFAULT/INITIAL/CURRENT]
--   [2] [R] [BOOLEAN] [Update properties flag]
--
------------------------------------------------------------------------
define method .initEditForm(!type is STRING, !updateFlag is BOOLEAN)

  -- Get the values to use for the edit form based on the !type variable
  if (!type eq 'DEFAULT') then
    !this.currentValues = !this.defaultValues
    !values = !this.currentValues
  elseif (!type eq 'INITIAL') then
    !this.currentValues = !this.initialValues
    !values = !this.currentValues
  else
    !values = !this.currentValues
  endif

  if (!this.editForm.listEdit) then

    -- Initialise variables
    !dtext  = ARRAY()
    !rText  = ARRAY()
    !row    = ARRAY()

    !editIndex[1] = !this.attrIndex
    !editIndex[2] = !this.despIndex
    !editIndex[3] = !this.spreIndex
    !editIndex[4] = !this.sbreIndex

    -- Compose list gadget contents
    do !i values !editIndex
      do !j indices !this.propertyData[!i]
        !data = !this.propertyData[!i][!j]

        -- Don't show hidden properties
        if (!data.hardType eq 'DDAT') then
          skip if (!data.ldisp.not())
        else
          skip if (!data.lhide)
        endif

        if (!data.purp eq 'SPRE' or !data.purp eq 'SBRE') then
          if (!values[!i][!j].badref()) then
            !vText = 'NONE'
          else
            !contents = !this.getVValuesString(!data)
            !vText = !contents[1][!contents[2].findFirst(!values[!i][!j].string())]
            -- check the need for this
            handle any
              !vText = 'NONE'
            endhandle
          endif
          !this.setValue(!data.purp, !j, !values[!i][!j])
        else
          -- get format for this PTYP
          !vText = !this.getFormattedString(!values[!i][!j],!data.ptyp)
        endif

        -- Build display string for all other properties
        !row[1] = !data.dTitle
        !row[2] = !vText
        !dtext.append(!row)
        !rText.append(!data.purp & ' ' & !j)
      enddo
    enddo

    -- populate list gadget on the properties edit form
    !row[1] = 'Property'
    !row[2] = 'Value'
    !this.editForm.properties.setHeadings(!row)
    !this.editForm.properties.setRows(!dtext)
    !this.editForm.properties.rText = !rText

  else

    -- Display attribute values
    do !i indices !this.propertyData[!this.attrIndex]
      skip if(undefined(!this.editForm.attrGadget[!i]))
      if (!this.editForm.attrGadget[!i].type() eq 'TEXT') then
        !this.editForm.attrGadget[!i].val = !values[!this.attrIndex][!i]
      elseif (!this.editForm.attrGadget[!i].type() eq 'TOGGLE') then
        !this.editForm.attrGadget[!i].val = !values[!this.attrIndex][!i]
        handle any
          !this.editForm.attrGadget[!i].val = false
        endhandle
      else
        !this.editForm.attrGadget[!i].select('rtext', !values[!this.attrIndex][!i].string())
        handle any
        endhandle
      endif
    enddo

    -- Display design parameter values
    do !i indices !this.propertyData[!this.despIndex]
       skip if(undefined(!this.editForm.despGadget[!i]))
       if (!this.editForm.despGadget[!i].type() eq 'TEXT') then
         if( !values[!this.despIndex][!i].objectType() eq 'REAL' ) then
           !this.editForm.despGadget[!i].val = !values[!this.despIndex][!i].queryString().real()
           handle any
           endhandle
         else
           !this.editForm.despGadget[!i].val = !values[!this.despIndex][!i]
         endif
       else
         !this.editForm.despGadget[!i].select('rtext', !values[!this.despIndex][!i].string())
         handle any
         endhandle
       endif
    enddo

    -- Display SPRE values
    do !i indices !this.propertyData[!this.spreIndex]
    skip if(undefined(!this.editForm.spreGadget[!i]))
      if (!this.editForm.spreGadget[!i].type() eq 'TEXT') then
        !spcoString = !this.editForm.spre$!<i>list[1][!this.editForm.spre$!<i>list[2].findFirst(!values[!this.spreIndex][!i].string())]
        handle any
          !spcoString = !this.editForm.spre$!<i>list[1][1]
          handle any
            !spcoString = ''
          endhandle
        endhandle
        !this.editForm.spreGadget[!i].val = !spcoString
      else
        !this.editForm.spreGadget[!i].select('rtext', !values[!this.spreIndex][!i].string())
        handle any
        endhandle
      endif
      !this.setValue('SPRE', !i, !values[!this.spreIndex][!i])
    enddo

    -- Display SBRE values
    do !i indices !this.propertyData[!this.sbreIndex]
      skip if(undefined(!this.editForm.sbreGadget[!i]))
      if (!this.editForm.sbreGadget[!i].type() eq 'TEXT') then
        if (!values[!this.sbreIndex][!i].badref()) then
          !spcoString = 'NONE'
        else
          !spcoString = !this.editForm.sbre$!<i>list[1][!this.editForm.sbre$!<i>list[2].findFirst(!values[!this.sbreIndex][!i].string())]
          handle any
            !spcoString = !this.editForm.sbre$!<i>list[1][1]
            handle any
              !spcoString = ''
            endhandle
          endhandle
        endif
        !this.editForm.sbreGadget[!i].val = !spcoString
      else
        if (!values[!this.sbreIndex][!i].badref()) then
          !selectText = 'nulref'
        else
          !selectText = !values[!this.sbreIndex][!i].string()
        endif
        !listPos = !this.editForm.sbreGadget[!i].rText.findFirst(!selectText)
        if (!selectText.set()) then
          !this.editForm.sbreGadget[!i].val = !listPos
        endif
      endif
      !this.setValue('SBRE', !i, !values[!this.sbreIndex][!i])
    enddo
  endif

  -- Set the design element prompt
  if (!this.designElement.set() and !this.isLinked.not()) then
    !nameString = !this.designElement.fullName
  elseif (!this.isLinked) then
    !nameString = !this.editFormName
  else
    if (!this.catalogueElement.desc.empty().not()) then
      !nameString = !this.catalogueElement.desc
    elseif (!this.catalogueElement.name.subString(1, 1) ne '=') then
      !nameString = !this.catalogueElement.name
    else
      !nameString = !this.spcoElement.name
    endif
  endif
  -- !this.editForm.name.val = !nameString.subString(1, !this.editForm.nameWidth)
  !this.editForm.name.val = !nameString

  if (!this.designElement.set()) then
    if (!this.designElement.attributes().findFirst('Spref').unset()) then
      !toggleState = true
    elseif (!this.designElement.spref eq !this.spcoElement) then
      !toggleState = true
    else
      !toggleState = false
    endif
  else
    !toggleState = false
  endif
  do !toggle values !this.editForm.dimToggles
    !toggle.active = !toggleState
  enddo

  -- update properties if in 'DYNAMIC' mode
  if (!updateFlag) then
    if (!this.editMode eq 'DYNAMIC') then
      !this.setProperties()
    endif
  endif

endmethod
-- End of method definition for .initEditForm(STRING, BOOLEAN)

------------------------------------------------------------------------
--
-- Method:      .getVValues(DBREF)
--
-- Description: Get valid values for a data set
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Range of valid values]
--
------------------------------------------------------------------------
define method .getVValues(!data is DBREF) is ARRAY

  -- Initialise return variable
  !returnArray = ARRAY()

  -- Check for data members
  if (!data.members.set()) then
    !values = ARRAY()
    !vvalues = !data.members

    -- Get value of each VVALUE element under the DDAT element
    do !i indices !vvalues
      if (defined(!tempValue)) then
        !tempValue.delete()
      endif

      if (!vvalues[!i].hardType.upcase() eq 'VVALUE') then

        -- ignore VVALUE elements with an unset validValue rule
        if (!vvalues[!i].validValue.trim() eq '') then
          !purpIndex = !this.purposeList.findFirst(!data.purpose)
          !ddatIndex = !this.propertyData[!purpIndex].findFirst(!data)
          !tempValue = !this.currentValues[!purpIndex][!ddatIndex]
          -- !!alert.warning('Valid Value ' & !vvalues[!i] & ' for DDAT ' & !data & ' is unset')

        else
          !tempValue = !data.evaluate(object BLOCK(!vvalues[!i].validValue))
          if( !tempValue.objectType() inset('REAL','BORE') ) then
            -- Use pseudo attribute to get correctly dimensioned value
            !tempValue.delete()
            !tempValue = !vvalues[!i].ldpr.vali
          endif
        endif
        !values.append(!tempValue)
      endif
    enddo

    !returnArray = !values
  endif

  return !returnArray

endmethod
-- End of method definition for .getVValues(DBREF) ARRAY

------------------------------------------------------------------------
--
-- Method:      .getAdjSpcos(DBREF)
--
-- Description: Get adjacent spco elements or vvalues
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [DBREF] [Data element]
--
-- Return:
--   [ARRAY] [Dtext and Rtext for list or option gadget]
--
------------------------------------------------------------------------
define method .getAdjSpcos(!data is DBREF) is ARRAY

  -- Initialise return array
  !returnArray[1] = ARRAY()
  !returnArray[2] = ARRAY()

  -- Check for valid values, these override any adjacent SPCO elements
  !contents = !this.getVValues(!data)

  if (!contents.empty()) then
    -- Get adjacent SPCO elements
    if (!data.dddfault.set()) then
      -- Try using evaluate to extract the DBREF object
      -- if this doesn't work, then use the commented out line
      -- and check for dddfault set to ( ID NULREF )
--      !spcoRef = !data.dddfault.part(3).dbref()
      !spcoRef = !data.evaluate(object BLOCK(!data.dddfault))
      if( !spcoRef.objectType() neq 'DBREF') then
        -- should only happen if default value set to the wrong type
        !contents = ARRAY()
      else
        if (!spcoRef.unset()) then
           !contents = ARRAY()
        elseif (!spcoRef.hardType inset(|SPCO|, |TABITE|, |GPART|)) then
           !contents = !spcoRef.owner.members
        elseif (!spcoRef.hardType inset(|SELE|, |CTABLE|)) then
           !contents = !spcoRef.members
        elseif (!spcoRef.hardType eq 'WDET') then
          -- load all WDETs in the STCA
          !contents = !!collectAllFor('WDET','',!spcoRef.owner)
        endif
      endif
    endif
  endif
  do !i indices !contents
    -- should only happen if valid values are set to the wrong type
    skip if (!contents[!i].objectType() neq 'DBREF')
    -- Use name of catRef or tmpref, only use spco name if others are unset
    if (!contents[!i].badref()) then
      !returnArray[1][!i] = 'NONE'
      !returnArray[2][!i] = 'nulref'
    else
      if (!contents[!i].hardType eq |WDET|) then
        -- Weld details
        !name = !contents[!i].name
        !item = !contents[!i]
      else
        -- Allow for one level of indirection if element is a TABITE
        if (!contents[!i].hardType eq |TABITE|) then
          !item = !contents[!i].prtref
        else
          !item = !contents[!i]
        endif
        -- Get element details
        if (!item.catRef.badref().not()) then
          if (!item.catRef.desc.empty().not()) then
            !name = !item.catRef.desc
          else
            !name = !item.catRef.name
          endif
        elseif (!item.tmpRef.badref().not()) then
          if (!item.tmpRef.desc.empty().not()) then
            !name = !item.tmpRef.desc
          else
            !name = !item.tmpRef.name
          endif
        else
          !name = !item.name
        endif
      endif
      if (!name.subString(1, 1) eq '=') then
        !name = !item.name
      endif
      -- Set return array
      !returnArray[1][!i] = !name
      !returnArray[2][!i] = !item.refNo.string()
    endif
  enddo

  return !returnArray

endmethod
-- End of method definition for .getAdjSpcos(DBREF) ARRAY

------------------------------------------------------------------------
--
-- Method:      .getElementSpre(DBREF, STRING)
--
-- Description: Get the current value for a SPRE data type
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]  [Design element]
--   [2] [R] [STRING] [DKEY attribute value for ddat element]
--
-- Return:
--   [DBREF] [Current SPRE value]
--
------------------------------------------------------------------------
define method .getElementSpre(!element is DBREF, !dKey is STRING) is DBREF

  !datasets = ARRAY()

  -- Find the datasets under the element
  var !tmpDataSets COLLECT MEMBERS OF $!<element> WITH ( TYPE EQ 'DDSE' )
  -- Convert array from strings to DB references
  do !i indices !tmpDataSets
    !datasets[!i] = !tmpDataSets[!i].dbref()
  enddo

  if (!datasets.size() lt 1) then
    -- No datasets under the design element, this means the spre data element has
    -- probably been inadvertently deleted, this will be rectified when the
    -- properties are set
    !defaultValue = object DBREF()

  else
    -- Find the data element
    do !i indices !datasets
      var !tmpDataElements COLLECT MEMBERS OF $!<datasets[$!<i>]> WITH ( DKEY EQ '$!<dKey>' )
      if (!tmpDataElements.set()) then
        !ddat = !tmpDataElements[1].dbref()
        break
      endif
    enddo

    if (defined(!ddat)) then
      !defaultValue = !ddat.cfdp.attribute(!dKey)
    else
      !defaultValue = object DBREF()
    endif

  endif

  return !defaultValue

endmethod
-- End of method definition for .getElementSpre(DBREF, STRING) DBREF

------------------------------------------------------------------------
--
-- Method:      .getElementSbre(DBREF, STRING, STRING, DBREF)
--
-- Description: Get the current value for a SBRE data type
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R]  [DBREF]  [Design element]
--   [2] [R]  [STRING] [PTYP attribute value for ddat element]
--   [3] [R]  [STRING] [DKEY attribute value for ddat element]
--   [3] [RW] [DBREF]  [Linked template design element]
--
-- Return:
--   [DBREF] [Current SBRE value]
--
------------------------------------------------------------------------
define method .getElementSbre(!element is DBREF, !ptyp is STRING, !dKey is STRING, !desiElement is DBREF) is DBREF

  -- find the linked template design element under the main element

  var !subElements COLLECT MEMBERS OF $!<element> WITH ( TYPE EQ '$!<ptyp>' AND PURP EQ '$!<dKey>' )


  if (!subElements.size() lt 1) then
    -- no linked template design element under the design element,
    -- this means the linked template design element has
    -- probably been inadvertently deleted, this will be rectified when the
    -- properties are set
    !defaultValue = object DBREF()
    !desiElement  = object DBREF()

  else
    !desiElement = !subElements[1].dbref()
    if (!desiElement.spref.badref()) then
      -- spref is pointing to unset reference, this will be rectified when properties are set
      !defaultValue = object DBREF()
    else
      !defaultValue = !desiElement.spref
    endif
  endif

  return !defaultValue

endmethod
-- End of method definition for .getElementSbre(DBREF, STRING, STRING, DBREF) DBREF

------------------------------------------------------------------------
--
-- Method:      .getCurrentDesignParameters()
--
-- Description: Get the current design parameter values
--
-- Method Type: Function
--
-- Return:
--   [ARRAY] Array of design parameter values
--
------------------------------------------------------------------------
define method .getCurrentDesignParameters() is ARRAY

  return !this.currentValues[!this.despIndex]

endmethod
-- End of method definition for .getCurrentDesignParameters() ARRAY

------------------------------------------------------------------------
--
-- Method:      .setCurrentDesignParameters()
--
-- Description: Set the current design parameter values
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R]  [ARRAY] [Array of parameter values]
--
------------------------------------------------------------------------
define method .setCurrentDesignParameters(!params is ARRAY)

  if (!params.set()) then
    !this.currentValues[!this.despIndex] = !params
  endif

endmethod
-- End of method definition for .setCurrentDesignParameters(ARRAY)

------------------------------------------------------------------------
--
-- Method:      .getCurrentDesignParameter(STRING)
--
-- Description: Get the current value for a given data type
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R]  [STRING] [DKEY attribute value for ddat element]
--
-- Return:
--   [REAL] [Current DESP value]
--
------------------------------------------------------------------------
define method .getCurrentDesignParameter(!dKey is STRING) is REAL

  !value = object REAL()

  -- Find DESP key
  do !i indices !this.propertyData[!this.despIndex]

    !data = !this.propertyData[!this.despIndex][!i]

    skip if( !data.dKey neq !dKey )

    !value = !this.currentValues[!this.despIndex][!i]
    break

  enddo

  return !value

endmethod
-- End of method definition for .getCurrentDesignParameter(STRING) REAL

------------------------------------------------------------------------
--
-- Method:      .currentUnitsVal(STRING, DBREF, DBREF, STRING)
--
-- Description: return the current value as a REAL in the current units
--
-- Method Type: Function
--
-- Arguments:
--   [1] [R] [STRING] [type of attribute to get value from]
--   [2] [R] [DBREF]  [data element]
--   [3] [R] [DBREF]  [element to EVALUATE attribute at]
--   [4] [R] [STRING] [attribute to evaluate]
--
-- Return:
--   [REAL] [value in current units]
--
------------------------------------------------------------------------
define method .currentUnitsVal(!type is STRING, !data is DBREF, !evalElement is DBREF, !attribute is STRING) is REAL

  if (!type eq 'dkey') then
    !value = !evalElement.attribute(!attribute).attribute(!data.dKey)
    handle any
      !value = REAL()
    endhandle
  elseif (!type eq 'evaluate') then
    !value = !evalElement.evaluate(object BLOCK(!attribute))
    handle any
      !value = REAL()
    endhandle
  else
    !value = !evalElement.attribute(!attribute)
    handle any
      !value = REAL()
    endhandle
  endif

  -- Check that the default value is the correct data type
  -- Change it if it isn't
  if (!value.objectType() ne 'REAL') then
    !tempValue = !value.real()
    handle any
      !tempValue = REAL()
    endhandle
    !value.delete()
    !value = !tempValue
    !tempValue.delete()
  endif

  !returnValue = !value

  return !returnValue

endmethod
-- End of method definition for .currentUnitsVal(STRING, DBREF, DBREF, STRING) REAL

------------------------------------------------------------------------
--
-- Method:      .evaluateRules()
--
-- Description: Evaluate all rules for the element
--
-- Method Type: Procedure
--
------------------------------------------------------------------------
define method .evaluateRules()

  import 'Aveva.Core.Editors'
  handle any
  endhandle

  using namespace 'Aveva.Core.Editors.Converters.RulesEngine'

  -- Store current database position
  !dbPos = !!ce

  -- Initialise rules engine object
  !rulesEngine = object NETRULESENGINE()

  -- Check we have read/write access to EVALUATE the rules.
  if( not !!dbRefUpdate(!this.designElement) ) then
    -- Navigate to original database position
    if (!dbPos.badref().not()) then
      !!ce = !dbPos
    endif
    return error 1 |Unable to modify read-only data.|
  endif

  -- Find the first level template
  !tmpl = !!dtbMemberOfType(!this.designElement, 'TMPL', 1)
  if (!tmpl.unset()) then
    -- No template, but still execute rules engine rules
    !rulesEngine.executeAllRules(!this.designElement.string())
    return
  endif

  -- Set the correct lock levels
  !!ce = !tmpl.owner
  UNLOCK ALL

  -- Execute Rules Engine rules for the template
  !rulesEngine.executeAllRules(!this.designElement.string())

  -- General repeat function (generic) (don't run it in the TPWL)
  !tmarRef = !!dtbGetOwnerType( !tmpl, 'TMAR' )
  if( !tmarRef.unset() ) then
    !this.genRepeat(!tmpl)
  endif

  !!ce = !tmpl.owner
  RULE REXE
  handle any
    !this.errorLogAppend('FAIL',!!error.text,'Execute rules',!!error.command,!!error.line)
  endhandle
  
  -- Unset the rule set reference for copied templates
  !this.unsetRuleEngineReferences(!tmpl)
  
  !!ce = !tmpl
  LOCK
  handle any
    !this.errorLogAppend('FAIL',!!error.text,'Lock Template',!!error.command,!!error.line)
  endhandle

  !this.updateAllDims()

  -- Navigate to original database position
  if (!dbPos.badref().not()) then
    !!ce = !dbPos
  endif

endmethod
-- End of method definition for .evaluateRules()

------------------------------------------------------------------------
--
-- Method:      .genRepeat(DBREF)
--
-- Description: Do the template repeats
--   NOW REDUNDANT - REPLACED BY NEW CORE REPEATS MECHANISM
--   THIS ONLY REMAINS IN CASE A USER HAS USED THIS METHOD
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Element for repeat]
--
------------------------------------------------------------------------
define method .genRepeat(!element is DBREF)

  !ref = !!ce

  -- at TEMPLATE
  !!ce = !element

  var !repeats       COLLECT ALL WITH ( upcase(func) eq 'REPEAT' )        FOR $!<element>
  var !masterRepeats COLLECT ALL WITH ( upcase(func) eq 'MASTER REPEAT' ) FOR $!<element>

  ---------------------------------------------------------------
  -- delete repeats before re-evaluating rules
  ---------------------------------------------------------------
  if (arraySize(!repeats) ge 1) then
    REM CE
    do !d from 1 to !repeats.size()
      !!ce = !repeats[!d].dbref()
      DELETE $!!ce.hardType
    enddo
    ADD CE
  endif

  ---------------------------------------------------------------------------
  -- The above block should be replaced at some stage to use existing repeats
  ---------------------------------------------------------------------------

  -- repeat Repeats !rnum of times
  -- for one repeat at the moment
  do !i indices !masterRepeats

    !repeatItem = !masterRepeats[!i].dbref()
    !!ce = !repeatItem

    !type = !repeatItem.hardType
    -- to cater for those items such as NXTR that do not have ddse's under them
    var !attrDummy DEPR ATTR
    handle any
      var !attrDummy DEPR ATTR OF OWNER
      handle any
        !!alert.error(|Repeat element does not have required repeat rules (in ddse)|)
        skip
      endhandle
      !attr = !attrDummy
      var !noffDummy  RDEP NOFF OF OWNER
      !noff = !noffDummy.real()
      var !ruleDummy  DEPR RULE OF OWNER
      !rule = !ruleDummy
      var !wrtDummy  DEPR WRTO OF OWNER
      !wrt = !wrtDummy
      var !dist  (DIST(LDPR DIST OF OWNER))
    elsehandle none
      !attr = !attrDummy
      var !noffDummy  RDEP NOFF
      !noff = !noffDummy.real()
      var !ruleDummy  DEPR RULE
      !rule = !ruleDummy
      var !wrtDummy  DEPR WRTO
      !wrt = !wrtDummy
      var !dist  (DIST(LDPR DIST))
    endhandle

    -- stop if no repeats required
    if (!noff lt 1) then
      !!ce = !ref
      skip
    endif

    !!ce = !repeatItem
    -- frig in case zdist is the attribute
    !testString = 'FITT,CMFI'
    if(!testString.match(!!ce.hardType).neq(0) and !attr.upcase().match('ZDIS').neq(0)) then
      RULE EXECUTE ALL ON ALL FOR OWN
       handle any
         -- in case the rule doesn't exist
       endhandle
    endif

    LAST
    !masterRefe = !repeatItem.refe

    -- try pointing the repeats to the master repeat
    !orrf = !repeatItem

    -- block to validate Repeat ddat values ------
    if(!rule.eq('unset')) then
      !rule = ''
    endif

    if(!wrt.eq('unset')) then
      !wrto = ''
    else
      !wrto = 'wrt ' & !wrt & ' from $!masterRefe '
    endif

    -- do the first copy, setting all attributes and handling possible errors
    -- also get rid of DDSE under repeats. Further repeats are a copy of this first
    -- repeat element. This should maximise repeat performance
    -- Make sure this element is created in the correct hierarchy because
    -- of possibility of >fixing>fixing
    !sequence = !!ce.sequence
    END
    NEW $!<type> AFTER $!sequence COPY $!<repeatItem>
    !firstCopy = !!ce
    ORRF $!orrf
    FUNCTION 'Repeat'
    handle any
      !!alert.error(|Repeat element does not have required function attribute|)
      DELETE $!<type>
      !!ce = !ref
      return
    endhandle

    -- set repeat number
    !m = 1
    !numb = 2
    NUMB ($!<numb>)
    handle any
      !!alert.error(|Repeat element does not have required number attribute|)
      DELETE $!<type>
      !!ce = !ref
      return
    endhandle
    -- set the rule
    if(!attr.upcase() eq 'POSS') then
      RULE SET POSE ($!rule ($!dist MM * $!m) WRT $!wrt FROM ATTRIB POSE OF $!masterRefe )
      RULE SET POSS ($!rule ($!dist MM * $!m) WRT $!wrt FROM ATTRIB POSS OF $!masterRefe )
    elseif(!attr.upcase().match('ZDIS').neq(0)) then
      !firstZDis = !masterRefe.zDist
      RULE SET $!attr ($!rule ($!firstZDis + ($!dist MM * $!m)) )
    else
      -- RULE SET $!attr ($!rule ($!dist MM * $!m)  WRT $!wrt FROM $!masterRefe )
      RULE SET $!attr ($!rule ($!dist MM * $!m)  $!wrto )
    endif

    -- get rid of repeat rules for repeat copy
    DDSE 1
    handle any
    elsehandle none
      DELETE DDSE
      handle any
        !!alert.warning('Repeat rules for repeat copy not deleted - ' & !!error.text)
        handle ANY
          -- Just in case the concatenated text is too long
          !!alert.warning(!!error.text)
        endhandle
      endhandle
    endhandle
    !!ce = !firstCopy

    -- do subsequent repeats by copying the first copy
    do !j from 2 to !noff

      -- Make sure this element is created in the correct hierarchy because
      -- of possibility of >fixing>fixing
      !sequence = !!ce.sequence
      END
      NEW $!<type> AFTER $!sequence COPY  $!<firstCopy>
      !newRepeatRef = !!ce
      ORRF $!<orrf>
      -- set repeat number
      !numb = !j + 1
      NUMB ($!<numb>)
      -- set rules
      if(upc(|$!attr|) eq |POSS|) then
        RULE SET POSE ($!rule ($!dist MM * $!j) WRT $!wrt FROM ATTRIB POSE OF $!masterRefe )
        RULE SET POSS ($!rule ($!dist MM * $!j) WRT $!wrt FROM ATTRIB POSS OF $!masterRefe )
      elseif(!attr.upcase().match('ZDIS').neq(0)) then
       !firstZDis = !masterRefe.zDist
       RULE SET $!attr ($!rule ($!firstZDis + ($!dist MM * $!j)) )
      else
        --RULE SET $!attr ($!rule ($!dist MM * $!j) WRT $!wrt FROM $!masterRefe )
        RULE SET $!attr ($!rule ($!dist MM * $!j) $!wrto  )
      endif

      !!ce = !newRepeatRef
    enddo
  enddo

  -- return to CE at start component
  if (!ref.badref().not()) then
    !!ce = !ref
  endif

endmethod
-- End of method definition for .genRepeat(DBREF)

-----------------------------------------------------------------------
--
-- Method:      .createTmpl(DBREF)
--
-- Description: Create Design Template
-- The command COPY REXE will set all ORRF references for the members of the
-- template and lock all members of the template.  This locking model is not
-- correct for most situations, the appware forces a locking model, where the
-- template element is locked but all its members are left unlocked.
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF] [Element that owns the new Template]
--   [2] [R] [DBREF] [Reference to template definition to be copied]
--
------------------------------------------------------------------------
define method .createTmpl(!tmplOwner is DBREF, !catalogueElement is DBREF) is DBREF

  !saveRef = !!ce
  !!ce = !tmplOwner

  -- T switch needed to temporarily allow two TMPL to exist
  -- long term solution is a Dabacon save and restore state function
  -- allowing new TMPL to replace the old one, but wind back if that fails
  $T41+
  NEW TMPL COPY REXE $!<catalogueElement>
  handle any
    $T41-
    !this.errorLogAppend('CRITICAL',!!error.text,'Copy Design Template Instance',!!error.command,!!error.line)
    return object DBREF()
  endhandle
 $T41-
  !newTmpl = !!ce
  UNLOCK ALL
  -- Lock the template
  LOCK
  !!ce = !saveRef

  return !newTmpl

endmethod
-- End of method definition

-----------------------------------------------------------------------
--
-- Method:      .errorLogAppend
--
-- Description: Add new message to the error log
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [ERROR]  [Error severity]
--   [2] [R] [ERROR]  [Error object]
--   [3] [R] [STRING] [Operation causing the error]
--
------------------------------------------------------------------------
define method .errorLogAppend(!severity is STRING, !error is STRING, !operation is STRING, !command is STRING, !line is STRING)

  !this.error.addError(!severity)
  !this.error.setErrorText(!error)
  !this.error.setErrorContext(!operation)
  !this.error.setErrorCommand(!command)
  !this.error.setErrorLine(!line)

endmethod
-- End of method definition

-----------------------------------------------------------------------
--
-- Method:      .getErrorLog
--
-- Description: Add new message to the error log
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [ERROR]  [Error object]
--   [2] [R] [STRING] [Operation causing the error]
--
------------------------------------------------------------------------
define method .getErrorLog() is COMPROPERROR

  return !this.error

endmethod
-- End of method definition

-----------------------------------------------------------------------
--
-- Method:      .okDelHier
--
-- Description: Can hierarchy be deleted
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [DBREF]  [Reference to top of tree to be tested]
--
------------------------------------------------------------------------
define method .okDelHier(!element is DBREF) is BOOLEAN

  VAR !del EVAL ( DACDEL ) for ALL for $!<element> IGNORE ANY |true|
  !index = !del.findFirst('false')
  return !index.unset()

endmethod
-- End of method definition

------------------------------------------------------------------------
--
-- Method:      .setDesignElementsArray(ARRAY)
--
-- Description: Set an Array of similar design elements to get the same properties
--
-- Method Type: Procedure
--
-- Arguments:
--   [1] [R] [ARRAY] [ARRAY of DBREFS]
--
------------------------------------------------------------------------
define method .setDesignElementsArray(!elementsArray is ARRAY)

  !this.designElementsArray = !elementsArray

endmethod
-- End of method definition for .setDesignElementsArray(ARRAY)

------------------------------------------------------------------------
--
-- Method:      .updateStructuralWelds()
--
-- Description: Create or Update STWELD elements for the Design Element. Calls C# classes to perform
--              the operations.
--
------------------------------------------------------------------------
define method .updateStructuralWelds()

  using namespace 'Aveva.E3D.Interaction.Structural.Entities.Weld'

  if (!this.designElement.badref()) then
    return
  endif

  -- C# class to handle weld creation
  !pmlNetWeldHelper = object PMLNETSTRUCTURALWELDHELPER()

  -- Create STWELDs from catalogue JWELD definition if available.
  !pmlNetWeldHelper.createWelds(!this.designElement.string(), !this.designElement.spref.string(), true)

  -- Update design parameters of welds under templates if they exist
  !pmlNetWeldHelper.updateWeldsUnderTemplate(!this.designElement.string())

endmethod

------------------------------------------------------------------------
--
-- Method:      .unsetRuleEngineReferences()
--
-- Description: Once a template is created, unset the ruleset references from copied elements to avoid 
--              lingering references to the catalogue
--
------------------------------------------------------------------------
define method .unsetRuleEngineReferences(!template is DBREF)

  !template.rlsref = nulref
  
  -- Search from the template's owner in case there are datasets copied outside the template.
  !owner = !template.owner
  do !ddat values !!collectAllFor('DDAT', '', !owner)
    !ddat.rulref = nulref
  enddo

endmethod
