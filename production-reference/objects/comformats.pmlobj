--    1   R      UNIT      unit object
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .pressureFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'PRESSURE'
  !format.label         = 'UNITS'
  !unitQualifier        = !unit.unitQualifier().upcase()
  if( !unitQualifier inset('BAR','ATM','MEGAPASCAL') ) then
    !format.dp          = 2
  elseif( !unitQualifier inset('PSI','INHG','TORR','KILOPASCAL') ) then
    !format.dp          = 1
  else
    !format.dp          = 0
  endif
  return !format

endmethod
