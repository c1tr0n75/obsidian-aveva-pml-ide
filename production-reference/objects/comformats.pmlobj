-- Method:      unitMassFormat
--
-- Description: Mass per unit length format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .unitMassFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'UMAS'
  !format.label         = 'UNITS'
  !format.units         = 'DRVD'

  -- try to adapt number of DP for given units
  !format.dp            = !this.decimalPlacesCalculator(1kg/metre)

  return !format

