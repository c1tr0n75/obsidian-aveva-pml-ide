--
--
-- Description:
-- Defines basic common formats for the system.
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  angleFormat()                    FORMAT              Angle format definition
--  angleFormat(STRING)              FORMAT              Angle format definition
--  angleFormat(UNIT)                FORMAT              Angle format definition
--  areaFormat()                     FORMAT              Area format definition
--  areaFormat(UNIT)                 FORMAT              Area format definition for specific units
--  boreFormat()                     FORMAT              Bore format definition
--  boreFormat(STRING)               FORMAT              Bore format definition
--  comFormats()                     -                   Constructor
--  compileCurrentUnits(BOOLEAN)     ARRAY
--  currentFormat()                  FORMAT              Current format definition
--  currentFormat(STRING)            FORMAT              Current format definition
--  decimalPlacesCalculator(REAL)    REAL                Recommends a number of DP for the given value in
--  defaults()                       -                   Default settings
--  densityFormat()                  FORMAT              Density format definition
--  distanceFormat()                 FORMAT              Distance format definition
--  distanceFormat(STRING)           FORMAT              Distance format definition
--  distanceFormatForm()             FORMAT              Distance format definition
--  emfFormat()                      FORMAT              EMF format definition
--  emfFormat(STRING)                FORMAT              EMF format definition
--  energyFormat()                   FORMAT              Energy format definition
--  energyFormat(STRING)             FORMAT              Energy format definition
--  energyFormat(UNIT)               FORMAT              Energy format definition for given unit
--  forceFormat()                    FORMAT              Force format definition
--  forceFormat(STRING)              FORMAT              Force format definition
--  forceFormat(UNIT)                FORMAT              Force format definition for given unit
--  getAllDescriptions()             ARRAY               Get Array of descriptions
--  getAllTypes()                    ARRAY               Get Array of types
--  getCurrentUnit(STRING)           STRING              get the current Distance/Bore units
--  getCurrentUnits()                -
--  getCurrentUnitsByPtype(STRING)   STRING
--  getDescriptionFromPtype(STRING)  STRING
--  getDimensionCurrentUnits(STRING) STRING
--  getFormatDefinition(REAL)        FORMAT              Get format of user defined distance format
--  getGlobalUnitsFormat(BORE)       FORMAT              return bore format object for a BORE type
--  getGlobalUnitsFormat(REAL)       FORMAT              Get format object for the given REAL
--  getGlobalUnitsFormat(STRING)     FORMAT              Get format object for the given dimension code
--  getGlobalUnitsFormatName(STRING) STRING              Get name of global format object for the given dimension code
--  getNonNumericPTypeList()         ARRAY               Get list of non-numeric PTYP's for datasets along with description
--  getNumericPTypeList()            ARRAY               Get list of Numeric PTYP's for datasets along with description
--  getPTypeByDimension(STRING)      STRING
--  getReferencePTypeList()          ARRAY               Get list of reference PTYP's for datasets along with description
--  getUserDefinedFormat(STRING)     FORMAT              Get user defined format for a given token
--  getUserDefinedFormatDescriptions(STRING,ARRAY) ARRAY               Get user defined format tokens
--  getUserDefinedFormatTokens(STRING) ARRAY               Get user defined format tokens
--  globalInstance()                 -                   create a global instance of the main object
--  globalInstance(REAL)             -                   Set global instance of specific format variables
--  impedanceFormat()                FORMAT              Impedance format definition
--  impedanceFormat(STRING)          FORMAT              Impedance format definition
--  integerFormat()                  FORMAT              Integer format definition
--  massFormat()                     FORMAT              Mass format definition
--  massFormat(STRING)               FORMAT              Mass format definition
--  massFormat(UNIT)                 FORMAT              Mass format definition
--  powerFormat()                    FORMAT              Power format definition
--  powerFormat(STRING)              FORMAT              Power format definition
--  powerFormat(UNIT)                FORMAT              Power format definition for given unit
--  pressureFormat()                 FORMAT              Pressure format definition
--  pressureFormat(STRING)           FORMAT              Pressure format definition
--  pressureFormat(UNIT)             FORMAT              Pressure format definition for given unit
--  reIndex()                        -                   Re-index pointer arrays to the main holding array.
--  realFormat()                     FORMAT              Real format definition
--  registerFormat(STRING,FORMAT)    -                   Register given format with given measure dimension
--  registerFormats()                -                   Registers formats with core for current units
--  restoreSavedUnits(STRING,BOOLEAN) -                   Restores the saved File, Saved based on GUI selections.
--  saveCurrentUnits()               -                   Save the units to file
--  saveProjectDefaultUnits()        -                   Save the units to project defaults file
--  setGlobalAngleFormat()           BOOLEAN             Set global angle format definition to default unit
--  setGlobalAngleFormat(FORMAT)     BOOLEAN
--  setGlobalAreaFormat(FORMAT)      BOOLEAN
--  setGlobalBoreFormat()            BOOLEAN             Set global bore format definition to default unit
--  setGlobalBoreFormat(FORMAT)      BOOLEAN
--  setGlobalBoreFormat(STRING)      BOOLEAN
--  setGlobalCurrentFormat()         BOOLEAN             Set global current format definition to default unit
--  setGlobalCurrentFormat(FORMAT)   BOOLEAN
--  setGlobalDensityFormat(FORMAT)   BOOLEAN
--  setGlobalDistanceFormat()        BOOLEAN             Set global distance format definition to default unit
--  setGlobalDistanceFormat(FORMAT)  BOOLEAN
--  setGlobalDistanceFormat(STRING)  BOOLEAN
--  setGlobalEmfFormat()             BOOLEAN             Set global EMF format definition to default unit
--  setGlobalEmfFormat(FORMAT)       BOOLEAN
--  setGlobalEnergyFormat()          BOOLEAN             Set global energy format definition to default unit
--  setGlobalEnergyFormat(FORMAT)    BOOLEAN
--  setGlobalForceFormat()           BOOLEAN             Set global force format definition to default unit
--  setGlobalForceFormat(FORMAT)     BOOLEAN
--  setGlobalImpedanceFormat()       BOOLEAN             Set global impedance format definition to default unit
--  setGlobalImpedanceFormat(FORMAT) BOOLEAN
--  setGlobalIntegerFormat(FORMAT)   BOOLEAN
--  setGlobalMassFormat()            BOOLEAN             Set global mass format definition to default unit
--  setGlobalMassFormat(FORMAT)      BOOLEAN
--  setGlobalPowerFormat()           BOOLEAN             Set global power format definition to default unit
--  setGlobalPowerFormat(FORMAT)     BOOLEAN
--  setGlobalPressureFormat()        BOOLEAN             Set global pressure format definition to default unit
--  setGlobalPressureFormat(FORMAT)  BOOLEAN
--  setGlobalRealFormat(FORMAT)      BOOLEAN
--  setGlobalTemperatureFormat()     BOOLEAN             Set global temperature format definition to default unit
--  setGlobalTemperatureFormat(FORMAT) BOOLEAN
--  setGlobalTemperatureGradientFormat(FORMAT) BOOLEAN
--  setGlobalTimeFormat()            BOOLEAN             Set global time format definition to default unit
--  setGlobalTimeFormat(FORMAT)      BOOLEAN
--  setGlobalUnitMassFormat(FORMAT)  BOOLEAN
--  setGlobalVolumeFormat(FORMAT)    BOOLEAN
--  setStandardFormats()             -                   Initialise standard set of Dimensions with corresponding formats
--  temperatureFormat()              FORMAT              Temperature format definition
--  temperatureFormat(STRING)        FORMAT              Temperature format definition
--  temperatureFormat(UNIT)          FORMAT              Temperature format definition for given unit
--  temperatureGradientFormat()      FORMAT              Temperature gradient format definition
--  testFormat(REAL,FORMAT)          BOOLEAN
--  timeFormat()                     FORMAT              Time format definition
--  timeFormat(STRING)               FORMAT              Time format definition
--  timeFormat(UNIT)                 FORMAT              Time format definition for given unit
--  unitMassFormat()                 FORMAT              Mass per unit length format definition
--  unitMassFormat(STRING)           FORMAT              Unit mass format definition
--  unitMassFormat(UNIT)             FORMAT              Mass per unit length format definition
--  userDefaults()                   -                   run user defaults stored in AVEVA_DESIGN_DFLTS
--  volumeFormat()                   FORMAT              Volume format definition
--  volumeFormat(UNIT)               FORMAT              Volume format definition
--
------------------------------------------------------------------------

define object COMFORMATS

  -- List of user defined formats
  member .userDefinitions  is ARRAY
  member .userTypes        is ARRAY
  member .userTokens       is ARRAY
  member .userDescriptions is ARRAY

  -- current values of the global definitions
  member .currentDistance  is REAL
  member .currentBore      is REAL

  -- members for new dimensions & units (12.1)
  -- The following arrays form a table
  -- Array of supported dimension names
  member .dimension              is ARRAY
  -- corresponding array of dimension global variable names
  member .currentFormat          is ARRAY
  -- corresponding array of dimension PTYPE codes (can be used for DTEXT)
  member .dimensionPTypes        is ARRAY
  -- corresponding array of dimension Descriptions (alternate description for DTEXT)
  member .dimensionDescriptions  is ARRAY
  -- default dimension formats for core format manager
  member .defaultDimensionFormats is ARRAY

  -- COMUNITS object provided current unit information
  member .commonUnitsObject      is COMUNITS
  member .allowUserSaveFile      is BOOLEAN

endobject
-- End of object definition for COMFORMATS

------------------------------------------------------------------------
--
-- Method:      comFormats()
--
-- Description: Constructor
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .comFormats()

  !this.defaults()

  -- Special members to control form active gadgets
  !this.allowUserSaveFile = true

endmethod
-- End of method definition for .comFormats()

------------------------------------------------------------------------
--
-- Method:      defaults()
--
-- Description: Default settings
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .defaults()

  -- Initialise Variables
  !this.userDefinitions.clear()
  !this.userDescriptions.clear()
  !this.userTypes.clear()

  -- initialise a set of standard formats for supported dimensions
  !this.setStandardFormats()

  -- Set up form format independent of distance units
  !!distanceFmtForm = !this.distanceFormatForm()

  -- load user defined distance formats
  !this.userDefaults()

endmethod
-- End of method definition for .defaults()

------------------------------------------------------------------------
--
-- Method:     userDefaults()
--
-- Description: run user defaults stored in AVEVA_DESIGN_DFLTS
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .userDefaults()

  !!runMacro('%AVEVA_DESIGN_DFLTS%/com-format-dflts.pmldat' , '')
  handle any
    -- in case the file does not exist
  elsehandle none
    !this.userDefinitions.appendArray(!!tmpFormat)
    !this.userDescriptions.appendArray(!!tmpDesc)
    !this.userTypes.appendArray(!!tmpType)

    -- delete temporary global arrays
    !!tmpFormat.delete()
    !!tmpDesc.delete()
    !!tmpType.delete()

    -- populate object members with what are DISTANCES/BORE
    !this.reIndex()

  endhandle

endmethod
-- End of method definition for .userDefaults()

------------------------------------------------------------------------
--
-- Method:      reIndex()
--
-- Description: Re-index pointer arrays to the main holding array.
--
-- Method Type: Procedure
--
------------------------------------------------------------------------

define method .reIndex()

  do !i indices !this.userTypes
    !pType               = !this.userTypes[!i].subString(1,4).upcase()
    !this.userTypes[!i]  = !pType
    !this.userTokens[!i] = 'USER:' + !i.string() + ':' + !pType
  enddo

endmethod
-- End of method definition for .reIndex()

------------------------------------------------------------------------
--
-- Method:      globalInstance()
--
-- Description: create a global instance of the main object
--
-- Method Type: Procedure
--
------------------------------------------------------------------------

define method .globalInstance()

  -- create the global instance of this object
  !!comFormats = !this

  -- Load saved Defaults
  !!comFormats.restoreSavedUnits(|AVEVA_DESIGN_DFLTS|, false)
  if (!!comFormats.allowUserSaveFile) then
    !!comFormats.restoreSavedUnits(|AVEVA_DESIGN_USER|, false)
  endif

endmethod
-- End of method definition for .globalInstance()

------------------------------------------------------------------------
--
-- Method:      globalInstance(REAL)
--
-- Description: Set global instance of specific format variables
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--   [1] [R]    [REAL]      [Index of format in holding Array]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .globalInstance(!index is REAL)

  -- Define Global Instance
  !string = '!!' & !this.userTypes[!index].lowcase() & 'Fmt = !this.userDefinitions[!index]'
  $!string

  -- set the units

  if(!this.userTypes[!index].upcase() inset('DISTANCE','BORE')) then
    !action = 'UNITS ' & !this.userDefinitions[!index].units  & ' ' & !this.userTypes[!index]
    $!action
    handle any
    endhandle
  endif

endmethod
-- End of method definition for .globalInstance(REAL)

------------------------------------------------------------------------
--
-- Method:      getFormatDefinition(REAL)
--
-- Description: Get format of user defined distance format
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--   [1] [R]    [REAL]      [Index of format in holding Array]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .getFormatDefinition(!index is REAL) is FORMAT

  -- Return distance definition
  return !this.userDefinitions[!index]

endmethod
-- End of method definition for .getFormatDefinition(REAL)

------------------------------------------------------------------------
--
-- Method:      saveCurrentUnits()
--
-- Description: Save the units to file
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .saveCurrentUnits()

  -- save the units to file
  !saveCommands =  !this.compileCurrentUnits(TRUE)
  !project      = CURRENT PROJECT
  -- Capture current units
  var !units SPLIT UNITS
  if (!units[3] eq 'MM') then
    !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-current-units-Met.pmldat')
  else
    !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-current-units-Imp.pmldat')
  endif

  -- write commands to file
  !file.writefile('OVERWRITE',!saveCommands)
  !file.close()

endmethod
-- End of method definition for .saveCurrentUnits()

------------------------------------------------------------------------
--
-- Method:      saveProjectDefaultUnits()
--
-- Description: Save the units to project defaults file
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .saveProjectDefaultUnits()

  -- save the units to file
  !saveCommands =  !this.compileCurrentUnits(TRUE)
  !project      = CURRENT PROJECT
  !projectDefaults = !project.code() & 'DFLTS'

  -- Capture current units
  var !units SPLIT UNITS
  if (!units[3] eq 'MM') then
    !style = 'Met'
  else
    !style = 'Imp'
  endif
  !file = object FILE('%' & !projectDefaults & '%/project-current-units-' & !style & '.pmldat')

  -- write commands to file
  !file.writefile('OVERWRITE',!saveCommands)
  !file.close()

endmethod
-- End of method definition for .saveCurrentUnits()


------------------------------------------------------------------------
--
-- Method:      CompileCurrentUnits()
--
-- Description: Compile the current units for saving to user file or options
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- 1 Boolean switch to determine if save data is for iso options or for file
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .compileCurrentUnits(!mode is BOOLEAN )is ARRAY

  !saveCommands = ARRAY()
  -- build up commands
  !m = object MEASURE()
  !unitType = ARRAY()
  !unit     = ARRAY()
  do !i indices !m.allDimensions()
    !unitType.append(!m.allDimensions()[!i])
    !unit.append(!m.allDimensions()[!i].currentUnits().name())
  enddo
  !saveCommands.append(|-- AVEVA - Units serialisation file               |)
  !saveCommands.append(|-- --------------------------------               |)
  !saveCommands.append(|                                                  |)
  !saveCommands.append(|-- Initialise variables                           |)
  !saveCommands.append(|!u = object COMUNITS()                            |)
  !saveCommands.append(|!!comFormats.allowUserSaveFile = true             |)
  !saveCommands.append(|                                                  |)
  !saveCommands.append(|-- Set saved units                                |)
  -- Length and Feet & Inches special case
  var !units SPLIT UNITS
  if (!units[3] eq 'FINC') then
    !saveCommands.append(|!u.setUnits('', 'Length', 'FINC')                 |)
    !needLength = false
  else
    !needLength = true
  endif
  do !i indices !unitType
    if (!needLength and ('$!unitType[$!i]' eq 'Length')) then
      !saveCommands.append(|!u.setUnits('', '$!unitType[$!i]', '$!unit[$!i]') |)
    elseif ('$!unitType[$!i]' inset ('Bore','Mass','Pressure','Temperature','Force','Energy','Power','Angle','Time','Current','EMF','Impedance')) then
      !saveCommands.append(|!u.setUnits('', '$!unitType[$!i]', '$!unit[$!i]') |)
    elseif !mode then
      if ('$!unitType[$!i]' neq ('Length')) then
        -- YOE !saveCommands.append(|-- !u.setUnits('', '$!unitType[$!i]', '$!unit[$!i]') |)
		!saveCommands.append(|!u.setUnits('', '$!unitType[$!i]', '$!unit[$!i]') |)
      endif
    endif
  enddo
  !saveCommands.append(|                                                  |)
  !saveCommands.append(|-- Angle always Degrees case                      |)
  !saveCommands.append(|!u.setUnits('', 'Angle', 'degree')                |)
  !saveCommands.append(|                                                  |)
  !saveCommands.append(|-- Set the formats for the above set units        |)
  !saveCommands.append(|!!comFormats.setStandardFormats()                 |)

  return !saveCommands

endmethod
-- End of method definition for .saveCurrentUnits()
------------------------------------------------------------------------
--
-- Method:      restoreSavedUnits
--
-- Description: Restores the saved File, Saved based on GUI selections.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING      Key word AVEVA_DESIGN_USER or AVEVA_DESIGN_DFLTS
--    2    R     BOOLEAN     Output a warning message
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .restoreSavedUnits(!location is STRING, !warn is BOOLEAN)

  -- save the units to file
  !project      = CURRENT PROJECT
  !projectDefaults = !project.code() & 'DFLTS'

  -- Capture current units
  !style = 'Met'
  if (!!isImperialLength('DIST')) then
    !style = 'Imp'
  endif

  if (!location eq 'AVEVA_DESIGN_USER') then
    !fileString = '%' & !location & '%/' & !project.code() & '-save-current-units-' & !style & '.pmldat'
  elseif (!location eq 'AVEVA_DESIGN_DFLTS') then
    !fileString = '%' & !projectDefaults & '%/project-current-units-' & !style & '.pmldat'
    !file = object FILE(!fileString)
    if (!file.exists().not()) then
      !fileString = '%' & !location & '%/system-current-units-' & !style & '.pmldat'
    endif
  endif

  -- Make a file object
  !file = object FILE(!fileString)

  if (!file.exists()) then
    !!runMacro(!fileString, '')
    handle ANY
      if (!location eq 'AVEVA_DESIGN_USER') then
        !!alert.error('There is a problem with User Saved Units file ' & !fileString)
      else
        !!alert.error('There is a problem with System Default Units file ' & !fileString)
      endif
    endhandle
  else
    if (!warn) then
      if (!location eq 'AVEVA_DESIGN_USER') then
        !!alert.error('User Saved Units file not found ' & !fileString)
      else
        !!alert.error('System Default Units file not found ' & !fileString)
      endif
    endif
  endif

endmethod

------------------------------------------------------------------------
--
-- Method:      getCurrentUnits
--
-- Description: Restores the saved current units File
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getCurrentUnits()

  -- get the units from file

  !project      = CURRENT PROJECT
  !!runMacro('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-current-units.pmldat' , '')
  handle any
    -- in case the file does not exist
  endhandle

endmethod
-- End of method definition for .getCurrentUnits()

------------------------------------------------------------------------
--
-- Method:      registerFormats
--
-- Description: Registers formats with core for current units
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .registerFormats()

  !format               = object FORMAT()
  !format.label         = 'UNITS'
  !format.trailZeros    = true

  -- PMLFORMATMANAGER is an interface to a global C# object so
  -- we can work with a local instance of the interface
  import 'Aveva.Core.Presentation'
  handle any
  endhandle
  using namespace 'Aveva.Core.Presentation'
  !formatManager = object PMLFORMATMANAGER()

  -- register basic formats for dimensions implemented in DESIGN
  !format.dimension     = 'DIST'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('DIST'), !format)
  !format.dimension     = 'BORE'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('BORE'), !format)
  !format.dimension     = 'MASS'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('MASS'), !format)
  !format.dimension     = 'PRESSURE'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('PRES'), !format)
  !format.dimension     = 'TEMPERATURE'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('TEMP'), !format)
  !format.dimension     = 'FORCE'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('FORC'), !format)
  !format.dimension     = 'ENERGY'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('ENER'), !format)
  !format.dimension     = 'POWER'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('POWE'), !format)
  !format.dimension     = 'DENSITY'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('DENS'), !format)
  !format.dimension     = 'MAND'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('MAND'), !format)
  !format.dimension     = 'CURRENT'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('CURR'), !format)
  !format.dimension     = 'EMF'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('EMF'), !format)
  !format.dimension     = 'IMPEDANCE'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('IMPE'), !format)
  !format.dimension     = 'TIME'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('TIME'), !format)

  ------------------------------------------------------------------
  -- derived formats
  !format.units         = 'DRVD'

  !format.dimension     = 'UMAS'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('UMAS'), !format)

  -- incase volume and area are set to have different units to distance
  !squareUnits = !this.getCurrentUnit('SQDI')
  if (!squareUnits neq (!this.getCurrentUnit('DIST') + '2')) then
       !format.units = !squareUnits
   endif

  !format.dimension     = 'SQDI'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('SQDI'), !format)

  !cubeUnits = !this.getCurrentUnit('CUDI')
  if (!cubeUnits neq (!this.getCurrentUnit('DIST') + '3')) then
       !format.units = !cubeUnits
  else
       !format.units         = 'DRVD'
  endif
  !format.dimension     = 'CUDI'
  !format.dp            = 2
  !formatManager.addDimensionFormat(object MEASURE('CUDI'), !format)

  !format.units         = 'DRVD'
  !format.dimension     = 'TPDI'
  !format.dp            = 0
  !formatManager.addDimensionFormat(object MEASURE('TPDI'), !format)

  ------------------------------------------------------------------
  -- special case formats
  !format.dimension     = 'ANGL'
  !format.units         = 'degree'
  !format.dp            = 2
  !format.trailZeros    = false
  !format.label         = ''
  !formatManager.addDimensionFormat(object MEASURE('ANGL'), !format)

  -- register formats for specific units
  -- distance
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('mm'), !this.distanceFormat('MM'))
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('cm'), !this.distanceFormat('CM'))
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('metre'), !this.distanceFormat('METRE'))
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('inch'), !this.distanceFormat('INCH'))
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('finch'), !this.distanceFormat('FINC'))
  !formatManager.addUnitFormat(object MEASURE('DIST'), object UNIT('ft'), !this.distanceFormat('FT'))
  -- bore
  !formatManager.addUnitFormat(object MEASURE('BORE'), object UNIT('mm'), !this.boreFormat('MM'))
  !formatManager.addUnitFormat(object MEASURE('BORE'), object UNIT('inch'), !this.boreFormat('IN'))
  !formatManager.addUnitFormat(object MEASURE('BORE'), object UNIT('finc'), !this.boreFormat('FINC'))
  -- area
  !formatManager.addUnitFormat(object MEASURE('SQDI'), object UNIT('mm2'), !this.areaFormat(object UNIT('mm2')))
  !formatManager.addUnitFormat(object MEASURE('SQDI'), object UNIT('cm2'), !this.areaFormat(object UNIT('cm2')))
  !formatManager.addUnitFormat(object MEASURE('SQDI'), object UNIT('m2'), !this.areaFormat(object UNIT('m2')))
  !formatManager.addUnitFormat(object MEASURE('SQDI'), object UNIT('in2'), !this.areaFormat(object UNIT('in2')))
  !formatManager.addUnitFormat(object MEASURE('SQDI'), object UNIT(squareUnits), !this.areaFormat(object UNIT(!squareUnits)))
  -- volume
  !formatManager.addUnitFormat(object MEASURE('CUDI'), object UNIT('mm3'), !this.volumeFormat(object UNIT('mm3')))
  !formatManager.addUnitFormat(object MEASURE('CUDI'), object UNIT('cm3'), !this.volumeFormat(object UNIT('cm3')))
  !formatManager.addUnitFormat(object MEASURE('CUDI'), object UNIT('m3'), !this.volumeFormat(object UNIT('m3')))
  !formatManager.addUnitFormat(object MEASURE('CUDI'), object UNIT('in3'), !this.volumeFormat(object UNIT('in3')))
  !formatManager.addUnitFormat(object MEASURE('CUDI'), object UNIT(!cubeUnits), !this.volumeFormat(object UNIT(!cubeUnits)))
  -- mass
  !formatManager.addUnitFormat(object MEASURE('MASS'), object UNIT('gram'), !this.massFormat(object UNIT('gram')))
  !formatManager.addUnitFormat(object MEASURE('MASS'), object UNIT('oz'), !this.massFormat(object UNIT('oz')))
  !formatManager.addUnitFormat(object MEASURE('MASS'), object UNIT('ton'), !this.massFormat(object UNIT('ton')))
  !formatManager.addUnitFormat(object MEASURE('MASS'), object UNIT('shorton'), !this.massFormat(object UNIT('shortTon')))
  !formatManager.addUnitFormat(object MEASURE('MASS'), object UNIT('tonne'), !this.massFormat(object UNIT('tonne')))
  -- pressure
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('bar'), !this.pressureFormat(object UNIT('bar')))
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('atm'), !this.pressureFormat(object UNIT('atm')))
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('psi'), !this.pressureFormat(object UNIT('psi')))
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('inhg'), !this.pressureFormat(object UNIT('inhg')))
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('torr'), !this.pressureFormat(object UNIT('torr')))
  !formatManager.addUnitFormat(object MEASURE('PRES'), object UNIT('kpa'), !this.pressureFormat(object UNIT('kpa')))
  -- power
  !formatManager.addUnitFormat(object MEASURE('POWE'), object UNIT('watt'), !this.powerFormat(object UNIT('watt')))
  -- force
  !formatManager.addUnitFormat(object MEASURE('FORC'), object UNIT('kgf'), !this.forceFormat(object UNIT('kgf')))
  !formatManager.addUnitFormat(object MEASURE('FORC'), object UNIT('lbf'), !this.forceFormat(object UNIT('lbf')))
  !formatManager.addUnitFormat(object MEASURE('FORC'), object UNIT('dyne'), !this.forceFormat(object UNIT('dyne')))
  -- energy
  !formatManager.addUnitFormat(object MEASURE('ENER'), object UNIT('kwh'), !this.energyFormat(object UNIT('kwh')))
  -- angle - register all formats for all units because current unit is always degree
  !formatManager.addUnitFormat(object MEASURE('ANGL'), object UNIT('radian'), !this.angleFormat(object UNIT('radian')))
  !formatManager.addUnitFormat(object MEASURE('ANGL'), object UNIT('gradian'), !this.angleFormat(object UNIT('gradian')))

endmethod
-- End of method
-- *********************************************************************
-- ***** Methods to extract the information for an external form    ****
-- *********************************************************************
------------------------------------------------------------------------

------------------------------------------------------------------------
--
-- Method:      getCurrentUnit(STRING)
--
-- Description: get the current Distance/Bore Unit
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--   [1] [R]    [STRING]    [Format type distance or Bore]
-- Return:
--   [Data Type] [Description]
--   [STRING]    [return the units of the current distance/bore]
--
------------------------------------------------------------------------

define method .getCurrentUnit(!type is STRING) is STRING

  return !this.getCurrentUnitsByPtype(!type)

endmethod
-- End of method definition for .getCurrentUnit(STRING)

------------------------------------------------------------------------
--
-- Method:      getAllDescriptions()
--
-- Description: Get Array of descriptions
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--   [ARRAY]    [return the descriptions of the format definitions]
--
------------------------------------------------------------------------

define method .getAllDescriptions()  is ARRAY

  return !this.userDescriptions

endmethod
-- End of method definition for .getAllDescriptions() ARRAY

------------------------------------------------------------------------
--
-- Method:      getAllTypes()
--
-- Description: Get Array of types
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--   [ARRAY]    [return the types of the format definitions]
--
------------------------------------------------------------------------

define method .getAllTypes()  is ARRAY

  return !this.userTypes

endmethod
-- End of method definition for .getAllTypes() ARRAY

------------------------------------------------------------------------
--
-- Method:      getGlobalUnitsFormatName()
--
-- Description: Get name of global format object for the given dimension code
--              An empty string is returned if code not recognised
--              The dimension code is the same code that is returned
--              by using .dimension() on a REAL dimensioned variable.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Dimension code
-- Return:
--   [Data Type] [Description]
--    STRING      Global FORMAT object name for given code
--
------------------------------------------------------------------------

define method .getGlobalUnitsFormatName(!dimension is STRING) is STRING

  !formatIndex = !this.dimension.findFirst(!dimension.upcase().trim())

  if(!formatIndex.unset()) then
    -- look up dimension PTYPE codes
    !formatIndex = !this.dimensionPTypes.findFirst(!dimension.upcase().trim())
  endif

  if( !formatIndex.unset()) then
    return ''
  else
    return '!!' + !this.currentFormat[!formatIndex]
  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getGlobalUnitsFormat()
--
-- Description: Get format object for the given dimension code
--              Unset FORMAT object returned if code not recognised
--              The dimension code is the same code that is returned
--              by using .dimension() on a REAL dimensioned variable.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Dimension code
-- Return:
--   [Data Type] [Description]
--    FORMAT      FORMAT object for given code
--
------------------------------------------------------------------------

define method .getGlobalUnitsFormat(!dimension is STRING) is FORMAT

  !globalFormatName = !this.getGlobalUnitsFormatName(!dimension)

  if( !globalFormatName.empty() ) then
    -- Dimension code not recognised
    !format = object FORMAT()
  else
    -- get format object definition from global format object name
    !block  = object BLOCK( !globalFormatName )
    !format = !block.evaluate()
    handle any
      !format = object FORMAT()
    endhandle
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getGlobalUnitsFormat()
--
-- Description: Get format object for the given REAL
--              Unset FORMAT object returned if code not recognised
--              The dimension code is the same code that is returned
--              by using .dimension() on a REAL dimensioned variable.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Real value from which dimension code is found
-- Return:
--   [Data Type] [Description]
--    FORMAT      FORMAT object for given code
--
------------------------------------------------------------------------

define method .getGlobalUnitsFormat(!real is REAL) is FORMAT

  return !this.getGlobalUnitsFormat(!real.dimension().name())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getGlobalUnitsFormat()
--
-- Description: return bore format object for a BORE type
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BORE        Bore object
-- Return:
--   [Data Type] [Description]
--    FORMAT      Bore FORMAT
--
------------------------------------------------------------------------

define method .getGlobalUnitsFormat(!dummyBore is BORE) is FORMAT

  return !!boreFmt

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setStandardFormats()
--
-- Description: Initialise standard set of Dimensions with corresponding formats
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .setStandardFormats()

  -- initialise abbreviations (PTYP) table of references to standard dimensions
  -- Distance
  !this.dimensionPTypes[1]  = 'DIST'
  !this.dimensionPTypes[2]  = 'BORE'
  !this.dimensionPTypes[3]  = 'REAL'
  !this.dimensionPTypes[4]  = 'INT'
  !this.dimensionPTypes[5]  = 'ANGL'
  !this.dimensionPTypes[6]  = 'SQDI'
  !this.dimensionPTypes[7]  = 'CUDI'
  !this.dimensionPTypes[8]  = 'MASS'
  !this.dimensionPTypes[9]  = 'UMAS'
  !this.dimensionPTypes[10] = 'PRES'
  !this.dimensionPTypes[11] = 'TEMP'
  !this.dimensionPTypes[12] = 'TPDI'
  !this.dimensionPTypes[13] = 'FORC'
  !this.dimensionPTypes[14] = 'ENER'
  !this.dimensionPTypes[15] = 'POWE'
  !this.dimensionPTypes[16] = 'DENS'
  !this.dimensionPTypes[17] = 'MAND'
  !this.dimensionPTypes[18] = 'CURR'
  !this.dimensionPTypes[19] = 'EMF'
  !this.dimensionPTypes[20] = 'IMPE'
  !this.dimensionPTypes[21] = 'TIME'
  -- duplicate needed for old LENGTH dimensions
  !this.dimensionPTypes[22] = 'DIST'
  !this.dimensionPTypes[23] = 'SQDI'
  !this.dimensionPTypes[24] = 'CUDI'

  -- set dimension description
  !this.dimensionDescriptions[1]  = 'Distance'
  !this.dimensionDescriptions[2]  = 'Bore'
  !this.dimensionDescriptions[3]  = 'Real'
  !this.dimensionDescriptions[4]  = 'Integer'
  !this.dimensionDescriptions[5]  = 'Angle'
  !this.dimensionDescriptions[6]  = 'Area'
  !this.dimensionDescriptions[7]  = 'Volume'
  !this.dimensionDescriptions[8]  = 'Mass'
  !this.dimensionDescriptions[9]  = 'Unit Mass'
  !this.dimensionDescriptions[10] = 'Pressure'
  !this.dimensionDescriptions[11] = 'Temperature'
  !this.dimensionDescriptions[12] = 'Temperature Gradient'
  !this.dimensionDescriptions[13] = 'Force'
  !this.dimensionDescriptions[14] = 'Energy'
  !this.dimensionDescriptions[15] = 'Power'
  !this.dimensionDescriptions[16] = 'Density'
  !this.dimensionDescriptions[17] = 'Manufacturing Density'
  !this.dimensionDescriptions[18] = 'Current'
  !this.dimensionDescriptions[19] = 'Voltage'
  !this.dimensionDescriptions[20] = 'Impedance'
  !this.dimensionDescriptions[21] = 'Time'
  -- duplicate needed for old LENGTH dimensions
  !this.dimensionDescriptions[22] = 'Distance'
  !this.dimensionDescriptions[23] = 'Area'
  !this.dimensionDescriptions[24] = 'Volume'

  -- Set global dimension objects and dimension string from !val.dimension()

  !this.setGlobalDistanceFormat()
  !this.currentFormat[1]    = 'distanceFmt'
  !this.dimension[1]        = 'L'
  -- BORE is not a core dimension
  !this.setGlobalBoreFormat()
  !this.currentFormat[2]    = 'boreFmt'
  !this.dimension[2]        = 'BORE'
  -- REAL and INT are PTYPE dimension NONE, but INT has 0 decimal places
  !this.setGlobalRealFormat( !this.realFormat() )
  !this.currentFormat[3]    = 'realFmt'
  !this.dimension[3]        = 'REAL'
  !this.setGlobalIntegerFormat( !this.integerFormat() )
  !this.currentFormat[4]    = 'integerFmt'
  !this.dimension[4]        = 'INT'
  -- ANGLE
  !this.setGlobalAngleFormat()
  !this.currentFormat[5]    = 'angleFmt'
  !this.dimension[5]        = !!angleFmt.dimension
  -- AREA
  !this.setGlobalAreaFormat( !this.areaFormat() )
  !this.currentFormat[6]    = 'areaFmt'
  !this.dimension[6]        = !!areaFmt.dimension
  -- VOLUME
  !this.setGlobalVolumeFormat( !this.volumeFormat() )
  !this.currentFormat[7]    = 'volumeFmt'
  !this.dimension[7]        = !!volumeFmt.dimension
  --MASS
  !this.setGlobalMassFormat()
  !this.currentFormat[8]    = 'massFmt'
  !this.dimension[8]        = !!massFmt.dimension
  -- UNIT MASS
  !this.setGlobalUnitMassFormat( !this.unitMassFormat() )
  !this.currentFormat[9]    = 'unitMassFmt'
  !this.dimension[9]        = !!unitMassFmt.dimension
  -- PRESSURE
  !this.setGlobalPressureFormat()
  !this.currentFormat[10]   = 'pressureFmt'
  !this.dimension[10]       = !!pressureFmt.dimension
  -- TEMPERATURE
  !this.setGlobalTemperatureFormat()
  !this.currentFormat[11]   = 'temperatureFmt'
  !this.dimension[11]       = !!temperatureFmt.dimension
  -- TEMPERATURE GRADIENT
  !this.setGlobalTemperatureGradientFormat( !this.temperatureGradientFormat() )
  !this.currentFormat[12]   = 'temperatureGradientFmt'
  !this.dimension[12]       = !!temperatureGradientFmt.dimension
  -- FORCE
  !this.setGlobalForceFormat()
  !this.currentFormat[13]   = 'forceFmt'
  !this.dimension[13]       = !!forceFmt.dimension
  -- ENERGY
  !this.setGlobalEnergyFormat()
  !this.currentFormat[14]   = 'energyFmt'
  !this.dimension[14]       = !!energyFmt.dimension
  -- POWER
  !this.setGlobalPowerFormat()
  !this.currentFormat[15]   = 'powerFmt'
  !this.dimension[15]       = !!powerFmt.dimension
  -- Density
  !this.setGlobalDensityFormat( !this.densityFormat() )
  !this.currentFormat[16]   = 'densityFmt'
  !this.dimension[16]       = !!densityFmt.dimension
  -- Density (MANU DB)
  !this.currentFormat[17]   = 'densityFmt'
  !this.dimension[17]       = 'MAND'
  -- CURRENT
  !this.setGlobalCurrentFormat()
  !this.currentFormat[18]   = 'currentFmt'
  !this.dimension[18]       = !!currentFmt.dimension
  -- EMF
  !this.setGlobalEmfFormat()
  !this.currentFormat[19]   = 'emfFmt'
  !this.dimension[19]       = !!emfFmt.dimension
  -- IMPEDENCE
  !this.setGlobalImpedanceFormat()
  !this.currentFormat[20]   = 'impedanceFmt'
  !this.dimension[20]       = !!impedanceFmt.dimension
  -- TIME
  !this.setGlobalTimeFormat()
  !this.currentFormat[21]   = 'timeFmt'
  !this.dimension[21]       = !!timeFmt.dimension
  -- L and LENGTH used for distances
  !this.currentFormat[22]   = 'distanceFmt'
  !this.dimension[22]       = 'LENGTH'
  -- Alternative AREA format L2
  !this.currentFormat[23]   = 'areaFmt'
  !this.dimension[23]       = 'L2'
  -- Alternative VOLUME format L3
  !this.currentFormat[24]   = 'volumeFmt'
  !this.dimension[24]       = 'L3'

   -- register formats with core
  !this.registerFormats()
  handle any
  endhandle

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      realFormat
--
-- Description: Real format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .realFormat() is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'NONE'
  !format.dp            = 2
  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      integerFormat
--
-- Description: Integer format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .integerFormat() is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'NONE'
  !format.dp            = 0
  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      angleFormat
--
-- Description: Angle format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .angleFormat() is FORMAT

  return !this.angleFormat(object UNIT('degree'))

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      angleFormat
--
-- Description: Angle format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      units as string
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .angleFormat(!unit is STRING) is FORMAT

  return !this.angleFormat(object UNIT(!unit))

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      angleFormat
--
-- Description: Angle format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .angleFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'ANGLE'
  !format.label         = 'UNITS'
  !format.dp            = 2
  !unitQualifier        = !unit.unitQualifier()
  !format.units         = !unitQualifier

  if( !unitQualifier.upcase() eq 'RADIAN' ) then
    !format.dp = 4
  elseif( !unitQualifier.upcase() eq 'DEGREE' ) then
    -- no label output for degrees
    !format.label = ''
	!format.trailZeros = false
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      distanceFormat
--
-- Description: Distance format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .distanceFormat() is FORMAT

  !unit = !this.getCurrentUnitsByPtype('L').upcase()

  return !this.distanceFormat(!unit)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      distanceFormat
--
-- Description: Distance format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .distanceFormat(!unit is STRING) is FORMAT

  !format                 = object FORMAT()
  !format.dimension       = 'L'

  if( !unit inset('INCH', 'IN' ) ) then
    !format.units         = 'INCH'
    !format.fraction      = true
    !format.denominator   = 32
    !format.inchSeparator = |.|
    !format.label         = |in|
  elseif ( !unit eq 'FINC' ) then
    !format.units         = 'FINCH'
    !format.label         = '"'
    !format.fraction      = true
    !format.denominator   = 32
    !format.ftLabel       = |'-|
    !format.inchSeparator = |.|
    !format.zeros         = false
  elseif( !unit eq 'FT' ) then
    -- feet
    !format.units         = 'FT'
    !format.label         = 'UNITS'
    !format.dp            = 3
    !format.trailZeros    = true
  elseif( !unit eq 'METRE' ) then
    -- metre
    !format.units         = 'METRE'
    !format.label         = 'UNITS'
    !format.dp            = 3
    !format.trailZeros    = false
  elseif( !unit eq 'CM' ) then
    !format.units         = 'CM'
    !format.label         = 'UNITS'
    !format.dp            = 3
    !format.trailZeros    = false
  elseif( !unit.before(':') eq 'USER' ) then
    !userUnit             = !unit.split(':')
    !index                = !userUnit[2].real()
    !format               = !this.userDefinitions[!index]
  elseif( !unit.empty() ) then
    -- should not happen, but default to MM
    !format.units         = 'MM'
    !format.label         = 'UNITS'
    !format.dp            = 2
    !format.trailZeros    = false
  else
    -- metric
    !format.units         = !unit
    !format.label         = 'UNITS'
    !format.dp            = 2
    !format.trailZeros    = false
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      boreFormat
--
-- Description: Bore format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .boreFormat() is FORMAT

  !unit = !this.getCurrentUnitsByPtype('BORE').upcase()

  return !this.boreFormat(!unit)

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      boreFormat
--
-- Description: Bore format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .boreFormat(!unit is STRING) is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'L'

  if ( !unit inset('IN','FINC','FT' ) ) then
    !format.units         = 'INCH'
    !format.dimension     = 'L'
    !format.fraction      = true
    !format.denominator   = 8
    !format.inchSeparator = |.|
    !format.label         = |in|
  elseif( !unit.before(':') eq 'USER' ) then
    !userUnit             = !unit.split(':')
    !index                = !userUnit[2].real()
    !format               = !this.userDefinitions[!index]
  else
    !format.units         = 'MM'
    !format.label         = 'UNITS'
    !format.dp            = 0
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      areaFormat
--
-- Description: Area format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .areaFormat() is FORMAT

  !measure = object MEASURE('SQDI')
  return !this.areaFormat(!measure.currentUnits())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      areaFormat
--
-- Description: Area format definition for specific units
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      UNIT        Specific unit
-- Return:
--   [Data Type] [Description]
--    FORMAT     FORMAT object for this unit
--
------------------------------------------------------------------------

define method .areaFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !unitQualifier        = !unit.unitQualifier().upcase()
  !format.dimension     = 'AREA'
  if (!unitQualifier neq (!this.getCurrentUnit('DIST').upcase() + '2')) then
      !format.units         = !unitQualifier
  else
      !format.units = 'DRVD'
  endif
  !format.label         = 'UNITS'

  if( !unitQualifier inset ('MM2', 'CM2', 'METRE2', 'IN2') ) then
    !format.dp          = 0
  else
    -- default for other units
    !format.dp          = 2
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      volumeFormat
--
-- Description: Volume format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .volumeFormat() is FORMAT

  !measure = object MEASURE('CUDI')
  return !this.volumeFormat(!measure.currentUnits())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      volumeFormat
--
-- Description: Volume format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      UNIT        Specific unit
-- Return:
--   [Data Type] [Description]
--    FORMAT     FORMAT object for this unit
--
------------------------------------------------------------------------

define method .volumeFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !unitQualifier        = !unit.unitQualifier().upcase()
  !format.dimension     = 'VOLUME'
  if (!unitQualifier neq (!this.getCurrentUnit('DIST').upcase() + '3')) then
      !format.units         = !unitQualifier
  else
      !format.units = 'DRVD'
  endif
  !format.label         = 'UNITS'

  if( !unitQualifier inset ('MM3', 'CM3', 'METRE3', 'IN3') ) then
    !format.dp          = 0
  else
    -- default for other units
    !format.dp          = 2
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      massFormat
--
-- Description: Mass format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .massFormat() is FORMAT

  !measure = object MEASURE('MASS')
  return !this.massFormat(!measure.currentUnits())

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      massFormat
--
-- Description: Mass format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Unit as string
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .massFormat(!unit is STRING) is FORMAT

  return !this.massFormat(object UNIT(!unit))

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      massFormat
--
-- Description: Mass format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      UNIT        Specific unit
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default FORMAT object for this dimension
--
------------------------------------------------------------------------

define method .massFormat(!unit is UNIT) is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'MASS'
  !format.label         = 'UNITS'

  !unitQualifier        = !unit.unitQualifier().upcase()
  if( !unitQualifier eq 'GRAM' ) then
    !format.dp          = 0
  elseif( !unitQualifier eq 'OZ' ) then
    !format.dp          = 1
  elseif( !unitQualifier eq 'LB' ) then
    !format.dp          = 2
  elseif( !unitQualifier.match('TON') neq 0 ) then
    !format.dp          = 3
  else
    !format.dp          = 2
  endif
  return !format

endmethod
-- End of method

