------------------------------------------------------------------------
--
-- Method:      testFormat
--
-- Description: Test format definition with given REAL
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        REAL to test FORMAT
--    2   R      FORMAT      FORMAT
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .testFormat( !testReal is REAL,  !format is FORMAT ) is BOOLEAN

  -- test new format
  !unusedTestString = !testReal.string(!format)
  handle any
    return false
  endhandle
  return true

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getDimensionCurrentUnits
--
-- Description: Get current units for given dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Dimension
-- Return:
--   [Data Type] [Description]
--    STRING     Current Unit
--
------------------------------------------------------------------------

define method .getDimensionCurrentUnits( !dimension is STRING ) is STRING

  -- look up PTYPE dimension names
  !formatIndex = !this.dimensionPTypes.findFirst(!dimension.upcase().trim())

  if(!formatIndex.unset()) then
    -- look up full dimension name if PTYPE not found
    !formatIndex = !this.dimension.findFirst(!dimension.upcase().trim())
  endif

  if( !formatIndex.unset()) then
    !unit = ''
  else
    !unit = !this.getCurrentUnitsByPtype(!this.dimensionPTypes[!formatIndex])
  endif

  return !unit

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getPTypeByDimension
--
-- Description: Get PTYPE for given dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Dimension
-- Return:
--   [Data Type] [Description]
--    STRING     Current Unit
--
------------------------------------------------------------------------

define method .getPTypeByDimension( !dimension is STRING ) is STRING

  -- look up PTYPE dimension names
  !formatIndex = !this.dimensionPTypes.findFirst(!dimension.upcase().trim())

  if(!formatIndex.unset()) then
    -- look up full dimension name if PTYPE not found
    !formatIndex = !this.dimension.findFirst(!dimension.upcase().trim())
  endif

  if( !formatIndex.unset()) then
    !pType = ''
  else
    !pType = !this.dimensionPTypes[!formatIndex]
  endif

  return !pType

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getDescriptionFromPtype
--
-- Description: Get descriptive text for given PTYP
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      PTYP
-- Return:
--   [Data Type] [Description]
--    STRING     PTYP description
--
------------------------------------------------------------------------

define method .getDescriptionFromPtype( !pType is STRING ) is STRING

  !index = !this.dimensionPTypes.findFirst(!pType)
  if( !index.unset() ) then
    return 'UNKNOWN'
  else
    return !this.dimensionDescriptions[!index]
  endif

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getCurrentUnitsByPtype
--
-- Description: Get current units for given dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Dimension
-- Return:
--   [Data Type] [Description]
--    STRING     Current Unit
--
------------------------------------------------------------------------

define method .getCurrentUnitsByPtype( !pType is STRING ) is STRING

  return !this.commonUnitsObject.getCurrentUnitsByPtype( !pType )

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getNumericPTypeList
--
-- Description: Get list of Numeric PTYP's for datasets along with description
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY      2D array: Array 1 is list of PTYP settings
--                         Array 2 is corresponding PTYP description (e.g. for DTEXT)
--                         Array 3 is corresponding description (e.g. for DTEXT)
--
------------------------------------------------------------------------

define method .getNumericPTypeList() is ARRAY

  !return[1] = ARRAY()
  !return[2] = ARRAY()
  !return[3] = ARRAY()
  do !dimensionIndex indices !this.dimensionPTypes
    -- do not output duplicate PTYPES
    skip if( !return[1].findFirst(!this.dimensionPTypes[!dimensionIndex]).set() )
    -- Put PTYP in array 1
    !return[1].append(!this.dimensionPTypes[!dimensionIndex])
    -- look up DTEXT for corresponding PTYP and put in array 2
    !return[2].append(!this.dimension[!dimensionIndex])
    -- look up alternative description string which may be used in DTEXT
    !return[3].append(!this.dimensionDescriptions[!dimensionIndex])
  enddo

  return !return

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getNonNumericPTypeList
--
-- Description: Get list of non-numeric PTYP's for datasets along with description
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY      2D array: Array 1 is list of PTYP settings
--                         Array 2 is corresponding PTYP description (e.g. for DTEXT)
--                         Array 3 is corresponding description (e.g. for DTEXT)
--
------------------------------------------------------------------------

define method .getNonNumericPTypeList() is ARRAY

  !return = ARRAY()
  -- Put PTYP in array 1 and DTEXT in array2
  !return[1][1] = |LOG|
  !return[2][1] = |Logical|
  !return[3][1] = |Logical|
  !return[1][2] = |TEXT|
  !return[2][2] = |String|
  !return[3][2] = |String|
  !return[1][3] = |FILE|
  !return[2][3] = |File|
  !return[3][3] = |File|

  return !return

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getReferencePTypeList
--
-- Description: Get list of reference PTYP's for datasets along with description
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY      2D array: Array 1 is list of PTYP settings
--                         Array 2 is corresponding PTYP description (e.g. for DTEXT)
--                         Array 3 is corresponding description (e.g. for DTEXT)
--
------------------------------------------------------------------------

define method .getReferencePTypeList() is ARRAY

  !return = ARRAY()
  -- Put PTYP in array 1 and DTEXT in array2
  !return[1][1] = |SPRE|
  !return[2][1] = |Spec Ref|
  !return[3][1] = |Component|
  !return[1][2] = |SUBE|
  !return[2][2] = |Sub Ref|
  !return[3][2] = |Sub-Component|

  return !return

endmethod
-- End of method
------------------------------------------------------------------------
--
-- Method:      distanceFormatForm
--
-- Description: Distance format definition (legacy code)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORMAT     Default form FORMAT object for distance dimensions
--
------------------------------------------------------------------------

define method .distanceFormatForm() is FORMAT

  !format               = object FORMAT()
  !format.dimension     = 'L'

  if ( !!isImperialLength('DIST') ) then
    !format.units         = 'INCH'
    !format.fraction      = true
    !format.denominator   = 32
    !format.inchSeparator = |.|
    !format.label         = |in|
  else
    !format.units         = 'MM'
    !format.label         = 'UNITS'
    !format.dp            = 2
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getUserDefinedFormatTokens
--
-- Description: Get user defined format tokens
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      PTYPE of dimension
-- Return:
--   [Data Type] [Description]
--    ARRAY       Array of tokens for user defined format for given PTYPE
--
------------------------------------------------------------------------

define method .getUserDefinedFormatTokens(!pType is STRING) is ARRAY

  !tokens = ARRAY()
  do !i indices !this.userTypes
    if( !this.userTypes[!i] eq !pType.upcase() ) then
      !tokens.append(!this.userTokens[!i])
    endif
  enddo

  return !tokens

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getUserDefinedFormatDescriptions
--
-- Description: Get user defined format tokens
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Prefix for descriptions
--    2   R      ARRAY       Array of tokens for user defined formats
-- Return:
--   [Data Type] [Description]
--    ARRAY       Array of format descriptions for given tokens
--
------------------------------------------------------------------------

define method .getUserDefinedFormatDescriptions(!prefix is STRING, !tokens is ARRAY) is ARRAY

  !descriptions        = ARRAY()
  do !i indices !tokens
    !index             = !this.userTokens.findFirst(!tokens[!i])
    if( !index.unset() ) then
      !descriptions[!i] = 'Not found'
    else
      !descriptions[!i] = !prefix + !this.userDescriptions[!index]
    endif
  enddo

  return !descriptions

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      getUserDefinedFormat
--
-- Description: Get user defined format for a given token
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      User defined format token
-- Return:
--   [Data Type] [Description]
--    FORMAT      Format for given token
--
------------------------------------------------------------------------

define method .getUserDefinedFormat(!token is STRING) is FORMAT

  !index    = !this.userTokens.findFirst(!token)
  if( !index.unset() ) then
    !format = object FORMAT()
  else
    !format = !this.userDefinitions[!index]
  endif

  return !format

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      decimalPlacesCalculator
--
-- Description: Recommends a number of DP for the given value in
--              current units by testing magnitude of value
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Test value
-- Return:
--   [Data Type] [Description]
--    REAL        Number of DP
--
------------------------------------------------------------------------

define method .decimalPlacesCalculator(!testValue is REAL) is REAL

  !dp     = 0
  !ten    = 10
  -- get magnitude of test value in current units
  !value  = !testValue.value()
  do !i from -1 to 5
    break if( !value gt !ten.power(!i * -1) )
    !dp   = !dp + 1
  enddo

  return !dp

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      registerFormat
--
-- Description: regiters the given unit format and measure dimension with Core
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING       Measure Dimension
--    2   R      FORMAT       format to register
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .registerFormat(!dim is STRING, !format is FORMAT)

  import 'Aveva.Core.Presentation'
  handle any
  endhandle
  using namespace 'Aveva.Core.Presentation'
  !formatManager = object PMLFORMATMANAGER()
  !formatManager.addUnitFormat(object MEASURE(!dim), object UNIT(!format.units), !format)
  handle any
  endhandle

endmethod
--End of method
