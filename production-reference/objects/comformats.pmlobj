------------------------------------------------------------------------
--
-- Method:      setGlobalRealFormat
--
-- Description: Global real format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global Real
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalRealFormat( !format is FORMAT ) is BOOLEAN

  if( !format.dimension neq 'NONE' ) then
    return false
  endif
  !!realFmt = !format
  return true

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalIntegerFormat
--
-- Description: Global integer format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global Integer
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalIntegerFormat( !format is FORMAT ) is BOOLEAN

  if( !format.dimension neq 'NONE' ) then
    return false
  endif
  !!integerFmt = !format
  return true

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalAngleFormat
--
-- Description: Set global angle format definition to default unit
--              for current dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalAngleFormat() is BOOLEAN

  return !this.setGlobalAngleFormat( !this.angleFormat() )

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalAngleFormat
--
-- Description: Global angle format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global angle
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalAngleFormat( !format is FORMAT ) is BOOLEAN

  -- test new format
  !testReal         = 1 degree
  !validFormat     = !this.testFormat(!testReal, !format)
  if( !validFormat ) then
    !!angleFmt      = !format
  else
    !!angleFmt     = !this.angleFormat()
  endif
  return !validFormat

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalDistanceFormat
--
-- Description: Set global distance format definition to default unit
--              for current dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalDistanceFormat() is BOOLEAN

  return !this.setGlobalDistanceFormat( !this.distanceFormat() )

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalDistanceFormat
--
-- Description: Global distance format definition given user format token
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global distance
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalDistanceFormat( !token is STRING ) is BOOLEAN

  if( !token.before(':') eq 'USER' ) then
    !userSelection = !token.split(':')
    !formatSet     = !this.setGlobalDistanceFormat(!this.userDefinitions[!userSelection[2].real()])
    handle any
      !formatSet   = !this.setGlobalDistanceFormat( !this.distanceFormat() )
    endhandle
  else
    !formatSet     = !this.setGlobalDistanceFormat( !this.distanceFormat() )
  endif
  return !formatSet

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalDistanceFormat
--
-- Description: Global distance format definition given format
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global distance
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalDistanceFormat( !format is FORMAT ) is BOOLEAN

  -- test new format
  !testReal         = 1 mm
  !validFormat     = !this.testFormat(!testReal, !format)
  if( !validFormat ) then
    !!distanceFmt   = !format
  else
    !!distanceFmt  = !this.distanceFormat()
  endif

  return !validFormat

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalBoreFormat
--
-- Description: Set global bore format definition to default unit
--              for current dimension
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalBoreFormat() is BOOLEAN

  return !this.setGlobalBoreFormat( !this.boreFormat() )

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalBoreFormat
--
-- Description: Global distance format definition given user format token
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global distance
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalBoreFormat( !token is STRING ) is BOOLEAN

  if( !token.before(':') eq 'USER' ) then
    !userSelection = !token.split(':')
    !formatSet     = !this.setGlobalBoreFormat(!this.userDefinitions[!userSelection[2].real()])
    handle any
      !formatSet   = !this.setGlobalBoreFormat( !this.boreFormat() )
    endhandle
  else
    !formatSet     = !this.setGlobalBoreFormat( !this.boreFormat() )
  endif
  return !formatSet

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalBoreFormat
--
-- Description: Bore format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global bore
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     True for success - False for bad format
--
------------------------------------------------------------------------

define method .setGlobalBoreFormat( !format is FORMAT ) is BOOLEAN

  -- test new format
  !testReal         = 1 mm
  !validFormat     = !this.testFormat(!testReal, !format)
  if( !validFormat ) then
    !!boreFmt    = !format
  else
    !!boreFmt      = !this.boreFormat()
  endif
  return !validFormat

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      setGlobalAreaFormat
--
-- Description: Area format definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORMAT      New global area
-- Return:
