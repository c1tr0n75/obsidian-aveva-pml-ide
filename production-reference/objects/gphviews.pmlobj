    !form.slookMenu.add('callback', 'South',       '!!gphviews.look(')
    !form.slookMenu.add('callback', 'East',        '!!gphviews.look(')
    !form.slookMenu.add('callback', 'West',        '!!gphviews.look(')
    !form.slookMenu.add('separator')
    !form.slookMenu.add('callback', 'Plan North',      '!!gphviews.plan(')
    !form.slookMenu.add('callback', 'Plan South',      '!!gphviews.plan(')
    !form.slookMenu.add('callback', 'Plan East',       '!!gphviews.plan(')
    !form.slookMenu.add('callback', 'Plan West',       '!!gphviews.plan(')

  endif

  !form.sisoMenu.add('callback', 'One',         '!!gphviews.isometric(')
