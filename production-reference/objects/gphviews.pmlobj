-- Description: Build short menus
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .sMenus(!form is FORM)

  !form.newMenu('sviewPopup')
  !form.newMenu('smouseMenu')
  !form.newMenu('slookMenu')
  !form.newMenu('sisoMenu')
