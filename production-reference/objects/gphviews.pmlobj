  !form.srotateMenu.add('CALLBACK', 'CE Origin',     '!!gphviews.rotateElement(')
  !form.srotateMenu.add('CALLBACK', 'Pick Origin',   '!!gphviews.rotatePick(')
  !form.srotateMenu.add('separator')
  !form.srotateMenu.add('CALLBACK', 'Limit Box',     '!!gphviews.rotateBox(')

  !form.ssettingsMenu.callback = '!!gphviews.graphicsToggles('
  !form.ssettingsMenu.add('toggle', 'Eye  F7', '!!gphviews.doMenuAction(')
  !form.ssettingsMenu.add('toggle', 'Shaded  F11', '!!gphviews.doMenuAction(')
  !form.ssettingsMenu.add('toggle', 'Perspective  F4', '!!gphviews.doMenuAction(')
  !form.ssettingsMenu.add('separator')
  !form.ssettingsMenu.add('toggle', 'Long Menus', '!!gphviews.longMenus(')

endmethod
-- End of method definition for .sMenus(FORM)

------------------------------------------------------------------------
--
-- Method:      longMenus
--
-- Description: Build long menus
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .longMenus(!menu is MENU, !action is STRING)

  !form = !menu.owner()

  if (!action eq 'SELECT') then

    !form.view.setPopup(!form.lviewPopup)

    !form.lsettingsMenu.select('Long Menus', TRUE)

  else

    !form.view.setPopup(!form.sviewPopup)

    !form.ssettingsMenu.select('Long Menus', FALSE)

  endif

endmethod
-- End of method definition for .longMenus(MENU, STRING)


------------------------------------------------------------------------
--
-- Method:      measure
--
-- Description: Setup edg event for widowing in
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Measurement type
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .measure(!option is STRING)

  -- Linear Dimension
  if(!option.upcase() eq 'DISTANCE') then
    !dimension = object GPHDIMENSION()
    !dimension.edit()

  -- Angle 3 points
  elseif (!option.upcase() eq 'ANGLE') then
    !dimension = object GPHANGLEDIMENSION()
    !dimension.edit('ANGLE')

  -- Angle 2 lines
  elseif (!option.upcase() eq 'LINEANGLE') then
    !dimension = object GPHANGLEDIMENSION()
    !dimension.edit('LINEANGLEARC')
  endif

endmethod
-- End of method definition for .measure(STRING)

------------------------------------------------------------------------
--
-- Method:      align
--
-- Description: MDS Only - Setup edg event for aligning a MDS Framework Support
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Alignment/Measurement type
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .align(!option is STRING)

  -- Linear Dimension Alignment
  if(!option.upcase() eq 'DISTANCE') then
    !dimension = object GPHDIMENSION()
    !dimension.align()
  endif

endmethod
-- End of method definition for .align(STRING)

------------------------------------------------------------------------
--
-- Method:      tag
--
-- Description: Tag elements
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Tag type
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .tag(!option is STRING)

  -- Linear Dimension
  if(!option.upcase() eq 'AXES') then
    !axes = object GPHAXES()
    !axes.edit(-1)

    -- Angle
  else


  endif

endmethod
-- End of method definition for .tag(STRING)

------------------------------------------------------------------------
--
-- Method:      windowPacket
--
-- Description: Graphic window packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
-- Return:
--   [Data Type] [Description]
--    EDGPACKET   Packet continuing data
--
------------------------------------------------------------------------

define method .windowPacket(!view is GADGET) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key            = 'windowPacket'
  !packet.description    = 'Standard Windowing'
  !packet.type           = 'gph'
  !packet.priority       = 0
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'
  !packet.action         = '!!gphviews.window(!this.return)'
  !packet.pickPacket.stdGphWindow('Window')
  !packet.remove         = TRUE

  -- Set priority
  !packet.priority       = 3

  -- Return
  return !packet

endmethod
-- End of method definition for .windowPacket(GADGET) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      window
--
-- Description: Window using the window store data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      ARRAY       Pick data
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .window(!data is ARRAY)

  -- Convert position into a metric position (regardless)
  !position         = !data[2].position
  !radius           = !data[2].radius

  -- Convert the ARC origin to a view "through" position
  !throughArray[1] = !position.east.dbUnits().value()
  !throughArray[2] = !position.north.dbUnits().value()
  !throughArray[3] = !position.up.dbUnits().value()

  !data[1].through = !throughArray
  !data[1].radius  = !radius.dbUnits().value()

endmethod
-- End of method definition for .window(ARRAY)

------------------------------------------------------------------------
--
-- Method:      window
--
-- Description: Setup edg event for widowing in
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .window(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view

  -- Get Packet
  !packet = !this.windowPacket(!view)

  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .window(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      rotatePacket
--
-- Description: Graphic window packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
--    2   R      STRING      Type of rotate, ORIGIN or CENTROID
-- Return:
--   [Data Type] [Description]
--    EDGPACKET   Packet continuing data
--
------------------------------------------------------------------------

define method .rotatePacket(!view is GADGET, !option is STRING) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key         = 'rotatePacket'
  !packet.description = 'Graphic Rotate'
  !packet.type        = 'gph'
  !packet.priority    = 0
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'

  -- Origin
  if(!option.upcase() eq 'ORIGIN') then
    !packet.action    = '!!gphviews.rotate(!this.return[1],!!edgCntrl.pickData.item.position)'
  else
    !packet.action    = '!!gphviews.rotate(!this.return[1],!!volume(!!edgCntrl.pickData.item))'
  endif
  !packet.pickPacket.stdElement('Pick item to "Rotate" about')
  !packet.remove      = TRUE

  -- Set priority
  !packet.priority    = 3

  -- Return
  return !packet

endmethod
-- End of method definition for .rotatePacket(GADGET, STRING) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      rotate
--
-- Description: Rotate about a position
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
--    2   R      VOLUME      Volume
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotate(!view is GADGET, !volume is VOLUME)

  -- Set positions wrt World
  !midPoint   = !volume.from.midPoint(!volume.to).wrt(World)

  -- Set view through point
  !this.rotate(!view, !midPoint)

endmethod
-- End of method definition for .rotate(GADGET, VOLUME)

------------------------------------------------------------------------
--
-- Method:      rotate
--
-- Description: Rotate about a position
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
--    2   R      POSITION    Explicit position
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotate(!view is GADGET, !position is POSITION)

  -- Get position wrt world
  !newPosition      = !position.wrt(World)

  !array[1]         = !!comValueConvert(!newPosition.east,'MM')
  !array[2]         = !!comValueConvert(!newPosition.north,'MM')
  !array[3]         = !!comValueConvert(!newPosition.up,'MM')

  -- Set view through point
  !this.rotate(!view, !array)

endmethod
-- End of method definition for .rotate(GADGET, POSITION)

------------------------------------------------------------------------
--
-- Method:      rotate
--
-- Description: Set rotation in its rawest sense
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
--    2   R      ARRAY       3 element radl array
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotate(!view is GADGET, !array is ARRAY)

  -- Set view through point
  !view.through = !array
  handle ANY
  endhandle

endmethod
-- End of method definition for .rotate(GADGET, ARRAY)

------------------------------------------------------------------------
--
-- Method:      rotateElement
--
-- Description: Set view rotation about an item
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotateElement(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Get Element Reference (if required)
  -- Owning Element
  if(!option.match('OWNER').boolean()) then
    !item = !!ce.owner

    -- Current Element
  elseif (!option.match('CE').boolean()) then
    !item = !!ce

  endif

  -- Current Elements Origin
  if(!option.match('ORIGIN').boolean()) then
    !this.rotate(!view, !item.position)

    -- Centroid of Element
  elseif (!option.match('CENTROID').boolean()) then
    !this.rotate(!view, !!volume(!item))

  endif

endmethod
-- End of method definition for .rotateElement(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      rotatePick
--
-- Description: Setup edge event for rotation
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotatePick(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Rotate about item
  !packet = !this.rotatePacket(!view, !option.part(2))
  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .rotatePick(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      rotateBox
--
-- Description: Set view rotation about a box
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotateBox(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- View Limits
  if(!option.match('LIMIT').boolean()) then

    -- Get view limits box
    !array       = !view.limits
    !newArray[1] = (!array[1] + !array[2]) / 2
    !newArray[2] = (!array[3] + !array[4]) / 2
    !newArray[3] = (!array[5] + !array[6]) / 2
    !this.rotate(!view, !newArray)

    -- Clip Box
  elseif (!option.match('CLIP').boolean()) then
    !clipbox        = !form.clipbox
    !position       = !clipbox.box.position
    !this.rotate(!view, !position)

  endif

endmethod
-- End of method definition for .rotateBox(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      rotateExplicit
--
-- Description: Show view explicit rotation form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .rotateExplicit(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view

  -- Load form if not previously loaded
  if(undefined(!!gph3DRotate)) then
    pml load form !!gph3DRotate
  endif

  -- Set view for rotation
  !!gph3DRotate.setView(!view)

  -- Define EDG positional pick
  !packet                = object EDGPACKET()
  !packet.positionLink('!!gph3DRotate.position', 'Rotate')
  !packet.form           = !!gph3dRotate
  !packet.description    = !!gph3dRotate.formTitle

  -- Set priority
  !packet.priority       = 2

  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .rotateExplicit(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsPacket
--
-- Description: Graphic window limits
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsPacket(!view is GADGET) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key            = 'limitsPacket'
  !packet.description    = 'Graphic Limits'
  !packet.type           = 'gph'
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'
  !packet.action         = '!!gphviews.limits(!this.return[1],!!edgCntrl.pickData.item)'
  !packet.pickPacket.stdElement('Pick item to set limits by')
  !packet.remove         = TRUE

  -- Set priority
  !packet.priority       = 3

  -- Return
  return !packet

endmethod
-- End of method definition for .limitsPacket(GADGET) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      limits
--
-- Description: Set limits to element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
--    2   R      DBREF       Dbref to get volume of
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limits(!view is GADGET, !item is DBREF)

  -- Are we at the world
  if(!item.fullType eq 'WORLD') then
    !!alert.message('Cannot set 3D View Limits to /* ')
    return
  endif

  if(!item.fullType eq 'WORLD' or !item.owner.fullType eq 'WORLD') then
    !type = !item.fullType
    !type = !type.substring(1,1) & !type.substring(2).lowcase()
    if(!!alert.confirm('OK to set limits to the ' & !type & '?').boolean().not()) then
      return
    endif
  endif

  -- Get volume of item
  !volume      = object VOLUME(!item)
  if(!volume.unset()) then
    !volume      = object VOLUME(!item.owner)
    if(!volume.unset()) then
      !!alert.error('Unable to derive volume of element')
      return
    endif
    !!alert.message('Unable to derive volume of element, using element''s owner.')
  endif

  -- If volume = 0, we will define a 1000mm box
  if(!volume.from.distance(!volume.to).between(-1mm, 1mm)) then
    !direction   = object DIRECTION('N45E35U')
    !volume.from = !volume.from.offset(!direction, 353mm)
    !volume.to   = !volume.to.offset(!direction.opposite(), 353mm)
  endif

  -- Set view Limits
  !view.limits = !this.convertVolumeToLimits(!volume)

endmethod
-- End of method definition for .limits(GADGET, DBREF)

------------------------------------------------------------------------
--
-- Method:      limits
--
-- Description: Set limits to volume
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
--    2   R      VOLUME      Explicit Volume
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limits(!view is GADGET, !passedVolume is VOLUME)

  -- Set view Limits
  !view.limits = !this.convertVolumeToLimits(!passedVolume)

endmethod
-- End of method definition for .limits(GADGET, VOLUME)

------------------------------------------------------------------------
--
-- Method:      limitsPick
--
-- Description: Setup edg event for picking the limits
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsPick(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view

  -- Get Packet
  !packet = !this.limitsPacket(!view)
  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .limitsPick(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsElement
--
-- Description: Setup the view limits to a db element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsElement(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Current Element
  if( !option.eq('CE') ) then
    !this.limits(!view, !!ce)

    -- Owner Volume
  elseif (!option eq 'OWNER') then
    !this.limits(!view, !!ce.owner)

  endif

endmethod
-- End of method definition for .limitsElement(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsRestore
--
-- Description: Restore view limits definition
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsRestore(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form        = !menu.owner()
  !view        = !form.view

  -- Reset to current limits
  !view.limits = !view.limits

endmethod
-- End of method definition for .limitsRestore(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsList
--
-- Description: Set the view limits to a "list"
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsList(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Get List
  if(!option.match('DRAW').boolean()) then
    var !collection COLLECT ALL FROM DRAWLIST
  else
    var !collection COLLECT ALL FROM OBST
  endif

  -- Check we have some items in the list
  if(!collection.unset()) then
    !!messageFile.warning(149, 8, !menu.pickedField)
    return
  endif

  -- Convert !collection array into array of DBREF
  !block    = object BLOCK('!collection[!evalIndex].dbRef()')
  !list     = !collection.evaluate(!block)
  !volume   = object VOLUME(!list)

  -- Setup view limits
  !this.limits(!view, !volume)

endmethod
-- End of method definition for .limitsList(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsBox
--
-- Description: Set the view limits to a "box"
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsBox(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()


  -- Clip Box Volume
  if(!option eq 'CLIPBOX') then

    -- Convert clip box definition into a volume object
    !volume             = object VOLUME(!form.clipbox.box)

    -- Setup view limits
    !this.limits(!view, !volume)

  endif


endmethod
-- End of method definition for .limitsBox(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      limitsExplicit
--
-- Description: Show the explicit view limits form
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .limitsExplicit(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view

  -- Load form if not previously loaded
  if(undefined(!!gphVolumeEdit)) then
    pml load form !!gphVolumeEdit
  endif

  -- Set view for rotation
  !!gphVolumeEdit.edit(!view)

endmethod
-- End of method definition for .limitsExplicit(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      copyPacket
--
-- Description: Copy pick view setting and apply to passed view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
-- Return:
--   [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
--
------------------------------------------------------------------------

define method .copyPacket(!view is GADGET) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key            = 'copyPacket'
  !packet.description    = 'Copy Picked View'
  !packet.type           = 'gph'
  !packet.priority       = 0
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'
  !packet.action         = '!!gphviews.copy(!this.return[1], !this.return[2])'
  !packet.pickPacket.stdView('Pick view to be copied')
  !packet.remove         = TRUE

  -- Set priority
  !packet.priority       = 3

  -- Return
  return !packet

endmethod
-- End of method definition for .copyPacket(GADGET) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      copy
--
-- Description: Copy last picked view into current view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View to be updated
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .copy(!view is GADGET, !copyView is GADGET)

  -- Initialise Variables

  -- This information could be got from a form?
  !view.limits     = !copyView.limits
  !view.through    = !copyView.through
  !view.direction  = !copyView.direction
  !view.radius     = !copyView.radius
  --   !view.shaded     = !copyView.shaded
  --   !view.background = !copyView.background

endmethod
-- End of method definition for .copy(GADGET, GADGET)

------------------------------------------------------------------------
--
-- Method:      copy
--
-- Description: Setup edg event to copy view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .copy(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Window in on the view
  if(!option eq 'COPY LIKE VIEW') then

    !packet = !this.copyPacket(!view)
    !!edgCntrl.add(!packet)

  endif

endmethod
-- End of method definition for .copy(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      navigate
--
-- Description: Set single pick navigation
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     true if in navigate mode - false otherwise
--
------------------------------------------------------------------------

define method .navigate() is BOOLEAN

  -- Add to state
  return !this.navigate(true)

endmethod
-- End of method definition for .navigate()

------------------------------------------------------------------------
--
-- Method:      navigate
--
-- Description: Single pick navigation
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     true to switch navigate mode on - false to switch off
-- Return:
--   [Data Type] [Description]
--    BOOLEAN     true if in navigate mode - false otherwise
--
------------------------------------------------------------------------

define method .navigate(!mode is BOOLEAN) is BOOLEAN

  if( !mode ) then
    -- switch EDG navigate on - add navigate Packet
  !packet = object EDGPACKET()
  !packet.navigate()
  !packet.remove = FALSE
    -- Set priority
    !packet.priority       = 3
  -- Add to state
  return !!edgCntrl.add(!packet)
  else
    !!edgCntrl.remove('Standard Navigate')
    return false
  endif

endmethod
-- End of method definition for .navigate()

------------------------------------------------------------------------
--
-- Method:      colour
--
-- Description: Show view colour settings form (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .colour(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form = !menu.owner()
  !view = !form.view
  !type = !menu.pickedField

  -- Type of Colour to be changed

  -- Background Colour
  if(!type.upcase() eq 'BACKGROUND...') then

    !command   = '!!' + !form.string() + '.' + !view.name() + '.background = !!colourSelectGet()'
    !title     = 'Background Colour'
    !colour    = !view.background

    -- ID Colour
  elseif (!type.upcase() eq 'HIGHLIGHT...') then

    !command   = '!!' + !form.string() + '.' + !view.name() + '.highlight = !!colourSelectGet()'
    !title     = 'Highlight Colour'
    !colour    = !view.highlight

    -- Aid Graphics
  elseif (!type.upcase() eq 'AID GRAPHICS...') then

    !command   = '!!gphColOpt.aids(!!colourSelectGet())'
    !title     = 'Aid Graphics'
    !colour    = !!gphColOpt.aids().code

    -- Current Element
  elseif (!type.upcase() eq 'CE...') then

    !command   = '!!gphColOpt.ce(!!colourSelectGet())'
    !title     = 'Current Element'
    !colour    = !!gphColOpt.ce().code

    -- Active Element
  elseif (!type.upcase() eq 'ACTIVE...') then

    !command   = '!!gphColOpt.active(!!colourSelectGet())'
    !title     = 'Active Element'
    !colour    = !!gphColOpt.active().code

    -- Visible Element
  elseif (!type.upcase() eq 'VISIBLE...') then

    !command   = '!!gphColOpt.visible(!!colourSelectGet())'
    !title     = 'Visible Element'
    !colour    = !!gphColOpt.visible().code

    -- ID Colour
  else
    !view.highlight = !type
    return
  endif

  -- Display colour selection form
  call !!colourSelectLoad(!command, !title, !colour)

endmethod
-- End of method definition for .colour(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      auto
--
-- Description: Auto view (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .auto(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form = !menu.owner()
  !view = !form.view
  !type = !menu.pickedField.upcase()

  -- Auto item
  if(!type.match('CE').boolean()) then
    ADD CE
    !this.limits(!view, !!ce)

    -- Add Owner to drawlist
  elseif (!type.match('OWNER').boolean()) then
    ADD OWNER
    !this.limits(!view, !!ce.owner)

  endif

endmethod
-- End of method definition for .auto(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      toDrawlist
--
-- Description: Add to drawlist (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .toDrawlist(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !type = !menu.pickedField.upcase()

  -- Add with a colour
  if(!type.upcase() eq 'ADD CE WITH COLOUR...') then

    -- Display colour selection form
    var !col COLOUR NUMBER GREY
    call !!colourSelectLoad('REM CE ADD CE COL $$!!colourSelect.setColour', 'Add Current Element', !col.real())

    -- Add Current Element to drawlist
  elseif(!type.match('ADD CE').boolean()) then
    ADD CE
    -- Add Owner to drawlist
  elseif (!type.match('ADD OWNER').boolean()) then
    ADD OWNER
  endif

endmethod
-- End of method definition for .toDrawlist(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      fromDrawlist
--
-- Description: Remove an item from the drawlist (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .fromDrawlist(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !type = !menu.pickedField.upcase()

  -- Remove Current Element to drawlist
  if(!type.match('REMOVE CE').boolean()) then
    REMOVE CE
  elseif (!type.match('REMOVE OWNER').boolean()) then
    REMOVE OWNER
  elseif (!type.match('REMOVE ALL').boolean()) then
    REMOVE ALL
  endif

endmethod
-- End of method definition for .fromDrawlist(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      look
--
-- Description: Set the view direction (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .look(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form = !menu.owner()
  !view = !form.view
  !look = !menu.pickedField

  -- Set Direction
  !direction = !look.direction()

  -- Convert Direction into Array
  !array[1]  = !direction.east
  !array[2]  = !direction.north
  !array[3]  = !direction.up

  -- Set View Direction
  !view.direction = !array

  -- Set view direction
  !this.look(!view, !direction)

endmethod
-- End of method definition for .look(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      look
--
-- Description: Set view to specified direction
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget
--    2   R      DIRECTION   View direction
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .look(!view is GADGET, !direction is DIRECTION)

  -- Convert Direction into Array
  !array[1]  = !direction.east
  !array[2]  = !direction.north
  !array[3]  = !direction.up

  -- Set View Direction
  !view.direction = !array

endmethod
-- End of method definition for .look(GADGET, DIRECTION)

------------------------------------------------------------------------
--
-- Method:      plan
--
-- Description: Set the view direction into a "plan" view (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .plan(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form = !menu.owner()
  !view = !form.view
  !look = !menu.pickedField

  -- Set Direction
  !direction = object DIRECTION(!look)
  handle ANY
    -- failsafe
    !direction = object DIRECTION('NORTH WRT WORLD')
  endhandle
  !array[1] = !direction.east
  !array[2] = !direction.north
  !array[3] = !direction.up

  -- Set View Direction
  !view.direction = !array

  !array[1] = 0
  !array[2] = 0
  !array[3] = -1

  -- Set View Direction
  !view.direction = !array

endmethod
-- End of method definition for .plan(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      lookExplicit
--
-- Description: Show the view direction explicit form (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .lookExplicit(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view

  -- Load form if not previously loaded
  if(undefined(!!gph3DLook)) then
    pml load form !!gph3DLook
  endif

  -- Set view for rotation
  !!gph3DLook.setView(!view)

  -- Show Form
  show !!gph3DLook

endmethod
-- End of method definition for .lookExplicit(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      isometric
--
-- Description: Set the view into an isometric view (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .isometric(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form = !menu.owner()
  !view = !form.view
  !iso  = !menu.pickedField

  -- Standard Iso Directions
  if(!iso.upcase() eq  |ONE|) then
    !direction = object DIRECTION('S 45 W 35.264 D')
  elseif(!iso.upcase() eq  |TWO|) then
    !direction = object DIRECTION('N 45 W 35.264 D')
  elseif(!iso.upcase() eq  |THREE|) then
    !direction = object DIRECTION('N 45 E 35.264 D')
  elseif(!iso.upcase() eq  |FOUR|) then
    !direction = object DIRECTION('S 45 E 35.264 D')
  endif

  -- Set view direction
  !this.look(!view, !direction)

endmethod
-- End of method definition for .isometric(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      clipButton
--
-- Description: Setup clipbox for view to passed element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Button
--    2   R      STRING      Selection
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipButton(!gadget is GADGET, !select is STRING)

  -- Initialise Variables
  !form    = !gadget.owner()
  !view    = !form.view

  -- Enable clipping
  if(!gadget.val.boolean()) then
    if (!view.clipPlanesAllOff) then
      !form.clipbox.enable()
    else
      do !i to 6
        if (!form.clipPlanes[!i].enabled) then
          -- Re-enable clipping plane
          !form.clipPlanes[!i].enable(TRUE)
        endif
      enddo
    endif
  else
    if (!view.clipPlanesAllOff) then
      !form.clipbox.disable()
    else
      !view.clipping = FALSE
    endif
  endif

endmethod
-- End of method definition for .clipButton(GADGET, STRING)

------------------------------------------------------------------------
--
-- Method:      clipboxPacket
--
-- Description: Clipbox packet
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
-- Return:
--   [Data Type] [Description]
--    EDGPACKET   Packet continuing data
--
------------------------------------------------------------------------

define method .clipboxPacket(!view is GADGET) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key         = 'clipboxPacket'
  !packet.description = 'Graphic Clipbox'
  !packet.type        = 'gph'
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'

  -- Origin
  !packet.action      = '!!gphviews.clipboxElement(!this.return[1], !this.return[2].item)'
  !packet.remove      = TRUE
  !packet.pickPacket.stdElement('Pick item to define clipbox')

  -- Set priority
  !packet.priority    = 3

  -- Return
  return !packet

endmethod
-- End of method definition for .clipboxPacket(GADGET) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      clipboxLimitsPacket
--
-- Description: Clipbox packet for defining limits
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget to be windowed in on
-- Return:
--   [Data Type] [Description]
--    EDGPACKET   Packet data
--
------------------------------------------------------------------------

define method .clipboxLimitsPacket(!view is GADGET) is EDGPACKET

  -- Set Data
  !fullName = '!!' & !view.owner().name() & '.' & !view.name()
  !packet                = object EDGPACKET()
  !packet.key         = 'clipboxPacket'
  !packet.description = 'Graphic Clipbox'
  !packet.type        = 'gph'
  !packet.initialisation = '!this.setupWithView(' & !fullName & ')'

  -- Origin
  !packet.action      = '!!gphviews.clipboxElement(!this.return[1], object VOLUME(!this.return[2][1].position.wrt(World), !this.return[2][2].position.wrt(World)))'

  !packet.remove      = TRUE

  -- Set priority
  !packet.priority    = 3

  -- Define pick packet
  !packet.pickPacket  = object EDGPICKPACKET()

  -- Set Data
  !packet.pickPacket.key         = 'clipboxPacket'
  !packet.pickPacket.description = 'Define clipbox limits'
  !packet.pickPacket.prompt      = 'Clipbox limits'
  !packet.pickPacket.picks.clear()
  !packet.pickPacket.picks[1]    = object EDGPICKTYPE()
  !packet.pickPacket.picks[1].stdPosition('from')
  !packet.pickPacket.picks[2]    = object EDGPICKTYPE()
  !packet.pickPacket.picks[2].stdPosition('to')

  -- Return
  return !packet

endmethod
-- End of method definition for .clipboxLimitsPacket(GADGET) EDGPACKET

------------------------------------------------------------------------
--
-- Method:      clipbox
--
-- Description: Turn clipbox on/off (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--    EDGPACKET   Packet continuing data
--
------------------------------------------------------------------------

define method .clipbox(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form    = !menu.owner()
  !view    = !form.view
  !option  = !menu.pickedField

  -- Options
  -- Clip Visibility
  if(!option.upcase() eq 'ENABLE') then

    -- Enable Clipping
    if(!selected eq 'SELECT') then
      if (!view.clipPlanesAllOff) then
        !form.clipbox.enable()
      else
        -- Clip planes are enabled if they have been defined, even if clipping is off
        do !i to 6
          if (!form.clipPlanes[!i].enabled) then
            -- Re-enable clipping plane as this ensures clip planes are active
            !form.clipPlanes[!i].enable(TRUE)
          endif
        enddo
      endif
    else
      if (!view.clipPlanesAllOff) then
        !form.clipbox.disable()
      else
        -- Don't disable individual clipping planes, just switch off clipping
        !view.clipping = FALSE
      endif
    endif

    -- Clip Capping
  elseif (!option.upcase() eq 'CAPPED') then

    -- Enable Clip Capping
    if(!selected eq 'SELECT') then
      if (!view.clipPlanesAllOff) then
        !form.clipbox.capOn()
      else
        do !i to 6
          !form.clipPlanes[!i].capOn()
        enddo
      endif
    else
      if (!view.clipPlanesAllOff) then
        !form.clipbox.capOff()
      else
        do !i to 6
          !form.clipPlanes[!i].capOff()
        enddo
      endif
    endif

    -- Clip Cap Colour
  elseif (!option.upcase().match('COLOUR') gt 0) then

    !command   = '!!gphviews.clipCapColour(!!' & !form & ', !!colourSelectGet())'
    !title     = 'Clip Cap Colour'
    !refColour = !form.clipbox.capColour.code
    if(!refColour.unset()) then
      !refColour = 1
    endif

    -- Display colour selection form
    call !!colourSelectLoad(!command, !title, !refColour)

  endif

endmethod
-- End of method definition for .clipbox(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      clipCapColour
--
-- Description: Set clip cap colour
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        View form
--    1   R      REAL        Colour
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipCapColour(!form is FORM, !colour is REAL)

  -- Set clip cap colour
  if (!form.view.clipPlanesAllOff) then
    !form.clipbox.capColour(!!colourSelectGet())
  else
    do !i to 6
      !form.clipPlanes[!i].capColour(!!colourSelectGet())
    enddo
  endif

endmethod
-- End of method definition for .clipCapColour(FORM, REAL)

------------------------------------------------------------------------
--
-- Method:      clipboxElement
--
-- Description: Setup clipbox to element (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxElement(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form    = !menu.owner()
  !view    = !form.view
  !option  = !menu.pickedField

  -- Current Element
  if(!option.upcase() eq 'CE') then
    !element = !!ce

    -- Owning Item
  else
    !element = !!ce.owner
  endif

  -- Clip element
  !this.clipboxElement(!view, !element)

endmethod
-- End of method definition for .clipboxElement(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      clipboxElement
--
-- Description: Setup clipbox for view to passed element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View
--    2   R      DBREF       Item clipbox is to encompass
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxElement(!view is GADGET, !element is DBREF)

  -- Get volume of element
  !volume   = object VOLUME(!element)

  -- Check for unset volume
  if(!volume.unset()) then

    -- Get view radius
    !radius   = !view.radius / 2

    -- Assume 1M about the position of the item
    !position = !element.position.wrt(World)
    handle ANY
      !!alert.warning('Element does not have volume or position.')
      return
    endhandle

    -- Define 1M cube about position
    !from       = !position
    !from.east  = !from.east  - $!<radius>mm
    !from.north = !from.north - $!<radius>mm
    !from.up    = !from.up    - $!<radius>mm
    !to         = !position
    !to.east    = !to.east    + $!<radius>mm
    !to.north   = !to.north   + $!<radius>mm
    !to.up      = !to.up      + $!<radius>mm
    !volume     = object VOLUME(!from, !to)
  endif

  !this.clipboxElement(!view, !volume)

endmethod
-- End of method definition for .clipboxElement(GADGET, DBREF)

------------------------------------------------------------------------
--
-- Method:      clipboxElement
--
-- Description: Setup clipbox for view to passed element
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View
--    2   R      VOLUME      Item clipbox is to encompass
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxElement(!view is GADGET, !volume is VOLUME)

  -- Initialise Variables
  !form    = !view.owner()

  -- Set clip box
  !form.clipbox.box = !volume.box()

  -- Action the clip box
  !form.clipbox.set()

  -- Enable clip
  !form.clipbox.enable()

endmethod
-- End of method definition for .clipboxElement(GADGET, VOLUME)

------------------------------------------------------------------------
--
-- Method:      clipboxExplicit
--
-- Description: Show explicit clipbox definition form (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxExplicit(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()

  -- Load form if not previously loaded
  if(undefined(!!gphClipboxEdit)) then
    pml load form !!gphClipboxEdit
  endif

  -- Define EDG positional pick
  !packet                = object EDGPACKET()
  !packet.positionLink('!!gphClipboxEdit.position', 'Clipbox origin')
  !packet.key            = 'clipboxPacket'
  !packet.description    = 'Graphic Clipbox'
  !packet.input[1]       = !form.clipbox
  !packet.initialisation = '!!gphClipboxEdit.setup(!this.input[1])'
  !packet.type           = 'gph'
  !packet.form           = !!gphClipboxEdit
  !packet.remove         = FALSE

  -- Set priority
  !packet.priority       = 2

  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .clipboxExplicit(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      clipboxEdit
--
-- Description: Show explicit clipbox definition form for given view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form containing view
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxEdit(!form is FORM)

  -- Load form if not previously loaded
  if(undefined(!!gphClipboxEdit)) then
    pml load form !!gphClipboxEdit
  endif

  !!gphClipboxEdit.setup(!form.clipbox)
  if( !!gphClipboxEdit.shown() ) then
    !!gphClipboxEdit.initialise()
  else
    show !!gphClipboxEdit
  endif

endmethod
-- End of method definition for .clipboxEdit(FORM)

------------------------------------------------------------------------
--
-- Method:      clipboxBox
--
-- Description: Set clipbox to a "box" (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxBox(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form    = !menu.owner()
  !view    = !form.view
  !option  = !menu.pickedField

  -- Options
  -- Current Limits Box
  if(!option.upcase() eq 'LIMITS BOX') then

    !this.clipboxViewLimits(!view)

  else

    -- Action the clip box
    !form.clipbox.set()
    -- Enable clip
    !form.clipbox.enable()

  endif

endmethod
-- End of method definition for .clipboxBox(MENU, STRING)
------------------------------------------------------------------------
--
-- Method:      clipboxViewLimits
--
-- Description: Set clipbox to view limits
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxViewLimits(!view is GADGET) is CLIPBOX

  -- Initialise Variables
  !form    = !view.owner()

  -- Current Limits Box
    -- Limits are stored without units, but units are MM
    !limits          = !view.limits

    !limitsX       = (!limits[1] + !limits[2]) * 0.5
    !limitsY       = (!limits[3] + !limits[4]) * 0.5
    !limitsZ       = (!limits[5] + !limits[6]) * 0.5

    !limitsXLength = !limits[2] - !limits[1]
    !limitsYLength = !limits[4] - !limits[3]
  !limitsZLength = !limits[6] - !limits[5]

    -- set clip box converted to current units
    !form.clipbox.box.position.east  = !!comConvertUnknownValue(!limitsX,'mm')
    !form.clipbox.box.position.north = !!comConvertUnknownValue(!limitsY,'mm')
    !form.clipbox.box.position.up    = !!comConvertUnknownValue(!limitsZ,'mm')

    !form.clipbox.box.xLength        = !!comConvertUnknownValue(!limitsXLength,'mm')
    !form.clipbox.box.yLength        = !!comConvertUnknownValue(!limitsYLength,'mm')
    !form.clipbox.box.zLength        = !!comConvertUnknownValue(!limitsZLength,'mm')

    !form.clipbox.box.orientation    = object ORIENTATION('Y is N')

  -- Action the clip box
  !form.clipbox.set()

  -- Enable clip
  !form.clipbox.enable()

endmethod
-- End of method definition for .clipboxViewLimits(GADGET)

------------------------------------------------------------------------
--
-- Method:      clipboxPick
--
-- Description: Setup edg event for picking clip box (menu selection)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipboxPick(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !option = !menu.pickedField.upcase()

  -- Packet for picking item
  if(!option eq 'PICK ITEM') then

    !packet = !this.clipboxPacket(!view)

    -- Packet for picking limits
  elseif (!option eq 'PICK LIMITS') then

    !packet = !this.clipboxLimitsPacket(!view)

  endif

  -- Add packet to event stack
  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .clipboxPick(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      clipPlanes
--
-- Description: Setup clip planes
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .clipPlanes(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form    = !menu.owner()

  -- Load form if not previously loaded so can initialise its parent member
  if(undefined(!!gphClipPlaneEdit)) then
    pml load form !!gphClipPlaneEdit
  endif
  !!gphClipPlaneEdit.setup(!form)
  show !!gphClipPlaneEdit

endmethod
-- End of method definition for .clipPlanes(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      drawlistButton
--
-- Description: Drawlist button action
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Button
--    2   R      STRING      Selection
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawlistButton(!gadget is GADGET, !selected is STRING)

  -- Get source view data
  !sourceView = !gadget.owner().view
  !token = !!gphDrawlists.token(!sourceView)

  -- Hide object on next pick (so can hide in middle of current EDG pick)
  !packet = object EDGPACKET()
  !packet.elementPick(|Hide element|)
  !packet.action = |!!gphviews.drawlistButtonPick(| & !token & |, !this.return[1].item)|
  !packet.remove  = TRUE
  !!edgCntrl.add(!packet)

endmethod
-- End of method definition for .drawlistButton(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      drawlistButtonPick
--
-- Description: EDG pick action for drawlist button
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      REAL        Drawlist token
--    2   R      DBREF       Picked element
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawlistButtonPick(!token is REAL, !pickedElement is DBREF)

  -- Get to a primary type
  !element = !pickedElement
  do
    break if (!element.primtype)
    !element = !element.owner
  enddo

  -- Hide the element
  !!gphDrawlists.drawlist(!token).visibility(!element, FALSE)

endmethod
-- End of method definition for .drawlistButtonPick, STRING)

------------------------------------------------------------------------
--
-- Method:      drawlistMenu
--
-- Description: Drawlist menu actions
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Menu
--    2   R      STRING      Selection
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawlistMenu(!menu is MENU, !selected is STRING)

  -- Get source view data
  !sourceView = !menu.owner().view

  if (!menu.pickedFieldName eq |**1|) then

    -- Show last hidden object
    !drawlist = !!gphDrawlists.drawlist(!sourceView)
    !drawlist.showLastHidden()

  elseif (!menu.pickedFieldName eq |**2|) then

    -- Show all hidden objects
    !drawlist = !!gphDrawlists.drawlist(!sourceView)
    !hiddenObjects = !drawlist.hidden()
    !drawlist.visibility(!hiddenObjects, TRUE)

  elseif (!menu.pickedFieldName eq |**3|) then

    -- Show hidden objects form
    if(undefined(!!gphHiddenList)) then
      pml load form !!gphHiddenList
    endif
    !!gphHiddenList.setup(!sourceView)
    show !!gphHiddenList

  elseif (!menu.pickedFieldName eq |**4|) then

    -- Create a new view with a new drawlist populated from the graphical selection
    !form = !this.addDesignForm()
    !token = !!gphDrawlists.createDrawlist()
    !!gphDrawlists.attachView(!token, !form.view)
    !selection = object SELECTION()
    !selection.getCurrent()
    !members = !selection.getSelection()
    !!gphDrawlists.drawlist(!token).addOnlyMembers(!members)
    !!gphDrawlists.drawlist(!token).followSelection(TRUE)

    -- Setup the view
    if (!members.empty().not()) then
      !volume = object VOLUME(!members)
      if(!volume.unset()) then
        !form.view.limits = !sourceView.limits
      else
        !this.limits(!form.view, !volume)
      endif
    else
      !form.view.limits = !sourceView.limits
    endif
    !form.view.direction = !sourceView.direction

  elseif (!menu.pickedFieldName eq |**5|) then

    -- Create a new view with the same drawlist
    !form = !this.addDesignForm()
    !!gphDrawlists.attachView(!!gphDrawlists.token(!sourceView), !form.view)

    -- Setup the view
    !form.view.limits    = !sourceView.limits
    !form.view.direction = !sourceView.direction

  elseif (!menu.pickedFieldName eq |**6|) then

    -- Drawlist form
    !this.drawlist(!sourceView)

  elseif (!menu.pickedFieldName eq |**7|) then

    -- Representation form
    if(undefined(!!gphDrawlistRep)) then
      pml load form !!gphDrawlistRep
    endif
    !!gphDrawlistRep.setup(!sourceView)
    show !!gphDrawlistRep

  endif

endmethod
-- End of method definition for .drawlistMenu(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      drawlist
--
-- Description: Show drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawlist(!view is GADGET)

  -- Drawlist form (setup and force re-initialisation)
  if(undefined(!!gphDrawlist)) then
    pml load form !!gphDrawlist
  endif
  !!gphDrawlist.setup(!view)
  if (!!gphDrawlist.shown()) then
    hide !!gphDrawlist
  else
    show !!gphDrawlist
  endif

endmethod
-- End of method definition for .drawlist(GADGET)

------------------------------------------------------------------------
--
-- Method:      drawlist
--
-- Description: Show drawlist for current view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .drawlist()

  -- Display drawlist for the currently selected view
  if (!!gphviews.views.empty()) then
    return error 1 'No current view'
  else
    !form = !!fmsys.currentDocument()
    handle ANY
      return error 1 'No current view'
    elsehandle NONE
      if (!form.set()) then
        !this.drawlist(!form.view)
      endif
    endhandle
  endif

endmethod
-- End of method definition for .drawlist()

------------------------------------------------------------------------
--
-- Method:      axesButton
--
-- Description: Set world axes property of view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      Button
--    2   R      STRING      Selection
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .axesButton(!gadget is GADGET, !select is STRING)

  -- Initialise Variables
  !form    = !gadget.owner()
  !view    = !form.view

  -- Set world axes property
  !view.showAxes = !gadget.val.boolean()

endmethod
-- End of method definition for .axesButton(GADGET, STRING)

------------------------------------------------------------------------
--
-- Method:      graphicsToggles
--
-- Description: Set graphic view toggle settings
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .graphicsToggles(!menu is MENU, !select is STRING)

  !view = !menu.owner().view
  !menu.select('Eye  F7', !view.eyeMode)
  !menu.select('Shaded  F11', !view.shaded)
  !menu.select('Perspective  F4', !view.projection eq 'PERSPECTIVE')


endmethod
-- End of method definition for .graphicsToggles(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      doMenuAction
--
-- Description: Action menu setting
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .doMenuAction(!menu is MENU, !select is STRING)

  !field = !menu.pickedField
  !view = !menu.owner().view

  if ( !field eq 'Eye  F7' ) then
    !view.eyeMode = not !view.eyeMode

  elseif ( !field eq 'Shaded  F11' ) then
    !view.shaded = not !view.shaded

  elseif ( !field eq 'Perspective  F4' ) then
    if (!view.projection eq 'PARALLEL') then
      !view.projection = 'PERSPECTIVE'
    else
      !view.projection = 'PARALLEL'
    endif

  elseif ( !field eq 'Zoom  F2' ) then
    !view.mouseMode = 'Zoom'

  elseif ( !field eq 'Pan  F3' ) then
    !view.mouseMode = 'Pan'

  elseif ( !field eq 'Rotate  F5' ) then
    !view.mouseMode = 'Rotate'

  elseif ( !field eq 'Walk  F6' ) then
    !view.mouseMode = 'Walk'

  elseif ( !field eq 'Save 1') then
    !view.saveView(1)

  elseif ( !field eq 'Save 2') then
    !view.saveView(2)

  elseif ( !field eq 'Save 3') then
    !view.saveView(3)

  elseif ( !field eq 'Save 4') then
    !view.saveView(4)

  elseif ( !field eq 'Restore 1') then
    !view.restoreView(1)

  elseif ( !field eq 'Restore 2') then
    !view.restoreView(2)

  elseif ( !field eq 'Restore 3') then
    !view.restoreView(3)

  elseif ( !field eq 'Restore 4') then
    !view.restoreView(4)

  endif

endmethod
-- End of method definition for .doMenuAction(MENU, STRING)
------------------------------------------------------------------------
--
-- Method:      saveViews
--
-- Description: Save definition views
--
-- Method Type: Function/Procedure
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .saveViews()
  !data = ARRAY()
  do !view values !this.views
    -- Ignore views on forms that have been killed
    !unusedViewOwner = !view.owner()
    handle ANY
      -- Attempt to reference non-existent object
      skip
    endhandle
    -- Do not save Clasher view
    if (defined(!!cDCLACHK)) then
      skip if (!view.owner() eq !!cDCLACHK )
    endif
    -- Do not save Integrator view
    skip if (!view.owner().formTitle eq |Integrator 3D View|)
    --Do not save ARF view
    skip if (!view.owner().formTitle.MatchWild(|*Graphical Explorer View*|))
    -- Set view limits
    !data.append( |!limits = ARRAY()| )
    do !limit values !view.limits
      !data.append( |!limits.append(| & !limit & |)| )
    enddo
    !data.append( !view.fullName() & |.limits = !limits| )

    -- Set view direction
    !data.append( |!direction = ARRAY()| )
    do !component values !view.direction
      !data.append( |!direction.append(| & !component & |)| )
    enddo
    !data.append( !view.fullName() & |.direction = !direction| )

    -- Set Through
    !data.append (|!through = ARRAY()| )
    do !i values !view.through
      !data.append( |!through.append(| & !i & |)| )
    enddo
    !data.append( !view.fullName() & |.through = !through| )


    -- Set shaded
    !shaded = !view.shaded
    !data.append( !view.fullName() & |.shaded = | & !shaded )
    -- Set Borders
    !borders = !view.borders
    !data.append( !view.fullName() & |.borders = | & !borders )
    -- Set eyeMode
    !eyeMode = !view.eyeMode
    !data.append( !view.fullName() & |.eyeMode = | & !eyeMode )
    -- Set mouseMode
    !mouseMode = !view.mouseMode
    !data.append( !view.fullName() & |.mouseMode = | & |'| & !mouseMode & |'| )
    -- Set background
    !background = !view.background
    !data.append( !view.fullName() & |.background = | & !background )
    -- Set projection
    !projection = !view.projection
    !data.append( !view.fullName() & |.projection = | & |'| & !projection & |'| )
    -- Set walkthrough
    !walkthrough = !view.walkthrough
    !data.append( !view.fullName() & |.walkthrough = | & !walkthrough )
    -- Set highlight
    !highlight = !view.highlight
    !data.append( !view.fullName() & |.highlight = | & !highlight )
    -- Set global axes
    !showAxes = !view.showAxes
    !data.append( !view.fullName() & |.showAxes = | & !showAxes )
    -- Set label style
    !labelStyle = !view.labelStyle
    !data.append( !view.fullName() & |.labelStyle = | & |'| & !labelStyle & |'| )
    -- Set clipPlanesAllOff
    !clipPlanesAllOff = !view.clipPlanesAllOff
    !data.append( !view.fullName() & |.clipPlanesAllOff = | & !clipPlanesAllOff )
    !data.appendArray(!view.owner().clipbox.save())
    handle ANY
      -- Form may have no clipbox
    endhandle
    do !i to 6
      !data.appendArray(!view.owner().clipPlanes[!i].save())
      handle ANY
        -- Form may have no clipplanes
      endhandle
    enddo
  enddo

  -- This is what save display used to do
  var !toleranceAngle tol ang
  !data.append( |tol ang $!toleranceAngle| )
  var !toleranceOffset tol off
  !data.append( |tol off $!toleranceOffset| )
  var !toleranceRatio tol rat
  !data.append( |tol ratio $!toleranceRatio| )
  var !hoff hoff
  !data.append( |hoffset $!hoff| )
  var !wgrid wgrid
  !data.append( |wgrid $!wgrid| )
  -- Ignore error if wgrid references an element that no longer exists
  !data.append( |handle ANY| )
  !data.append( |endhandle|  )
  -- Output to file
  !module   = !!module().appkey
  !project  = current project
  !projCode = !project.code().lowcase()
  var !mdb mdb
  !mdb = !mdb.after('/')
    --account for instances where a user may have used a forward slash in the mdbname (not common)
    --rename any occurrences with '_F-S_'
    !mdb = !mdb.replace('/', '_F-S_')
  !fileName = '%AVEVA_DESIGN_USER%\' & !module & '-' & !projCode & '-' & !mdb & '-gphviews.pmldat'

  !file = object FILE(!fileName)
  !file.writeFile(|OVERWRITE|, !data)

endmethod

------------------------------------------------------------------------
--
-- Method:      SaveRestoreViews
--
-- Description: Show Save & Restore View form
--
-- Method Type: Function/Procedure
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .saveRestoreViews()

  show !!saveRestoreView

endmethod

------------------------------------------------------------------------
--
-- Method:      advancedViewControl
--
-- Description: Show advanced view control form
--
-- Method Type: Function/Procedure
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .advancedViewControl()

  if (undefined(!!comSpaceManagement)) then
    pml reload form !!comSpaceManagement
  endif

  if (!!comSpaceManagement.shown()) then
    hide !!comSpaceManagement
  endif

  -- set the forms .currentForm member which stores the form and hence view that we are currently editing
  -- without this we have trouble with editing multiple view layouts
  !!comSpaceManagement.setCurrentForm()

  show !!comSpaceManagement

endmethod

------------------------------------------------------------------------
--
-- Method:      restoreViews
--
-- Description: Restore definition of view
--
-- Method Type: Function/Procedure
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .restoreViews()
  -- Run in file
  !module   = !!module().appkey
  !project  = current project
  !projCode = !project.code().lowcase()
  var !mdb mdb
  !mdb = !mdb.after('/')
    --account for instances where a user may have used a forward slash in the mdbname (not common)
    --rename any occurrences with '_F-S_'
    !mdb = !mdb.replace('/', '_F-S_')
  !fileName = '%AVEVA_DESIGN_USER%\' & !module & '-' & !projCode & '-' & !mdb & '-gphviews.pmldat'
  -- Restore views
  !!runMacro(|$!fileName|, ||)
  handle ANY
  endhandle

endmethod

------------------------------------------------------------------------
--
-- Method:      convertVolumeToLimits
--
-- Description: Set limits to volume
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      VOLUME      Explicit Volume
-- Return:
--   [Data Type] [Description]
--    ARRAY       Limits array
--
------------------------------------------------------------------------

define method .convertVolumeToLimits(!volume is VOLUME) is ARRAY

  -- Load view limits with Volume
  !array[1]    = !volume.from.east.dbUnits().value()
  !array[2]    = !volume.to.east.dbUnits().value()
  !array[3]    = !volume.from.north.dbUnits().value()
  !array[4]    = !volume.to.north.dbUnits().value()
  !array[5]    = !volume.from.up.dbUnits().value()
  !array[6]    = !volume.to.up.dbUnits().value()

  -- return view Limits
  return !array

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      refreshAllViews
--
-- Description: refresh all views
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .refreshAllViews()

  -- refresh each view
  do !view values !this.views
    !view.refresh()
    handle ANY
    endhandle
  enddo

endmethod
-- End of method

------------------------------------------------------------------------
--
-- Method:      remAll
--
-- Description: Remove all from drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .remAll()

!drawlistToken = !!gphDrawlists.token(!!fmsys.currentDocument().view)
!drawlist = !!gphDrawlists.drawlist(!drawlistToken)
!drawlist.removeall()

endmethod

------------------------------------------------------------------------
--
-- Method:      setAntiAlias
--
-- Description: Set anti-alias for all views
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     True to switch on - false to switch off
--    2   R      REAL        Anti-alias Level
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setAntiAlias(!antiAlias is BOOLEAN, !antiAliasLevel is REAL)

  -- refresh each view
  do !view values !this.views

    !view.antiAlias         = !antiAlias
      handle ANY
      endhandle

    !view.antiAliasSampling = !antiAliasLevel
      handle ANY
      endhandle

  enddo

endmethod

------------------------------------------------------------------------
--
-- Method:      setShadows
--
-- Description: Set shadows for all views
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      BOOLEAN     True to switch on - false to switch off
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setShadows(!onOff is BOOLEAN)

  -- Refresh each view
  do !view values !this.views

    !view.shadows = !onOff
      handle ANY
      endhandle

  enddo

endmethod

------------------------------------------------------------------------
--
-- Method:      setHighlightCol(COLOUR)
--
-- Description: Set highlight colour for all views
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1n  R      COLOUR      Highlight colour
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setHighlightCol(!colour is COLOUR)

  -- refresh each view
  do !view values !this.views
    !view.highlight = !colour.code
    handle any
      skip
    endhandle
  enddo

endmethod
