  !form.sisoMenu.add('callback', 'Three',       '!!gphviews.isometric(')
  !form.sisoMenu.add('callback', 'Four',        '!!gphviews.isometric(')

  !form.slimitsMenu.add('callback', 'CE',          '!!gphviews.limitsElement(')
