--
-- Description: Object for graphic view control
--
-- NOTE : All packet methods will be actioned in the edgPacket object,
--        therefore, any action for methods outside edgPacket must be
--        referred to fully (NOT in terms of !this).
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  add(FORM)                        -                   Add view into the system
--  add(GADGET)                      -                   Add view into the system
--  addDesign()                      -                   Add standard design form  into the system
--  addDesignForm()                  FORM                Add standard design form  into the system
--  addDesignForm(BOOLEAN)           FORM                Add standard design form  into the system
--  addNavigate()                    -                   Add standard navigate form  into the system
--  advancedViewControl()            -                   Show advanced view control form
--  align(STRING)                    -                   MDS Only - Setup edg event for aligning a MDS Framework Support
--  auto(MENU,STRING)                -                   Auto view (menu selection)
--  axesButton(GADGET,STRING)        -                   Set world axes property of view
--  bar(FORM)                        -                   Next available view number
--  checkAddDesign(STRING)           -                   Check and add standard design form into the system if not already defined
--  clipBoxModify(FORM,BOOLEAN)      -                   Manage clip box modification settings across all view
--  clipButton(GADGET,STRING)        -                   Clipping activated from form button
--  clipCapColour(FORM,REAL)         -                   Set clip cap colour
--  clipPlanes(MENU,STRING)          -                   Setup clip planes
--  clipbox(MENU,STRING)             -                   Turn clipbox on/off (menu selection)
--  clipboxBox(MENU,STRING)          -                   Set clipbox to a "box" (menu selection)
--  clipboxEdit(FORM)                -                   Show explicit clipbox definition form for given view
--  clipboxElement(GADGET,DBREF)     -                   Setup clipbox for view to passed element
--  clipboxElement(GADGET,VOLUME)    -                   Setup clipbox for view to passed volume
--  clipboxElement(MENU,STRING)      -                   Setup clipbox to element (menu selection)
--  clipboxExplicit(MENU,STRING)     -                   Show explicit clipbox definition form (menu selection)
--  clipboxLimitsPacket(GADGET)      EDGPACKET           Clipbox packet for defining limits
--  clipboxPacket(GADGET)            EDGPACKET           Clipbox packet
--  clipboxPick(MENU,STRING)         -                   Setup edg event for picking clip box (menu selection)
--  clipboxViewLimits(GADGET)        CLIPBOX             Set clipbox to view limits
--  close(FORM)                      -                   Close the passed view/form down
--  close(MENU,STRING)               -                   Close the passed view/form down
--  colour(MENU,STRING)              -                   Show view colour settings form (menu selection)
--  convertVolumeToLimits(VOLUME)    ARRAY               Set limits to volume
--  copy(GADGET,GADGET)              -                   Copy last picked view into current view
--  copy(MENU,STRING)                -                   Setup edg event to copy view
--  copyDesignForm(FORM)             FORM                Copy standard design form and add to the system
--  copyDesignForm(FORM,BOOLEAN)     FORM                Copy standard design form and add to the system
--  copyDesignFormView(FORM,BOOLEAN) FORM
--  copyDesignFormView(FORM,BOOLEAN,BOOLEAN) FORM
--  copyPacket(GADGET)               EDGPACKET           Copy pick view setting and apply to passed view
--  doMenuAction(MENU,STRING)        -                   Action menu setting
--  drawlist()                       -                   Show drawlist for current view
--  drawlist(GADGET)                 -                   Show drawlist
--  drawlistButton(GADGET,STRING)    -                   Create a new view with a local drawlist containing the current graphical selection
--  drawlistButtonPick(REAL,DBREF)   -                   EDG pick action for drawlist button
--  drawlistMenu(MENU,STRING)        -                   Drawlist menu
--  findFormWithPurpose(STRING)      ARRAY               Find a form with given purpose (not case sensitive)
--  fromDrawlist(MENU,STRING)        -                   Remove an item from the drawlist (menu selection)
--  globalInstance()                 -                   Create global instance of object
--  graphicsToggles(MENU,STRING)     -                   Set graphic view toggle settings
--  isometric(MENU,STRING)           -                   Set the view into an isometric view (menu selection)
--  lMenus(FORM)                     -                   Build long menus
--  limits(GADGET,DBREF)             -                   Set limits to element
--  limits(GADGET,VOLUME)            -                   Set limits to volume
--  limitsBox(MENU,STRING)           -                   Set the view limits to a "box"
--  limitsElement(MENU,STRING)       -                   Setup the view limits to a db element
--  limitsExplicit(MENU,STRING)      -                   Show the explicit view limits form
--  limitsList(MENU,STRING)          -                   Set the view limits to a "list"
--  limitsPacket(GADGET)             EDGPACKET           Graphic window limits
--  limitsPick(MENU,STRING)          -                   Setup edg event for picking the limits
--  limitsRestore(MENU,STRING)       -                   Restore view limits definition
--  longMenus(MENU,STRING)           -                   Build long menus
--  look(GADGET,DIRECTION)           -                   Set view to specified direction
--  look(MENU,STRING)                -                   Set the view direction (menu selection)
--  lookExplicit(MENU,STRING)        -                   Show the view direction explicit form (menu selection)
--  measure(STRING)                  -                   Setup edg event for widowing in
--  navigate()                       BOOLEAN             Single pick navigation
--  navigate(BOOLEAN)                BOOLEAN             Single pick navigation
--  nextAvailable()                  REAL                Next available view number
--  plan(MENU,STRING)                -                   Set the view direction into a "plan" view (menu selection)
--  refreshAllViews()                -                   refresh all views
--  remAll()                         -                   Remove all from drawlist
--  remove(GADGET)                   -                   Add view into the system
--  restoreViews()                   -                   Restore definition of view
--  rotate(GADGET,ARRAY)             -                   Set rotation in its rawest sense
--  rotate(GADGET,POSITION)          -                   Rotate about a position
--  rotate(GADGET,VOLUME)            -                   Rotate about a position
--  rotateBox(MENU,STRING)           -                   Set view rotation about a box
--  rotateElement(MENU,STRING)       -                   Set view rotation about an item
--  rotateExplicit(MENU,STRING)      -                   Show view explicit rotation form
--  rotatePacket(GADGET,STRING)      EDGPACKET           Graphic window packet
--  rotatePick(MENU,STRING)          -                   Setup edge event for rotation
--  sMenus(FORM)                     -                   Build short menus
--  saveRestoreViews()               -                   Show Save & Restore View form
--  saveViews()                      -                   Save the 3d graphical view information
--  setAntiAlias(BOOLEAN,REAL)       -                   Set anti-alias for all views
--  setHighlightCol(COLOUR)          -                   Set highlight colour for all views
--  setShadows(BOOLEAN)              -                   Set shadows for all views
--  tag(STRING)                      -                   Tag elements
--  toDrawlist(MENU,STRING)          -                   Add to drawlist (menu selection)
--  viewIndex(GADGET)                REAL                Window using the window store data
--  window(ARRAY)                    -                   Window using the window store data
--  window(MENU,STRING)              -                   Setup edg event for widowing in
--  windowPacket(GADGET)             EDGPACKET           Graphic window packet
--
------------------------------------------------------------------------

-- Define object
define object GPHVIEWS

  -- List of graphical views
  member .views         is ARRAY

  -- List of forms owning the views
  --  member .forms         is ARRAY

  -- Active view
  member .activeView    is GADGET

  -- Selected views
  member .selectedViews is ARRAY

endobject
-- End of object definition for gphviews

------------------------------------------------------------------------
--
-- Method:      globalInstance
--
-- Description: Create global instance of object
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .globalInstance()

  -- Create Global Variable
  !!gphviews    = !this

  -- Load global object related to graphics

  -- Check the aid data is loaded
  if(undefined(!!aidNumbers)) then
    !aidNumber = object AIDNUMBERS()
    !aidNumber.globalInstance()
  endif

endmethod
-- End of method definition for .globalInstance()

------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add view into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .add(!view is GADGET)

  -- Add view/form to system
  if (!this.views.find(!view).unset()) then
    !this.views.append(!view)
  endif

  -- Update control form if exists and shown
  if(defined(!!gphControl)) then
    if(!!gphControl.shown()) then
      !!gphControl.initialise()
    endif
  endif

  -- Make sure view settings is removed before the new view is created
  -- otherwise show form will crash
  if(defined(!!viewSettings)) then
    if(!!viewSettings.shown()) then
      !!viewSettings.hide()
    endif
  endif

  -- show new 3D view form
  !view.owner().show('AT', 0, 0)

  -- If form is an "design" form, then add to edg system
  if(defined(!view.owner().type)) then
    if(!view.owner().type.upcase() eq 'DESIGN') then

      -- Is the EDG system load
      if(undefined(!!edgCntrl)) then
        !edgCntrl = object EDGCNTRL()
        !edgCntrl.globalInstance()
      endif

      -- Add into edg system
      !!edgCntrl.addView(!view)
    endif
  endif

endmethod
-- End of method definition for .add(GADGET)

------------------------------------------------------------------------
--
-- Method:      add
--
-- Description: Add view into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form view gadget is on
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .add(!form is FORM)

  -- Scan form for graphical view
  !members = !form.attributes()
  do !member values !members
    !memberType = !form.attribute(!member.upcase()).type()
    handle ANY
      skip
    endhandle

    -- Check for G3D gadget types
    if(!memberType inset('G3D','GM3D')) then
      !view = !form.attribute(!member.upcase())

      -- Add view/form to system
      !this.add(!view)
      return
    endif
  enddo

  -- If there is no view defined, then abort
  !!alert.error('Unable to find 3D graphical view form.')
  return error 1 noalert

endmethod
-- End of method definition for .add(FORM)

------------------------------------------------------------------------
--
-- Method:      findFormWithPurpose
--
-- Description: Find a form with given purpose (not case sensitive)
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      Form purpose
-- Return:
--   [Data Type] [Description]
--    FORM       Array of FORM objects with purpose, or empty if none found
--
------------------------------------------------------------------------

-- Define method
define method .findFormWithPurpose(!purpose is STRING) is ARRAY

  !result = ARRAY()

  -- Scan for form with given purpose
  do !view values !this.views
    !form = !view.owner()
    handle ANY
      skip
    endhandle

    -- test view purpose against given string
    !found = !form.viewPurpose.upcase().trim().eq(!purpose.upcase().trim())
    handle any
      !found = false
    endhandle
    if(!found) then
      !result.append(!form)
    endif
  enddo

  return !result

endmethod
-- End of method definition for .add(FORM)

------------------------------------------------------------------------
--
-- Method:      clipBoxModify
--
-- Description: Manage clip box modification settings across all view
--              Switch on/off clip box for given view
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        View Form owning clipBox
--    2   R      BOOLEAN     True - on; false - off
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .clipBoxModify(!clipForm is FORM, !clipBoxOn is BOOLEAN)

  if( !clipBoxOn ) then
    -- modify can only be on in one view (per drawlist)
    do !view values !this.views
      !form = !view.owner()
      handle ANY
        skip
      endhandle

      skip if(!form eq !clipForm)

      -- test clip box modify setting
      !active = !form.clipBox.active()
      handle any
        skip
      endhandle
      if( !active ) then
        -- switch off modify in this view
        !form.clipBox.active(false)
      endif
    enddo
  endif

  -- set clipping box visibility for given form view
  !clipForm.clipBox.active(!clipBoxOn)
  handle any
  endhandle



endmethod
-- End of method definition for .add(FORM)

------------------------------------------------------------------------
--
-- Method:      copyDesignForm
--
-- Description: Copy standard design form and add to the system with new or existing drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form to be copied
--    2   R      BOOLEAN     True to make new drawlist, false for new view on existing drawlist
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------

-- Define method
define method .copyDesignFormView(!sourceForm is FORM, !newDrawlist is BOOLEAN) is FORM
   return !this.copyDesignFormView(!sourceForm,!newDrawlist,false)
endmethod

------------------------------------------------------------------------
--
-- Method:      copyDesignForm
--
-- Description: Copy standard design form and add to the system with new or existing drawlist
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form to be copied
--    2   R      BOOLEAN     True to make new drawlist, false for new view on existing drawlist
--    3   R      BOOLEAN     Whether new form should be floating
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------

-- Define method
define method .copyDesignFormView(!sourceForm is FORM, !newDrawlist is BOOLEAN, !floating is BOOLEAN) is FORM

  !drawlistIndex = -1
  !mono = false
  -- Get the drawlist that this view is attached to
  do !index indices !!gphDrawlists.drawlists
    do !view val !!gphDrawlists.views(!index)
      if (!view.owner().name().eq(!sourceForm.name())) then
        !drawlistIndex = !index
        break
      endif
    enddo
  enddo
  if (undefined(!!gphDrawlists.monoControl[!drawlistIndex])) then
    !mono = false
  else
    !mono = true
  endif

  !form = !this.copyDesignForm(!sourceForm, !floating)
  if( !form.unset() ) then
    return !form
  endif

  -- source has ARF enabled
  if (!sourceForm.view.enableExternalGeometry) then
    !form.view.enableExternalGeometry = true
    !form.formTitle = !form.formTitle.replace('3D', 'Graphical Explorer')
  endif

  if( !newDrawlist ) then
    -- Create a new drawlist populated from the source view
    !token = !!gphDrawlists.createDrawlist(true, true)
    !!gphDrawlists.attachView(!token, !form.view)

    -- Copy the drawlist
    !sourceToken  = !!gphDrawlists.token(!sourceForm.view)
    !members      = !!gphDrawlists.drawlist(!sourceToken).members()
    handle any
      -- use the common drawlist
      !globalDrawlist = object DRAWLIST()
      !members = !globalDrawlist.globalDrawlist().members()
    endhandle
    !!gphDrawlists.drawlist(!token).addMembers(!members)
    if( !mono) then
      !viewGadgets   = !!gphDrawlists.views(!token)
      !drawlistControl = object GPHMONOCONTROL(!viewGadgets)
      !!gphDrawlists.monoControl[!token] = !drawlistControl
      !!gphDrawlists.monoControl[!token].monochrome()
    endif

  else
    -- Attach new view to original draw list
    !token      = !!gphDrawlists.token(!sourceForm.view)
    !!gphDrawlists.attachView(!token, !form.view)
    handle any
      -- view attached to global draw list
      !form.formTitle = !form.formTitle & ' - Drawlist(1)'
    endhandle
  endif

  -- set up the clip box
  if( defined(!sourceForm.clipBox) ) then
    if( !sourceForm.clipBox.hasClipBox() ) then
      -- get clip details from the copied view
      !form.clipBox.copyView(!sourceForm.view)
    endif
  endif

  return !form

endmethod
-- End of method definition for .copyDesignForm() is FORM

------------------------------------------------------------------------
--
-- Method:      copyDesignForm
--
-- Description: Copy standard design form and add to the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form to be copied
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------
define method .copyDesignForm(!sourceForm is FORM) is FORM
   return !this.copyDesignForm(!sourceForm, false)
endmethod

------------------------------------------------------------------------
--
-- Method:      copyDesignForm
--
-- Description: Copy standard design form and add to the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form to be copied
--    2   R      BOOLEAN     Whether form should be floating
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------

-- Define method
define method .copyDesignForm(!sourceForm is FORM, !floating is BOOLEAN) is FORM

  !drawlistIndex = -1
  !mono = false
  -- Get the drawlist that this view is attached to
  do !index indices !!gphDrawlists.drawlists
    do !view val !!gphDrawlists.views(!index)
      if (!view.owner().name().eq(!sourceForm.name())) then
        !drawlistIndex = !index
        break
      endif
    enddo
  enddo
  if (undefined(!!gphDrawlists.monoControl[!drawlistIndex])) then
    !mono = false
  else
    !mono = true
  endif
  -- Add a new 3D view
  !form       = !this.addDesignForm(!floating)

  !sourceView = !sourceForm.view
  handle any
    -- just create a new view if no existing view found
    return !form
  endhandle

  -- Set up new view to match old view
  !form.view.limits    = !sourceView.limits
  !form.view.direction = !sourceView.direction
  if(!mono) then
    !!gphDrawlists.monoControl[!drawlistIndex].reset()
  endif
  -- Setup the view
  !viewOptions = object GPHVIEWOPT()
  !viewOptions.readView(!sourceView)
  !viewOptions.setView(!form.view, false)
  if(!mono) then
    !!gphDrawlists.monoControl[!drawlistIndex].monochrome()
  endif
  -- copy application specific members
  !form.isGridRefView   = !sourceForm.isGridRefView
  handle any
    !form.isGridRefView = false
  endhandle
  !form.gridRef   = !sourceForm.gridRef
  handle any
    !form.gridRef = object DBREF()
  endhandle
  !form.viewPurpose = !sourceForm.viewPurpose
  handle any
    !form.viewPurpose = ''
  endhandle

  return !form

endmethod
-- End of method definition for .copyDesignForm() is FORM

------------------------------------------------------------------------
--
-- Method:      addDesignForm
--
-- Description: Add standard design form  into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------

define method .addDesignForm() is FORM
   return !this.addDesignForm(false)
endmethod
-- End of method definition for .addDesignForm() is FORM

------------------------------------------------------------------------
--
-- Method:      addDesignForm
--
-- Description: Add standard design form  into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1  R      BOOLEAN     Whether form should be floating
-- Return:
--   [Data Type] [Description]
--    FORM        New form created
--
------------------------------------------------------------------------

-- Define method
define method .addDesignForm(!floating is BOOLEAN) is FORM

  if(defined(!!gphsettings)) then
    if (!!gphsettings.shown()) then
      !!gphsettings.hide()
    endif
  endif

  -- Get next design view
  do !i from 1

    -- Skip if form is already defined
    skip if(defined(!!gph3DDESIGN$!<i>))

    -- Load view create view and add to system
    !form = !!gph3DDesign(!i,!floating)
    !this.add(!form)
    return !form

  enddo

endmethod
-- End of method definition for .addDesignForm() is FORM

------------------------------------------------------------------------
--
-- Method:      addDesign
--
-- Description: Add standard design form  into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .addDesign()

  -- Thin layer to other method that returns form, retained for upwards compatibility
  !unusedForm = !this.addDesignForm()

endmethod
-- End of method definition for .addDesign()

------------------------------------------------------------------------
--
-- Method:      checkAddDesign
--
-- Description: Check and add standard design form into the system if not already defined
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      STRING      View full name e.g. !!gph3dDesign2.view
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .checkAddDesign(!view is STRING)

  -- Check if view is defined
  if (undefined($!view)) then

    -- Check if view name conforms
    if (!view.lowcase().substring(1, 13) neq |!!gph3ddesign| or !view.lowcase().substring(-5, 5) neq |.view|) then
      return error 1 |View name is not like !!gph3ddesign1.view|
    endif

    -- Get form number
    !numberString = !view.upcase().after(|GPH3DDESIGN|).before(|.VIEW|)
    if (!numberString.trim() eq ||) then
      -- Unset string will not fail conversion to real so trap separately
      return error 1 |View name is not like !!gph3ddesign1.view|
    endif
    !number = !numberString.real()
    handle (2,441)
      -- Unable to convert number
      return error 1 |View name is not like !!gph3ddesign1.view|
    endhandle

    -- Create view and add to system
    !this.add(!!gph3DDesign(!number))

  endif

endmethod
-- End of method definition for .checkAddDesign(GADGET)

------------------------------------------------------------------------
--
-- Method:      addNavigate
--
-- Description: Add standard navigate form  into the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .addNavigate()

  -- Get next design view
  do !i from 1

    -- Skip if form is already defined
    skip if(defined(!!gph3DNavigate$!<i>))

    -- Load view create view and add to system
    !this.add(!!gph3DNavigate(!i))

    break
  enddo

endmethod
-- End of method definition for .addNavigate()

------------------------------------------------------------------------
--
-- Method:      remove
--
-- Description: Remove view from the system
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View gadget
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

-- Define method
define method .remove(!view is GADGET)

  -- Initialise Variables
  !form  = !view.owner()

  --add code to automatically close the comSpaceManagement view form if it is currently storing the view that is to be removed
  if(defined(!!comSpaceManagement)) then
    !removeAdvancedViewForm = !!comSpaceManagement.isCurrentForm(!form)
  else
    !removeAdvancedViewForm = FALSE
  endif

  -- Get view index
  !index = !this.viewIndex(!view)

  -- Return if we can't find the view in the system
  if(!index.unset()) then
    return
  endif

  !number = !form.number
  handle (2, 759) $* Form does not have a member 'number'
    !number = 0
  endhandle

  -- If form is a "design" form, then remove from edg system
  if(defined(!form.type)) then
    if(!form.type.upcase() eq 'DESIGN') then

      -- Remove from edg system
      !!edgCntrl.removeView(!view)
    endif
  endif

  -- Detach it from any draw lists
  if (defined(!!gphDrawlists)) then
    !!gphDrawlists.detachView(!view)
    handle any
    endhandle
  endif

  -- Remove view and its form from the lists
  !this.views.remove(!index)

  -- Kill the form
  !formString = '!!' & !form.string()
  kill $!<formString>

  -- Update control form if exists and shown
  if(defined(!!gphControl)) then
    if(!!gphControl.shown()) then
      !!gphControl.initialise()
    endif
  endif

  --remove the comSpaceManagement form because it has now lost the view that it was assigned to
  if(!removeAdvancedViewForm) then
    if(!!comSpaceManagement.shown()) then
      !!comSpaceManagement.tidy()
      !!comSpaceManagement.hide()
    endif
  endif

  if( !number eq 1 ) then
    !!alert.warning('3D View 1 cannot be closed. Opening a new 3D View 1')

    -- reinstate the first view with draw list 1
    !form = !this.addDesignForm()
    !token = !!gphDrawlists.token(!form.view)

    -- Clear the drawlist as the system does not seem to like it with contents
    !drawlist = !!gphdrawlists.drawlist(!token)
    !drawlist.removeall()

    -- Check if the view was monochrome, if so clear it
    if (defined(!!gphDrawlists.monoControl[!token])) then
    	!!gphdrawlists.monoControl.deleteFrom(!token,1)
    endif

  endif

endmethod
-- End of method definition for .remove(GADGET)

------------------------------------------------------------------------
--
-- Method:      viewIndex
--
-- Description: Window using the window store data
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      GADGET      View name
-- Return:
--   [Data Type] [Description]
--    REAL        Index in the store of the passed view
--
------------------------------------------------------------------------

define method .viewIndex(!view is GADGET) is REAL

  -- Loop through list
  do !i indices !this.views
    if (!view eq !this.views[!i]) then
      return !i
    endif
  enddo
  return REAL()

endmethod
-- End of method definition for .viewIndex(GADGET) REAL

------------------------------------------------------------------------
--
-- Method:      close
--
-- Description: Close the passed view/form down
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--    REAL        Available number
--
------------------------------------------------------------------------

define method .close(!menu is MENU, !selected is STRING)

  -- Initialise Variables
  !form   = !menu.owner()
  !view   = !form.view
  !this.remove(!view)

endmethod
-- End of method definition for .close(MENU, STRING)

------------------------------------------------------------------------
--
-- Method:      close
--
-- Description: Close the passed view/form down
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form
-- Return:
--   [Data Type] [Description]
--    REAL        Available number
--
------------------------------------------------------------------------

define method .close(!form is FORM)

  -- Get form number
  !number = !form.number
    handle (2, 759)
      -- Form does not have a member 'number'
    elsehandle none

      -- Test for form 1
      if (!number.eq(1)) then
  	    !!alert.warning('3D View 1 cannot be closed. It will be reset.')
  	
  	    -- Get the form token
  	    !token = !!gphDrawlists.token(!form.view)

        -- Clear the drawlist as the system does not seem to like it with contents
        !drawlist = !!gphdrawlists.drawlist(!token)
        !drawlist.removeall()

        -- Check if the view was monochrome, if so clear it
        if (defined(!!gphDrawlists.monoControl[!token])) then
    	    !!gphdrawlists.monoControl.deleteFrom(!token,1)
        endif

        !!gph3DDesign1.show()
  	    return
      endif
    	
    endhandle

  -- Initialise Variables
  !view   = !form.view 
  !this.remove(!view)
  
  -- ARF view checked Icon needs to be handled in main close method due to floating/docking not synchronising reason
    !!designviewenablearf.refreshButtonCheckedState()

endmethod
-- End of method definition for .close(FORM)

------------------------------------------------------------------------
--
-- Method:      nextAvailable
--
-- Description: Next available view number
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    REAL        Available number
--
------------------------------------------------------------------------

define method .nextAvailable() is REAL
  return !this.views.maxIndex() + 1
endmethod
-- End of method definition for .nextAvailable() REAL

------------------------------------------------------------------------
--
-- Method:      designBar
--
-- Description: Next available view number
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      FORM        Form bar menu is to be applied to
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------

define method .bar(!form is FORM)

  -- Form type
  !formType = !form.type.upcase()
  handle ANY
    !formType = ''
  endhandle

  !this.lMenus(!form)
  !this.sMenus(!form)

  if (!!gphViewOpt.longMenus) then
    !menuAction = 'SELECT'
  else
    !menuAction = 'UNSELECT'
  endif
  !this.longMenus(!form.ssettingsMenu, !menuAction)

endmethod
-- End of method definition for .bar(FORM)

------------------------------------------------------------------------
--
-- Method:      lMenus
--
-- Description: Build long menus
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      MENU        Form bar menu selected from
--    2   R      STRING      Select state
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .lMenus(!form is FORM)

  !form.newMenu('lviewPopup')
  !form.newMenu('lmouseMenu')
  !form.newMenu('llookMenu')
  !form.newMenu('lisoMenu')
  !form.newMenu('llimitsMenu')
  !form.newMenu('lrotateMenu')
  !form.newMenu('lclippingMenu')
  !form.newMenu('lsettingsMenu')
  !form.newMenu('lsaveMenu')
  !form.newMenu('lrestoreMenu')

  !form.lviewPopup.add('menu', 'View Control',  'lmouseMenu')
  !form.lviewPopup.add('separator')
  !form.lviewPopup.add('menu', 'Look',  'llookMenu')
  !form.lviewPopup.add('menu', 'Iso',  'lisoMenu')
  !form.lviewPopup.add('menu', 'Limits',  'llimitsMenu')
  !form.lviewPopup.add('menu', 'Rotate',  'lrotateMenu')
  !form.lviewPopup.add('menu', 'Clipping',  'lclippingMenu')
  !form.lviewPopup.add('separator')
  !form.lviewPopup.add('menu', 'Settings',  'lsettingsMenu')

  !form.lmouseMenu.add('callback', 'Zoom  F2', '!!gphviews.doMenuAction(')
  !form.lmouseMenu.add('callback', 'Pan  F3', '!!gphviews.doMenuAction(')
  !form.lmouseMenu.add('callback', 'Rotate  F5', '!!gphviews.doMenuAction(')
  !form.lmouseMenu.add('callback', 'Walk  F6', '!!gphviews.doMenuAction(')

  var !coordinate coordinate
  if (!coordinate.eq('XYZ')) then

    !form.llookMenu.add('callback', ' X',       '!!gphviews.look(')
    !form.llookMenu.add('callback', '-X',       '!!gphviews.look(')
    !form.llookMenu.add('callback', ' Y',       '!!gphviews.look(')
    !form.llookMenu.add('callback', '-Y',       '!!gphviews.look(')
    !form.llookMenu.add('callback', ' Z',       '!!gphviews.look(')
    !form.llookMenu.add('callback', '-Z',       '!!gphviews.look(')
    !form.llookMenu.add('separator')
    !form.llookMenu.add('callback', 'Plan  Y',      '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan -Y',      '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan  X',      '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan -X',      '!!gphviews.plan(')
  else
    !form.llookMenu.add('callback', 'Up',          '!!gphviews.look(')
    !form.llookMenu.add('callback', 'Down',        '!!gphviews.look(')
    !form.llookMenu.add('callback', 'North',       '!!gphviews.look(')
    !form.llookMenu.add('callback', 'South',       '!!gphviews.look(')
    !form.llookMenu.add('callback', 'East',        '!!gphviews.look(')
    !form.llookMenu.add('callback', 'West',        '!!gphviews.look(')
    !form.llookMenu.add('separator')
    !form.llookMenu.add('callback', 'Plan North',      '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan South',      '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan East',       '!!gphviews.plan(')
    !form.llookMenu.add('callback', 'Plan West',       '!!gphviews.plan(')
  endif
  !form.llookMenu.add('separator')
  !form.llookMenu.add('CALLBACK', 'Explicit...', '!!gphviews.lookExplicit(')

  !form.lisoMenu.add('callback', 'One',         '!!gphviews.isometric(')
  !form.lisoMenu.add('callback', 'Two',         '!!gphviews.isometric(')
  !form.lisoMenu.add('callback', 'Three',       '!!gphviews.isometric(')
  !form.lisoMenu.add('callback', 'Four',        '!!gphviews.isometric(')

  !form.llimitsMenu.add('callback', 'CE',          '!!gphviews.limitsElement(')
  !form.llimitsMenu.add('callback', 'Owner',       '!!gphviews.limitsElement(')
  !form.llimitsMenu.add('callback', 'Pick',      '!!gphviews.limitsPick(')
  !form.llimitsMenu.add('callback', 'Drawlist',    '!!gphviews.limitsList(')
  !form.llimitsMenu.add('CALLBACK', 'Obstruction', '!!gphviews.limitsList(')
  !form.llimitsMenu.add('CALLBACK', 'Window',      '!!gphviews.window(')
  !form.llimitsMenu.add('CALLBACK', 'Clipbox',     '!!gphviews.limitsBox(')
  !form.llimitsMenu.add('separator')
  !form.llimitsMenu.add('CALLBACK', 'Restore',     '!!gphviews.limitsRestore(')
  !form.llimitsMenu.add('separator')
  !form.llimitsMenu.add('CALLBACK', 'Explicit...', '!!gphviews.limitsExplicit(')

  !form.lrotateMenu.add('CALLBACK', 'CE Origin',     '!!gphviews.rotateElement(')
  !form.lrotateMenu.add('CALLBACK', 'CE Centroid',   '!!gphviews.rotateElement(')
  !form.lrotateMenu.add('CALLBACK', 'Pick Origin',   '!!gphviews.rotatePick(')
  !form.lrotateMenu.add('CALLBACK', 'Pick Centroid', '!!gphviews.rotatePick(')
  !form.lrotateMenu.add('separator')
  !form.lrotateMenu.add('CALLBACK', 'Limit Box',     '!!gphviews.rotateBox(')
  !form.lrotateMenu.add('CALLBACK', 'Clip Box',      '!!gphviews.rotateBox(')
  !form.lrotateMenu.add('separator')
  !form.lrotateMenu.add('CALLBACK', 'Explicit...',   '!!gphviews.rotateExplicit(')

  !form.lclippingMenu.add('toggle',   'Enable',      '!!gphviews.clipbox(')
  !form.lclippingMenu.add('toggle',   'Capped',      '!!gphviews.clipbox(')
  !form.lclippingMenu.add('callback', 'Colour...',   '!!gphviews.clipbox(')
  !form.lclippingMenu.add('separator')
  !form.lclippingMenu.add('callback', 'CE',            '!!gphviews.clipboxElement(')
  !form.lclippingMenu.add('callback', 'Owner',         '!!gphviews.clipboxElement(')
  !form.lclippingMenu.add('callback', 'Limits Box',    '!!gphviews.clipboxBox(')
  !form.lclippingMenu.add('callback', 'Pick item',     '!!gphviews.clipboxPick(')
  !form.lclippingMenu.add('separator')
  !form.lclippingMenu.add('callback', 'Pick limits',   '!!gphviews.clipboxPick(')
  !form.lclippingMenu.add('separator')
  !form.lclippingMenu.add('callback', 'Explicit...', '!!gphviews.clipboxExplicit(')

  !form.lsettingsMenu.callback = '!!gphviews.graphicsToggles('
  !form.lsettingsMenu.add('toggle', 'Eye  F7', '!!gphviews.doMenuAction(')
  !form.lsettingsMenu.add('toggle', 'Shaded  F11', '!!gphviews.doMenuAction(')
  !form.lsettingsMenu.add('toggle', 'Perspective  F4', '!!gphviews.doMenuAction(')
  !form.lsettingsMenu.add('separator')
  !form.lsettingsMenu.add('callback', 'Background...',   '!!gphviews.colour(')
  !form.lsettingsMenu.add('separator')
  !form.lsettingsMenu.add('menu', 'Save View', 'lsaveMenu')
  !form.lsettingsMenu.add('menu', 'Restore View', 'lrestoreMenu')
  !form.lsettingsMenu.add('callback', 'Copy like view', '!!gphviews.copy(')
  !form.lsettingsMenu.add('separator')
  !form.lsettingsMenu.add('toggle', 'Long Menus', '!!gphviews.longMenus(')

  !form.lsaveMenu.add('callback', 'Save 1', '!!gphviews.doMenuAction(')
  !form.lsaveMenu.add('callback', 'Save 2', '!!gphviews.doMenuAction(')
  !form.lsaveMenu.add('callback', 'Save 3', '!!gphviews.doMenuAction(')
  !form.lsaveMenu.add('callback', 'Save 4', '!!gphviews.doMenuAction(')

  !form.lrestoreMenu.add('callback', 'Restore 1', '!!gphviews.doMenuAction(')
  !form.lrestoreMenu.add('callback', 'Restore 2', '!!gphviews.doMenuAction(')
  !form.lrestoreMenu.add('callback', 'Restore 3', '!!gphviews.doMenuAction(')
  !form.lrestoreMenu.add('callback', 'Restore 4', '!!gphviews.doMenuAction(')

endmethod
-- End of method definition for .lMenus(FORM)

------------------------------------------------------------------------
--
-- Method:      sMenus
