setup command !!machineLearningLaunch

exit

------------------------------------------------------------------------
-- Method:      !!machineLearningLaunch
-- Description: Constructor
------------------------------------------------------------------------
define method .machineLearningLaunch()
  -- initialise events and command key
  !this.key     = 'AVEVA.MachineLearning.Launch'
  !this.execute = 'execute'
endmethod

------------------------------------------------------------------------
-- Method:     execute
-- Description: Execute event
------------------------------------------------------------------------
define method .execute(!dummyArgs is ARRAY)
  show !!machineLearning
endmethod