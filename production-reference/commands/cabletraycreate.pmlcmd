setup command !!cableTrayCreate

exit

------------------------------------------------------------------------
-- Method:      cableTrayCreate
-- Description: Constructor
------------------------------------------------------------------------
define method .cableTrayCreate()
  -- initialise events and command key
  !this.key     = 'AVEVA.CableTray.CommandCableTrayCreate'
  !this.execute = 'execute'
endmethod

------------------------------------------------------------------------
-- Method:     execute
-- Description: Execute event
------------------------------------------------------------------------
define method .execute(!dummyArgs is ARRAY)
  show !!cdCTPIPE
endmethod
